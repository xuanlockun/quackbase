---
interface Props {
	label: string;
	icon: "edit" | "delete" | "view" | "toggle" | "open" | "copy";
	href?: string;
	type?: "button" | "submit";
	variant?: string;
	attrs?: Record<string, string | boolean | undefined>;
	disabled?: boolean;
}

const { label, icon, href, type = "button", variant = "btn-outline-secondary", attrs = {}, disabled = false } =
	Astro.props as Props;

const icons: Record<Props["icon"], string> = {
	edit: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 20h9" />
			<path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L8 18l-4 1 1-4Z" />
		</svg>
	`,
	delete: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M4 7h16" />
			<path d="M10 11v6" />
			<path d="M14 11v6" />
			<path d="M6 7l1 13h10l1-13" />
			<path d="M9 7V4h6v3" />
		</svg>
	`,
	view: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12Z" />
			<circle cx="12" cy="12" r="2.5" />
		</svg>
	`,
	toggle: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<rect x="3.5" y="5" width="17" height="14" rx="0" />
			<path d="M8 9h8" />
			<path d="M8 13h5" />
		</svg>
	`,
	open: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M7 17l10-10" />
			<path d="M10 7h7v7" />
			<path d="M5 5h4v4" />
		</svg>
	`,
	copy: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M9 9h10v10H9z" />
			<path d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1" />
		</svg>
	`,
};
---

{
	href ? (
		<a
			class={`btn btn-sm ${variant} admin-icon-action`}
			href={href}
			aria-label={label}
			title={label}
			{...attrs}
		>
			<span class="admin-icon-action-icon" aria-hidden="true" set:html={icons[icon]}></span>
			<span class="visually-hidden">{label}</span>
		</a>
	) : (
		<button
			class={`btn btn-sm ${variant} admin-icon-action`}
			type={type}
			aria-label={label}
			title={label}
			disabled={disabled}
			{...attrs}
		>
			<span class="admin-icon-action-icon" aria-hidden="true" set:html={icons[icon]}></span>
			<span class="visually-hidden">{label}</span>
		</button>
	)
}
