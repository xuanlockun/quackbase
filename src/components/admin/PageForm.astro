---
import type { PageSectionConfig, SitePage } from "../../lib/blog";
import { getSupportedLanguages, getLocalizedPagePath } from "../../lib/blog";
import type { ContactFormField } from "../../lib/forms";
import { getLanguageCatalog, getUiTranslations, localizeAdminHref } from "../../lib/i18n";

interface Props {
	mode: "create" | "edit";
	action: string;
	page?: SitePage | null;
	canSubmit: boolean;
	backHref?: string;
	loadError?: string;
	contactFormFields?: ContactFormField[];
}

const {
	mode,
	action,
	page = null,
	canSubmit,
	backHref = "/admin/pages",
	loadError = "",
	contactFormFields = [],
} = Astro.props;

const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const def = catalog.defaultLanguageCode;
const submitLabel = mode === "edit" ? t("actions.savePage") : t("actions.createPage");
const isDisabled = Boolean(loadError) || !canSubmit;
const languages = getSupportedLanguages(catalog);
const initialLanguage = page?.requestedLanguage ?? language;
const titleTranslations = {
	[def]: "",
	...(page?.titleTranslations ?? {}),
};
const contentTranslations = {
	[def]: "# New page",
	...(page?.contentTranslations ?? {}),
};
const sectionMap = new Map((page?.pageSections ?? []).map((section) => [section.type, section]));
const pageContentSection = sectionMap.get("page_content") ?? { type: "page_content", order: 1 };
const bannerSection = sectionMap.get("banner_slider");
const blogFeedSection = sectionMap.get("blog_feed");
const contactSection = sectionMap.get("contact_form");
const initialSections: PageSectionConfig[] = [
	pageContentSection,
	...(bannerSection ? [bannerSection] : []),
	...(blogFeedSection ? [blogFeedSection] : []),
	...(contactSection ? [contactSection] : []),
];
const initialContactFields = contactFormFields.map((field) => ({
	id: field.id,
	type: field.type,
	label: field.label,
	required: field.required,
	order: field.order,
}));
---

<div class="admin-form-header">
	<a class="admin-ghost-button" href={localizeAdminHref(backHref, language)}>{t("actions.back")}</a>
	<p class="admin-muted">
		{canSubmit ? t("messages.changesSavePageRoutes") : t("messages.cannotSavePage")}
	</p>
</div>

{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

<form class="admin-form-stack" method="post" action={action}>
	{mode === "edit" && page && <input type="hidden" name="id" value={page.id} />}
	<div class="admin-form-grid">
		<label>
			<span>{t("labels.slug")}</span>
			<input
				name="slug"
				required
				pattern="[a-z0-9-]+"
				value={page?.slug ?? ""}
				placeholder="services"
				disabled={isDisabled}
			/>
		</label>
		<label>
			<span>{t("labels.description")}</span>
			<input
				name="description"
				required
				value={page?.description ?? ""}
				placeholder="Page summary"
				disabled={isDisabled}
			/>
		</label>
		<label>
			<span>{t("labels.status")}</span>
			<select name="status" disabled={isDisabled}>
				<option value="published" selected={page?.status !== "draft"}>{t("status.published")}</option>
				<option value="draft" selected={page?.status === "draft"}>{t("status.draft")}</option>
			</select>
		</label>
	</div>

	<div
		class="admin-form-section localized-editor"
		data-localized-editor
		data-active-language={initialLanguage}
		data-default-language={def}
	>
		<div class="localized-editor-header">
			<div>
				<h2>{t("headings.localizedContent")}</h2>
				<p class="admin-muted">{t("messages.localizedPageHelp")}</p>
			</div>
			<div class="localized-editor-tabs" role="tablist" aria-label={t("labels.language")}>
				{
					languages.map((languageOption) => (
						<button
							type="button"
							class:list={[
								"localized-editor-tab",
								initialLanguage === languageOption.code && "is-active",
							]}
							data-language-tab={languageOption.code}
							role="tab"
							aria-selected={initialLanguage === languageOption.code ? "true" : "false"}
							disabled={isDisabled}
						>
							{languageOption.code.toUpperCase()}
						</button>
					))
				}
			</div>
		</div>

		<input type="hidden" name="title" data-title-translations value={JSON.stringify(titleTranslations)} />
		<input type="hidden" name="content" data-content-translations value={JSON.stringify(contentTranslations)} />

		{
			languages.map((languageOption) => (
				<section
					class:list={[
						"localized-editor-panel",
						initialLanguage === languageOption.code && "is-active",
					]}
					data-language-panel={languageOption.code}
					hidden={initialLanguage !== languageOption.code}
				>
					<label>
						<span>{t("labels.title")} ({languageOption.label})</span>
						<input
							data-title-input={languageOption.code}
							value={titleTranslations[languageOption.code] ?? ""}
							placeholder={languageOption.code === def ? "About us" : languageOption.code === "vi" ? "Gioi thieu" : ""}
							disabled={isDisabled}
						/>
					</label>
					<label>
						<span>{t("labels.content")} ({languageOption.label})</span>
						<textarea data-content-input={languageOption.code} rows="14" disabled={isDisabled}
							>{contentTranslations[languageOption.code] ?? (languageOption.code === def ? "# New page" : "")}</textarea
						>
					</label>
				</section>
			))
		}
	</div>

	<div class="admin-form-section">
		<div class="page-sections-heading">
			<div>
				<span>{t("headings.pageSections")}</span>
			</div>
			<div class="page-sections-actions">
				<select data-section-select>
					<option value="" selected disabled>{t("actions.addSection")}</option>
				</select>
				<button
					class="admin-ghost-button"
					type="button"
					data-section-add
					disabled={isDisabled}
				>
					{t("actions.addSection")}
				</button>
			</div>
		</div>

		<input
			type="hidden"
			name="pageSectionsConfig"
			data-page-sections-config
			value={JSON.stringify(initialSections)}
			disabled={isDisabled}
		/>
		<input
			type="hidden"
			name="contactFormFields"
			data-contact-fields-payload
			value={JSON.stringify(initialContactFields)}
			disabled={isDisabled}
		/>

		<div class="admin-table" aria-label={t("headings.pageSections")}>
			<div class="admin-table-row admin-table-head" role="row">
				<span></span>
				<span>Section</span>
				<span>Details</span>
				<span>Actions</span>
			</div>
			<div class="admin-table-body" data-section-rows></div>
		</div>
	</div>

	<div class="admin-form-section contact-fields-wrapper" data-contact-fields-wrapper hidden>
		<div
			class="contact-fields-editor"
			data-contact-fields-editor
			data-disabled={String(isDisabled)}
			data-remove-label={t("actions.remove")}
			data-type-label={t("labels.fieldType")}
			data-required-label={t("labels.required")}
			data-label-en={`${t("labels.label")} (EN)`}
			data-label-vi={`${t("labels.label")} (VI)`}
			data-text-option={t("labels.textField")}
			data-email-option={t("labels.emailField")}
			data-textarea-option={t("labels.textareaField")}
		>
			<div class="contact-fields-toolbar">
				<strong>{t("headings.contactFormFields")}</strong>
				<button class="admin-ghost-button" type="button" data-contact-field-add disabled={isDisabled}>
					{t("actions.addField")}
				</button>
			</div>
			<p class="admin-muted">{t("messages.contactFormSharedConfig")}</p>
			<div class="contact-fields-config">
				<div class="contact-fields-table" role="table">
					<div class="contact-fields-rows" data-contact-fields-rows></div>
				</div>
				<p class="admin-muted" data-contact-fields-empty hidden>
					{t("messages.noContactFieldsConfigured")}
				</p>
			</div>
		</div>
	</div>

	<div class="admin-form-actions">
		<button class="admin-primary-button" type="submit" disabled={isDisabled}>{submitLabel}</button>
		{mode === "edit" && page && <a href={getLocalizedPagePath(page.slug, language, catalog)}>{t("actions.openPage")}</a>}
	</div>
</form>

<style>
	.localized-editor,
	.contact-fields-config {
		display: grid;
		gap: 1rem;
	}

	.localized-editor-header,
	.contact-fields-toolbar {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
	}

	.localized-editor-header h2 {
		margin: 0;
		font-size: 1.1rem;
	}

	.localized-editor-header p {
		margin: 0.35rem 0 0;
	}

	.localized-editor-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.localized-editor-tab {
		border: 1px solid rgba(var(--gray), 0.25);
		border-radius: 999px;
		padding: 0.4rem 0.8rem;
		background: white;
		font: inherit;
		cursor: pointer;
	}

	.localized-editor-tab.is-active {
		background: rgb(var(--accent));
		border-color: rgb(var(--accent));
		color: white;
	}

	.localized-editor-panel {
		display: grid;
		gap: 0.8rem;
	}

	.localized-editor-panel textarea {
		min-height: 280px;
	}

	.page-sections-heading {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.page-sections-actions {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.page-sections-actions select {
		min-width: 200px;
		border-radius: 8px;
		border: 1px solid rgba(var(--gray), 0.35);
		padding: 0.4rem 0.6rem;
		background: white;
	}

	.contact-fields-toolbar strong {
		font-size: 0.95rem;
	}

	@media (max-width: 720px) {
		.localized-editor-header,
		.contact-fields-toolbar {
			flex-direction: column;
			align-items: stretch;
		}
	}
</style>

<script>
	const syncLocalizedEditor = (root) => {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const titleField = root.querySelector("[data-title-translations]");
		const contentField = root.querySelector("[data-content-translations]");
		if (!(titleField instanceof HTMLInputElement) || !(contentField instanceof HTMLInputElement)) {
			return;
		}

		const titleTranslations = {};
		root.querySelectorAll("[data-title-input]").forEach((input) => {
			if (!(input instanceof HTMLInputElement)) {
				return;
			}
			const code = input.dataset.titleInput;
			if (code) {
				titleTranslations[code] = input.value;
			}
		});

		const contentTranslations = {};
		root.querySelectorAll("[data-content-input]").forEach((input) => {
			if (!(input instanceof HTMLTextAreaElement)) {
				return;
			}
			const code = input.dataset.contentInput;
			if (code) {
				contentTranslations[code] = input.value;
			}
		});

		titleField.value = JSON.stringify(titleTranslations);
		contentField.value = JSON.stringify(contentTranslations);
	};

	document.querySelectorAll("[data-localized-editor]").forEach((root) => {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const setActiveLanguage = (nextLanguage) => {
			root.dataset.activeLanguage = nextLanguage;
			root.querySelectorAll("[data-language-tab]").forEach((button) => {
				if (!(button instanceof HTMLButtonElement)) {
					return;
				}
				const isActive = button.dataset.languageTab === nextLanguage;
				button.classList.toggle("is-active", isActive);
				button.setAttribute("aria-selected", isActive ? "true" : "false");
			});
			root.querySelectorAll("[data-language-panel]").forEach((panel) => {
				if (!(panel instanceof HTMLElement)) {
					return;
				}
				const isActive = panel.dataset.languagePanel === nextLanguage;
				panel.hidden = !isActive;
				panel.classList.toggle("is-active", isActive);
			});
		};

		root.querySelectorAll("[data-language-tab]").forEach((button) => {
			button.addEventListener("click", () => {
				if (button instanceof HTMLButtonElement && button.dataset.languageTab) {
					setActiveLanguage(button.dataset.languageTab);
				}
			});
		});

		root.addEventListener("input", () => syncLocalizedEditor(root));
		syncLocalizedEditor(root);
		setActiveLanguage(root.dataset.activeLanguage || root.dataset.defaultLanguage || "en");
	});

	const sectionsEditor = document.querySelector("[data-page-sections-editor]");
	const sectionsPayload = document.querySelector("[data-page-sections-config]");

	const syncSections = () => {
		if (!(sectionsEditor instanceof HTMLElement) || !(sectionsPayload instanceof HTMLInputElement)) {
			return;
		}

		const cards = Array.from(sectionsEditor.querySelectorAll("[data-section]"));
		const sections = cards
			.map((card) => {
				if (!(card instanceof HTMLElement)) {
					return null;
				}

				const type = card.dataset.section;
				if (!type) {
					return null;
				}

				const enabledInput = card.querySelector("[data-section-enabled]");
				const enabled = enabledInput instanceof HTMLInputElement ? enabledInput.checked : true;
				if (!enabled && type !== "page_content") {
					return null;
				}

				const orderInput = card.querySelector("[data-section-order]");
				const order =
					orderInput instanceof HTMLInputElement
						? Math.max(1, Number.parseInt(orderInput.value || "1", 10) || 1)
						: 1;

				if (type === "banner_slider") {
					const urlsInput = card.querySelector("[data-banner-urls]");
					const bannerUrls =
						urlsInput instanceof HTMLTextAreaElement
							? urlsInput.value
									.split(/\r?\n/)
									.map((entry) => entry.trim())
									.filter(Boolean)
							: [];

					if (enabled && bannerUrls.length === 0) {
						return null;
					}

					return { type, order, bannerUrls };
				}

				return { type, order };
			})
			.filter(Boolean)
			.sort((left, right) => left.order - right.order);

		sectionsPayload.value = JSON.stringify(sections);
	};

	const fieldsEditor = document.querySelector("[data-contact-fields-editor]");
	const fieldsRows = fieldsEditor?.querySelector("[data-contact-fields-rows]");
	const fieldsPayload = document.querySelector("[data-contact-fields-payload]");
	const emptyState = fieldsEditor?.querySelector("[data-contact-fields-empty]");
	const addFieldButton = fieldsEditor?.querySelector("[data-contact-field-add]");
	let nextFieldId = Array.from(document.querySelectorAll("[data-contact-field]")).reduce((max, row) => {
		if (!(row instanceof HTMLElement)) {
			return max;
		}
		const currentId = Number.parseInt(row.dataset.fieldId || "0", 10);
		return Number.isFinite(currentId) ? Math.max(max, currentId) : max;
	}, 0);

	const buildFieldRow = (field = {}) => {
		const row = document.createElement("div");
		row.className = "contact-field-row";
		row.dataset.contactField = "";
		row.dataset.fieldId = String(field.id || ++nextFieldId);

		const meta = document.createElement("div");
		meta.className = "contact-field-meta";

		const typeLabel = document.createElement("label");
		const typeLabelText = document.createElement("span");
		typeLabelText.textContent = fieldsEditor instanceof HTMLElement ? fieldsEditor.dataset.typeLabel || "Type" : "Type";
		typeLabel.append(typeLabelText);
		const typeSelect = document.createElement("select");
		typeSelect.dataset.contactFieldType = "";
		const optionLabels =
			fieldsEditor instanceof HTMLElement
				? {
						text: fieldsEditor.dataset.textOption || "Text",
						email: fieldsEditor.dataset.emailOption || "Email",
						textarea: fieldsEditor.dataset.textareaOption || "Textarea",
					}
				: { text: "Text", email: "Email", textarea: "Textarea" };
		["text", "email", "textarea"].forEach((value) => {
			const option = document.createElement("option");
			option.value = value;
			option.textContent = optionLabels[value] || value;
			option.selected = value === (field.type || "text");
			typeSelect.append(option);
		});
		typeLabel.append(typeSelect);

		const orderLabel = document.createElement("label");
		const orderLabelText = document.createElement("span");
		orderLabelText.textContent = fieldsEditor instanceof HTMLElement ? fieldsEditor.dataset.orderLabel || "Order" : "Order";
		orderLabel.append(orderLabelText);
		const orderInput = document.createElement("input");
		orderInput.type = "number";
		orderInput.min = "1";
		orderInput.value = String(field.order || (fieldsRows?.children.length || 0) + 1);
		orderInput.dataset.contactFieldOrder = "";
		orderLabel.append(orderInput);

		const requiredLabel = document.createElement("label");
		requiredLabel.className = "contact-field-required";
		const requiredLabelText = document.createElement("span");
		requiredLabelText.textContent =
			fieldsEditor instanceof HTMLElement ? fieldsEditor.dataset.requiredLabel || "Required" : "Required";
		requiredLabel.append(requiredLabelText);
		const requiredInput = document.createElement("input");
		requiredInput.type = "checkbox";
		requiredInput.checked = Boolean(field.required);
		requiredInput.dataset.contactFieldRequired = "";
		requiredLabel.append(requiredInput);

		const removeButton = document.createElement("button");
		removeButton.className = "admin-ghost-button";
		removeButton.type = "button";
		removeButton.dataset.contactFieldRemove = "";
		removeButton.textContent = fieldsEditor instanceof HTMLElement ? fieldsEditor.dataset.removeLabel || "Remove" : "Remove";

		meta.append(typeLabel, orderLabel, requiredLabel, removeButton);

		const labels = document.createElement("div");
		labels.className = "contact-field-labels";

		const enLabel = document.createElement("label");
		const enLabelText = document.createElement("span");
		enLabelText.textContent = fieldsEditor instanceof HTMLElement ? fieldsEditor.dataset.labelEn || "Label (EN)" : "Label (EN)";
		enLabel.append(enLabelText);
		const enInput = document.createElement("input");
		enInput.type = "text";
		enInput.placeholder = "Message";
		enInput.value = field.label?.en || "";
		enInput.dataset.contactFieldLabelEn = "";
		enLabel.append(enInput);

		const viLabel = document.createElement("label");
		const viLabelText = document.createElement("span");
		viLabelText.textContent = fieldsEditor instanceof HTMLElement ? fieldsEditor.dataset.labelVi || "Label (VI)" : "Label (VI)";
		viLabel.append(viLabelText);
		const viInput = document.createElement("input");
		viInput.type = "text";
		viInput.placeholder = "Tin nhan";
		viInput.value = field.label?.vi || "";
		viInput.dataset.contactFieldLabelVi = "";
		viLabel.append(viInput);

		labels.append(enLabel, viLabel);
		row.append(meta, labels);
		return row;
	};

	const syncContactFields = () => {
		if (!(fieldsRows instanceof HTMLElement) || !(fieldsPayload instanceof HTMLInputElement)) {
			return;
		}

		const fields = Array.from(fieldsRows.querySelectorAll("[data-contact-field]"))
			.map((row, index) => {
				if (!(row instanceof HTMLElement)) {
					return null;
				}

				const typeInput = row.querySelector("[data-contact-field-type]");
				const orderInput = row.querySelector("[data-contact-field-order]");
				const requiredInput = row.querySelector("[data-contact-field-required]");
				const labelEnInput = row.querySelector("[data-contact-field-label-en]");
				const labelViInput = row.querySelector("[data-contact-field-label-vi]");

				if (
					!(typeInput instanceof HTMLSelectElement) ||
					!(orderInput instanceof HTMLInputElement) ||
					!(requiredInput instanceof HTMLInputElement) ||
					!(labelEnInput instanceof HTMLInputElement) ||
					!(labelViInput instanceof HTMLInputElement)
				) {
					return null;
				}

				const labelEn = labelEnInput.value.trim();
				if (!labelEn) {
					return null;
				}

				const labelVi = labelViInput.value.trim();
				return {
					id: Number.parseInt(row.dataset.fieldId || String(index + 1), 10) || index + 1,
					type: typeInput.value,
					required: requiredInput.checked,
					order: Math.max(1, Number.parseInt(orderInput.value || String(index + 1), 10) || index + 1),
					label: {
						en: labelEn,
						...(labelVi ? { vi: labelVi } : {}),
					},
				};
			})
			.filter(Boolean)
			.sort((left, right) => left.order - right.order);

		fieldsPayload.value = JSON.stringify(fields);
		if (emptyState instanceof HTMLElement) {
			emptyState.hidden = fields.length > 0;
		}
	};

	fieldsRows?.addEventListener("input", syncContactFields);
	fieldsRows?.addEventListener("change", syncContactFields);
	fieldsRows?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement) || !target.matches("[data-contact-field-remove]")) {
			return;
		}

		target.closest("[data-contact-field]")?.remove();
		syncContactFields();
	});

	addFieldButton?.addEventListener("click", () => {
		if (!(fieldsRows instanceof HTMLElement)) {
			return;
		}

		fieldsRows.append(buildFieldRow());
		syncContactFields();
		const lastInput = fieldsRows.querySelector("[data-contact-field]:last-child [data-contact-field-label-en]");
		if (lastInput instanceof HTMLInputElement) {
			lastInput.focus();
		}
	});

	sectionsEditor?.addEventListener("input", syncSections);
	sectionsEditor?.addEventListener("change", syncSections);
	syncSections();
	syncContactFields();
</script>
