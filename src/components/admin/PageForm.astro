---
import type { PageSectionConfig, SitePage } from "../../lib/blog";
import { getSupportedLanguages, getLocalizedPagePath } from "../../lib/blog";
import { getUiTranslations, localizeAdminHref } from "../../lib/i18n";

interface Props {
	mode: "create" | "edit";
	action: string;
	page?: SitePage | null;
	canSubmit: boolean;
	backHref?: string;
	loadError?: string;
}

const {
	mode,
	action,
	page = null,
	canSubmit,
	backHref = "/admin/pages",
	loadError = "",
} = Astro.props;

const { t, language } = getUiTranslations(Astro);
const submitLabel = mode === "edit" ? t("actions.savePage") : t("actions.createPage");
const isDisabled = Boolean(loadError) || !canSubmit;
const languages = getSupportedLanguages();
const initialLanguage = page?.requestedLanguage ?? language;
const titleTranslations = {
	en: "",
	...(page?.titleTranslations ?? {}),
};
const contentTranslations = {
	en: "# New page",
	...(page?.contentTranslations ?? {}),
};
const sectionMap = new Map((page?.pageSections ?? []).map((section) => [section.type, section]));
const pageContentSection = sectionMap.get("page_content") ?? { type: "page_content", order: 1 };
const bannerSection = sectionMap.get("banner_slider");
const blogFeedSection = sectionMap.get("blog_feed");
const contactSection = sectionMap.get("contact_form");
const initialSections: PageSectionConfig[] = [
	pageContentSection,
	...(bannerSection ? [bannerSection] : []),
	...(blogFeedSection ? [blogFeedSection] : []),
	...(contactSection ? [contactSection] : []),
];
---

<div class="admin-form-header">
	<a class="admin-ghost-button" href={localizeAdminHref(backHref, language)}>{t("actions.back")}</a>
	<p class="admin-muted">
		{canSubmit
			? t("messages.changesSavePageRoutes")
			: t("messages.cannotSavePage")}
	</p>
</div>

{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

<form class="admin-form-stack" method="post" action={action}>
	{mode === "edit" && page && <input type="hidden" name="id" value={page.id} />}
	<div class="admin-form-grid">
		<label>
			<span>{t("labels.slug")}</span>
			<input
				name="slug"
				required
				pattern="[a-z0-9-]+"
				value={page?.slug ?? ""}
				placeholder="services"
				disabled={isDisabled}
			/>
		</label>
		<label>
			<span>{t("labels.description")}</span>
			<input
				name="description"
				required
				value={page?.description ?? ""}
				placeholder="Page summary"
				disabled={isDisabled}
			/>
		</label>
		<label>
			<span>{t("labels.status")}</span>
			<select name="status" disabled={isDisabled}>
				<option value="published" selected={page?.status !== "draft"}>{t("status.published")}</option>
				<option value="draft" selected={page?.status === "draft"}>{t("status.draft")}</option>
			</select>
		</label>
	</div>

	<div class="admin-form-section localized-editor" data-localized-editor data-active-language={initialLanguage}>
		<div class="localized-editor-header">
			<div>
				<h2>{t("headings.localizedContent")}</h2>
				<p class="admin-muted">{t("messages.localizedPageHelp")}</p>
			</div>
			<div class="localized-editor-tabs" role="tablist" aria-label={t("labels.language")}>
				{
					languages.map((language) => (
						<button
							type="button"
							class:list={["localized-editor-tab", initialLanguage === language.code && "is-active"]}
							data-language-tab={language.code}
							role="tab"
							aria-selected={initialLanguage === language.code ? "true" : "false"}
							disabled={isDisabled}
						>
							{language.code.toUpperCase()}
						</button>
					))
				}
			</div>
		</div>

		<input type="hidden" name="title" data-title-translations value={JSON.stringify(titleTranslations)} />
		<input type="hidden" name="content" data-content-translations value={JSON.stringify(contentTranslations)} />

		{
			languages.map((language) => (
				<section
					class:list={["localized-editor-panel", initialLanguage === language.code && "is-active"]}
					data-language-panel={language.code}
					hidden={initialLanguage !== language.code}
				>
					<label>
						<span>{t("labels.title")} ({language.label})</span>
						<input
							data-title-input={language.code}
							value={titleTranslations[language.code] ?? ""}
							placeholder={language.code === "en" ? "About us" : "Gioi thieu"}
							disabled={isDisabled}
						/>
					</label>
					<label>
						<span>{t("labels.content")} ({language.label})</span>
						<textarea data-content-input={language.code} rows="14" disabled={isDisabled}
							>{contentTranslations[language.code] ?? (language.code === "en" ? "# New page" : "")}</textarea
						>
					</label>
				</section>
			))
		}
	</div>

	<div class="admin-form-section">
		<div class="page-sections-heading">
			<div>
				<span>{t("headings.pageSections")}</span>
				<p class="admin-muted">{t("messages.pageSectionsHelp")}</p>
			</div>
		</div>

		<input
			type="hidden"
			name="pageSectionsConfig"
			data-page-sections-config
			value={JSON.stringify(initialSections)}
			disabled={isDisabled}
		/>

		<div class="page-sections-stack" data-page-sections-editor>
			<div class="page-section-card page-section-card-always" data-section="page_content">
				<div class="page-section-card-top">
					<div>
						<strong>{t("messages.pageContent")}</strong>
						<p class="admin-muted">{t("messages.pageContentHelp")}</p>
					</div>
					<label class="page-section-order">
						<span>{t("labels.order")}</span>
						<input type="number" min="1" value={pageContentSection.order} data-section-order disabled={isDisabled} />
					</label>
				</div>
			</div>

			<div class="page-section-card" data-section="banner_slider">
				<div class="page-section-card-top">
					<label class="admin-check-row">
						<input type="checkbox" data-section-enabled checked={Boolean(bannerSection)} disabled={isDisabled} />
						{t("messages.bannerSlider")}
					</label>
					<label class="page-section-order">
						<span>{t("labels.order")}</span>
						<input
							type="number"
							min="1"
							value={bannerSection?.order ?? 1}
							data-section-order
							disabled={isDisabled}
						/>
					</label>
				</div>
				<label>
					<span>{t("labels.bannerImageUrls")}</span>
					<textarea
						rows="4"
						placeholder="https://example.com/banner-1.jpg&#10;https://example.com/banner-2.jpg"
						data-banner-urls
						disabled={isDisabled}
					>{bannerSection?.bannerUrls?.join("\n") ?? ""}</textarea>
				</label>
			</div>

			<div class="page-section-card" data-section="blog_feed">
				<div class="page-section-card-top">
					<label class="admin-check-row">
						<input type="checkbox" data-section-enabled checked={Boolean(blogFeedSection)} disabled={isDisabled} />
						{t("messages.blogFeedGrid")}
					</label>
					<label class="page-section-order">
						<span>{t("labels.order")}</span>
						<input
							type="number"
							min="1"
							value={blogFeedSection?.order ?? 2}
							data-section-order
							disabled={isDisabled}
						/>
					</label>
				</div>
				<p class="admin-muted">{t("messages.latestPublishedPosts")}</p>
			</div>

			<div class="page-section-card" data-section="contact_form">
				<div class="page-section-card-top">
					<label class="admin-check-row">
						<input type="checkbox" data-section-enabled checked={Boolean(contactSection)} disabled={isDisabled} />
						{t("messages.contactForm")}
					</label>
					<label class="page-section-order">
						<span>{t("labels.order")}</span>
						<input
							type="number"
							min="1"
							value={contactSection?.order ?? 3}
							data-section-order
							disabled={isDisabled}
						/>
					</label>
				</div>
				<p class="admin-muted">{t("messages.contactFormHelp")}</p>
			</div>
		</div>
	</div>

	<div class="admin-form-actions">
		<button class="admin-primary-button" type="submit" disabled={isDisabled}>{submitLabel}</button>
		{mode === "edit" && page && <a href={getLocalizedPagePath(page.slug, language)}>{t("actions.openPage")}</a>}
	</div>
</form>

<style>
	.localized-editor,
	.page-sections-stack {
		display: grid;
		gap: 1rem;
	}

	.localized-editor-header,
	.page-section-card-top {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.localized-editor-header h2 {
		margin: 0;
		font-size: 1.1rem;
	}

	.localized-editor-header p,
	.page-sections-heading p {
		margin: 0.35rem 0 0;
	}

	.localized-editor-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.localized-editor-tab {
		border: 1px solid rgba(var(--gray), 0.25);
		border-radius: 999px;
		padding: 0.4rem 0.8rem;
		background: white;
		font: inherit;
		cursor: pointer;
	}

	.localized-editor-tab.is-active {
		background: rgb(var(--accent));
		border-color: rgb(var(--accent));
		color: white;
	}

	.localized-editor-panel,
	.page-section-card {
		display: grid;
		gap: 0.8rem;
		padding: 1rem;
		border-radius: 18px;
		background: rgba(var(--gray-light), 0.28);
	}

	.localized-editor-panel textarea {
		min-height: 280px;
	}

	.page-section-order {
		display: grid;
		gap: 0.35rem;
		min-width: 96px;
	}

	.page-section-order input {
		max-width: 96px;
	}

	.page-section-card :global(textarea[data-banner-urls]) {
		min-height: 110px;
	}

	@media (max-width: 720px) {
		.localized-editor-header,
		.page-section-card-top {
			flex-direction: column;
			align-items: stretch;
		}
	}
</style>

<script>
	const syncLocalizedEditor = (root) => {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const titleField = root.querySelector("[data-title-translations]");
		const contentField = root.querySelector("[data-content-translations]");
		if (!(titleField instanceof HTMLInputElement) || !(contentField instanceof HTMLInputElement)) {
			return;
		}

		const titleTranslations = {};
		root.querySelectorAll("[data-title-input]").forEach((input) => {
			if (!(input instanceof HTMLInputElement)) {
				return;
			}
			const code = input.dataset.titleInput;
			if (code) {
				titleTranslations[code] = input.value;
			}
		});

		const contentTranslations = {};
		root.querySelectorAll("[data-content-input]").forEach((input) => {
			if (!(input instanceof HTMLTextAreaElement)) {
				return;
			}
			const code = input.dataset.contentInput;
			if (code) {
				contentTranslations[code] = input.value;
			}
		});

		titleField.value = JSON.stringify(titleTranslations);
		contentField.value = JSON.stringify(contentTranslations);
	};

	document.querySelectorAll("[data-localized-editor]").forEach((root) => {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const setActiveLanguage = (language) => {
			root.dataset.activeLanguage = language;
			root.querySelectorAll("[data-language-tab]").forEach((button) => {
				if (!(button instanceof HTMLButtonElement)) {
					return;
				}
				const isActive = button.dataset.languageTab === language;
				button.classList.toggle("is-active", isActive);
				button.setAttribute("aria-selected", isActive ? "true" : "false");
			});
			root.querySelectorAll("[data-language-panel]").forEach((panel) => {
				if (!(panel instanceof HTMLElement)) {
					return;
				}
				const isActive = panel.dataset.languagePanel === language;
				panel.hidden = !isActive;
				panel.classList.toggle("is-active", isActive);
			});
		};

		root.querySelectorAll("[data-language-tab]").forEach((button) => {
			button.addEventListener("click", () => {
				if (button instanceof HTMLButtonElement && button.dataset.languageTab) {
					setActiveLanguage(button.dataset.languageTab);
				}
			});
		});

		root.addEventListener("input", () => syncLocalizedEditor(root));
		syncLocalizedEditor(root);
		setActiveLanguage(root.dataset.activeLanguage || "en");
	});

	const editor = document.querySelector("[data-page-sections-editor]");
	const payload = document.querySelector("[data-page-sections-config]");

	const syncSections = () => {
		if (!(editor instanceof HTMLElement) || !(payload instanceof HTMLInputElement)) {
			return;
		}

		const cards = Array.from(editor.querySelectorAll("[data-section]"));
		const sections = cards
			.map((card) => {
				if (!(card instanceof HTMLElement)) {
					return null;
				}

				const type = card.dataset.section;
				if (!type) {
					return null;
				}

				const enabledInput = card.querySelector("[data-section-enabled]");
				const enabled = enabledInput instanceof HTMLInputElement ? enabledInput.checked : true;
				if (!enabled && type !== "page_content") {
					return null;
				}

				const orderInput = card.querySelector("[data-section-order]");
				const order =
					orderInput instanceof HTMLInputElement
						? Math.max(1, Number.parseInt(orderInput.value || "1", 10) || 1)
						: 1;

				if (type === "banner_slider") {
					const urlsInput = card.querySelector("[data-banner-urls]");
					const bannerUrls =
						urlsInput instanceof HTMLTextAreaElement
							? urlsInput.value
									.split(/\r?\n/)
									.map((entry) => entry.trim())
									.filter(Boolean)
							: [];

					if (enabled && bannerUrls.length === 0) {
						return null;
					}

					return { type, order, bannerUrls };
				}

				return { type, order };
			})
			.filter(Boolean)
			.sort((left, right) => left.order - right.order);

		payload.value = JSON.stringify(sections);
	};

	editor?.addEventListener("input", syncSections);
	editor?.addEventListener("change", syncSections);
	syncSections();
</script>
