---
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	id: string;
	title?: string;
	message?: string;
	confirmLabel?: string;
	cancelLabel?: string;
	tone?: "danger" | "warning";
}

const { t } = getUiTranslations(Astro);
const {
	id,
	title = t("messages.confirmActionTitle", "Confirm action"),
	message = t("messages.confirmActionMessage", "Are you sure you want to continue?"),
	confirmLabel = t("actions.confirm", "Confirm"),
	cancelLabel = t("actions.cancel", "Cancel"),
	tone = "danger",
} = Astro.props;
---

<div class="modal fade" id={id} tabindex="-1" aria-hidden="true" data-admin-confirm-modal data-confirm-tone={tone}>
	<div class="modal-dialog modal-dialog-centered admin-feedback-modal-dialog">
		<div class="modal-content border-0 shadow-sm admin-feedback-modal-shell">
			<div class="admin-feedback-modal-accent" aria-hidden="true"></div>
			<div class="modal-header py-3 px-3 px-sm-4 admin-feedback-modal-header">
				<div class="d-flex align-items-start gap-3 min-w-0">
					<span class="admin-feedback-modal-icon" data-confirm-modal-icon aria-hidden="true">
						<span class="admin-feedback-modal-glyph" data-confirm-modal-glyph>!</span>
					</span>
					<div class="min-w-0">
						<p class="admin-feedback-modal-kicker mb-1 text-capitalize" data-confirm-modal-kicker>{tone}</p>
						<h2 class="modal-title h5 mb-0 text-break" data-confirm-modal-title>{title}</h2>
					</div>
				</div>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label={cancelLabel}></button>
			</div>
			<div class="modal-body px-3 px-sm-4 py-3 admin-feedback-modal-body">
				<p class="mb-1 fw-semibold text-body" data-confirm-modal-message>{message}</p>
				<p class="mb-0 small text-body-secondary" data-confirm-modal-detail hidden></p>
			</div>
			<div class="modal-footer py-3 px-3 px-sm-4 border-0">
				<button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">{cancelLabel}</button>
				<button type="button" class="btn btn-danger btn-sm" data-confirm-modal-confirm>{confirmLabel}</button>
			</div>
		</div>
	</div>
</div>

<script is:inline define:vars={{ modalId: id }}>
	(() => {
		const toneIcons = {
			danger: "✖",
			warning: "⚠",
		};
		const toneLabels = {
			danger: "Danger",
			warning: "Warning",
		};

		const getModalElement = () => document.getElementById(modalId);
		let pendingForm = null;

		const setContent = (modalEl, { title, message, detail, confirmLabel, tone }) => {
			const titleEl = modalEl.querySelector("[data-confirm-modal-title]");
			const messageEl = modalEl.querySelector("[data-confirm-modal-message]");
			const detailEl = modalEl.querySelector("[data-confirm-modal-detail]");
			const iconEl = modalEl.querySelector("[data-confirm-modal-icon]");
			const glyphEl = modalEl.querySelector("[data-confirm-modal-glyph]");
			const kickerEl = modalEl.querySelector("[data-confirm-modal-kicker]");
			const confirmButton = modalEl.querySelector("[data-confirm-modal-confirm]");

			if (titleEl instanceof HTMLElement) {
					titleEl.textContent = title || titleEl.textContent || "";
			}
			if (messageEl instanceof HTMLElement) {
				messageEl.textContent = message || "";
			}
			if (detailEl instanceof HTMLElement) {
				if (detail) {
					detailEl.textContent = detail;
					detailEl.hidden = false;
				} else {
					detailEl.textContent = "";
					detailEl.hidden = true;
				}
			}
			if (iconEl instanceof HTMLElement) {
				iconEl.setAttribute("data-tone", tone);
			}
			if (glyphEl instanceof HTMLElement) {
				glyphEl.textContent = toneIcons[tone] || toneIcons.danger;
			}
			if (kickerEl instanceof HTMLElement) {
				kickerEl.textContent = toneLabels[tone] || toneLabels.danger;
			}
			if (confirmButton instanceof HTMLButtonElement) {
					confirmButton.textContent = confirmLabel || "";
			}
			modalEl.dataset.confirmTone = tone || "danger";
		};

		const showAdminConfirmModal = (payload = {}) => {
			const modalEl = getModalElement();
			if (!(modalEl instanceof HTMLElement)) {
				return;
			}

			setContent(modalEl, payload);

			const bootstrap = window.bootstrap;
			if (bootstrap?.Modal) {
				const instance = bootstrap.Modal.getOrCreateInstance(modalEl);
				modalEl.addEventListener(
					"shown.bs.modal",
					() => {
						const confirmButton = modalEl.querySelector("[data-confirm-modal-confirm]");
						if (confirmButton instanceof HTMLButtonElement) {
							confirmButton.focus();
						}
					},
					{ once: true },
				);
				instance.show();
			}
		};

		window.showAdminConfirmModal = showAdminConfirmModal;

		document.addEventListener("submit", (event) => {
			const form = event.target;
			if (!(form instanceof HTMLFormElement) || !form.matches("[data-admin-confirm-form]")) {
				return;
			}

			if (form.dataset.adminConfirmAccepted === "1") {
				delete form.dataset.adminConfirmAccepted;
				return;
			}

			event.preventDefault();
			event.stopImmediatePropagation();
			pendingForm = form;

			const modalEl = getModalElement();
			const payload = {
					title: form.dataset.confirmTitle || "",
					message: form.dataset.confirmMessage || "",
					detail: form.dataset.confirmDetail || "",
					confirmLabel: form.dataset.confirmConfirmLabel || "",
				tone: form.dataset.confirmTone || "danger",
			};

			showAdminConfirmModal(payload);

			if (modalEl instanceof HTMLElement) {
				const confirmButton = modalEl.querySelector("[data-confirm-modal-confirm]");
				if (confirmButton instanceof HTMLButtonElement) {
					confirmButton.onclick = () => {
						if (!(pendingForm instanceof HTMLFormElement)) {
							return;
						}
						const form = pendingForm;
						form.dataset.adminConfirmAccepted = "1";
						const submit = form.requestSubmit?.bind(form);
						pendingForm = null;
						if (submit) {
							submit();
						} else {
							form.submit();
						}
						window.setTimeout(() => {
							delete form.dataset.adminConfirmAccepted;
						}, 0);
					};
				}
			}
		}, true);
	})();
</script>
