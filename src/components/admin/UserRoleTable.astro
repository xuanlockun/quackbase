---
import type { AdminUserSummary, RoleSummary } from "../../lib/auth/types";

interface Props {
	users: AdminUserSummary[];
	roles: RoleSummary[];
}

const { users, roles } = Astro.props;
---

<section class="panel-stack" id="user-role-table" data-users={JSON.stringify(users)} data-roles={JSON.stringify(roles)}>
	<section class="panel">
		<div class="toolbar">
			<div>
				<h2>Admin Users</h2>
				<p class="muted">Create admin accounts and manage their active role assignments.</p>
			</div>
		</div>
		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th>User</th>
						<th>Status</th>
						<th>Roles</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					{
						users.map((user) => (
							<tr>
								<td>
									<strong>{user.displayName}</strong>
									<br />
									<span class="muted">{user.email}</span>
								</td>
								<td>
									<span class:list={["status-pill", user.isActive ? "active" : "inactive"]}>
										{user.isActive ? "Active" : "Inactive"}
									</span>
								</td>
								<td>
									<div class="badge-row">
										{user.roles.map((role) => <span class="role-badge">{role.label}</span>)}
										{user.roles.length === 0 && <span class="muted">No roles</span>}
									</div>
								</td>
								<td>
									<button
										class="secondary edit-user"
										type="button"
										data-user-id={user.id}
									>
										Edit
									</button>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	</section>

	<section class="panel">
		<h3>Create Admin User</h3>
		<form class="stack" data-create-user-form>
			<label><span>Email</span><input name="email" type="email" required /></label>
			<label><span>Display name</span><input name="displayName" required /></label>
			<label><span>Password</span><input name="password" type="password" minlength="8" required /></label>
			<label class="checkbox-row"><input name="isActive" type="checkbox" checked /> Active</label>
			<fieldset>
				<legend>Roles</legend>
				<div class="check-grid">
					{
						roles.map((role) => (
							<label class="checkbox-row">
								<input type="checkbox" name="roleIds" value={role.id} />
								{role.label}
							</label>
						))
					}
				</div>
			</fieldset>
			<p class="message" data-create-message></p>
			<button class="primary" type="submit">Create user</button>
		</form>
	</section>

	<section class="panel hidden" data-edit-user-panel>
		<h3>Edit Admin User</h3>
		<form class="stack" data-edit-user-form>
			<input type="hidden" name="userId" />
			<label><span>Email</span><input name="email" disabled /></label>
			<label><span>Display name</span><input name="displayName" required /></label>
			<label><span>New password</span><input name="password" type="password" minlength="8" placeholder="Leave blank to keep current password" /></label>
			<label class="checkbox-row"><input name="isActive" type="checkbox" /> Active</label>
			<fieldset>
				<legend>Roles</legend>
				<div class="check-grid" data-edit-role-list></div>
			</fieldset>
			<p class="message" data-edit-message></p>
			<div class="toolbar">
				<button class="primary" type="submit">Save user</button>
				<button class="secondary" type="button" data-cancel-edit>Cancel</button>
			</div>
		</form>
	</section>
</section>

<script is:inline>
	const root = document.getElementById("user-role-table");
	if (root) {
		const users = JSON.parse(root.dataset.users ?? "[]");
		const roles = JSON.parse(root.dataset.roles ?? "[]");
		const createForm = root.querySelector("[data-create-user-form]");
		const editPanel = root.querySelector("[data-edit-user-panel]");
		const editForm = root.querySelector("[data-edit-user-form]");
		const editRoleList = root.querySelector("[data-edit-role-list]");

		const selectedRoleIds = (scope) =>
			Array.from(scope.querySelectorAll('input[name="roleIds"]:checked')).map((input) => Number(input.value));

		const renderEditRoleInputs = (selectedIds) => {
			if (!editRoleList) return;
			editRoleList.innerHTML = roles
				.map(
					(role) =>
						`<label class="checkbox-row"><input type="checkbox" name="roleIds" value="${role.id}" ${
							selectedIds.includes(role.id) ? "checked" : ""
						}/> ${role.label}</label>`,
				)
				.join("");
		};

		createForm?.addEventListener("submit", async (event) => {
			event.preventDefault();
			const form = event.currentTarget;
			const message = root.querySelector("[data-create-message]");
			message.textContent = "";

			const response = await fetch("/api/admin/users", {
				method: "POST",
				headers: { "Content-Type": "application/json", Accept: "application/json" },
				body: JSON.stringify({
					email: form.email.value,
					displayName: form.displayName.value,
					password: form.password.value,
					isActive: form.isActive.checked,
					roleIds: selectedRoleIds(form),
				}),
			});

			if (response.ok) {
				window.location.reload();
				return;
			}

			const body = await response.json().catch(() => ({ error: "Request failed." }));
			message.textContent = body.error ?? "Request failed.";
		});

		root.querySelectorAll(".edit-user").forEach((button) => {
			button.addEventListener("click", () => {
				const userId = Number(button.dataset.userId);
				const user = users.find((entry) => entry.id === userId);
				if (!user || !editForm) return;

				editPanel?.classList.remove("hidden");
				editForm.userId.value = String(user.id);
				editForm.email.value = user.email;
				editForm.displayName.value = user.displayName;
				editForm.password.value = "";
				editForm.isActive.checked = Boolean(user.isActive);
				renderEditRoleInputs(user.roles.map((role) => role.id));
			});
		});

		editForm?.addEventListener("submit", async (event) => {
			event.preventDefault();
			const form = event.currentTarget;
			const message = root.querySelector("[data-edit-message]");
			message.textContent = "";

			const payload = {
				displayName: form.displayName.value,
				password: form.password.value,
				isActive: form.isActive.checked,
				roleIds: selectedRoleIds(form),
			};

			const response = await fetch(`/api/admin/users/${form.userId.value}`, {
				method: "PATCH",
				headers: { "Content-Type": "application/json", Accept: "application/json" },
				body: JSON.stringify(payload),
			});

			if (response.ok) {
				window.location.reload();
				return;
			}

			const body = await response.json().catch(() => ({ error: "Request failed." }));
			message.textContent = body.error ?? "Request failed.";
		});

		root.querySelector("[data-cancel-edit]")?.addEventListener("click", () => {
			editPanel?.classList.add("hidden");
		});
	}
</script>

<style>
	.panel-stack,
	.stack {
		display: grid;
		gap: 1rem;
	}
	.panel {
		background: white;
		border-radius: 22px;
		box-shadow: 0 18px 40px rgba(var(--gray), 0.12);
		padding: 1.35rem;
		border: 1px solid rgba(var(--gray-light), 0.8);
	}
	.table-wrap {
		overflow-x: auto;
	}
	.toolbar,
	.badge-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
	}
	table {
		width: 100%;
		border-collapse: collapse;
	}
	th,
	td {
		padding: 0.9rem 0.7rem;
		text-align: left;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.check-grid {
		display: grid;
		gap: 0.65rem;
	}
	.checkbox-row {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	label,
	fieldset {
		display: grid;
		gap: 0.45rem;
	}
	input,
	button {
		font: inherit;
		padding: 0.8rem 0.95rem;
		border-radius: 12px;
		border: 1px solid rgb(var(--gray-light));
	}
	button {
		cursor: pointer;
	}
	.primary,
	.secondary {
		border: none;
	}
	.primary {
		background: linear-gradient(135deg, #1f4fff, #3a7bff);
		color: white;
	}
	.secondary {
		background: white;
		color: rgb(var(--gray-dark));
		border: 1px solid rgb(var(--gray-light));
	}
	.status-pill,
	.role-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.55rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 700;
	}
	.status-pill.active,
	.role-badge {
		background: rgba(35, 55, 255, 0.1);
		color: var(--accent-dark);
	}
	.status-pill.inactive {
		background: #fff1f2;
		color: #9f1239;
	}
	.message {
		min-height: 1.2rem;
		color: #9f1239;
		margin: 0;
	}
	.muted {
		color: rgb(var(--gray));
	}
	.hidden {
		display: none;
	}
</style>
