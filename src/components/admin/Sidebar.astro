---
import { getVisibleAdminNavItems } from "../../lib/rbac/policies";
import type { AdminSession } from "../../lib/auth/types";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	session: AdminSession | null;
}

const { session } = Astro.props;
const pathname = Astro.url.pathname;
const links = getVisibleAdminNavItems(session);
const { t, localizeAdminHref } = getUiTranslations(Astro);
const adminBrandName = "Quackbase";
const adminBrandDuckIcon = `
	<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
		<path d="M11 34H30C37.18 34 43 39.82 43 47C43 54.18 37.18 60 30 60H20.8C10.97 60 3 52.03 3 42.2V42C3 37.58 6.58 34 11 34Z" fill="white"/>
