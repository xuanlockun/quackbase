			<path d="M8 14h5" />
		</svg>
	`,
	"nav.contactForms": `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<rect x="4" y="5" width="16" height="14" rx="2" />
			<path d="M8 9h8" />
			<path d="M8 13h6" />
			<path d="M8 17h4" />
		</svg>
	`,
	"nav.media": `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<rect x="4" y="5" width="16" height="14" rx="2" />
			<path d="M8 14l2.5-3 2 2 2-3 3.5 4" />
			<circle cx="9" cy="9" r="1.25" />
		</svg>
	`,
	"nav.backup": `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 3v10" />
			<path d="M8 9l4 4 4-4" />
			<path d="M5 14.5V19a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4.5" />
		</svg>
	`,
	"nav.footer": `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<rect x="4" y="5" width="16" height="14" rx="2" />
			<path d="M7 9h10" />
			<path d="M7 13h6" />
			<path d="M7 17h4" />
		</svg>
	`,
	"nav.settings": `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="12" r="3" />
			<path d="M4.8 12h2.4" />
			<path d="M17.7 12h2.4" />
			<path d="M12 4.8v2.4" />
			<path d="M12 17.7v2.4" />
		</svg>
	`,
	"nav.themes": `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 4c-4.418 0-8 3.358-8 7.5C4 15.09 6.91 18 10.5 18H12a2 2 0 0 0 0-4h-.5a2.5 2.5 0 0 1 0-5H20" />
			<circle cx="7.5" cy="10" r="1" />
			<circle cx="10.5" cy="7.5" r="1" />
			<circle cx="15.5" cy="7.5" r="1" />
		</svg>
	`,
	"nav.users": `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="8" r="3" />
