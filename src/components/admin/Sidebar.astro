	{ title: "Management", labelKeys: ["nav.users", "nav.roles"] },
	{ title: "Settings", labelKeys: ["nav.backup", "nav.settings", "nav.languages"] },
];

const sections = sectionConfig
	.map((section) => ({
		title: section.title,
		links: links.filter((link) => section.labelKeys.includes(link.labelKey)),
	}))
	.filter((section) => section.links.length > 0);

function isActiveLink(href: string, currentPath: string): boolean {
	if (href === "/admin") {
		return currentPath === "/admin" || currentPath === "/admin/";
	}

	return currentPath === href || currentPath.startsWith(`${href}/`);
}

---

<nav aria-label="Admin navigation" class="admin-sidebar-nav d-flex flex-column h-100">
	<header class="admin-sidebar-header">
		<a href={localizeAdminHref("/admin")} class="admin-sidebar-brand text-decoration-none">
			<span class="admin-sidebar-mark admin-sidebar-mark--duck" aria-hidden="true" set:html={adminBrandDuckIcon}>
			</span>
			<div class="admin-sidebar-brand-copy">
				<p class="mb-0 fw-semibold text-white">{adminBrandName}</p>
			</div>
		</a>
	</header>
	<div class="admin-sidebar-body overflow-auto">
		{
			sections.map((section) => (
				<section key={section.title} class="admin-sidebar-section">
					{section.title && <p class="text-uppercase mb-2 admin-sidebar-section-label">{section.title}</p>}
					<div class="nav nav-pills flex-column admin-sidebar-links">
						{
							section.links.map((link) => (
								<a
									role="menuitem"
									aria-current={isActiveLink(link.href, pathname) ? "page" : undefined}
									class:list={["nav-link", "w-100 text-start", isActiveLink(link.href, pathname) && "active"]}
									href={localizeAdminHref(link.href)}
									data-admin-sidebar-link
								>
									<span class="d-inline-flex align-items-center justify-content-center flex-shrink-0 admin-sidebar-icon-wrap">
										<span aria-hidden="true" set:html={navIconHtml(link.labelKey)}></span>
									</span>
									<span>{t(link.labelKey, navLabelFallbacks[link.labelKey])}</span>
								</a>
							))
						}
					</div>
				</section>
			))
		}
	</div>
	<footer class="admin-sidebar-footer">
		<p class="mb-0 small text-uppercase letter-spacing-wide">{adminBrandName}</p>
		<small class="text-muted">Admin navigation</small>
	</footer>
</nav>
