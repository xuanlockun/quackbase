---
import FormattedDate from "../FormattedDate.astro";
import IconAction from "./IconAction.astro";
import type { ContactFormRecord } from "../../lib/contact-forms";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	forms: ContactFormRecord[];
	canUpdate: boolean;
	canDelete: boolean;
	canViewLeads: boolean;
	submissionCounts?: Record<string, number>;
}

const { forms, canUpdate, canDelete, canViewLeads, submissionCounts = {} } = Astro.props;
const { t } = getUiTranslations(Astro);
---

{
	forms.length === 0 ? (
		<div class="admin-state-surface">
			<h2 class="h5 mb-2">{t("messages.noContactFormsYet")}</h2>
			<p class="mb-0 admin-muted">{t("messages.manageContactForms")}</p>
		</div>
	) : (
		<div class="admin-table-surface table-responsive">
			<table class="table table-sm table-hover align-middle mb-0">
				<thead>
						<tr>
							<th>{t("labels.title")}</th>
							<th>{t("labels.description")}</th>
							<th>{t("labels.template")}</th>
							<th>{t("labels.fieldType")}</th>
							<th>{t("labels.status")}</th>
							<th>{t("labels.updated")}</th>
							<th>{t("labels.action")}</th>
						</tr>
				</thead>
				<tbody>
					{
						forms.map((form) => (
							<tr>
								<td>
									<div class="d-grid">
										<strong>{form.title}</strong>
										<span class="text-muted small">{form.fields.length} fields</span>
										<span class="text-muted small">{submissionCounts[form.id] ?? 0} leads</span>
									</div>
								</td>
								<td>
									<span class="text-muted small">{form.description || "—"}</span>
								</td>
								<td>
									<span class="badge text-bg-light text-uppercase">{form.layout}</span>
								</td>
								<td><code>{form.fields.length}</code></td>
								<td>
									<span class={`badge text-uppercase ${form.isActive ? "bg-success" : "bg-secondary"}`}>
										{form.isActive ? t("status.active") : t("status.inactive")}
									</span>
								</td>
								<td><FormattedDate date={form.updatedAt} /></td>
								<td class="admin-action-cell">
									<div class="admin-action-group">
										{canViewLeads && (
											<IconAction
												href={`/admin/contact-forms/${form.id}/leads`}
												icon="view"
												label="Leads"
											/>
										)}
										{canUpdate && (
											<IconAction
												href={`/admin/contact-forms/${form.id}/edit`}
												icon="edit"
												label={t("actions.edit")}
												variant="btn-outline-primary"
											/>
										)}
										{canDelete && (
											<form class="d-inline" method="post" action="/api/admin/contact-forms/delete">
												<input type="hidden" name="id" value={form.id} />
												<IconAction type="submit" icon="delete" label={t("actions.delete")} variant="btn-outline-danger" />
											</form>
										)}
									</div>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	)
}
