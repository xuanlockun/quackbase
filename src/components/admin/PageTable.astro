---
import FormattedDate from "../FormattedDate.astro";
import { getLocalizedPagePath, type SitePage } from "../../lib/blog";
import { getLanguageCatalog, getUiTranslations } from "../../lib/i18n";

interface Props {
	pages: SitePage[];
	canUpdate: boolean;
	canDelete: boolean;
	emptyTitle?: string;
	emptyDescription?: string;
}

const { pages, canUpdate, canDelete, emptyTitle, emptyDescription } = Astro.props;
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
---

{
	pages.length === 0 ? (
		<div class="admin-state-surface">
			<h2 class="h5 mb-2">{emptyTitle ?? t("messages.noPagesYet")}</h2>
			<p class="mb-0 admin-muted">{emptyDescription ?? t("messages.noPagesHelp")}</p>
		</div>
	) : (
		<div class="admin-table-surface table-responsive">
			<table class="table table-sm table-hover align-middle mb-0">
				<thead>
					<tr>
						<th>{t("labels.title")}</th>
						<th>{t("labels.status")}</th>
						<th>{t("labels.updated")}</th>
						<th>{t("labels.slug")}</th>
						<th>{t("labels.action")}</th>
					</tr>
				</thead>
				<tbody>
					{
						pages.map((page) => (
							<tr>
								<td>
									<div class="d-flex flex-column gap-1">
										<strong>{page.title}</strong>
										<span class="text-muted small">{page.description}</span>
									</div>
								</td>
								<td>
									<span class={`badge text-uppercase ${page.status === "published" ? "bg-success" : "bg-secondary"}`}>
										{t(`status.${page.status}`, page.status)}
									</span>
								</td>
								<td>
									<FormattedDate date={page.updatedAt} />
								</td>
								<td>
									<code>{page.slug}</code>
								</td>
								<td>
									<div class="d-flex flex-wrap gap-2">
										{canUpdate && (
											<a class="btn btn-sm btn-outline-primary" href={`/admin/pages/${page.id}/edit`}>
												{t("actions.edit")}
											</a>
										)}
										<a class="btn btn-sm btn-outline-secondary" href={getLocalizedPagePath(page.slug, language, catalog)}>
											{t("actions.view")}
										</a>
										{canDelete && (
											<form class="d-inline" method="post" action="/api/admin/pages/delete">
												<input type="hidden" name="id" value={page.id} />
												<button class="btn btn-sm btn-outline-danger" type="submit">
													{t("actions.delete")}
												</button>
											</form>
										)}
									</div>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	)
}
