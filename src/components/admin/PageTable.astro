---
import FormattedDate from "../FormattedDate.astro";
import { getLocalizedPagePath, type SitePage } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	pages: SitePage[];
	canUpdate: boolean;
	canDelete: boolean;
}

const { pages, canUpdate, canDelete } = Astro.props;
const { t, language } = getUiTranslations(Astro);
---

{
	pages.length === 0 ? (
		<div class="admin-empty-state">
			<h2>{t("messages.noPagesYet")}</h2>
			<p>{t("messages.noPagesHelp")}</p>
		</div>
	) : (
		<div class="admin-table-wrap">
			<table class="admin-table table table-sm align-middle mb-0">
				<thead>
					<tr>
						<th>{t("labels.title")}</th>
						<th>{t("labels.status")}</th>
						<th>{t("labels.updated")}</th>
						<th>{t("labels.slug")}</th>
						<th>{t("labels.action")}</th>
					</tr>
				</thead>
				<tbody>
					{
						pages.map((page) => (
							<tr>
								<td>
									<div class="admin-meta-block">
										<strong>{page.title}</strong>
										<span class="admin-muted">{page.description}</span>
									</div>
								</td>
								<td>
									<span class="admin-status-pill">{t(`status.${page.status}`, page.status)}</span>
								</td>
								<td>
									<FormattedDate date={page.updatedAt} />
								</td>
								<td>
									<code>{page.slug}</code>
								</td>
								<td>
									<div class="admin-row-actions">
										{canUpdate && <a href={`/admin/pages/${page.id}/edit`}>{t("actions.edit")}</a>}
										<a href={getLocalizedPagePath(page.slug, language)}>{t("actions.view")}</a>
										{canDelete && (
											<form class="admin-inline-form" method="post" action="/api/admin/pages/delete">
												<input type="hidden" name="id" value={page.id} />
												<button class="admin-danger-button" type="submit">{t("actions.delete")}</button>
											</form>
										)}
									</div>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	)
}
