---
import FormattedDate from "../FormattedDate.astro";
import type { AdminPostSummary } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	posts: AdminPostSummary[];
	canUpdate: boolean;
	canDelete: boolean;
}

const { posts, canUpdate, canDelete } = Astro.props;
const { t } = getUiTranslations(Astro);
---

{
	posts.length === 0 ? (
		<div class="admin-empty-state">
			<h2>{t("messages.noPostsYet")}</h2>
			<p>{t("messages.noPostsHelp")}</p>
		</div>
	) : (
		<div class="admin-table-wrap">
			<table class="admin-table">
				<thead>
					<tr>
						<th>{t("labels.title")}</th>
						<th>{t("labels.status")}</th>
						<th>{t("labels.updated")}</th>
						<th>{t("labels.slug")}</th>
						<th>{t("labels.action")}</th>
					</tr>
				</thead>
				<tbody>
					{
						posts.map((post) => (
							<tr>
								<td>
									<div class="admin-meta-block">
										<strong>{post.title}</strong>
										<span class="admin-muted">{post.description}</span>
									</div>
								</td>
								<td>
									<span class="admin-status-pill">{t(`status.${post.status}`, post.status)}</span>
								</td>
								<td>
									<FormattedDate date={new Date(post.updatedAt)} />
								</td>
								<td>
									<code>{post.slug}</code>
								</td>
								<td>
									<div class="admin-row-actions">
										{canUpdate && <a href={post.editHref}>{t("actions.editPost")}</a>}
										<a href={post.viewHref}>{t("actions.view")}</a>
										{canDelete && (
											<form method="post" action="/api/admin/posts/delete" class="admin-inline-form">
												<input type="hidden" name="id" value={post.id} />
												<button class="admin-danger-button" type="submit">{t("actions.delete")}</button>
											</form>
										)}
									</div>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	)
}
