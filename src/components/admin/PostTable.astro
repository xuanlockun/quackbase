---
import FormattedDate from "../FormattedDate.astro";
import IconAction from "./IconAction.astro";
import type { AdminPostSummary } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	posts: AdminPostSummary[];
	canUpdate: boolean;
	canDelete: boolean;
	emptyTitle?: string;
	emptyDescription?: string;
}

const { posts, canUpdate, canDelete, emptyTitle, emptyDescription } = Astro.props;
const { t } = getUiTranslations(Astro);
---

{
	posts.length === 0 ? (
		<div class="admin-state-surface">
			<h2 class="h5 mb-2">{emptyTitle ?? t("messages.noPostsYet")}</h2>
			<p class="mb-0 admin-muted">{emptyDescription ?? t("messages.noPostsHelp")}</p>
		</div>
	) : (
		<div class="admin-table-surface table-responsive">
			<table class="table table-sm table-hover align-middle mb-0">
				<thead>
					<tr>
						<th>{t("labels.title")}</th>
						<th>{t("labels.status")}</th>
						<th>{t("labels.updated")}</th>
						<th>{t("labels.slug")}</th>
						<th>{t("labels.action")}</th>
					</tr>
				</thead>
				<tbody>
					{
						posts.map((post) => (
							<tr>
								<td>
									<div class="d-flex flex-column gap-1">
										<strong>{post.title}</strong>
										<span class="text-muted small">{post.description}</span>
									</div>
								</td>
								<td>
									<span class={`badge text-uppercase ${post.status === "published" ? "bg-success" : "bg-secondary"}`}>
										{t(`status.${post.status}`, post.status)}
									</span>
								</td>
								<td>
									<FormattedDate date={new Date(post.updatedAt)} />
								</td>
								<td>
									<code>{post.slug}</code>
								</td>
								<td class="admin-action-cell">
									<div class="admin-action-group">
										{canUpdate && (
											<IconAction href={post.editHref} icon="edit" label={t("actions.editPost")} variant="btn-outline-primary" />
										)}
										<IconAction href={post.viewHref} icon="view" label={t("actions.view")} />
										{canDelete && (
											<form method="post" action="/api/admin/posts/delete" class="d-inline">
												<input type="hidden" name="id" value={post.id} />
												<IconAction type="submit" icon="delete" label={t("actions.delete")} variant="btn-outline-danger" />
											</form>
										)}
									</div>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	)
}
