---
import PermissionBadge from "./PermissionBadge.astro";
import type { AdminRole } from "../../lib/auth/types";

interface Props {
	roles: AdminRole[];
}

const { roles } = Astro.props;
---

{
	roles.length === 0 ? (
		<div class="admin-empty-state">
			<h2>No roles yet</h2>
			<p>Create a role to group permission bundles for admin users.</p>
		</div>
	) : (
		<div class="admin-content-stack">
			{
				roles.map((role) => (
					<article class="admin-section-card">
						<div class="admin-page-header border-0 pb-0">
							<div class="admin-page-copy">
								<h2 class="h5 mb-0">{role.label}</h2>
								<p class="admin-page-description">
									<code>{role.name}</code>{role.isSystem ? " | system role" : ""}
								</p>
							</div>
							<div class="admin-row-actions">
								<a href={`/admin/roles/${role.id}/edit`}>Edit</a>
								{
									!role.isSystem && (
										<form
											class="admin-inline-form"
											method="post"
											action={`/api/admin/roles/${role.id}`}
											onsubmit="return confirm('Delete this role?');"
										>
											<input type="hidden" name="_intent" value="delete" />
											<button class="admin-danger-button" type="submit">Delete</button>
										</form>
									)
								}
							</div>
						</div>
						{role.description && <p class="admin-muted">{role.description}</p>}
						<div class="admin-row-actions">
							{role.permissions.map((permission) => (
								<PermissionBadge label={permission.label} resource={permission.resource} />
							))}
							{role.permissions.length === 0 && <span class="admin-muted">No permissions assigned</span>}
						</div>
					</article>
				))
			}
		</div>
	)
}
