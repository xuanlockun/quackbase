---
import type { AdminSecretRecord } from "../../lib/secrets";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	secrets: AdminSecretRecord[];
	canManage: boolean;
	loadError?: string;
}

const { secrets, canManage, loadError = "" } = Astro.props;
const { t } = getUiTranslations(Astro);
const testTokenHelp = t(
	"messages.secretTestHelp",
	"This only verifies the token with Cloudflare and does not store it. Paste the full token, often starting with cfat_.",
);
---

<div class="admin-form-surface">
	<div class="admin-surface-header mb-3">
		<div>
			<h2 class="h5 mb-1">{t("headings.secrets")}</h2>
			<p class="admin-inline-muted mb-0">{t("messages.manageSecrets")}</p>
		</div>
	</div>

	<p class="admin-inline-muted mb-3">{t("messages.secretsHelp")}</p>

	{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

	<form class="admin-form-shell admin-compact-form mb-4" method="post" action="/api/admin/secrets" data-secret-test-form>
		<input type="hidden" name="intent" value="create" />
		<input type="hidden" name="secretType" value="cloudflare_api_access_token" />
		<div class="admin-form-surface">
			<div class="admin-grid-two">
				<label style="grid-column: 1 / -1;">
					<span>{t("labels.cloudflareApiAccessToken")}</span>
					<input
						class="form-control"
						type="password"
						name="secretValue"
						autocomplete="off"
						placeholder="cfat_..."
						disabled={!canManage || Boolean(loadError)}
						required
					/>
				</label>
			</div>
			<p class="admin-inline-muted mb-0 mt-2" data-secret-test-note>{testTokenHelp}</p>
		</div>
		<div class="admin-form-section d-flex flex-wrap gap-2 align-items-center">
			<p class="admin-muted mb-0">{t("messages.secretEncryptedHint")}</p>
			<div class="ms-auto d-flex flex-wrap gap-2">
				<button
					class="btn btn-outline-secondary"
					type="button"
					data-secret-test-button
					disabled={!canManage || Boolean(loadError)}
				>
					{t("actions.testToken", "Test token")}
				</button>
				<button class="btn btn-primary" type="submit" disabled={!canManage || Boolean(loadError)}>
					{t("actions.addSecret")}
				</button>
			</div>
		</div>
	</form>

	{
		secrets.length === 0 ? (
			<div class="admin-state-surface">
				<h3 class="h5 mb-2">{t("messages.noSecretsYet")}</h3>
				<p class="mb-0 admin-muted">{t("messages.secretsHelp")}</p>
			</div>
		) : (
			<div class="admin-table-surface admin-compact-table table-responsive">
				<table class="table table-sm table-hover align-middle mb-0">
					<thead>
						<tr>
							<th>{t("labels.secretName")}</th>
							<th>{t("labels.secretValue")}</th>
							<th>{t("labels.updated")}</th>
							<th>{t("labels.action")}</th>
						</tr>
					</thead>
					<tbody>
						{
							secrets.map((secret) => (
								<tr>
									<td>
										<div class="d-grid">
											<strong>{secret.label}</strong>
											<small class="text-muted">{secret.secretType}</small>
										</div>
									</td>
									<td>
										<code>{secret.maskedValue}</code>
									</td>
									<td>{secret.updatedAt.toLocaleString()}</td>
									<td>
										<form
											method="post"
											action="/api/admin/secrets"
											class="d-inline"
											data-admin-confirm-form
											data-confirm-title="Delete secret?"
											data-confirm-message="This secret will be removed from the admin store."
											data-confirm-confirm-label={t("actions.deleteSecret")}
											data-confirm-tone="danger"
										>
											<input type="hidden" name="intent" value="delete" />
											<input type="hidden" name="secretId" value={secret.id} />
											<button class="btn btn-sm btn-outline-danger" type="submit" disabled={!canManage || Boolean(loadError)}>
												{t("actions.deleteSecret")}
											</button>
										</form>
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		)
	}
</div>

<script type="module">
	const form = document.querySelector("[data-secret-test-form]");
	const input = form?.querySelector('input[name="secretValue"]');
	const testButton = form?.querySelector("[data-secret-test-button]");
	const testEndpoint = "/api/admin/secrets/verify";
	const showFeedbackModal = window.showAdminFeedbackModal;
	const modalElement = document.querySelector("[data-admin-feedback-modal]");

	if (
		form instanceof HTMLFormElement &&
		input instanceof HTMLInputElement &&
		testButton instanceof HTMLButtonElement
	) {
		const showModal = (title, message, detail = "", tone = "info", busy = false) => {
			if (typeof showFeedbackModal === "function") {
				showFeedbackModal({ title, message, detail, tone, busy });
			}
		};

		testButton.addEventListener("click", async () => {
			const secretValue = input.value.trim();
			if (!secretValue) {
				showModal("Token required", "Enter a token first.", "", "warning");
				return;
			}

			testButton.disabled = true;
			testButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Testing...';
			showModal("Verifying token", "Checking the token against Cloudflare.", "", "info", true);

			try {
				const response = await fetch(testEndpoint, {
					method: "POST",
					credentials: "same-origin",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({ secretValue: secretValue.replace(/^["']|["']$/g, "") }),
				});

				const payload = await response.json().catch(() => ({}));
				if (!response.ok || !payload?.ok) {
					throw new Error(payload?.error || "Token test failed.");
				}

				const pieces = [`Token is ${payload.status || "active"}.`];
				if (payload.tokenId) {
					pieces.push(`Token ID: ${payload.tokenId}.`);
				}
				if (payload.expiresOn) {
					pieces.push(`Expires: ${new Date(payload.expiresOn).toLocaleString()}.`);
				}

				const saveResponse = await fetch("/api/admin/secrets", {
					method: "POST",
					credentials: "same-origin",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({
						intent: "create",
						secretType: "cloudflare_api_access_token",
						secretValue,
					}),
				});

				const savePayload = await saveResponse.json().catch(() => ({}));
				if (!saveResponse.ok || !savePayload?.ok) {
					throw new Error(savePayload?.error || "The secret request failed.");
				}

				if (modalElement instanceof HTMLElement) {
					modalElement.addEventListener(
						"hidden.bs.modal",
						() => {
							window.location.reload();
						},
						{ once: true },
					);
				}
				showModal("Token verified", `${pieces.join(" ")} The secret was saved.`, "", "success");
			} catch (error) {
				showModal("Token failed", error instanceof Error ? error.message : "Token test failed.", "", "error");
			} finally {
				testButton.disabled = false;
				testButton.textContent = t("actions.testToken", "Test token");
			}
		});
	}
</script>
