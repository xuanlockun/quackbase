</style>

<script type="module">
	const editor = document.querySelector("[data-nav-items-editor]");
	const rowsContainer = editor?.querySelector("[data-nav-items-rows]");
	const payloadInput = document.getElementById("nav-items-payload");
	const addRootButton = editor?.querySelector("[data-nav-add]");
	const addEmptyButton = editor?.querySelector("[data-nav-empty-add]");
	const addChildGlobalButton = editor?.querySelector("[data-nav-add-child-global]");
	const indentSelectedButton = editor?.querySelector("[data-nav-indent-selected]");
	const outdentSelectedButton = editor?.querySelector("[data-nav-outdent-selected]");
	const removeSelectedButton = editor?.querySelector("[data-nav-remove-selected]");
	const emptyStateRow = editor?.querySelector("[data-nav-empty]");
	const inspector = editor?.querySelector("[data-nav-inspector]");
	const inspectorBody = editor?.querySelector("[data-nav-inspector-body]");
	const inspectorEmpty = editor?.querySelector("[data-nav-inspector-empty]");
	const inspectorFields = editor?.querySelector("[data-nav-inspector-fields]");
	const inspectorTitle = editor?.querySelector("[data-nav-inspector-title]");
	const inspectorCopy = editor?.querySelector("[data-nav-inspector-copy]");
	const inspectorDepth = editor?.querySelector("[data-nav-inspector-depth]");
	const inspectorRole = editor?.querySelector("[data-nav-inspector-role]");
	const rootCount = document.querySelector("[data-nav-root-count]");
	const totalCount = document.querySelector("[data-nav-total-count]");
	const removeLabel = editor?.dataset.removeLabel ?? "Remove";
	const addChildLabel = editor?.dataset.addChildLabel ?? "Add item";
	const indentLabel = editor?.dataset.indentLabel ?? "Indent";
	const outdentLabel = editor?.dataset.outdentLabel ?? "Outdent";
	const dragLabel = editor?.dataset.dragLabel ?? "Drag to reorder";
	const collapseLabel = editor?.dataset.collapseLabel ?? "Collapse";
	const expandLabel = editor?.dataset.expandLabel ?? "Expand";
	const noSelectionTitle = editor?.dataset.noSelectionTitle ?? "Select a navigation item";
	const noSelectionCopy = editor?.dataset.noSelectionCopy ?? "Choose a row from the tree to edit its label and path here.";
	const inspectorDefaultTitle = editor?.dataset.inspectorTitle ?? "Selected item";
	const inspectorDefaultCopy = editor?.dataset.inspectorCopy ?? "Keep the tree on the left for structure and use this panel for editing the selected item.";
	const parentRoleLabel = editor?.dataset.parentRoleLabel ?? "Parent";
	const itemRoleLabel = editor?.dataset.itemRoleLabel ?? "Item";
	const levelLabel = editor?.dataset.levelLabel ?? "Level";
	const rootLevelLabel = editor?.dataset.rootLevelLabel ?? "Root level";
	const isReadOnly = editor?.dataset.disabled === "true";
	const maxNavDepth = Number(editor?.dataset.maxDepth ?? "4");
	const defaultNavLabel = editor?.dataset.exampleLabel ?? "New item";
	const navActionIcons = {
		edit: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M12 20h9" />
				<path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L8 18l-4 1 1-4Z" />
			</svg>
		`,
		addChild: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M12 5v14" />
				<path d="M5 12h14" />
			</svg>
		`,
		indent: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 7h14" />
				<path d="M5 12h8" />
				<path d="M5 17h14" />
				<path d="M13 9l4 3-4 3" />
			</svg>
		`,
		outdent: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 7h14" />
				<path d="M5 12h8" />
				<path d="M5 17h14" />
				<path d="M9 9l-4 3 4 3" />
			</svg>
		`,
		remove: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M6 6l12 12" />
				<path d="M18 6L6 18" />
			</svg>
		`,
		drag: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M9 5h.01" />
				<path d="M9 12h.01" />
				<path d="M9 19h.01" />
				<path d="M15 5h.01" />
				<path d="M15 12h.01" />
				<path d="M15 19h.01" />
			</svg>
		`,
	};

	let selectedRow = null;
	let draggedRows = [];
	let navRowIdCounter = 0;

	const clampDepth = (value) => {
		const depth = Number.isFinite(value) ? value : 0;
		return Math.max(0, Math.min(maxNavDepth, Math.floor(depth)));
	};

	const setRowDepth = (row, depth) => {
		const normalized = clampDepth(depth);
		row.dataset.depth = String(normalized);
		row.style.setProperty("--nav-depth", String(normalized));
		renderDepthGuides(row);
		return normalized;
	};

	const ensureRowId = (row) => {
		if (!(row instanceof HTMLElement)) {
			return "";
		}
		const currentId = row.dataset.rowId?.trim();
		if (currentId) {
			return currentId;
		}
		navRowIdCounter += 1;
		const nextId = `nav-row-runtime-${navRowIdCounter}`;
		row.dataset.rowId = nextId;
		return nextId;
	};

	const getFieldBankForRow = (row) => {
		if (!(row instanceof HTMLElement)) {
			return null;
		}
		const rowId = ensureRowId(row);
		if (!rowId) {
			return null;
		}
		return document.querySelector(`[data-nav-field-bank][data-nav-owner="${rowId}"]`);
	};

	const getNavRows = () => Array.from(rowsContainer?.querySelectorAll("[data-nav-row]") ?? []);
	const getVisibleNavRows = () => getNavRows().filter((row) => !row.hidden);
	const getRowDepth = (row) => clampDepth(Number(row.dataset.depth ?? "0"));

	const getRowEditorInputs = (row) => {
		const fieldBank = getFieldBankForRow(row);
		return {
			labels: Array.from(fieldBank?.querySelectorAll("[data-nav-label]") ?? []).filter(
			(input) => input instanceof HTMLInputElement,
			),
			href: fieldBank?.querySelector("[data-nav-href]") ?? null,
		};
	};

	const getRowLabel = (row) => {
		const { labels } = getRowEditorInputs(row);
		for (const input of labels) {
			const value = input.value.trim();
			if (value) {
				return value;
			}
		}
		return "";
	};

	const getRowRoleLabel = (row) => (row.dataset.hasChildren === "true" ? parentRoleLabel : itemRoleLabel);

	const updateRowPreview = (row) => {
		if (!(row instanceof HTMLElement)) {
			return;
		}

		const title = row.querySelector("[data-nav-preview-title]");
		const path = row.querySelector("[data-nav-preview-path]");
		const label = getRowLabel(row);
		const { href: hrefInput } = getRowEditorInputs(row);

		if (title instanceof HTMLElement) {
			title.textContent = label || defaultNavLabel;
		}

		if (path instanceof HTMLElement && hrefInput instanceof HTMLInputElement) {
			path.textContent = hrefInput.value.trim() || "/";
		}
	};

	const updateStats = () => {
		const rows = getNavRows();
		const rootItems = rows.filter((row) => getRowDepth(row) === 0).length;
		if (rootCount instanceof HTMLElement) {
			rootCount.textContent = String(rootItems);
		}
		if (totalCount instanceof HTMLElement) {
			totalCount.textContent = String(rows.length);
		}
	};

	const renderDepthGuides = (row) => {
		const depth = getRowDepth(row);
		Array.from(row.querySelectorAll("[data-guide-index]")).forEach((guide) => {
			if (!(guide instanceof HTMLElement)) {
				return;
			}
			const index = Number(guide.dataset.guideIndex ?? "-1");
			guide.dataset.active = index < depth ? "true" : "false";
			guide.style.left = `${1 + index * 2.2}rem`;
		});
	};

	const normalizeRowDepths = () => {
		const rows = getNavRows();
		let previousDepth = -1;
		for (const row of rows) {
			const allowedDepth = Math.min(maxNavDepth, previousDepth + 1);
			const normalizedDepth = Math.min(getRowDepth(row), Math.max(0, allowedDepth));
			setRowDepth(row, normalizedDepth);
			previousDepth = normalizedDepth;
		}
	};

	const updateRowToggle = (row) => {
		const hasChildren = row.dataset.hasChildren === "true";
		const toggle = row.querySelector("[data-nav-toggle]");
		if (!(toggle instanceof HTMLButtonElement)) {
			return;
		}

		toggle.hidden = !hasChildren;
		const glyph = toggle.querySelector(".nav-tree-toggle-glyph");
		const isCollapsed = hasChildren && row.dataset.collapsed === "true";
		toggle.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
		toggle.setAttribute("aria-label", isCollapsed ? expandLabel : collapseLabel);
		if (glyph instanceof HTMLElement) {
			glyph.innerHTML = isCollapsed
				? `
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M9 6l6 6-6 6" />
					</svg>
				`
				: `
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M6 9l6 6 6-6" />
					</svg>
				`;
		}
	};

	const refreshTreeState = () => {
		if (!(rowsContainer instanceof HTMLElement)) {
			return;
		}

		const rows = getNavRows();
		const collapseStack = [];
		for (let index = 0; index < rows.length; index += 1) {
			const row = rows[index];
			const depth = getRowDepth(row);
			collapseStack.length = depth;
			const ancestorCollapsed = collapseStack.some(Boolean);
			row.hidden = ancestorCollapsed;
			row.setAttribute("aria-hidden", ancestorCollapsed ? "true" : "false");

			const hasChildren = index + 1 < rows.length && getRowDepth(rows[index + 1]) > depth;
			row.dataset.hasChildren = hasChildren ? "true" : "false";
			updateRowToggle(row);

			const isCollapsed = hasChildren && row.dataset.collapsed === "true";
			collapseStack[depth] = isCollapsed;
		}

		if (selectedRow instanceof HTMLElement && selectedRow.hidden) {
			selectedRow.dataset.collapsed = "false";
			refreshTreeState();
			return;
		}

		updateStats();
		updateSelectedRowUi();
	};

	const buildNodeFromRow = (row) => {
		const { href, labels } = getRowEditorInputs(row);

		if (!(href instanceof HTMLInputElement)) {
			return null;
		}

		const trimmedHref = href.value.trim();
		if (!trimmedHref) {
			return null;
		}

		const labelTranslations = {};
		for (const input of labels) {
			const code = input.dataset.languageCode?.trim();
			const value = input.value.trim();
			if (code && value) {
				labelTranslations[code] = value;
			}
		}

		const fallbackLabel = labelTranslations[editor?.dataset.defaultLanguage ?? ""] ?? Object.values(labelTranslations)[0] ?? "";
		if (!fallbackLabel) {
			return null;
		}

		const defaultLanguageCode = editor?.dataset.defaultLanguage?.trim();
		if (defaultLanguageCode && !labelTranslations[defaultLanguageCode]) {
			labelTranslations[defaultLanguageCode] = fallbackLabel;
		}

		return {
			label: fallbackLabel,
			labelTranslations,
			href: trimmedHref,
			children: [],
		};
	};

	const updateEmptyState = () => {
		if (!emptyStateRow || !rowsContainer) {
			return;
		}
		const hasRows = Boolean(rowsContainer.querySelector("[data-nav-row]"));
		emptyStateRow.hidden = hasRows;
	};

	const syncPayload = () => {
		if (!(rowsContainer instanceof HTMLElement) || !(payloadInput instanceof HTMLInputElement)) {
			return;
		}

		normalizeRowDepths();
		const tree = [];
		const stack = [{ depth: -1, children: tree }];
		for (const row of rowsContainer.querySelectorAll("[data-nav-row]")) {
			const currentDepth = getRowDepth(row);
			updateRowPreview(row);
			const node = buildNodeFromRow(row);
			if (!node) {
				continue;
			}

			while (stack[stack.length - 1].depth >= currentDepth) {
				stack.pop();
			}

			stack[stack.length - 1].children.push(node);
			stack.push({ depth: currentDepth, children: node.children });
		}

		payloadInput.value = JSON.stringify(tree);
		refreshTreeState();
		updateEmptyState();
	};

	const restoreFieldBank = (row) => {
		if (!(row instanceof HTMLElement)) {
			return;
		}
		const host = row.querySelector("[data-nav-field-host]");
		const bank = getFieldBankForRow(row);
		if (host instanceof HTMLElement && bank instanceof HTMLElement) {
			host.append(bank);
		}
	};

	const updateSelectedRowUi = () => {
		const rows = getNavRows();
		for (const row of rows) {
			row.dataset.selected = selectedRow === row ? "true" : "false";
			const main = row.querySelector("[data-nav-select]");
			if (main instanceof HTMLElement) {
				main.setAttribute("aria-pressed", selectedRow === row ? "true" : "false");
			}
		}

		const hasSelection = selectedRow instanceof HTMLElement;
		const disableSelectionActions = isReadOnly || !hasSelection;
		if (addChildGlobalButton instanceof HTMLButtonElement) {
			addChildGlobalButton.disabled = disableSelectionActions;
		}
		if (indentSelectedButton instanceof HTMLButtonElement) {
			indentSelectedButton.disabled = disableSelectionActions;
		}
		if (outdentSelectedButton instanceof HTMLButtonElement) {
			outdentSelectedButton.disabled = disableSelectionActions;
		}
		if (removeSelectedButton instanceof HTMLButtonElement) {
			removeSelectedButton.disabled = disableSelectionActions;
		}

		if (!(selectedRow instanceof HTMLElement)) {
			if (inspectorBody instanceof HTMLElement) {
				inspectorBody.hidden = true;
			}
			if (inspectorEmpty instanceof HTMLElement) {
				inspectorEmpty.hidden = false;
			}
			if (inspectorTitle instanceof HTMLElement) {
				inspectorTitle.textContent = noSelectionTitle;
			}
			if (inspectorCopy instanceof HTMLElement) {
				inspectorCopy.textContent = noSelectionCopy;
			}
			if (inspectorDepth instanceof HTMLElement) {
				inspectorDepth.hidden = true;
			}
			if (inspectorRole instanceof HTMLElement) {
				inspectorRole.hidden = true;
			}
			return;
		}

		const bank = getFieldBankForRow(selectedRow);
		if (bank instanceof HTMLElement && inspectorFields instanceof HTMLElement) {
			inspectorFields.replaceChildren(bank);
		}

		if (inspectorBody instanceof HTMLElement) {
			inspectorBody.hidden = false;
		}
		if (inspectorEmpty instanceof HTMLElement) {
			inspectorEmpty.hidden = true;
		}
		if (inspectorTitle instanceof HTMLElement) {
			inspectorTitle.textContent = getRowLabel(selectedRow) || defaultNavLabel;
		}
		if (inspectorCopy instanceof HTMLElement) {
			inspectorCopy.textContent = inspectorDefaultCopy;
		}
		if (inspectorDepth instanceof HTMLElement) {
			inspectorDepth.hidden = false;
			inspectorDepth.textContent = getRowDepth(selectedRow) === 0 ? rootLevelLabel : `${levelLabel} ${getRowDepth(selectedRow) + 1}`;
		}
		if (inspectorRole instanceof HTMLElement) {
			inspectorRole.hidden = false;
			inspectorRole.textContent = getRowRoleLabel(selectedRow);
		}
	};

	const selectRow = (row, options = {}) => {
		if (!(row instanceof HTMLElement)) {
			selectedRow = null;
			updateSelectedRowUi();
			return;
		}

		if (selectedRow && selectedRow !== row) {
			restoreFieldBank(selectedRow);
		}

		selectedRow = row;
		updateSelectedRowUi();

		if (options.focusInspector) {
			const firstInput = inspectorFields?.querySelector("input");
			if (firstInput instanceof HTMLInputElement) {
				requestAnimationFrame(() => {
					firstInput.focus();
					firstInput.select();
				});
			}
		}
	};

	const getSubtreeRows = (row) => {
		if (!(row instanceof HTMLElement)) {
			return [];
		}
		const rows = [row];
		const parentDepth = getRowDepth(row);
		let current = row.nextElementSibling;
		while (current instanceof HTMLElement && current.matches("[data-nav-row]") && getRowDepth(current) > parentDepth) {
			rows.push(current);
			current = current.nextElementSibling;
		}
		return rows;
	};

	const attachNavRow = (row) => {
		if (!(row instanceof HTMLElement) || row.dataset.navRowAttached === "true") {
			return;
		}
		row.dataset.navRowAttached = "true";
		const rowId = ensureRowId(row);
		const bank = row.querySelector("[data-nav-field-bank]");
		if (bank instanceof HTMLElement && !bank.dataset.navOwner) {
			bank.dataset.navOwner = rowId;
		}
		row.dataset.collapsed = row.dataset.collapsed ?? "false";
		row.dataset.selected = row.dataset.selected ?? "false";
		setRowDepth(row, Number(row.dataset.depth ?? "0"));
		row.draggable = !isReadOnly;

		row.addEventListener("dragstart", (event) => {
			if (isReadOnly) {
				return;
			}
			const dragHandle = event.target instanceof Element ? event.target.closest("[data-drag-handle]") : null;
			if (!dragHandle) {
				event.preventDefault();
				return;
			}
			draggedRows = getSubtreeRows(row);
			row.classList.add("is-dragging");
			event.dataTransfer?.setData("text/plain", "");
		});

		row.addEventListener("dragover", (event) => {
			if (!draggedRows.length) {
				return;
			}
			const targetRow = event.currentTarget;
			if (!(targetRow instanceof HTMLElement) || draggedRows.includes(targetRow)) {
				return;
			}
			event.preventDefault();
			getNavRows().forEach((entry) => entry.classList.remove("is-drop-target"));
			targetRow.classList.add("is-drop-target");
			const bounds = targetRow.getBoundingClientRect();
			const insertAfter = event.clientY > bounds.top + bounds.height / 2;
			const fragment = document.createDocumentFragment();
			for (const draggedRow of draggedRows) {
				fragment.append(draggedRow);
			}
			if (insertAfter) {
				const subtree = getSubtreeRows(targetRow);
				subtree[subtree.length - 1].after(fragment);
			} else {
				targetRow.before(fragment);
			}
		});

		row.addEventListener("drop", (event) => {
			if (!draggedRows.length) {
				return;
			}
			event.preventDefault();
			getNavRows().forEach((entry) => entry.classList.remove("is-drop-target", "is-dragging"));
			draggedRows = [];
			syncPayload();
		});

		row.addEventListener("dragend", () => {
			getNavRows().forEach((entry) => entry.classList.remove("is-drop-target", "is-dragging"));
			draggedRows = [];
		});
	};

	const createFieldBank = (entry = {}) => {
		const languages = JSON.parse(editor?.dataset.languages ?? "[]");
		const labelTranslations = { ...(entry.labelTranslations ?? {}) };
		const defaultLanguage = editor?.dataset.defaultLanguage ?? "";
		if (entry.label && defaultLanguage && !labelTranslations[defaultLanguage]) {
			labelTranslations[defaultLanguage] = entry.label;
		}
		const fieldBank = document.createElement("div");
		fieldBank.className = "nav-tree-fields";
		fieldBank.dataset.navFieldBank = "";
		fieldBank.dataset.navOwner = entry.rowId ?? "";

		const createField = (labelText, input) => {
			const field = document.createElement("label");
			field.className = "nav-tree-field";
			const fieldLabel = document.createElement("span");
			fieldLabel.className = "nav-tree-field-label";
			fieldLabel.textContent = labelText;
			field.append(fieldLabel, input);
			return field;
		};

		for (const languageOption of languages) {
			const input = document.createElement("input");
			input.type = "text";
			input.className = "form-control";
			input.dataset.navLabel = "";
			input.dataset.languageCode = languageOption.code;
			input.placeholder = languageOption.label;
			input.value = labelTranslations[languageOption.code] ?? "";
			if (isReadOnly) {
				input.disabled = true;
			}
			fieldBank.append(createField(`${editor?.dataset.labelLabel ?? "Label"} (${languageOption.label})`, input));
		}

		const hrefInput = document.createElement("input");
		hrefInput.type = "text";
		hrefInput.className = "form-control";
		hrefInput.dataset.navHref = "";
		hrefInput.placeholder = "/about or https://example.com";
		hrefInput.value = entry.href ?? "/";
		if (isReadOnly) {
			hrefInput.disabled = true;
		}
		const linkField = createField(editor?.dataset.linkLabel ?? "Link", hrefInput);
		linkField.classList.add("nav-tree-field-link");
		fieldBank.append(linkField);
		return fieldBank;
	};

	const createNavRow = (entry = {}, depth = 0) => {
		const rowId = entry.rowId?.trim() || `nav-row-runtime-${++navRowIdCounter}`;
		const normalizedEntry = {
			...entry,
			rowId,
			label: entry.label ?? defaultNavLabel,
			href: entry.href ?? "/",
		};
		const labelTranslations = normalizedEntry.labelTranslations ?? {};
		const fallbackLabel =
			labelTranslations[editor?.dataset.defaultLanguage ?? ""] ??
			Object.values(labelTranslations)[0] ??
			normalizedEntry.label ??
			defaultNavLabel;

		const row = document.createElement("article");
		row.className = "nav-tree-row";
		row.setAttribute("role", "listitem");
		row.dataset.navRow = "";
		row.dataset.rowIndex = "-1";
		row.dataset.rowId = rowId;
		row.dataset.hasChildren = "false";
		row.dataset.collapsed = "false";
		row.draggable = !isReadOnly;
		setRowDepth(row, depth);

		const guides = document.createElement("div");
		guides.className = "nav-tree-row-guides";
		guides.setAttribute("aria-hidden", "true");
		for (let index = 0; index < maxNavDepth; index += 1) {
			const guide = document.createElement("span");
			guide.className = "nav-tree-guide";
			guide.dataset.guideIndex = String(index);
			guides.append(guide);
		}
		row.append(guides);

		const card = document.createElement("div");
		card.className = "nav-tree-card";

		const main = document.createElement("div");
		main.className = "nav-tree-main";
		main.dataset.navSelect = "";
		main.tabIndex = 0;
		main.setAttribute("role", "button");
		main.setAttribute("aria-pressed", "false");

		const toggleButton = document.createElement("button");
		toggleButton.type = "button";
		toggleButton.className = "btn btn-sm btn-outline-secondary nav-tree-toggle";
		toggleButton.dataset.navToggle = "";
		toggleButton.hidden = true;
		toggleButton.setAttribute("aria-expanded", "true");
		toggleButton.setAttribute("aria-label", collapseLabel);

		const toggleGlyph = document.createElement("span");
		toggleGlyph.className = "nav-tree-toggle-glyph";
		toggleGlyph.setAttribute("aria-hidden", "true");
		toggleGlyph.innerHTML = `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M6 9l6 6 6-6" />
			</svg>
		`;
		toggleButton.append(toggleGlyph);

		const dragHandle = document.createElement("span");
		dragHandle.className = "nav-drag-handle";
		dragHandle.dataset.dragHandle = "";
		dragHandle.setAttribute("aria-label", dragLabel);

		const summary = document.createElement("div");
		summary.className = "nav-tree-summary";

		const title = document.createElement("strong");
		title.className = "nav-tree-title";
		title.dataset.navPreviewTitle = "";
		title.textContent = fallbackLabel;

		const path = document.createElement("span");
		path.className = "nav-tree-path";
		path.dataset.navPreviewPath = "";
		path.hidden = true;
		path.textContent = normalizedEntry.href;

		summary.append(title, path);
		main.append(toggleButton, dragHandle, summary);
		card.append(main);
		row.append(card);

		const fieldHost = document.createElement("div");
		fieldHost.className = "nav-tree-field-bank-host";
		fieldHost.dataset.navFieldHost = "";
		fieldHost.hidden = true;
		fieldHost.append(createFieldBank(normalizedEntry));
		row.append(fieldHost);

		attachNavRow(row);
		updateRowPreview(row);
		refreshTreeState();
		return row;
	};

	const findInsertPositionForChild = (row) => {
		let reference = row;
		const parentDepth = getRowDepth(row);
		while (reference.nextElementSibling instanceof HTMLElement) {
			const nextDepth = getRowDepth(reference.nextElementSibling);
			if (nextDepth <= parentDepth) {
				break;
			}
			reference = reference.nextElementSibling;
		}
		return reference;
	};

	const changeDepth = (row, delta) => {
		if (!(row instanceof HTMLElement)) {
			return;
		}
		setRowDepth(row, getRowDepth(row) + delta);
		selectRow(row);
		syncPayload();
	};

	const addChildRow = (parentRow) => {
		if (isReadOnly || !(rowsContainer instanceof HTMLElement) || !(parentRow instanceof HTMLElement)) {
			return;
		}
		const depth = clampDepth(getRowDepth(parentRow) + 1);
		const newRow = createNavRow({ label: defaultNavLabel, href: "/" }, depth);
		const insertAfter = findInsertPositionForChild(parentRow);
		insertAfter.after(newRow);
		selectRow(newRow, { focusInspector: true });
		newRow.scrollIntoView({ block: "nearest" });
		syncPayload();
	};

	const addRootRow = () => {
		if (isReadOnly || !(rowsContainer instanceof HTMLElement)) {
			return;
		}
		const newRow = createNavRow({ label: defaultNavLabel, href: "/" }, 0);
		rowsContainer.append(newRow);
		selectRow(newRow, { focusInspector: true });
		newRow.scrollIntoView({ block: "nearest" });
		syncPayload();
	};

	const removeRow = (row) => {
		if (!(row instanceof HTMLElement)) {
			return;
		}
		const subtree = getSubtreeRows(row);
		const fallbackSelection = row.nextElementSibling instanceof HTMLElement
			? row.nextElementSibling.matches("[data-nav-row]") ? row.nextElementSibling : row.previousElementSibling
			: row.previousElementSibling;
		if (selectedRow === row) {
			restoreFieldBank(row);
			selectedRow = null;
		}
		subtree.forEach((entry) => entry.remove());
		selectRow(fallbackSelection instanceof HTMLElement && fallbackSelection.matches("[data-nav-row]") ? fallbackSelection : null);
		syncPayload();
	};

	Array.from(rowsContainer?.querySelectorAll("[data-nav-row]") ?? []).forEach((row) => attachNavRow(row));

	rowsContainer?.addEventListener("input", (event) => {
		const row = event.target instanceof Element ? event.target.closest("[data-nav-row]") : null;
		if (row instanceof HTMLElement) {
			updateRowPreview(row);
			if (selectedRow === row) {
				updateSelectedRowUi();
			}
		}
		syncPayload();
	});

	rowsContainer?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) {
			return;
		}
		const row = target.closest("[data-nav-row]");
		if (!(row instanceof HTMLElement)) {
			return;
		}

		const actionButton = target.closest("button");
		if (actionButton?.matches("[data-nav-toggle]")) {
			row.dataset.collapsed = row.dataset.collapsed === "true" ? "false" : "true";
			refreshTreeState();
			return;
		}
		if (target.closest("[data-nav-select]")) {
			selectRow(row);
		}
	});

	rowsContainer?.addEventListener("keydown", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement) || !target.matches("[data-nav-select]")) {
			return;
		}
		const row = target.closest("[data-nav-row]");
		if (!(row instanceof HTMLElement)) {
			return;
		}

		if (event.key === "Enter" || event.key === " ") {
			event.preventDefault();
			selectRow(row, { focusInspector: event.key === "Enter" });
		}
		if (event.key === "ArrowDown") {
			event.preventDefault();
			const rows = getVisibleNavRows();
			const currentIndex = rows.indexOf(row);
			const nextRow = rows[currentIndex + 1];
			if (nextRow instanceof HTMLElement) {
				selectRow(nextRow);
				nextRow.querySelector("[data-nav-select]")?.focus();
			}
		}
		if (event.key === "ArrowUp") {
			event.preventDefault();
			const rows = getVisibleNavRows();
			const currentIndex = rows.indexOf(row);
			const previousRow = rows[currentIndex - 1];
			if (previousRow instanceof HTMLElement) {
				selectRow(previousRow);
				previousRow.querySelector("[data-nav-select]")?.focus();
			}
		}
	});

	addRootButton?.addEventListener("click", (event) => {
		event.preventDefault();
		addRootRow();
	});

	addEmptyButton?.addEventListener("click", (event) => {
		event.preventDefault();
		addRootRow();
	});

	addChildGlobalButton?.addEventListener("click", (event) => {
		event.preventDefault();
		if (selectedRow instanceof HTMLElement) {
			addChildRow(selectedRow);
		}
	});

	indentSelectedButton?.addEventListener("click", (event) => {
		event.preventDefault();
		if (selectedRow instanceof HTMLElement) {
			changeDepth(selectedRow, 1);
		}
	});

	outdentSelectedButton?.addEventListener("click", (event) => {
		event.preventDefault();
		if (selectedRow instanceof HTMLElement) {
			changeDepth(selectedRow, -1);
		}
	});

	removeSelectedButton?.addEventListener("click", (event) => {
		event.preventDefault();
		if (selectedRow instanceof HTMLElement) {
			removeRow(selectedRow);
		}
	});

	updateEmptyState();
	syncPayload();
	const firstRow = rowsContainer?.querySelector("[data-nav-row]");
	if (firstRow instanceof HTMLElement && !isReadOnly) {
		selectRow(firstRow);
	} else {
		updateSelectedRowUi();
	}
</script>
