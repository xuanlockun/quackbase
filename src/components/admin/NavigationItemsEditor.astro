---
import type { SiteNavItem } from "../../lib/blog";
import { getLanguageCatalog, getSupportedLanguages, getUiTranslations, type LocalizedText } from "../../lib/i18n";

interface Props {
	navItems: SiteNavItem[];
	loadError?: string;
}

const { navItems = [], loadError = "" } = Astro.props;
const { t } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const languages = getSupportedLanguages(catalog);
const defaultLanguageCode = catalog.defaultLanguageCode;
const languagesJson = JSON.stringify(languages);
const resolveNavPreviewLabel = (translations?: LocalizedText, fallback = "") => {
	if (!translations) {
		return fallback;
	}

	const defaultValue = translations[defaultLanguageCode]?.trim();
	if (defaultValue) {
		return defaultValue;
	}

	for (const language of languages) {
		const value = translations[language.code]?.trim();
		if (value) {
			return value;
		}
	}

	return fallback;
};

const flattenNavItems = (items: SiteNavItem[] = [], depth = 0): { item: SiteNavItem; depth: number }[] => {
	const rows: { item: SiteNavItem; depth: number }[] = [];
	for (const entry of items) {
		rows.push({ item: entry, depth });
		if (entry.children?.length) {
			rows.push(...flattenNavItems(entry.children, depth + 1));
		}
	}
	return rows;
};

const navRows = flattenNavItems(navItems ?? []);
const navEntries = navRows.map(({ item, depth }, index) => ({
	item,
	depth,
	hasChildren: (navRows[index + 1]?.depth ?? -1) > depth,
}));
const rootItemCount = navRows.filter(({ depth }) => depth === 0).length;
const totalItemCount = navRows.length;
---

<div class="admin-form-section nav-tree-editor">
	<div class="nav-tree-editor-header">
		<div>
			<h2 class="h5 mb-1">{t("labels.navigationItems")}</h2>
		</div>
		<div class="nav-tree-editor-meta">
			<span class="badge text-bg-light border">{rootItemCount} root</span>
			<span class="badge text-bg-light border">{totalItemCount} total</span>
		</div>
	</div>

	<input
		type="hidden"
		name="navItems"
		id="nav-items-payload"
		value={JSON.stringify(navItems ?? [])}
		disabled={Boolean(loadError)}
	/>

	<div
		class="nav-tree-editor-surface"
		data-nav-items-editor
		data-languages={languagesJson}
		data-default-language={defaultLanguageCode}
		data-disabled={Boolean(loadError)}
		data-remove-label={t("actions.remove")}
		data-add-child-label={t("actions.addChild")}
		data-indent-label={t("actions.indent")}
		data-outdent-label={t("actions.outdent")}
		data-parent-label={t("labels.parent")}
		data-child-label={t("labels.child")}
		data-label-label={t("labels.label")}
		data-link-label={t("labels.link")}
		data-drag-label={t("labels.dragToReorder")}
		data-collapse-label={t("actions.collapse", "Collapse")}
		data-expand-label={t("actions.expand", "Expand")}
		data-edit-label={t("actions.edit", "Edit")}
		data-example-label={t("nav.home")}
	>
		<div class="nav-tree-board">
			<div class="nav-tree-board-head">
				<div class="nav-tree-board-copy">
					<span class="nav-tree-kicker">{t("labels.navigationItems")}</span>
					<h3 class="h6 mb-1">{t("messages.pageNavigationHub")}</h3>
				</div>
				<div class="nav-tree-board-hint">
					<span class="badge bg-primary-subtle border border-primary-subtle text-primary-emphasis">
						{t("labels.dragToReorder")}
					</span>
				</div>
			</div>

			<div class="nav-tree-list" data-nav-items-rows role="list">
				<div class="nav-tree-empty admin-state-surface" data-nav-empty hidden={navRows.length > 0}>
					<h3 class="h6 mb-2">{t("messages.noNavigationItemsConfigured")}</h3>
				</div>

				{
					navEntries.map(({ item, depth, hasChildren }, index) => (
						<article
							class="nav-tree-row"
							role="listitem"
							data-nav-row
							data-depth={depth}
							data-has-children={hasChildren ? "true" : "false"}
							style={`--nav-depth: ${depth}`}
							draggable={!Boolean(loadError) ? "true" : "false"}
							data-row-index={index}
						>
							<div class="nav-tree-rail" aria-hidden="true">
								<span class="nav-drag-handle" data-drag-handle aria-label={t("labels.dragToReorder")}></span>
								<span class="nav-tree-spine"></span>
							</div>

							<div class="nav-tree-body">
								<div class="nav-tree-summary">
									<div class="nav-tree-summary-copy">
										<div class="nav-tree-summary-line">
											{hasChildren ? (
												<button
													class="btn btn-sm btn-outline-secondary nav-tree-toggle"
													type="button"
													data-nav-toggle
													aria-expanded="true"
													aria-label={t("labels.collapse", "Collapse")}
												>
													<span class="nav-tree-toggle-glyph" aria-hidden="true">-</span>
												</button>
											) : null}
										</div>
										<strong class="nav-tree-title" data-nav-preview-title>{resolveNavPreviewLabel(item.labelTranslations, item.label)}</strong>
										<span class="nav-tree-path" data-nav-preview-path>{item.href}</span>
									</div>
								</div>

								<div class="nav-tree-fields">
									{
										languages.map((languageOption) => (
											<label class="nav-tree-field">
												<span class="nav-tree-field-label">
													{t("labels.label")} ({languageOption.label})
												</span>
												<input
													class="form-control form-control-sm"
													type="text"
													value={item.labelTranslations?.[languageOption.code] ?? ""}
													placeholder={languageOption.label}
													data-nav-label
													data-language-code={languageOption.code}
													disabled={Boolean(loadError)}
												/>
											</label>
										))
									}

									<label class="nav-tree-field nav-tree-field-link">
										<span class="nav-tree-field-label">{t("labels.link")}</span>
										<input
											class="form-control form-control-sm"
											type="text"
											value={item.href}
											placeholder="/about or https://example.com"
											data-nav-href
											disabled={Boolean(loadError)}
										/>
									</label>
								</div>
							</div>

							<div class="nav-tree-actions">
								<button
									class="btn btn-sm btn-outline-secondary nav-action"
									type="button"
									data-nav-edit
									disabled={Boolean(loadError)}
									aria-label={t("actions.edit")}
									aria-pressed="false"
								>
									<span class="nav-action-icon" aria-hidden="true">✎</span>
									<span class="visually-hidden">{t("actions.edit")}</span>
								</button>
								<button
									class="btn btn-sm btn-outline-secondary nav-action"
									type="button"
									data-nav-add-child
									disabled={Boolean(loadError)}
									aria-label={t("actions.addChild")}
								>
									<span class="nav-action-icon" aria-hidden="true">+</span>
									<span class="visually-hidden">{t("actions.addChild")}</span>
								</button>
								<button
									class="btn btn-sm btn-outline-secondary nav-action"
									type="button"
									data-nav-indent
									disabled={Boolean(loadError)}
									aria-label={t("actions.indent")}
								>
									<span class="nav-action-icon" aria-hidden="true">›</span>
									<span class="visually-hidden">{t("actions.indent")}</span>
								</button>
								<button
									class="btn btn-sm btn-outline-secondary nav-action"
									type="button"
									data-nav-outdent
									disabled={Boolean(loadError)}
									aria-label={t("actions.outdent")}
								>
									<span class="nav-action-icon" aria-hidden="true">‹</span>
									<span class="visually-hidden">{t("actions.outdent")}</span>
								</button>
								<button
									class="btn btn-sm btn-outline-danger nav-item-remove"
									type="button"
									data-nav-remove
									disabled={Boolean(loadError)}
									aria-label={t("actions.remove")}
								>
									<span class="nav-action-icon" aria-hidden="true">×</span>
									<span class="visually-hidden">{t("actions.remove")}</span>
								</button>
							</div>
						</article>
					))
				}
			</div>
		</div>

		<div class="nav-tree-footer">
			<button class="btn btn-sm btn-outline-secondary nav-tree-add-row" type="button" data-nav-add disabled={Boolean(loadError)}>
				<span class="nav-action-icon" aria-hidden="true">+</span>
				<span>{t("actions.addRow")}</span>
			</button>
		</div>
	</div>

	<div class="admin-form-section">
		<button class="btn btn-primary" type="submit" disabled={Boolean(loadError)}>{t("actions.saveChanges")}</button>
	</div>
</div>

<style>
	.nav-tree-editor {
		display: grid;
		gap: 0.7rem;
	}

	.nav-tree-editor .btn,
	.nav-tree-editor .badge,
	.nav-tree-editor .form-control,
	.nav-tree-editor .form-select {
		box-shadow: none;
	}

	.nav-tree-editor .btn-sm {
		min-height: 1.8rem;
		padding: 0.16rem 0.4rem;
		font-size: 0.72rem;
		line-height: 1.05;
	}

	.nav-tree-editor .form-control,
	.nav-tree-editor .form-select {
		min-height: 1.85rem;
		padding: 0.14rem 0.4rem;
		font-size: 0.8rem;
		line-height: 1.1;
	}

	.nav-tree-editor .badge {
		border-radius: 0.25rem;
		padding: 0.12rem 0.34rem;
		font-size: 0.62rem;
		line-height: 1;
	}

	.nav-tree-editor-header,
	.nav-tree-board-head,
	.nav-tree-footer {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.nav-tree-editor-meta {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.3rem;
	}

	.nav-tree-editor-surface {
		display: grid;
		gap: 0.65rem;
	}

	.nav-tree-board {
		display: grid;
		gap: 0.3rem;
		padding: 0.05rem 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.nav-tree-kicker {
		display: inline-flex;
		align-items: center;
		margin-bottom: 0.25rem;
		font-size: 0.62rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.13em;
		color: rgba(15, 23, 42, 0.5);
	}

	.nav-tree-list {
		--tree-step: 1rem;
		display: grid;
		gap: 0;
		position: relative;
		padding-left: 0;
		border: 0;
		background: transparent;
	}

	.nav-tree-empty {
		border: 0;
		background: transparent;
		box-shadow: none;
		border-radius: 0;
		padding: 0.5rem 0.1rem;
	}

	.nav-tree-row {
		--nav-indent: calc(var(--nav-depth, 0) * var(--tree-step));
		--nav-row-padding-left: calc(0.1rem + var(--nav-indent));
		position: relative;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		gap: 0.16rem;
		align-items: center;
		padding: 0.12rem 0.16rem 0.12rem var(--nav-row-padding-left);
		border-radius: 0;
		border: 0;
		background: transparent;
		box-shadow: none;
		transition: background-color 0.15s ease;
		margin-left: 0;
	}

	.nav-tree-row[data-depth="0"] {
		margin-left: 0;
	}

	.nav-tree-row[data-editing="true"] {
		background: rgba(15, 23, 42, 0.03);
	}

	.nav-tree-row:hover {
		transform: none;
		background: rgba(15, 23, 42, 0.028);
	}

	.nav-tree-row:focus-within {
		background: rgba(15, 23, 42, 0.038);
	}

	.nav-tree-row[data-collapsed="true"] .nav-tree-toggle {
		background: rgba(15, 23, 42, 0.03);
		border-color: rgba(15, 23, 42, 0.12);
	}

	.nav-tree-row.is-dragging {
		opacity: 0.7;
		transform: none;
	}

	.nav-tree-rail {
		display: none;
	}

	.nav-tree-spine {
		display: none;
	}

	.nav-drag-handle {
		width: 0.72rem;
		height: 0.72rem;
		cursor: grab;
		border-radius: 0;
		background:
			radial-gradient(circle at center, rgba(15, 23, 42, 0.68) 0 1px, transparent 1.1px) center / 0.3rem 0.3rem,
			radial-gradient(circle at center, rgba(15, 23, 42, 0.68) 0 1px, transparent 1.1px) 50% 0.25rem / 0.3rem 0.3rem,
			radial-gradient(circle at center, rgba(15, 23, 42, 0.68) 0 1px, transparent 1.1px) 0.25rem 50% / 0.3rem 0.3rem,
			radial-gradient(circle at center, rgba(15, 23, 42, 0.68) 0 1px, transparent 1.1px) 0.25rem calc(100% - 0.25rem) / 0.3rem 0.3rem;
		background-repeat: no-repeat;
		opacity: 0.72;
	}

	.nav-tree-body {
		min-width: 0;
		display: grid;
		gap: 0;
	}

	.nav-tree-summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.22rem;
		min-width: 0;
	}

	.nav-tree-summary-copy {
		min-width: 0;
		display: flex;
		align-items: center;
		gap: 0.18rem;
		flex-wrap: nowrap;
		width: 100%;
		overflow: hidden;
	}

	.nav-tree-summary-line {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		gap: 0.16rem;
		flex: 0 0 auto;
		min-width: 0;
	}

	.nav-tree-leaf-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.15rem;
		padding: 0;
		border-radius: 0;
		font-size: 0.52rem;
		font-weight: 600;
		text-transform: none;
		letter-spacing: 0.02em;
		color: rgba(15, 23, 42, 0.42);
		background: transparent;
	}

	.nav-tree-row[data-depth="0"] .nav-tree-title {
		font-size: 0.79rem;
		font-weight: 650;
	}

	.nav-tree-row[data-editing="true"] .nav-tree-title,
	.nav-tree-row[data-editing="true"] .nav-tree-path {
		display: none;
	}

	.nav-tree-toggle {
		line-height: 1;
		width: 1rem;
		height: 1rem;
		padding: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.2rem;
		background: transparent;
		border-color: transparent;
		color: rgba(15, 23, 42, 0.56);
	}

	.nav-tree-toggle-glyph {
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1;
	}

	.nav-tree-title {
		font-size: 0.78rem;
		line-height: 1.2;
		font-weight: 600;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		flex: 1 1 auto;
	}

	.nav-tree-path {
		font-size: 0.62rem;
		color: rgba(15, 23, 42, 0.36);
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		flex: 0 1 auto;
	}

	.nav-tree-fields {
		display: none;
		grid-template-columns: repeat(auto-fit, minmax(10.5rem, 1fr));
		gap: 0.18rem;
		padding-top: 0;
		border-top: 0;
	}

	.nav-tree-row[data-editing="true"] .nav-tree-fields {
		display: grid;
	}

	.nav-tree-field {
		display: grid;
		gap: 0.1rem;
	}

	.nav-tree-field-label {
		font-size: 0.5rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.09em;
		color: rgba(15, 23, 42, 0.38);
	}

	.nav-tree-field-link {
		grid-column: 1 / -1;
	}

	.nav-tree-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.12rem;
		align-content: start;
		align-items: center;
	}

	.nav-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0;
		width: 1.45rem;
		height: 1.45rem;
		min-height: 1.45rem;
		padding: 0;
		border-radius: 0.3rem;
		font-size: 0.72rem;
	}

	.nav-item-remove {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.45rem;
		height: 1.45rem;
		min-height: 1.45rem;
		padding: 0;
		border-radius: 0.3rem;
		font-size: 0.72rem;
	}

	.nav-action-icon {
		font-size: 0.84rem;
		line-height: 1;
		font-weight: 700;
	}

	.nav-tree-footer {
		align-items: center;
		padding-top: 0.1rem;
	}

	.nav-tree-add-row {
		display: inline-flex;
		align-items: center;
		gap: 0.28rem;
		padding-inline: 0.55rem;
		min-height: 1.55rem;
	}

	@media (max-width: 992px) {
		.nav-tree-row {
			grid-template-columns: 1fr;
			padding-left: 0.5rem;
		}

		.nav-tree-rail {
			display: none;
		}

		.nav-tree-summary {
			flex-direction: row;
		}

		.nav-tree-fields {
			grid-template-columns: 1fr;
		}

		.nav-tree-actions {
			justify-content: flex-start;
		}
	}

	@media (max-width: 576px) {
		.nav-tree-editor-header,
		.nav-tree-board-head,
		.nav-tree-footer {
			align-items: stretch;
		}

		.nav-tree-board {
			padding: 0.35rem 0;
		}

		.nav-tree-row {
			padding: 0.24rem 0.14rem 0.24rem 0.5rem;
		}

		.nav-tree-fields {
			grid-template-columns: 1fr;
		}
	}
</style>

<script type="module">
	const editor = document.querySelector("[data-nav-items-editor]");
	const rowsContainer = editor?.querySelector("[data-nav-items-rows]");
	const payloadInput = document.getElementById("nav-items-payload");
	const addButton = editor?.querySelector("[data-nav-add]");
	const emptyStateRow = editor?.querySelector("[data-nav-empty]");
	const removeLabel = editor?.dataset.removeLabel ?? "Remove";
	const addChildLabel = editor?.dataset.addChildLabel ?? "Add child";
	const indentLabel = editor?.dataset.indentLabel ?? "Indent";
	const outdentLabel = editor?.dataset.outdentLabel ?? "Outdent";
	const parentLabel = editor?.dataset.parentLabel ?? "Parent";
	const childLabel = editor?.dataset.childLabel ?? "Child";
	const labelLabel = editor?.dataset.labelLabel ?? "Label";
	const linkLabel = editor?.dataset.linkLabel ?? "Link";
	const dragLabel = editor?.dataset.dragLabel ?? "Drag to reorder";
	const collapseLabel = editor?.dataset.collapseLabel ?? "Collapse";
	const expandLabel = editor?.dataset.expandLabel ?? "Expand";
	const editLabel = editor?.dataset.editLabel ?? "Edit";
	const isReadOnly = editor?.dataset.disabled === "true";
	let draggedNavRow = null;
	const MAX_NAV_DEPTH = 4;
	const defaultNavLabel = editor?.dataset.exampleLabel ?? "New item";

	const clampDepth = (value) => {
		const depth = Number.isFinite(value) ? value : 0;
		return Math.max(0, Math.min(MAX_NAV_DEPTH, Math.floor(depth)));
	};

	const setRowDepth = (row, depth) => {
		const normalized = clampDepth(depth);
		row.dataset.depth = String(normalized);
		row.style.setProperty("--nav-depth", String(normalized));
		return normalized;
	};

	const getNavRows = () => Array.from(rowsContainer?.querySelectorAll("[data-nav-row]") ?? []);

	const getRowDepth = (row) => clampDepth(Number(row.dataset.depth ?? "0"));

	const getRowEditorInputs = (row) => ({
		labels: Array.from(row.querySelectorAll("[data-nav-label]")).filter(
			(input) => input instanceof HTMLInputElement,
		),
		href: row.querySelector("[data-nav-href]"),
	});

	const getRowLabel = (row) => {
		const { labels } = getRowEditorInputs(row);
		for (const input of labels) {
			const value = input.value.trim();
			if (value) {
				return value;
			}
		}
		return "";
	};

	const updateRowPreview = (row) => {
		if (!(row instanceof HTMLElement)) {
			return;
		}

		const title = row.querySelector("[data-nav-preview-title]");
		const path = row.querySelector("[data-nav-preview-path]");
		const label = getRowLabel(row);
		const hrefInput = row.querySelector("[data-nav-href]");

		if (title instanceof HTMLElement) {
			title.textContent = label || defaultNavLabel;
		}

		if (path instanceof HTMLElement && hrefInput instanceof HTMLInputElement) {
			path.textContent = hrefInput.value.trim() || "/";
		}
	};

	let activeEditRow = null;

	const setRowEditing = (row, editing) => {
		if (!(row instanceof HTMLElement)) {
			return;
		}

		const nextEditing = Boolean(editing);
		const currentActive = activeEditRow;
		if (nextEditing && currentActive && currentActive !== row) {
			setRowEditing(currentActive, false);
		}

		row.dataset.editing = nextEditing ? "true" : "false";
		activeEditRow = nextEditing ? row : activeEditRow === row ? null : activeEditRow;

		const editButton = row.querySelector("[data-nav-edit]");
		if (editButton instanceof HTMLButtonElement) {
			editButton.setAttribute("aria-pressed", nextEditing ? "true" : "false");
			editButton.setAttribute("aria-label", editLabel);
		}

		const firstInput = row.querySelector("[data-nav-label]");
		if (nextEditing && firstInput instanceof HTMLInputElement) {
			requestAnimationFrame(() => {
				firstInput.focus();
				firstInput.select();
			});
		}

		updateRowPreview(row);
	};

	const exitActiveEditRow = () => {
		if (activeEditRow) {
			setRowEditing(activeEditRow, false);
			syncPayload();
		}
	};

	const updateRowToggle = (row) => {
		const hasChildren = row.dataset.hasChildren === "true";
		const toggle = row.querySelector("[data-nav-toggle]");
		if (!(toggle instanceof HTMLButtonElement)) {
			return;
		}

		toggle.hidden = !hasChildren;
		if (!hasChildren) {
			toggle.setAttribute("aria-expanded", "false");
			toggle.setAttribute("aria-label", collapseLabel);
			const glyph = toggle.querySelector(".nav-tree-toggle-glyph");
			if (glyph instanceof HTMLElement) {
				glyph.textContent = "•";
			}
			return;
		}

		const isCollapsed = row.dataset.collapsed === "true";
		toggle.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
		toggle.setAttribute("aria-label", isCollapsed ? expandLabel : collapseLabel);
		const glyph = toggle.querySelector(".nav-tree-toggle-glyph");
		if (glyph instanceof HTMLElement) {
			glyph.textContent = isCollapsed ? "+" : "-";
		}
	};

	const refreshTreeState = () => {
		if (!(rowsContainer instanceof HTMLElement)) {
			return;
		}

		const rows = getNavRows();
		const collapseStack = [];
		for (let index = 0; index < rows.length; index += 1) {
			const row = rows[index];
			const depth = getRowDepth(row);
			collapseStack.length = depth;
			const ancestorCollapsed = collapseStack.some(Boolean);
			row.hidden = ancestorCollapsed;
			row.setAttribute("aria-hidden", ancestorCollapsed ? "true" : "false");

			const hasChildren = (getRowDepth(rows[index + 1] ?? row) > depth) && index + 1 < rows.length;
			row.dataset.hasChildren = hasChildren ? "true" : "false";
			if (!hasChildren) {
				row.dataset.collapsed = "false";
			}
			updateRowToggle(row);

			const isCollapsed = hasChildren && row.dataset.collapsed === "true";
			collapseStack[depth] = isCollapsed;
		}
	};

	const buildNodeFromRow = (row) => {
		const href = row.querySelector("[data-nav-href]");

		if (!(href instanceof HTMLInputElement)) {
			return null;
		}

		const trimmedHref = href.value.trim();
		if (!trimmedHref) {
			return null;
		}

		const labelTranslations = {};
		for (const input of row.querySelectorAll("[data-nav-label]")) {
			if (!(input instanceof HTMLInputElement)) {
				continue;
			}
			const code = input.dataset.languageCode?.trim();
			const value = input.value.trim();
			if (code && value) {
				labelTranslations[code] = value;
			}
		}

		const fallbackLabel = labelTranslations[editor?.dataset.defaultLanguage ?? ""] ?? Object.values(labelTranslations)[0] ?? "";
		if (!fallbackLabel) {
			return null;
		}

		const defaultLanguageCode = editor?.dataset.defaultLanguage?.trim();
		if (defaultLanguageCode && !labelTranslations[defaultLanguageCode]) {
			labelTranslations[defaultLanguageCode] = fallbackLabel;
		}

		return {
			label: fallbackLabel,
			labelTranslations,
			href: trimmedHref,
			children: [],
		};
	};

	const syncPayload = () => {
		if (!(rowsContainer instanceof HTMLElement) || !(payloadInput instanceof HTMLInputElement)) {
			return;
		}

		const tree = [];
		const stack = [{ depth: -1, children: tree }];
		for (const row of rowsContainer.querySelectorAll("[data-nav-row]")) {
			const currentDepth = clampDepth(Number(row.dataset.depth ?? "0"));
			setRowDepth(row, currentDepth);
			updateRowPreview(row);
			const node = buildNodeFromRow(row);
			if (!node) {
				continue;
			}

			while (stack[stack.length - 1].depth >= currentDepth) {
				stack.pop();
			}

			stack[stack.length - 1].children.push(node);
			stack.push({ depth: currentDepth, children: node.children });
		}

		payloadInput.value = JSON.stringify(tree);
		refreshTreeState();
		updateEmptyState();
	};

	const attachNavRow = (row) => {
		if (!(row instanceof HTMLElement) || row.dataset.navRowAttached === "true") {
			return;
		}
		row.dataset.navRowAttached = "true";
		row.dataset.collapsed = row.dataset.collapsed ?? "false";
		row.dataset.editing = row.dataset.editing ?? "false";
		setRowDepth(row, Number(row.dataset.depth ?? "0"));
		row.draggable = !isReadOnly;
		row.addEventListener("dragstart", onNavDragStart);
		row.addEventListener("dragover", onNavDragOver);
		row.addEventListener("drop", onNavDragDrop);
		row.addEventListener("dragend", onNavDragEnd);
		row.addEventListener("focusout", (event) => {
			if (!(event.relatedTarget instanceof Node) || row.contains(event.relatedTarget)) {
				return;
			}
			if (row.dataset.editing === "true") {
				setRowEditing(row, false);
				syncPayload();
			}
		});
	};

	const findNavRow = (target) => (target instanceof Element ? target.closest("[data-nav-row]") : null);

	const onNavDragStart = (event) => {
		if (isReadOnly) {
			return;
		}
		const row = event.currentTarget;
		if (!(row instanceof HTMLElement)) {
			return;
		}
		draggedNavRow = row;
		row.classList.add("is-dragging");
		event.dataTransfer?.setData("text/plain", "");
		event.dataTransfer?.setDragImage(row, 0, 0);
	};

	const onNavDragOver = (event) => {
		if (!draggedNavRow) {
			return;
		}
		event.preventDefault();
		const row = event.currentTarget;
		if (!(row instanceof HTMLElement) || row === draggedNavRow) {
			return;
		}
		const bounding = row.getBoundingClientRect();
		const after = event.clientY > bounding.top + bounding.height / 2;
		if (after) {
			row.after(draggedNavRow);
		} else {
			row.before(draggedNavRow);
		}
	};

	const onNavDragDrop = (event) => {
		event.preventDefault();
		if (!draggedNavRow) {
			return;
		}
		draggedNavRow.classList.remove("is-dragging");
		draggedNavRow = null;
		syncPayload();
	};

	const onNavDragEnd = () => {
		if (draggedNavRow) {
			draggedNavRow.classList.remove("is-dragging");
			draggedNavRow = null;
		}
	};

	const createNavRow = (entry = {}, depth = 0) => {
		const labelTranslations = entry.labelTranslations ?? {};
		const fallbackLabel =
			labelTranslations[editor?.dataset.defaultLanguage ?? ""] ??
			Object.values(labelTranslations)[0] ??
			entry.label ??
			defaultNavLabel;
		const languages = JSON.parse(editor?.dataset.languages ?? "[]");

		const row = document.createElement("article");
		row.className = "nav-tree-row";
		row.setAttribute("role", "listitem");
		row.dataset.navRow = "";
		row.dataset.hasChildren = "false";
		row.dataset.collapsed = "false";
		setRowDepth(row, depth);
		row.draggable = !isReadOnly;

		const rail = document.createElement("div");
		rail.className = "nav-tree-rail";
		rail.setAttribute("aria-hidden", "true");
		const handle = document.createElement("span");
		handle.className = "nav-drag-handle";
		handle.dataset.dragHandle = "";
		handle.setAttribute("aria-label", dragLabel);
		const spine = document.createElement("span");
		spine.className = "nav-tree-spine";
		rail.append(handle, spine);
		row.append(rail);

		const body = document.createElement("div");
		body.className = "nav-tree-body";

		const summary = document.createElement("div");
		summary.className = "nav-tree-summary";
		const summaryCopy = document.createElement("div");
		summaryCopy.className = "nav-tree-summary-copy";
		const summaryLine = document.createElement("div");
		summaryLine.className = "nav-tree-summary-line";

		const toggleButton = document.createElement("button");
		toggleButton.type = "button";
		toggleButton.className = "btn btn-sm btn-outline-secondary nav-tree-toggle";
		toggleButton.dataset.navToggle = "";
		toggleButton.hidden = true;
		toggleButton.setAttribute("aria-expanded", "true");
		toggleButton.setAttribute("aria-label", collapseLabel);
		const toggleGlyph = document.createElement("span");
		toggleGlyph.className = "nav-tree-toggle-glyph";
		toggleGlyph.setAttribute("aria-hidden", "true");
		toggleGlyph.textContent = "-";
		toggleButton.append(toggleGlyph);
		summaryLine.append(toggleButton);
		summaryCopy.append(summaryLine);

		const title = document.createElement("strong");
		title.className = "nav-tree-title";
		title.dataset.navPreviewTitle = "";
		title.textContent = fallbackLabel;
		const path = document.createElement("span");
		path.className = "nav-tree-path";
		path.dataset.navPreviewPath = "";
		path.textContent = entry.href ?? "/";
		summaryCopy.append(title, path);
		summary.append(summaryCopy);
		body.append(summary);

		const fields = document.createElement("div");
		fields.className = "nav-tree-fields";

		const createField = (labelText, input) => {
			const field = document.createElement("label");
			field.className = "nav-tree-field";
			const fieldLabel = document.createElement("span");
			fieldLabel.className = "nav-tree-field-label";
			fieldLabel.textContent = labelText;
			field.append(fieldLabel, input);
			return field;
		};

		for (const languageOption of languages) {
			const input = document.createElement("input");
			input.type = "text";
			input.className = "form-control form-control-sm";
			input.dataset.navLabel = "";
			input.dataset.languageCode = languageOption.code;
			input.placeholder = languageOption.label;
			input.value = labelTranslations[languageOption.code] ?? "";
			if (isReadOnly) {
				input.disabled = true;
			}
			fields.append(createField(`${labelLabel} (${languageOption.label})`, input));
		}

		const hrefInput = document.createElement("input");
		hrefInput.type = "text";
		hrefInput.className = "form-control form-control-sm";
		hrefInput.dataset.navHref = "";
		hrefInput.placeholder = "/about or https://example.com";
		hrefInput.value = entry.href ?? "/";
		if (isReadOnly) {
			hrefInput.disabled = true;
		}
		const linkField = createField(linkLabel, hrefInput);
		linkField.classList.add("nav-tree-field-link");
		fields.append(linkField);

		body.append(fields);
		row.append(body);

		const actions = document.createElement("div");
		actions.className = "nav-tree-actions";
		const buttonConfigs = [
			["navEdit", "✎", editLabel, "btn btn-sm btn-outline-secondary nav-action"],
			["navAddChild", "+", addChildLabel, "btn btn-sm btn-outline-secondary nav-action"],
			["navIndent", "›", indentLabel, "btn btn-sm btn-outline-secondary nav-action"],
			["navOutdent", "‹", outdentLabel, "btn btn-sm btn-outline-secondary nav-action"],
		];

		for (const [datasetKey, symbol, label, className] of buttonConfigs) {
			const button = document.createElement("button");
			button.type = "button";
			button.className = className;
			button.dataset[datasetKey] = "";
			button.setAttribute("aria-label", label);
			if (datasetKey === "navEdit") {
				button.setAttribute("aria-pressed", "false");
			}
			button.textContent = symbol;
			if (isReadOnly) {
				button.disabled = true;
			}
			actions.append(button);
		}

		const removeButton = document.createElement("button");
		removeButton.type = "button";
		removeButton.className = "btn btn-sm btn-outline-danger nav-item-remove";
		removeButton.dataset.navRemove = "";
		removeButton.setAttribute("aria-label", removeLabel);
		removeButton.innerHTML = `<span class="nav-action-icon" aria-hidden="true">×</span><span class="visually-hidden">${removeLabel}</span>`;
		if (isReadOnly) {
			removeButton.disabled = true;
		}
		actions.append(removeButton);

		row.append(actions);

		attachNavRow(row);
		return row;
	};

	const findInsertPositionForChild = (row) => {
		let reference = row;
		const parentDepth = clampDepth(Number(row.dataset.depth ?? "0"));
		while (reference.nextElementSibling instanceof HTMLElement) {
			const nextDepth = clampDepth(Number(reference.nextElementSibling.dataset.depth ?? "0"));
			if (nextDepth <= parentDepth) {
				break;
			}
			reference = reference.nextElementSibling;
		}
		return reference;
	};

	const changeDepth = (row, delta) => {
		const current = Number(row.dataset.depth ?? "0");
		setRowDepth(row, current + delta);
		syncPayload();
	};

	const addChildRow = (parentRow) => {
		if (isReadOnly || !(rowsContainer instanceof HTMLElement)) {
			return;
		}
		const depth = clampDepth(Number(parentRow.dataset.depth ?? "0") + 1);
		const newRow = createNavRow({}, depth);
		const insertAfter = findInsertPositionForChild(parentRow);
		insertAfter.after(newRow);
		newRow.scrollIntoView({ block: "nearest" });
		setRowEditing(newRow, true);
		syncPayload();
	};

	Array.from(rowsContainer?.querySelectorAll("[data-nav-row]") ?? []).forEach((row) => attachNavRow(row));

	rowsContainer?.addEventListener("input", syncPayload);
	rowsContainer?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) {
			return;
		}
		const row = findNavRow(target);
		if (!row) {
			return;
		}
		const actionButton = target.closest("button");

		if (actionButton?.matches("[data-nav-edit]")) {
			if (row.dataset.editing === "true") {
				setRowEditing(row, false);
				syncPayload();
			} else {
				setRowEditing(row, true);
			}
			return;
		}

		if (actionButton?.matches("[data-nav-remove]")) {
			if (activeEditRow === row) {
				activeEditRow = null;
			}
			row.remove();
			syncPayload();
			return;
		}

		if (actionButton?.matches("[data-nav-add-child]")) {
			addChildRow(row);
			return;
		}

		if (actionButton?.matches("[data-nav-toggle]")) {
			row.dataset.collapsed = row.dataset.collapsed === "true" ? "false" : "true";
			refreshTreeState();
			return;
		}

		if (actionButton?.matches("[data-nav-indent]")) {
			changeDepth(row, 1);
			return;
		}

		if (actionButton?.matches("[data-nav-outdent]")) {
			changeDepth(row, -1);
			return;
		}
	});

	addButton?.addEventListener("click", (event) => {
		event.preventDefault();
		if (isReadOnly || !(rowsContainer instanceof HTMLElement)) {
			return;
		}
		const newRow = createNavRow({ label: defaultNavLabel, href: "/" }, 0);
		rowsContainer.append(newRow);
		newRow.scrollIntoView({ block: "nearest" });
		setRowEditing(newRow, true);
		syncPayload();
	});

	const updateEmptyState = () => {
		if (!emptyStateRow || !rowsContainer) {
			return;
		}
		const hasRows = Boolean(rowsContainer.querySelector("[data-nav-row]"));
		emptyStateRow.hidden = hasRows;
	};

	updateEmptyState();
	syncPayload();
</script>



