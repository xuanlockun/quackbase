			radial-gradient(circle, currentColor 0.9px, transparent 1px) 0.26rem 0 / 0.26rem 0.26rem,
			radial-gradient(circle, currentColor 0.9px, transparent 1px) 0 0.26rem / 0.26rem 0.26rem,
