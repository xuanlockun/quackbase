---
import type { SiteNavItem } from "../../lib/blog";
import { getLanguageCatalog, getSupportedLanguages, getUiTranslations, type LocalizedText } from "../../lib/i18n";

interface Props {
	navItems: SiteNavItem[];
	loadError?: string;
}

const { navItems = [], loadError = "" } = Astro.props;
const { t } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const languages = getSupportedLanguages(catalog);
const defaultLanguageCode = catalog.defaultLanguageCode;
const languagesJson = JSON.stringify(languages);
const maxNavDepth = 4;
const guideSlots = Array.from({ length: maxNavDepth }, (_, index) => index);

const resolveNavPreviewLabel = (translations?: LocalizedText, fallback = "") => {
	if (!translations) {
		return fallback;
	}

	const defaultValue = translations[defaultLanguageCode]?.trim();
	if (defaultValue) {
		return defaultValue;
	}

	for (const language of languages) {
		const value = translations[language.code]?.trim();
		if (value) {
			return value;
		}
	}

	return fallback;
};

const flattenNavItems = (items: SiteNavItem[] = [], depth = 0): { item: SiteNavItem; depth: number }[] => {
	const rows: { item: SiteNavItem; depth: number }[] = [];
	for (const entry of items) {
		rows.push({ item: entry, depth });
		if (entry.children?.length) {
			rows.push(...flattenNavItems(entry.children, depth + 1));
		}
	}
	return rows;
};

const navRows = flattenNavItems(navItems ?? []);
const navEntries = navRows.map(({ item, depth }, index) => ({
	item,
	depth,
	hasChildren: (navRows[index + 1]?.depth ?? -1) > depth,
}));
const rootItemCount = navRows.filter(({ depth }) => depth === 0).length;
const totalItemCount = navRows.length;
const navActionIcons = {
	edit: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 20h9" />
			<path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L8 18l-4 1 1-4Z" />
		</svg>
	`,
	addChild: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 5v14" />
			<path d="M5 12h14" />
		</svg>
	`,
	indent: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M5 7h14" />
			<path d="M5 12h8" />
			<path d="M5 17h14" />
			<path d="M13 9l4 3-4 3" />
		</svg>
	`,
	outdent: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M5 7h14" />
			<path d="M5 12h8" />
			<path d="M5 17h14" />
			<path d="M9 9l-4 3 4 3" />
		</svg>
	`,
	remove: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M6 6l12 12" />
			<path d="M18 6L6 18" />
		</svg>
	`,
	addRow: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 5v14" />
			<path d="M5 12h14" />
		</svg>
	`,
	drag: `
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<path d="M9 5h.01" />
			<path d="M9 12h.01" />
			<path d="M9 19h.01" />
			<path d="M15 5h.01" />
			<path d="M15 12h.01" />
			<path d="M15 19h.01" />
		</svg>
	`,
};
---

<div class="admin-form-section nav-builder">
	<div class="nav-builder-header">
		<div class="nav-builder-heading">
			<div class="nav-builder-kicker">{t("labels.navigationItems", "Navigation items")}</div>
			<h2 class="h4 mb-1">{t("messages.pageNavigationHub", "Page navigation")}</h2>
			<p class="admin-inline-muted mb-0">{t("messages.pageNavigationHubHelp", "Arrange your navigation structure, select an item to edit it, and drag rows to reorder.")}</p>
		</div>
		<div class="nav-builder-stats" aria-label={t("labels.navigationItems", "Navigation items")}>
			<span class="nav-builder-stat">
				<strong data-nav-root-count>{rootItemCount}</strong>
				<span>{t("labels.rootItems", "Root items")}</span>
			</span>
			<span class="nav-builder-stat">
				<strong data-nav-total-count>{totalItemCount}</strong>
				<span>{t("labels.totalItems", "Total items")}</span>
			</span>
		</div>
	</div>

	<input
		type="hidden"
		name="navItems"
		id="nav-items-payload"
		value={JSON.stringify(navItems ?? [])}
		disabled={Boolean(loadError)}
	/>

	<div
		class="nav-builder-surface"
		data-nav-items-editor
		data-languages={languagesJson}
		data-default-language={defaultLanguageCode}
		data-disabled={Boolean(loadError)}
		data-max-depth={maxNavDepth}
		data-remove-label={t("actions.remove", "Remove")}
		data-add-child-label={t("actions.addChild", "Add item")}
		data-add-row-label={t("actions.addRow", "Add row")}
		data-indent-label={t("actions.indent", "Indent")}
		data-outdent-label={t("actions.outdent", "Outdent")}
		data-parent-label={t("labels.parent", "Parent")}
		data-child-label={t("labels.child", "Child")}
		data-label-label={t("labels.label", "Label")}
		data-link-label={t("labels.link", "Link")}
		data-drag-label={t("labels.dragToReorder", "Drag to reorder")}
		data-collapse-label={t("actions.collapse", "Collapse")}
		data-expand-label={t("actions.expand", "Expand")}
		data-edit-label={t("actions.edit", "Edit")}
		data-example-label={t("nav.home", "Home")}
		data-no-selection-title={t("messages.selectNavigationItemTitle", "Select a navigation item")}
		data-no-selection-copy={t("messages.selectNavigationItemCopy", "Choose a row from the tree to edit its label and path here.")}
		data-inspector-title={t("labels.selectedItem", "Selected item")}
		data-inspector-copy={t("messages.navigationInspectorHelp", "Keep the tree on the left for structure and use this panel for editing the selected item.")}
		data-root-label={t("labels.root", "Root")}
		data-level-label={t("labels.level", "Level")}
		data-parent-role-label={t("labels.parent", "Parent")}
		data-item-role-label={t("labels.item", "Item")}
		data-root-level-label={t("labels.rootLevel", "Root level")}
	>
		<div class="nav-builder-workspace">
			<div class="nav-tree-shell">
				<div class="nav-tree-toolbar">
					<div class="nav-tree-toolbar-copy">
						<span class="nav-tree-toolbar-kicker">{t("labels.navigationItems", "Navigation items")}</span>
						<h3 class="h6 mb-1">{t("messages.navigationTree", "Navigation tree")}</h3>
						<p class="mb-0">{t("messages.navigationTreeHelp", "Drag rows to reorder, collapse long branches, and select any item to edit it in the inspector.")}</p>
					</div>
					<div class="nav-tree-toolbar-actions">
						<button class="btn btn-primary nav-builder-action" type="button" data-nav-add disabled={Boolean(loadError)}>
							<span class="nav-action-icon" aria-hidden="true" set:html={navActionIcons.addRow}></span>
							<span>{t("actions.addItem", "Add item")}</span>
						</button>
						<button class="btn btn-outline-secondary nav-builder-action" type="button" data-nav-add-child-global disabled={Boolean(loadError)}>
							<span class="nav-action-icon" aria-hidden="true" set:html={navActionIcons.addChild}></span>
							<span>{t("actions.addChild", "Add item")}</span>
						</button>
						<button class="btn btn-outline-danger nav-builder-action" type="button" data-nav-remove-selected disabled={Boolean(loadError)}>
							<span class="nav-action-icon" aria-hidden="true" set:html={navActionIcons.remove}></span>
							<span>{t("actions.remove", "Delete")}</span>
						</button>
						<details class="nav-toolbar-menu">
							<summary class="btn btn-outline-secondary nav-builder-action">
								<span>{t("actions.moreActions", "More actions")}</span>
							</summary>
							<div class="nav-toolbar-menu-panel">
								<button class="btn btn-link nav-toolbar-menu-item" type="button" data-nav-indent-selected disabled={Boolean(loadError)}>
									<span class="nav-action-icon" aria-hidden="true" set:html={navActionIcons.indent}></span>
									<span>{t("actions.indent", "Indent")}</span>
								</button>
								<button class="btn btn-link nav-toolbar-menu-item" type="button" data-nav-outdent-selected disabled={Boolean(loadError)}>
									<span class="nav-action-icon" aria-hidden="true" set:html={navActionIcons.outdent}></span>
									<span>{t("actions.outdent", "Outdent")}</span>
								</button>
							</div>
						</details>
					</div>
				</div>

				<div class="nav-tree-list" data-nav-items-rows role="list">
					<div class="nav-tree-empty admin-state-surface" data-nav-empty hidden={navRows.length > 0}>
						<h3 class="h6 mb-2">{t("messages.noNavigationItemsConfigured", "No navigation items configured")}</h3>
						<p class="mb-3 text-body-secondary small">{t("messages.navigationEmptyHelp", "Start by adding a root row, then nest child items underneath it.")}</p>
						<button class="btn btn-primary" type="button" data-nav-empty-add disabled={Boolean(loadError)}>
							<span class="nav-action-icon" aria-hidden="true" set:html={navActionIcons.addRow}></span>
							<span>{t("actions.addItem", "Add item")}</span>
						</button>
					</div>

					{
						navEntries.map(({ item, depth, hasChildren }, index) => (
							<article
								class="nav-tree-row"
								role="listitem"
								data-nav-row
								data-row-id={`nav-row-${index}`}
								data-depth={depth}
								data-has-children={hasChildren ? "true" : "false"}
								data-row-index={index}
								style={`--nav-depth: ${depth}`}
								draggable={!Boolean(loadError) ? "true" : "false"}
							>
								<div class="nav-tree-row-guides" aria-hidden="true">
									{
										guideSlots.map((slot) => (
											<span class="nav-tree-guide" data-guide-index={slot}></span>
										))
									}
								</div>

								<div class="nav-tree-card">
									<div class="nav-tree-main" data-nav-select tabindex="0" role="button" aria-pressed="false">
										<button
											class="btn btn-sm btn-outline-secondary nav-tree-toggle"
											type="button"
											data-nav-toggle
											hidden={!hasChildren}
											aria-expanded="true"
											aria-label={t("actions.collapse", "Collapse")}
										>
											<span class="nav-tree-toggle-glyph" aria-hidden="true">
												<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
													<path d="M6 9l6 6 6-6" />
												</svg>
											</span>
										</button>
										<span class="nav-drag-handle" data-drag-handle aria-label={t("labels.dragToReorder", "Drag to reorder")}></span>
										<div class="nav-tree-summary">
											<strong class="nav-tree-title" data-nav-preview-title>{resolveNavPreviewLabel(item.labelTranslations, item.label)}</strong>
											<span class="nav-tree-path" data-nav-preview-path hidden>{item.href}</span>
										</div>
									</div>
								</div>

								<div class="nav-tree-field-bank-host" data-nav-field-host hidden>
									<div class="nav-tree-fields" data-nav-field-bank data-nav-owner={`nav-row-${index}`}>
										{
											languages.map((languageOption) => (
												<label class="nav-tree-field">
													<span class="nav-tree-field-label">
														{t("labels.label", "Label")} ({languageOption.label})
													</span>
													<input
														class="form-control"
														type="text"
														value={item.labelTranslations?.[languageOption.code] ?? ""}
														placeholder={languageOption.label}
														data-nav-label
														data-language-code={languageOption.code}
														disabled={Boolean(loadError)}
													/>
												</label>
											))
										}

										<label class="nav-tree-field nav-tree-field-link">
											<span class="nav-tree-field-label">{t("labels.link", "Link")}</span>
											<input
												class="form-control"
												type="text"
												value={item.href}
												placeholder="/about or https://example.com"
												data-nav-href
												disabled={Boolean(loadError)}
											/>
										</label>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>

			<aside class="nav-inspector" data-nav-inspector>
				<div class="nav-inspector-header">
					<div>
						<span class="nav-inspector-kicker">{t("labels.selectedItem", "Selected item")}</span>
						<h3 class="h5 mb-1" data-nav-inspector-title>{t("messages.selectNavigationItemTitle", "Select a navigation item")}</h3>
						<p class="mb-0 text-body-secondary small" data-nav-inspector-copy>{t("messages.selectNavigationItemCopy", "Choose a row from the tree to edit its label and path here.")}</p>
					</div>
					<div class="nav-inspector-tags">
						<span class="nav-inspector-tag" data-nav-inspector-depth hidden></span>
						<span class="nav-inspector-tag" data-nav-inspector-role hidden></span>
					</div>
				</div>

				<div class="nav-inspector-empty" data-nav-inspector-empty>
					<div class="nav-inspector-empty-icon" aria-hidden="true" set:html={navActionIcons.edit}></div>
					<p class="mb-1 fw-semibold">{t("messages.selectNavigationItemTitle", "Select a navigation item")}</p>
					<p class="mb-0 text-body-secondary small">{t("messages.selectNavigationItemCopy", "Choose a row from the tree to edit its label and path here.")}</p>
				</div>

				<div class="nav-inspector-body" data-nav-inspector-body hidden>
					<div class="nav-inspector-card">
						<div class="nav-inspector-card-head">
							<div>
								<p class="nav-inspector-card-label mb-1">{t("labels.itemSettings", "Item details")}</p>
								<p class="mb-0 text-body-secondary small">{t("messages.navigationInspectorHelp", "Update the selected item while keeping the tree visible for context.")}</p>
							</div>
						</div>
						<div class="nav-inspector-fields" data-nav-inspector-fields></div>
					</div>

				</div>
			</aside>
		</div>

		<div class="nav-builder-footer">
			<div class="nav-builder-footer-copy">
				<span class="nav-builder-footer-pill">{t("labels.dragToReorder", "Drag to reorder")}</span>
				<p class="mb-0">{t("messages.navigationFooterHelp", "Use indentation and drag-and-drop to organize deep menu hierarchies without losing context.")}</p>
			</div>
			<div class="nav-builder-footer-actions">
				{loadError && <span class="text-danger small">{loadError}</span>}
				<button class="btn btn-primary nav-builder-save" type="submit" disabled={Boolean(loadError)}>{t("actions.saveChanges", "Save changes")}</button>
			</div>
		</div>
	</div>
</div>

<style>
	.nav-builder {
		display: grid;
		gap: 1.25rem;
	}

	.nav-builder-header,
	.nav-tree-toolbar,
	.nav-builder-footer,
	.nav-inspector-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.nav-builder-kicker,
	.nav-tree-toolbar-kicker,
	.nav-inspector-kicker,
	.nav-inspector-card-label {
		display: inline-flex;
		align-items: center;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #667085;
	}

	.nav-builder-heading,
	.nav-tree-toolbar-copy {
		max-width: 44rem;
	}

	.nav-builder-stats {
		display: inline-flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.nav-builder-stat {
		min-width: 7rem;
		padding: 0.85rem 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.96));
		box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
		display: grid;
		gap: 0.2rem;
	}

	.nav-builder-stat strong {
		font-size: 1.15rem;
		font-weight: 700;
		color: #0f172a;
	}

	.nav-builder-stat span:last-child {
		font-size: 0.8rem;
		color: #64748b;
	}

	.nav-builder-surface {
		display: grid;
		gap: 1rem;
	}

	.nav-builder-workspace {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(20rem, 0.95fr);
		gap: 1rem;
		align-items: start;
	}

	.nav-tree-shell,
	.nav-inspector,
	.nav-builder-footer {
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1.25rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98)),
			linear-gradient(135deg, rgba(59, 130, 246, 0.06), rgba(148, 163, 184, 0.03));
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
	}

	.nav-tree-shell {
		display: grid;
		gap: 1rem;
		padding: 1.1rem;
	}

	.nav-tree-toolbar-copy p,
	.nav-builder-footer-copy p {
		font-size: 0.9rem;
		color: #64748b;
	}

	.nav-tree-toolbar-actions,
	.nav-builder-footer-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
		justify-content: flex-end;
	}

	.nav-toolbar-menu {
		position: relative;
	}

	.nav-toolbar-menu > summary {
		list-style: none;
	}

	.nav-toolbar-menu > summary::-webkit-details-marker {
		display: none;
	}

	.nav-toolbar-menu-panel {
		position: absolute;
		top: calc(100% + 0.45rem);
		right: 0;
		z-index: 3;
		min-width: 12rem;
		display: none;
		gap: 0.2rem;
		padding: 0.45rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0.85rem;
		background: #fff;
		box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
	}

	.nav-toolbar-menu[open] .nav-toolbar-menu-panel {
		display: grid;
	}

	.nav-toolbar-menu-item {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		justify-content: flex-start;
		padding: 0.7rem 0.8rem;
		border-radius: 0.7rem;
		color: #334155;
		text-decoration: none;
	}

	.nav-toolbar-menu-item:hover {
		background: rgba(59, 130, 246, 0.08);
		color: #0f172a;
	}

	.nav-builder-action,
	.nav-builder-save {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		border-radius: 0.9rem;
		min-height: 2.75rem;
		padding-inline: 1rem;
		font-weight: 600;
	}

	.nav-builder-footer-pill,
	.nav-inspector-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		padding: 0.4rem 0.75rem;
		font-size: 0.76rem;
		font-weight: 600;
	}

	.nav-builder-footer-pill {
		background: rgba(59, 130, 246, 0.08);
		color: #1d4ed8;
	}

	.nav-action-icon,
	.nav-inspector-empty-icon,
	.nav-drag-handle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.nav-action-icon svg,
	.nav-inspector-empty-icon svg {
		display: block;
		width: 1rem;
		height: 1rem;
	}

	.nav-drag-handle::before {
		content: "";
		display: block;
		width: 0.72rem;
		height: 0.9rem;
		background:
			radial-gradient(circle, currentColor 1px, transparent 1.1px) 0 0 / 0.35rem 0.35rem,
			radial-gradient(circle, currentColor 1px, transparent 1.1px) 0.35rem 0 / 0.35rem 0.35rem,
			radial-gradient(circle, currentColor 1px, transparent 1.1px) 0 0.35rem / 0.35rem 0.35rem,
			radial-gradient(circle, currentColor 1px, transparent 1.1px) 0.35rem 0.35rem / 0.35rem 0.35rem,
			radial-gradient(circle, currentColor 1px, transparent 1.1px) 0 0.7rem / 0.35rem 0.35rem,
			radial-gradient(circle, currentColor 1px, transparent 1.1px) 0.35rem 0.7rem / 0.35rem 0.35rem;
		background-repeat: no-repeat;
	}

	.nav-tree-list {
		display: grid;
		gap: 0.65rem;
	}

	.nav-tree-empty {
		padding: 1.25rem;
		border-radius: 1rem;
		border-style: dashed;
		display: grid;
		gap: 0.2rem;
		justify-items: start;
	}

	.nav-tree-row {
		--nav-indent: calc(var(--nav-depth, 0) * 2.2rem);
		position: relative;
		display: grid;
		gap: 0.42rem;
		padding-left: var(--nav-indent);
	}

	.nav-tree-row[hidden] {
		display: none;
	}

	.nav-tree-row-guides {
		position: absolute;
		inset: 0 auto 0 0;
		width: calc(var(--nav-indent) + 1.2rem);
		pointer-events: none;
	}

	.nav-tree-guide {
		position: absolute;
		top: 0.05rem;
		bottom: 0.05rem;
		width: 1px;
		background: linear-gradient(180deg, rgba(148, 163, 184, 0.2), rgba(148, 163, 184, 0.55), rgba(148, 163, 184, 0.2));
		opacity: 0;
	}

	.nav-tree-guide[data-active="true"] {
		opacity: 1;
	}

	.nav-tree-card {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0.25rem;
		align-items: center;
		padding: 0.42rem 0.7rem;
		border: 1px solid rgba(226, 232, 240, 0.95);
		border-radius: 0.55rem;
		background: rgba(255, 255, 255, 0.98);
