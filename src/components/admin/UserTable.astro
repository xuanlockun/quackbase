---
import type { AdminUserSummary } from "../../lib/auth/types";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	users: AdminUserSummary[];
}

const { users } = Astro.props;
const { t } = getUiTranslations(Astro);
---

{
	users.length === 0 ? (
		<div class="admin-empty-state">
			<h2>{t("messages.noUsersYet")}</h2>
			<p>{t("messages.noUsersHelp")}</p>
		</div>
	) : (
		<div class="admin-table-wrap">
			<table class="admin-table table table-sm align-middle mb-0">
				<thead>
					<tr>
						<th>{t("labels.user")}</th>
						<th>{t("labels.status")}</th>
						<th>{t("labels.roles")}</th>
						<th>{t("labels.action")}</th>
					</tr>
				</thead>
				<tbody>
					{
						users.map((user) => (
							<tr>
								<td>
									<div class="admin-meta-block">
										<strong>{user.displayName}</strong>
										<span class="admin-muted">{user.email}</span>
									</div>
								</td>
								<td>
									<span class:list={["admin-status-pill", !user.isActive && "admin-status-pill-inactive"]}>
										{user.isActive ? t("status.active") : t("status.inactive")}
									</span>
								</td>
								<td>
									<div class="admin-row-actions">
										{user.roles.length > 0 ? user.roles.map((role) => <span class="admin-role-chip">{role.label}</span>) : <span class="admin-muted">{t("messages.noRolesAssigned")}</span>}
									</div>
								</td>
								<td>
									<div class="admin-row-actions">
										<a href={`/admin/users/${user.id}/edit`}>{t("actions.edit")}</a>
									</div>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	)
}
