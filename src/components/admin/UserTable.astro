---
import type { AdminUserSummary } from "../../lib/auth/types";
import { getUiTranslations } from "../../lib/i18n";

interface Props {
	users: AdminUserSummary[];
}

const { users } = Astro.props;
const { t } = getUiTranslations(Astro);
---

{
	users.length === 0 ? (
		<div class="alert alert-secondary p-4">
			<h2 class="h5">{t("messages.noUsersYet")}</h2>
			<p class="mb-0">{t("messages.noUsersHelp")}</p>
		</div>
	) : (
		<div class="table-responsive">
			<table class="table table-striped table-hover align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th>{t("labels.user")}</th>
						<th>{t("labels.status")}</th>
						<th>{t("labels.roles")}</th>
						<th>{t("labels.action")}</th>
					</tr>
				</thead>
				<tbody>
					{
						users.map((user) => (
							<tr>
								<td>
									<div class="d-flex flex-column gap-1">
										<strong>{user.displayName}</strong>
										<span class="text-muted small">{user.email}</span>
									</div>
								</td>
								<td>
									<span class={`badge ${user.isActive ? "bg-success" : "bg-secondary"}`}>
										{user.isActive ? t("status.active") : t("status.inactive")}
									</span>
								</td>
								<td>
									<div class="d-flex flex-wrap gap-1">
										{
											user.roles.length > 0 ? (
												user.roles.map((role) => (
													<span class="badge bg-primary text-uppercase">{role.label}</span>
												))
											) : (
												<span class="text-muted small">{t("messages.noRolesAssigned")}</span>
											)
										}
									</div>
								</td>
								<td>
									<a class="btn btn-sm btn-outline-primary" href={`/admin/users/${user.id}/edit`}>
										{t("actions.edit")}
									</a>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	)
}
