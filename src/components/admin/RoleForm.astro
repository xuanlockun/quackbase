---
import type { AdminPermission, AdminRole } from "../../lib/auth/types";
import CreateSubmit from "./CreateSubmit.astro";
import { getUiTranslations, localizeAdminHref } from "../../lib/i18n";

interface Props {
	mode: "create" | "edit";
	action: string;
	role?: AdminRole | null;
	permissions: AdminPermission[];
	canSubmit: boolean;
	backHref?: string;
	loadError?: string;
}

const {
	mode,
	action,
	role = null,
	permissions,
	canSubmit,
	backHref = "/admin/roles",
	loadError = "",
} = Astro.props;

const { t, language } = getUiTranslations(Astro);
const submitLabel = mode === "edit" ? t("actions.saveRole") : t("actions.createRole");
const isDisabled = Boolean(loadError) || !canSubmit;
const selectedPermissionIds = new Set(role?.permissions.map((permission) => permission.id) ?? []);
const backIcon = `
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
		<path d="M14 6l-6 6 6 6" />
		<path d="M20 12H8" />
	</svg>
`;
---

<div class="admin-surface-header">
	<a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2" href={localizeAdminHref(backHref, language)}>
		<span aria-hidden="true" set:html={backIcon}></span>
		{t("actions.back")}
	</a>
	{!canSubmit && <p class="admin-inline-muted mb-0">{t("messages.cannotSavePage")}</p>}
</div>

{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

<form class="admin-form-shell" method="post" action={action}>
	<div class="admin-form-surface">
		<div class="admin-form-grid">
			<label>
				<span>{t("labels.roleName")}</span>
				<input
					class="form-control"
					name="name"
					required={mode === "create"}
					pattern="[a-z0-9.-]+"
					value={role?.name ?? ""}
					readonly={mode === "edit"}
					disabled={isDisabled || mode === "edit"}
				/>
			</label>
			<label>
				<span>{t("labels.displayName")}</span>
				<input class="form-control" name="label" required value={role?.label ?? ""} disabled={isDisabled} />
			</label>
		</div>
		<label>
			<span>{t("labels.description")}</span>
			<textarea class="form-control" name="description" rows="4" disabled={isDisabled}>{role?.description ?? ""}</textarea>
		</label>
	</div>

	<div class="admin-form-section">
		<span>{t("labels.permissions")}</span>
		<div class="admin-check-grid admin-permission-grid">
			{
				permissions.map((permission) => (
					<label class="admin-check-row admin-permission-item">
						<input
							class="form-check-input"
							type="checkbox"
							name="permissionIds"
							value={permission.id}
							checked={selectedPermissionIds.has(permission.id)}
							disabled={isDisabled}
						/>
						<span>{permission.label}</span>
					</label>
				))
			}
		</div>
	</div>

	<div class="admin-form-actions">
		{mode === "create" ? (
			<CreateSubmit label={submitLabel} disabled={isDisabled} />
		) : (
			<button class="btn btn-primary" type="submit" disabled={isDisabled}>{submitLabel}</button>
		)}
	</div>
</form>

<style>
	.admin-permission-grid {
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}

	.admin-permission-item {
		align-items: flex-start;
		padding: 0.8rem 0.9rem;
	}

	.admin-permission-item > span {
		font-size: 0.92rem;
		text-transform: none;
		letter-spacing: normal;
	}
</style>
