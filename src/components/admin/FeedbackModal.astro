---
interface Props {
	id: string;
	title?: string;
	closeLabel?: string;
	tone?: "info" | "success" | "warning" | "error";
}

const { id, title = "Status update", closeLabel = "Close", tone = "info" } = Astro.props;
---

<div class="modal fade" id={id} tabindex="-1" aria-hidden="true" data-admin-feedback-modal data-feedback-tone={tone}>
	<div class="modal-dialog modal-dialog-centered modal-dialog-scrollable admin-feedback-modal-dialog">
		<div class="modal-content border-0 shadow-sm admin-feedback-modal-shell">
			<div class="admin-feedback-modal-accent" aria-hidden="true"></div>
			<div class="modal-header py-3 px-3 px-sm-4 admin-feedback-modal-header">
				<div class="d-flex align-items-start gap-3 min-w-0">
					<span class="admin-feedback-modal-icon" data-feedback-modal-icon aria-hidden="true">
						<span class="admin-feedback-modal-glyph" data-feedback-modal-glyph>i</span>
					</span>
					<div class="min-w-0">
						<p class="admin-feedback-modal-kicker mb-1" data-feedback-modal-kicker>Info</p>
						<h2 class="modal-title h5 mb-0 text-break" data-feedback-modal-title>{title}</h2>
					</div>
				</div>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label={closeLabel}></button>
			</div>
			<div class="modal-body px-3 px-sm-4 py-3 admin-feedback-modal-body">
				<div class="admin-feedback-modal-spinner-wrap" data-feedback-modal-spinner hidden>
					<div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
				</div>
				<p class="mb-1 fw-semibold text-body" data-feedback-modal-message></p>
				<p class="mb-0 small text-body-secondary" data-feedback-modal-detail hidden></p>
			</div>
			<div class="modal-footer py-3 px-3 px-sm-4 border-0">
				<button type="button" class="btn btn-sm btn-primary" data-bs-dismiss="modal" data-feedback-modal-primary>{closeLabel}</button>
			</div>
		</div>
	</div>
</div>

<script is:inline define:vars={{ modalId: id }}>
	(() => {
		const toneIcons = {
			info: "i",
			success: "✓",
			warning: "⚠",
			error: "✖",
		};
		const toneLabels = {
			info: "Info",
			success: "Success",
			warning: "Warning",
			error: "Error",
		};

		const getModalElement = () => document.getElementById(modalId);

		const showAdminFeedbackModal = ({ tone = "info", title, message, detail, busy = false } = {}) => {
			const modalEl = getModalElement();
			if (!(modalEl instanceof HTMLElement)) {
				return;
			}

			const titleEl = modalEl.querySelector("[data-feedback-modal-title]");
			const messageEl = modalEl.querySelector("[data-feedback-modal-message]");
			const detailEl = modalEl.querySelector("[data-feedback-modal-detail]");
			const iconEl = modalEl.querySelector("[data-feedback-modal-icon]");
			const glyphEl = modalEl.querySelector("[data-feedback-modal-glyph]");
			const kickerEl = modalEl.querySelector("[data-feedback-modal-kicker]");
			const spinnerEl = modalEl.querySelector("[data-feedback-modal-spinner]");
			const primaryButton = modalEl.querySelector("[data-feedback-modal-primary]");

			if (titleEl instanceof HTMLElement) {
				titleEl.textContent = title || titleEl.textContent || "Status update";
			}
			if (messageEl instanceof HTMLElement) {
				messageEl.textContent = message || "";
			}
			if (detailEl instanceof HTMLElement) {
				if (detail) {
					detailEl.textContent = detail;
					detailEl.hidden = false;
				} else {
					detailEl.textContent = "";
					detailEl.hidden = true;
				}
			}
			if (iconEl instanceof HTMLElement) {
				iconEl.setAttribute("data-tone", tone);
			}
			if (glyphEl instanceof HTMLElement) {
				glyphEl.textContent = toneIcons[tone] || toneIcons.info;
			}
			if (kickerEl instanceof HTMLElement) {
				kickerEl.textContent = toneLabels[tone] || toneLabels.info;
			}
			if (spinnerEl instanceof HTMLElement) {
				spinnerEl.hidden = !busy;
			}

			modalEl.dataset.feedbackTone = tone;

			const bootstrap = window.bootstrap;
			if (bootstrap?.Modal) {
				const instance = bootstrap.Modal.getOrCreateInstance(modalEl);
				modalEl.addEventListener(
					"shown.bs.modal",
					() => {
						if (busy) {
							return;
						}
						(primaryButton instanceof HTMLButtonElement ? primaryButton : modalEl.querySelector("[data-bs-dismiss='modal']"))?.focus?.();
					},
					{ once: true },
				);
				instance.show();
			}
		};

		window.showAdminFeedbackModal = showAdminFeedbackModal;
	})();
</script>
