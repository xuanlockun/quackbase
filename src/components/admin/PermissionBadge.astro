---
interface Props {
	label: string;
	resource?: string;
}

const { label, resource } = Astro.props;
---

<span class="permission-badge" data-resource={resource ?? "generic"}>{label}</span>

<style>
	.permission-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.55rem;
		border-radius: 999px;
		background: rgba(35, 55, 255, 0.1);
		color: var(--accent-dark);
		font-size: 0.75rem;
		font-weight: 700;
		border: 1px solid rgba(35, 55, 255, 0.15);
	}
	.permission-badge[data-resource="roles"],
	.permission-badge[data-resource="users"] {
		background: rgba(19, 120, 89, 0.1);
		color: #0f6b50;
		border-color: rgba(19, 120, 89, 0.14);
	}
	.permission-badge[data-resource="site"] {
		background: rgba(180, 83, 9, 0.1);
		color: #9a3412;
		border-color: rgba(180, 83, 9, 0.16);
	}
</style>
