---
interface ShowcaseItem {
	title: string;
	description: string;
}

interface LogoItem {
	name: string;
	logo: string;
}

const showcaseItems: ShowcaseItem[] = [
	{
		title: "Strategy",
		description: "Plan campaigns, websites, and digital touchpoints with a clear structure from the start.",
	},
	{
		title: "Design",
		description: "Shape cleaner interfaces, stronger visuals, and layouts that feel more intentional.",
	},
	{
		title: "Development",
		description: "Build fast, responsive experiences that still stay easy to maintain later.",
	},
	{
		title: "Content",
		description: "Organize copy, media, and storytelling into sections people can scan quickly.",
	},
	{
		title: "Marketing",
		description: "Support launches and lead generation with flexible landing-page style sections.",
	},
	{
		title: "Support",
		description: "Keep iterating after launch with reusable blocks and easier content updates.",
	},
];

const clientLogos: LogoItem[] = [
	{ name: "Client 4", logo: "https://ncs.vn/wp-content/uploads/2020/03/client4.png" },
	{ name: "Client 5", logo: "https://ncs.vn/wp-content/uploads/2020/03/client5.svg" },
	{ name: "Client 6", logo: "https://ncs.vn/wp-content/uploads/2020/03/client6.svg" },
	{ name: "Client 1", logo: "https://ncs.vn/wp-content/uploads/2020/03/client1.svg" },
	{ name: "Client 2", logo: "https://ncs.vn/wp-content/uploads/2020/03/client2.svg" },
	{ name: "Client 3", logo: "https://ncs.vn/wp-content/uploads/2020/03/client3.svg" },
];

const partnerLogos: LogoItem[] = [
	{ name: "Partner 1", logo: "https://ncs.vn/wp-content/uploads/2020/03/client1.svg" },
	{ name: "Partner 2", logo: "https://ncs.vn/wp-content/uploads/2020/03/client2.svg" },
	{ name: "Partner 3", logo: "https://ncs.vn/wp-content/uploads/2020/03/client3.svg" },
	{ name: "Partner 4", logo: "https://ncs.vn/wp-content/uploads/2020/03/client4.png" },
	{ name: "Partner 5", logo: "https://ncs.vn/wp-content/uploads/2020/03/client5.svg" },
	{ name: "Partner 6", logo: "https://ncs.vn/wp-content/uploads/2020/03/client6.svg" },
];
---

<section class="home-showcase-section">
	<div class="home-showcase-shell">
		<div class="home-showcase-heading">
			<p class="site-eyebrow mb-2">Capabilities</p>
			<h2 class="home-showcase-title">A cleaner grid section for featured services</h2>
			<p class="home-showcase-intro mb-0">
				This is a dedicated block, so you do not need to force the layout through markdown columns anymore.
			</p>
		</div>

		<div class="home-showcase-grid">
			{
				showcaseItems.map((item, index) => (
					<article class="home-showcase-card">
						<span class="home-showcase-index">0{index + 1}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<section class="logo-strip-section" aria-labelledby="clients-strip-title">
	<div class="logo-strip-shell">
		<div class="logo-strip-header">
			<p class="site-eyebrow mb-2">Clients</p>
			<h2 id="clients-strip-title" class="logo-strip-title">Trusted by client teams</h2>
		</div>

		<div class="logo-strip-grid">
			{
				clientLogos.map((item) => (
					<div class="logo-strip-item">
						<img src={item.logo} alt={item.name} loading="lazy" />
					</div>
				))
			}
		</div>
	</div>
</section>

<section class="logo-strip-section" aria-labelledby="partners-strip-title">
	<div class="logo-strip-shell">
		<div class="logo-strip-header">
			<p class="site-eyebrow mb-2">Partners</p>
			<h2 id="partners-strip-title" class="logo-strip-title">Technology and delivery partners</h2>
		</div>

		<div class="logo-strip-grid logo-strip-grid--compact">
			{
				partnerLogos.map((item) => (
					<div class="logo-strip-item">
						<img src={item.logo} alt={item.name} loading="lazy" />
					</div>
				))
			}
		</div>
	</div>
</section>
