---
import {
	getRenderableFormFields,
	type ContactFormField,
} from "../lib/forms";
import { getLanguageCatalog, getUiTranslations } from "../lib/i18n";

interface Props {
	fields: ContactFormField[];
	currentLanguage?: string;
	sourcePath?: string;
	contactFormId?: number;
	title?: string;
	description?: string;
	backgroundStyle?: "solid" | "gradient" | "radial";
	backgroundColor?: string;
	buttonColor?: string;
}

const catalog = getLanguageCatalog(Astro.locals);
const {
	fields,
	currentLanguage = catalog.defaultLanguageCode,
	sourcePath = "/",
	contactFormId = 0,
	title = "",
	description = "",
	backgroundStyle = "solid",
	backgroundColor = "#f8fbff",
	buttonColor = "#4f80ff",
} = Astro.props;
const { t } = getUiTranslations(Astro);
const renderableFields = getRenderableFormFields(fields, currentLanguage, catalog);
const formStyle = `--contact-form-bg: ${backgroundColor}; --contact-submit-bg: ${buttonColor};`;
const formBackgroundStyle = backgroundStyle;
---

{
	renderableFields.length === 0 ? (
		<div class="alert alert-secondary">
			<h3 class="h5 mb-2">{t("messages.noContactFieldsConfigured")}</h3>
			<p class="mb-0">{t("messages.noContactFieldsConfiguredHelp")}</p>
		</div>
	) : (
		<form
			class="contact-form card border-0 shadow-lg overflow-hidden"
			method="post"
			action="/api/forms/contact"
			data-dynamic-contact-form
			data-background-style={formBackgroundStyle}
			data-success-message={t("messages.contactFormSubmitted")}
			data-error-message={t("messages.contactFormSubmitFailed")}
			style={formStyle}
		>
			<div class="card-body p-4 p-lg-5">
				{title && <h3 class="contact-form-title h4 mb-2">{title}</h3>}
				{description && <p class="contact-form-description text-muted mb-4">{description}</p>}
				<input type="hidden" name="language" value={currentLanguage} />
				<input type="hidden" name="sourcePath" value={sourcePath} />
				{contactFormId > 0 && <input type="hidden" name="contactFormId" value={String(contactFormId)} />}

				<div class="row g-3">
					{
						renderableFields.map((field) => (
							<div class={field.type === "textarea" ? "col-12" : "col-12 col-md-6"}>
								<label class="form-label fw-medium">
									{field.labelText}
									{field.required && <span class="text-danger ms-1">*</span>}
								</label>
								{
									field.type === "textarea" ? (
										<textarea
											class="form-control form-control-lg"
											name={field.inputName}
											rows="5"
											required={field.required}
										/>
									) : (
										<input
											class="form-control form-control-lg"
											type={field.type}
											name={field.inputName}
											required={field.required}
										/>
									)
								}
							</div>
						))
					}
				</div>

				<div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between mt-4 gap-3">
					<button class="btn btn-primary btn-lg px-4 contact-form-submit" type="submit">{t("actions.sendMessage")}</button>
					<p class="mb-0 text-muted small" data-contact-form-status aria-live="polite"></p>
				</div>
			</div>
		</form>
	)
}

<script>
	document.querySelectorAll("[data-dynamic-contact-form]").forEach((form) => {
		if (!(form instanceof HTMLFormElement)) {
			return;
		}

		const status = form.querySelector("[data-contact-form-status]");
		const submitButton = form.querySelector('button[type="submit"]');

		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			if (!(status instanceof HTMLElement)) {
				return;
			}

			const formData = new FormData(form);
			const payload = {
				language: String(formData.get("language") || "en"),
				sourcePath: String(formData.get("sourcePath") || "/"),
				contactFormId: Number(formData.get("contactFormId") || 0),
				values: {},
			};

			for (const [key, value] of formData.entries()) {
				if (!key.startsWith("field-") || typeof value !== "string") {
					continue;
				}
				payload.values[key.slice("field-".length)] = value;
			}

			status.textContent = "";
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
			}

			try {
				const response = await fetch(form.action, {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
						Accept: "application/json",
					},
					body: JSON.stringify(payload),
				});

				const data = await response.json().catch(() => ({}));
				if (!response.ok) {
					throw new Error(typeof data.error === "string" ? data.error : form.dataset.errorMessage || "Request failed.");
				}

				form.reset();
				status.textContent = form.dataset.successMessage || "Message sent.";
				status.classList.remove("is-error");
				status.classList.add("is-success");
			} catch (error) {
				status.textContent = error instanceof Error ? error.message : form.dataset.errorMessage || "Request failed.";
				status.classList.remove("is-success");
				status.classList.add("is-error");
			} finally {
				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = false;
				}
			}
		});
	});
</script>

<style>
	.contact-form {
		background-color: var(--contact-form-bg);
		border-radius: 0;
		border: 1px solid rgba(55, 80, 138, 0.14);
	}

	.contact-form[data-background-style="gradient"] {
		background-image: linear-gradient(135deg, var(--contact-form-bg), color-mix(in srgb, var(--contact-form-bg) 75%, white));
	}

	.contact-form[data-background-style="radial"] {
		background-image: radial-gradient(circle at top left, color-mix(in srgb, var(--contact-form-bg) 90%, white), var(--contact-form-bg));
	}

	.contact-form .card-body {
		border-radius: 0;
	}

	.contact-form .form-control,
	.contact-form .form-select,
	.contact-form .btn {
		border-radius: 0;
	}

	.contact-form .form-control:focus,
	.contact-form .form-select:focus {
		box-shadow: none;
		border-color: var(--contact-submit-bg);
	}

	.contact-form .form-label {
		color: #22304f;
	}

	.contact-form .text-muted {
		color: rgba(34, 48, 79, 0.72) !important;
	}

	.contact-form-title {
		color: #17233c;
	}

	.contact-form-submit {
		background-color: var(--contact-submit-bg);
		border-color: var(--contact-submit-bg);
	}

	.contact-form-submit:hover,
	.contact-form-submit:focus {
		background-color: color-mix(in srgb, var(--contact-submit-bg) 86%, black);
		border-color: color-mix(in srgb, var(--contact-submit-bg) 86%, black);
	}
</style>
