---
import LanguageSwitch from './LanguageSwitch.astro';
import { SITE_TITLE } from '../consts';
import { getDb, getSiteConfig, type SiteNavItem } from '../lib/blog';
import { getLanguageCatalog, getLanguageSwitchOptions, getUiTranslations } from '../lib/i18n';
import { escapeHtml, renderTemplateHtml } from '../lib/template-html';

let siteTitle = SITE_TITLE;
let logoUrl = "/logo.svg";
let headerBackground = '#ffffff';
let headerTextColor = '#0f1219';
let headerAccentColor = '#2337ff';
let headerTemplateHtml = "";
let navbarTemplateHtml = "";
const { language, t, localizeHref, localizeAdminHref } = getUiTranslations(Astro);
let navItems: SiteNavItem[] = [
	{ label: t("nav.home"), labelTranslations: { en: "Home", vi: "Trang chu" }, href: '/', sortOrder: 0 },
];

try {
	const config = await getSiteConfig(getDb(Astro.locals));
	siteTitle = config.siteTitle;
	logoUrl = config.logoUrl;
	headerBackground = config.headerBackground;
	headerTextColor = config.headerTextColor;
	headerAccentColor = config.headerAccentColor;
	headerTemplateHtml = config.headerTemplateHtml;
	navbarTemplateHtml = config.navbarTemplateHtml;
	navItems = config.navItems.length ? config.navItems : navItems;
} catch {
	// Fall back to baked-in navigation if D1 is unavailable on this route.
}

if (Astro.url.pathname.startsWith('/admin') && !navItems.some((item) => item.href === '/admin')) {
	navItems = [
		...navItems,
		{ label: t("nav.cms"), labelTranslations: { en: "CMS", vi: "CMS" }, href: '/admin', sortOrder: 999 },
	];
}

const currentPathname = Astro.url.pathname;
const resolveNavHref = (href = "/") => (href.startsWith('/admin') ? localizeAdminHref(href) : localizeHref(href));
const getNavLabel = (item: SiteNavItem) => item.labelTranslations?.[language] ?? item.labelTranslations?.en ?? item.label;
const isActivePath = (href: string) => href === currentPathname;
const hasActiveDescendant = (item: SiteNavItem): boolean =>
	(item.children ?? []).some((child) => isActivePath(child.href) || hasActiveDescendant(child));
const buildClass = (...classes: (string | false | undefined)[]) => classes.filter(Boolean).join(" ");
const catalog = getLanguageCatalog(Astro.locals);
const languageSwitchOptions = getLanguageSwitchOptions(Astro.url, language, catalog);
const brandHtml = buildBrandHtml();
const navItemsHtml = navItems.map((item) => renderNavItemHtml(item)).join("");
const languageSwitchHtml = buildLanguageSwitchHtml();
const headerTemplateHtmlRendered = renderTemplateHtml(headerTemplateHtml, {
	brand: brandHtml,
	languageSwitch: languageSwitchHtml,
});
const navbarTemplateHtmlRendered = renderTemplateHtml(navbarTemplateHtml, {
	navItems: navItemsHtml,
	languageSwitch: languageSwitchHtml,
});

function buildBrandHtml(): string {
	const siteTitleHtml = escapeHtml(siteTitle);
	const logoAltHtml = escapeHtml(siteTitle);
	const homeHref = escapeHtml(localizeHref("/"));

	return logoUrl
		? `<a class="navbar-brand d-flex align-items-center gap-2 fs-5 fw-bold flex-shrink-0" href="${homeHref}"><img src="${escapeHtml(logoUrl)}" alt="${logoAltHtml}" class="site-navbar-logo" loading="eager" /><span class="site-navbar-title">${siteTitleHtml}</span></a>`
		: `<a class="navbar-brand d-flex align-items-center gap-2 fs-5 fw-bold flex-shrink-0" href="${homeHref}"><span class="site-navbar-mark" aria-hidden="true">${escapeHtml(siteTitle.charAt(0) || siteTitle)}</span><span class="site-navbar-title">${siteTitleHtml}</span></a>`;
}

function buildLanguageSwitchHtml(): string {
	const optionsHtml = languageSwitchOptions
		.map(
			(option) =>
				`<option value="${escapeHtml(option.href)}"${option.isActive ? " selected" : ""}>${escapeHtml(option.label)}</option>`,
		)
		.join("");

	return `<label class="language-switch"><span class="visually-hidden">${escapeHtml(t("labels.language"))}</span><select class="form-select form-select-sm language-switch-select w-auto" aria-label="${escapeHtml(t("labels.language"))}" data-language-switch>${optionsHtml}</select></label><script>document.querySelectorAll("[data-language-switch]").forEach((select) => {if (!(select instanceof HTMLSelectElement)) {return;}select.addEventListener("change", () => {if (select.value) {window.location.href = select.value;}});});</script>`;
}

function renderNavItemHtml(item: SiteNavItem): string {
	const hasChildren = Boolean(item.children?.length);
	const linkHref = escapeHtml(resolveNavHref(item.href));
	const label = escapeHtml(getNavLabel(item));
	const active = isActivePath(item.href) || (hasChildren && hasActiveDescendant(item));

	if (!hasChildren) {
		return `<li class="nav-item"><a class="${buildClass("nav-link", active && "active")}" href="${linkHref}">${label}</a></li>`;
	}

	return `<li class="${buildClass("nav-item", "dropdown", active && "active")}"><a class="nav-link dropdown-toggle" href="${linkHref}" data-bs-toggle="dropdown" aria-expanded="false">${label}</a><ul class="${buildClass("dropdown-menu", "dropdown-submenu-menu")}">${item.children!.map((child) => renderNavItemHtml(child)).join("")}</ul></li>`;
}
---

{headerTemplateHtml.trim() ? (
	<Fragment set:html={headerTemplateHtmlRendered} />
) : (
<header class="bg-white border-bottom shadow-sm">
	<div class="container-fluid px-3 px-lg-4">
		<nav class="navbar navbar-expand-lg py-2">
			<div class="container-fluid px-0">
				<a class="navbar-brand d-flex align-items-center gap-2 fs-5 fw-bold flex-shrink-0" href={localizeHref("/")}>
					{logoUrl ? (
						<img
							src={logoUrl}
							alt={siteTitle}
							class="site-navbar-logo"
							loading="eager"
						/>
					) : (
						<span class="site-navbar-mark" aria-hidden="true">{siteTitle.charAt(0)}</span>
					)}
					<span class="site-navbar-title">{siteTitle}</span>
				</a>
				<button
					class="navbar-toggler"
					type="button"
					data-bs-toggle="collapse"
					data-bs-target="#mainNavbar"
					aria-controls="mainNavbar"
					aria-expanded="false"
					aria-label="Toggle navigation"
				>
					<span class="navbar-toggler-icon"></span>
				</button>
					<div class="collapse navbar-collapse w-100" id="mainNavbar">
					{navbarTemplateHtml.trim() ? (
						<Fragment set:html={navbarTemplateHtmlRendered} />
					) : (
					<div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center w-100 gap-lg-3">
						<ul class="navbar-nav flex-grow-1 justify-content-lg-center mb-3 mb-lg-0 gap-lg-1">
						{(() => {
							const renderItem = (item: SiteNavItem) => {
								const hasChildren = Boolean(item.children?.length);
								const linkHref = resolveNavHref(item.href);
								const active = isActivePath(item.href) || (hasChildren && hasActiveDescendant(item));

								if (!hasChildren) {
									return (
										<li class={buildClass("nav-item")}>
											<a class={buildClass("nav-link", active && "active")} href={linkHref}>
												{getNavLabel(item)}
											</a>
										</li>
									);
								}

								return (
									<li class={buildClass("nav-item", "dropdown", active && "active")}>
										<a
											class="nav-link dropdown-toggle"
											href={linkHref}
											data-bs-toggle="dropdown"
											aria-expanded="false"
										>
											{getNavLabel(item)}
										</a>
										<ul class={buildClass("dropdown-menu", "dropdown-submenu-menu")}>
											{item.children!.map((child) => renderItem(child))}
										</ul>
									</li>
								);
							};

							return navItems.map((item) => renderItem(item));
						})()}
						</ul>
						<div class="d-flex align-items-center justify-content-lg-end mt-3 mt-lg-0 flex-shrink-0">
							<LanguageSwitch fullWidth={false} />
						</div>
					</div>
					)}
				</div>
			</div>
		</nav>
	</div>
</header>
)
}
<style>
	.site-navbar-logo {
		display: block;
		width: auto;
		max-width: 170px;
		height: 40px;
		object-fit: contain;
	}

	.site-navbar-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: 2px solid #2337ff;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.95rem;
		line-height: 1;
		color: #2337ff;
	}

	.site-navbar-title {
		white-space: nowrap;
	}

	.navbar-nav .dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
	}

	.navbar-nav .dropdown-menu.show {
		display: block;
	}

	.navbar-nav .nav-item.dropdown:hover > .dropdown-menu,
	.navbar-nav .dropdown-submenu:hover > .dropdown-menu {
		display: block;
	}

	.navbar-nav .dropdown-submenu {
		position: relative;
	}

	.navbar-nav .dropdown-submenu .dropdown-menu {
		top: 0;
		left: 100%;
		margin-left: 0.25rem;
	}

	.dropdown-submenu-menu {
		min-width: 12rem;
	}

	@media (max-width: 992px) {
		.navbar-nav .dropdown-menu {
			position: static;
		}

		.site-navbar-logo {
			max-width: 130px;
			height: 34px;
		}

		.site-navbar-mark {
			width: 34px;
			height: 34px;
			font-size: 0.85rem;
		}

		.site-navbar-title {
			font-size: 0.95rem;
		}
	}
</style>
