---
import LanguageSwitchScript from "./LanguageSwitchScript.astro";
import { SITE_TITLE } from '../consts';
import { getDb, getSiteConfig, type SiteNavItem } from '../lib/blog';
import { getLanguageCatalog, getLanguageSwitchOptions, getUiTranslations } from '../lib/i18n';
import { DEFAULT_LOGO_URL, DEFAULT_TEMPLATE_THEME } from "../lib/site-defaults";
import { buildBrandHtml, buildLanguageSwitchHtml, buildNavItemsHtml } from "../lib/public-template-fragments";
import { DEFAULT_HEADER_TEMPLATE_HTML, DEFAULT_NAVIGATION_TEMPLATE_HTML, escapeHtml, renderTemplateHtml } from '../lib/template-html';

let siteTitle = SITE_TITLE;
let logoUrl = DEFAULT_LOGO_URL;
let headerBackground = DEFAULT_TEMPLATE_THEME.headerBackground;
let headerTextColor = DEFAULT_TEMPLATE_THEME.headerTextColor;
let headerAccentColor = DEFAULT_TEMPLATE_THEME.headerAccentColor;
let headerTemplateHtml = "";
let navbarTemplateHtml = "";
const { language, t, localizeHref, localizeAdminHref } = getUiTranslations(Astro);
let navItems: SiteNavItem[] = [
	{ label: t("nav.home"), labelTranslations: { en: "Home", vi: "Trang chu" }, href: '/', sortOrder: 0 },
];

try {
	const config = await getSiteConfig(getDb(Astro.locals));
	siteTitle = config.siteTitle;
	logoUrl = config.logoUrl;
	headerBackground = config.headerBackground;
	headerTextColor = config.headerTextColor;
	headerAccentColor = config.headerAccentColor;
	headerTemplateHtml = config.headerTemplateHtml;
	navbarTemplateHtml = config.navbarTemplateHtml;
	navItems = config.navItems.length ? config.navItems : navItems;
} catch {
	// Fall back to baked-in navigation if D1 is unavailable on this route.
}

if (Astro.url.pathname.startsWith('/admin') && !navItems.some((item) => item.href === '/admin')) {
	navItems = [
		...navItems,
		{ label: t("nav.cms"), labelTranslations: { en: "CMS", vi: "CMS" }, href: '/admin', sortOrder: 999 },
	];
}

const currentPathname = Astro.url.pathname;
const resolveNavHref = (href = "/") => (href.startsWith('/admin') ? localizeAdminHref(href) : localizeHref(href));
const catalog = getLanguageCatalog(Astro.locals);
const languageSwitchOptions = getLanguageSwitchOptions(Astro.url, language, catalog);
const brandHtml = buildBrandHtml({
	siteTitle,
	logoUrl,
	homeHref: localizeHref("/"),
	escapeHtml,
});
const navItemsHtml = buildNavItemsHtml({
	items: navItems,
	language,
	currentPathname,
	resolveHref: resolveNavHref,
	escapeHtml,
});
const languageSwitchHtml = buildLanguageSwitchHtml({
	label: t("labels.language"),
	options: languageSwitchOptions,
	escapeHtml,
});
const navigationHtml = renderTemplateHtml(headerTemplateHtml.trim() ? DEFAULT_NAVIGATION_TEMPLATE_HTML : navbarTemplateHtml.trim() || DEFAULT_NAVIGATION_TEMPLATE_HTML, {
	navItems: navItemsHtml,
	languageSwitch: languageSwitchHtml,
});
const headerTemplateHtmlRendered = renderTemplateHtml(headerTemplateHtml.trim() ? headerTemplateHtml : DEFAULT_HEADER_TEMPLATE_HTML, {
	brand: brandHtml,
	navigation: navigationHtml,
	navItems: navItemsHtml,
	languageSwitch: languageSwitchHtml,
});
---

<div
	class="site-header"
	style={`--site-header-background:${headerBackground};--site-header-text:${headerTextColor};--site-header-accent:${headerAccentColor};`}
>
	<Fragment set:html={headerTemplateHtmlRendered} />
	<LanguageSwitchScript />
</div>
