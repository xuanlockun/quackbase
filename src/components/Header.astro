---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import { SITE_TITLE } from '../consts';
import { getDb, getSiteConfig, type SiteNavItem } from '../lib/blog';
import { getUiTranslations } from '../lib/i18n';

let siteTitle = SITE_TITLE;
let headerBackground = '#ffffff';
let headerTextColor = '#0f1219';
let headerAccentColor = '#2337ff';
const { language, t, localizeHref, localizeAdminHref } = getUiTranslations(Astro);
let navItems: SiteNavItem[] = [
	{ label: t("nav.home"), labelTranslations: { en: "Home", vi: "Trang chu" }, href: '/', sortOrder: 0 },
];

try {
	const config = await getSiteConfig(getDb(Astro.locals));
	siteTitle = config.siteTitle;
	headerBackground = config.headerBackground;
	headerTextColor = config.headerTextColor;
	headerAccentColor = config.headerAccentColor;
	navItems = config.navItems.length ? config.navItems : navItems;
} catch {
	// Fall back to baked-in navigation if D1 is unavailable on this route.
}

if (Astro.url.pathname.startsWith('/admin') && !navItems.some((item) => item.href === '/admin')) {
	navItems = [
		...navItems,
		{ label: t("nav.cms"), labelTranslations: { en: "CMS", vi: "CMS" }, href: '/admin', sortOrder: 999 },
	];
}
---

<header style={`--header-bg:${headerBackground}; --header-text:${headerTextColor}; --header-accent:${headerAccentColor};`}>
	<nav>
		<h2 class="site-brand"><a href={localizeHref("/")}>{siteTitle}</a></h2>
		<div class="internal-links">
			{
				navItems.map((item) => (
					<HeaderLink href={item.href.startsWith('/admin') ? localizeAdminHref(item.href) : localizeHref(item.href)}>
						{item.labelTranslations?.[language] || item.labelTranslations?.en || item.label}
					</HeaderLink>
				))
			}
		</div>
		<div class="header-switch">
			<LanguageSwitch fullWidth={true} />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.25rem;
		background: var(--header-bg);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		min-height: 72px;
	}
	.site-brand {
		justify-self: start;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem;
		align-items: center;
		justify-content: center;
		justify-self: center;
		min-width: 0;
	}
	.internal-links a,
	h2 a {
		padding: 1rem 0.6rem;
		color: var(--header-text);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		white-space: nowrap;
	}
	.internal-links a.active,
	h2 a.active {
		text-decoration: none;
		border-bottom-color: var(--header-accent);
	}
	.header-switch {
		justify-self: end;
		display: flex;
		align-items: center;
		width: 180px;
	}
	.header-switch :global(.language-switch),
	.header-switch :global(.language-switch-full) {
		width: 100%;
	}
	@media (max-width: 720px) {
		nav {
			grid-template-columns: 1fr;
			justify-items: center;
			padding: 0.75rem 0;
		}
		.site-brand,
		.internal-links {
			justify-content: center;
			justify-self: center;
		}
		.header-switch {
			justify-self: center;
			width: 120px;
		}
	}
</style>
