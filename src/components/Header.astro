---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import { SITE_TITLE } from '../consts';
import { getDb, getSiteConfig, type SiteNavItem } from '../lib/blog';
import { getUiTranslations } from '../lib/i18n';

let siteTitle = SITE_TITLE;
let headerBackground = '#ffffff';
let headerTextColor = '#0f1219';
let headerAccentColor = '#2337ff';
const { language, t, localizeHref, localizeAdminHref } = getUiTranslations(Astro);
let navItems: SiteNavItem[] = [
	{ label: t("nav.home"), labelTranslations: { en: "Home", vi: "Trang chu" }, href: '/', sortOrder: 0 },
];

try {
	const config = await getSiteConfig(getDb(Astro.locals));
	siteTitle = config.siteTitle;
	headerBackground = config.headerBackground;
	headerTextColor = config.headerTextColor;
	headerAccentColor = config.headerAccentColor;
	navItems = config.navItems.length ? config.navItems : navItems;
} catch {
	// Fall back to baked-in navigation if D1 is unavailable on this route.
}

if (Astro.url.pathname.startsWith('/admin') && !navItems.some((item) => item.href === '/admin')) {
	navItems = [
		...navItems,
		{ label: t("nav.cms"), labelTranslations: { en: "CMS", vi: "CMS" }, href: '/admin', sortOrder: 999 },
	];
}
---

<header class="bg-white border-bottom">
	<div class="container-fluid">
		<nav class="navbar navbar-expand-lg">
			<div class="container-fluid px-3">
				<a class="navbar-brand d-flex align-items-center gap-2 fs-5 fw-bold" href={localizeHref("/")}>
					<span class="border border-2 border-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;">{siteTitle.charAt(0)}</span>
					<span>{siteTitle}</span>
				</a>
				<button
					class="navbar-toggler"
					type="button"
					data-bs-toggle="collapse"
					data-bs-target="#mainNavbar"
					aria-controls="mainNavbar"
					aria-expanded="false"
					aria-label="Toggle navigation"
				>
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="mainNavbar">
					<ul class="navbar-nav me-auto mb-2 mb-lg-0">
						{
							navItems.map((item) => (
								<li class="nav-item" key={item.label}>
									<a
										class:list={["nav-link", { active: item.href === Astro.url.pathname }]}
										href={item.href.startsWith('/admin') ? localizeAdminHref(item.href) : localizeHref(item.href)}
									>
										{item.labelTranslations?.[language] || item.labelTranslations?.en || item.label}
									</a>
								</li>
							))
						}
					</ul>
					<div class="d-flex align-items-center">
						<LanguageSwitch fullWidth={false} />
					</div>
				</div>
			</div>
		</nav>
	</div>
</header>
