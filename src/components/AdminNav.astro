---
const pathname = Astro.url.pathname;
const links = [
	{ href: "/admin/posts", label: "Posts" },
	{ href: "/admin/pages", label: "Pages" },
	{ href: "/admin/header", label: "Header" },
];
---

<nav class="admin-nav">
	{
		links.map((link) => (
			<a class:list={["admin-link", pathname === link.href && "active"]} href={link.href}>
				{link.label}
			</a>
		))
	}
</nav>

<style>
	.admin-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.admin-link {
		display: inline-block;
		padding: 0.65rem 0.9rem;
		border-radius: 999px;
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.admin-link.active {
		background: rgba(35, 55, 255, 0.12);
		color: var(--accent-dark);
	}
</style>
