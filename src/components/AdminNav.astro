---
const pathname = Astro.url.pathname;
const links = [
	{ href: "/admin/posts", label: "Posts" },
	{ href: "/admin/pages", label: "Pages" },
	{ href: "/admin/header", label: "Header" },
];
---

<nav class="admin-nav">
	{
		links.map((link) => (
			<a class:list={["admin-link", pathname === link.href && "active"]} href={link.href}>
				{link.label}
			</a>
		))
	}
</nav>

<style>
	.admin-nav {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.admin-link {
		display: block;
		padding: 0.9rem 1rem;
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(var(--gray-light), 0.8);
		color: rgb(var(--gray-dark));
		text-decoration: none;
		box-shadow: 0 12px 24px rgba(var(--gray), 0.08);
	}
	.admin-link.active {
		background: rgba(35, 55, 255, 0.12);
		border-color: rgba(35, 55, 255, 0.24);
		color: var(--accent-dark);
	}
</style>
