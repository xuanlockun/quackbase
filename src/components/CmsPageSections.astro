---
import {
	getLocalizedPostPath,
	getDb,
	type PageSectionConfig,
	listPublishedPosts,
} from "../lib/blog";
import BannerSection from "./BannerSection.astro";
import DynamicForm from "./DynamicForm.astro";
import { listFormFields } from "../lib/forms";
import { getLanguageCatalog, getUiTranslations } from "../lib/i18n";

interface Props {
	pageSections: PageSectionConfig[];
	contentHtml: string;
	currentLanguage?: string;
	currentPath?: string;
}

const catalog = getLanguageCatalog(Astro.locals);
const { pageSections, contentHtml, currentLanguage = catalog.defaultLanguageCode, currentPath = "/" } = Astro.props;
const { t } = getUiTranslations(Astro);

let posts = [];
let contactFields = [];

try {
	const db = getDb(Astro.locals);
	if (pageSections.some((section) => section.type === "blog_feed")) {
		posts = await listPublishedPosts(db, currentLanguage, catalog);
	}
	if (pageSections.some((section) => section.type === "contact_form")) {
		contactFields = await listFormFields(db);
	}
} catch {
	posts = [];
	contactFields = [];
}

const orderedSections = [...pageSections].sort((left, right) => left.order - right.order);
---

{
	orderedSections.map((section) => {
		if (section.type === "page_content") {
			return <div class="page-rich-content" set:html={contentHtml} />;
		}

		if (section.type === "banner_slider" && section.bannerUrls && section.bannerUrls.length > 0) {
			return <BannerSection bannerUrls={section.bannerUrls} />;
		}

		if (section.type === "blog_feed" && posts.length > 0) {
			return (
				<section class="page-section">
					<h2>{t("headings.latestPosts")}</h2>
					<div class="card-grid">
						{
							posts.slice(0, 6).map((post) => (
								<a class="mini-card" href={getLocalizedPostPath(post.slugTranslations, currentLanguage, catalog)}>
									<img src={post.heroImage || "/blog-placeholder-1.jpg"} alt="" width={520} height={292} />
									<h3>{post.title}</h3>
									<p>{post.description}</p>
								</a>
							))
						}
					</div>
				</section>
			);
		}

		if (section.type === "contact_form") {
			return (
				<section class="page-section contact-section-shell">
					<div class="contact-section-copy">
						<p class="contact-section-kicker">{t("headings.contactUs")}</p>
						<h2>{t("headings.contactFormTitle")}</h2>
						<p>{t("messages.contactFormIntro")}</p>
					</div>
					<DynamicForm fields={contactFields} currentLanguage={currentLanguage} sourcePath={currentPath} />
				</section>
			);
		}

		return null;
	})
}

<style>
	.page-section {
		margin-top: 1.75rem;
	}

	.page-rich-content :global(:first-child) {
		margin-top: 0;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.mini-card,
	.contact-section-shell {
		display: block;
		padding: 1rem;
		border-radius: 18px;
		background: white;
		box-shadow: var(--box-shadow);
		text-decoration: none;
		color: inherit;
	}

	.mini-card img,
	.banner-slide img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		margin-bottom: 0.8rem;
		border-radius: 14px;
	}

	.mini-card h3 {
		margin: 0 0 0.45rem 0;
		font-size: 1.15rem;
	}

	.mini-card p,
	.contact-section-copy p {
		margin: 0;
		color: rgb(var(--gray));
	}

	.page-section h2 {
		margin-bottom: 0.85rem;
	}

	.contact-section-shell {
		display: grid;
		gap: 1rem;
		padding: clamp(1.25rem, 3vw, 2rem);
	}

	.contact-section-kicker {
		margin: 0 0 0.5rem;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	.contact-section-copy {
		display: grid;
		gap: 0.55rem;
		max-width: 42rem;
	}

	@media (max-width: 1024px) {
		.card-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.card-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
