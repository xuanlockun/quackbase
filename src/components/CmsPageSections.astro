---
import {
	getDb,
	type PageSectionConfig,
	listPublishedPosts,
} from "../lib/blog";
import { listBanners, type BannerRecord } from "../lib/banners";
import { listFormFields, type ContactFormField } from "../lib/forms";
import { listContactForms, type ContactFormRecord } from "../lib/contact-forms";
import CmsPageSection from "./CmsPageSection.astro";
import { getLanguageCatalog } from "../lib/i18n";

interface Props {
	pageSections: PageSectionConfig[];
	contentHtml: string;
	pageTemplateHtml?: string;
	blogFeedTemplateHtml?: string;
	currentLanguage?: string;
	currentPath?: string;
}

interface BannerSlide {
	imageUrl: string;
	title: string;
	altText?: string;
	linkUrl?: string;
}

const catalog = getLanguageCatalog(Astro.locals);
const {
	pageSections,
	contentHtml,
	pageTemplateHtml = "",
	blogFeedTemplateHtml = "",
	currentLanguage = catalog.defaultLanguageCode,
	currentPath = "/",
} = Astro.props;

let posts = [];
let legacyContactFields = [];
let banners = [];
let contactForms = [];

try {
	const db = getDb(Astro.locals);
	if (pageSections.some((section) => section.type === "blog_feed")) {
		posts = await listPublishedPosts(db, currentLanguage, catalog);
	}
	if (pageSections.some((section) => section.type === "banner_slider")) {
		banners = await listBanners(db, true, currentLanguage, catalog);
	}
	if (pageSections.some((section) => section.type === "contact_form")) {
		contactForms = await listContactForms(db, true);
		if (contactForms.length === 0) {
			legacyContactFields = await listFormFields(db);
		}
	}
} catch {
	posts = [];
	legacyContactFields = [];
	banners = [];
	contactForms = [];
}

const orderedSections = [...pageSections].sort((left, right) => left.order - right.order);
---

{
	orderedSections.map((section) => (
		<CmsPageSection
			section={section}
			contentHtml={contentHtml}
			pageTemplateHtml={pageTemplateHtml}
			blogFeedTemplateHtml={blogFeedTemplateHtml}
			currentLanguage={currentLanguage}
			currentPath={currentPath}
			posts={posts}
			banners={banners}
			contactForms={contactForms}
			legacyContactFields={legacyContactFields}
		/>
	))
}
