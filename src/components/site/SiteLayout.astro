---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getDb, getSiteConfig } from "../../lib/blog";
import "../../styles/site-theme.css";

interface Props {
	title: string;
	description: string;
	lang?: string;
	faviconHref?: string;
	bodyClass?: string;
	mainClass?: string;
}

const {
	title,
	description,
	lang = "en",
	faviconHref,
	bodyClass = "bg-body site-app",
	mainClass = "site-main",
} = Astro.props;

let siteThemeKey = "classic";

try {
	siteThemeKey = (await getSiteConfig(getDb(Astro.locals))).themeKey;
} catch {
	siteThemeKey = "classic";
}
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} faviconHref={faviconHref} />
	</head>

	<body class={bodyClass} data-site-theme={siteThemeKey}>
		<Header />
		<main class={mainClass}>
			<slot />
		</main>
		<Footer />
	</body>
</html>
