---
import { getDb, getSiteConfig } from "../lib/blog";
import { getUiTranslations } from "../lib/i18n";
import { buildSocialLinksHtml } from "../lib/public-template-fragments";
import { escapeHtml, renderTemplateHtml } from "../lib/template-html";

const today = new Date();
let footerText = "Edge CMS. Content updates go live straight from D1.";
let footerTemplateHtml = "";
let footerBackground = "#eef2f7";
let footerTextColor = "#60739f";
const { t } = getUiTranslations(Astro);

try {
	const config = await getSiteConfig(getDb(Astro.locals));
	footerText = config.footerText;
	footerTemplateHtml = config.footerTemplateHtml;
	footerBackground = config.footerBackground;
	footerTextColor = config.footerTextColor;
} catch {
	// Fall back to baked-in footer settings if D1 is unavailable on this route.
}

const socialLinksHtml = buildSocialLinksHtml({
	mastodonLabel: t("messages.followAstroMastodon"),
	twitterLabel: t("messages.followAstroTwitter"),
	githubLabel: t("messages.visitAstroGithub"),
	escapeHtml,
});
const footerTemplateHtmlRendered = renderTemplateHtml(footerTemplateHtml, {
	footerText: escapeHtml(footerText),
	year: String(today.getFullYear()),
	socialLinks: socialLinksHtml,
});
---

<div
	class="site-footer-shell"
	style={`--site-footer-background:${footerBackground};--site-footer-text:${footerTextColor};`}
>
	{
		footerTemplateHtml.trim() ? (
			<Fragment set:html={footerTemplateHtmlRendered} />
		) : (
			<footer class="site-footer-fallback">{`© ${today.getFullYear()} ${footerText}`}</footer>
		)
	}
</div>
