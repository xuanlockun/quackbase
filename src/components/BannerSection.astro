---
interface BannerSlide {
	imageUrl: string;
	title: string;
	headline?: string;
	caption?: string;
	altText?: string;
	linkUrl?: string;
}

interface Props {
	slides?: BannerSlide[];
	bannerUrls?: string[];
}

const slides =
	Astro.props.slides ??
	(Astro.props.bannerUrls ?? []).map((url, index) => ({
		imageUrl: url,
		title: `Banner ${index + 1}`,
		altText: `Banner ${index + 1}`,
	}));
---

<section class="banner-section">
	<div class="banner-section-frame">
		<div
			id="bannerCarousel"
			class="carousel slide"
			data-bs-ride="carousel"
			data-bs-interval="5000"
		>
			<div class="carousel-inner">
				{
					slides.map((slide, index) => (
						<div class:list={["carousel-item", index === 0 && "active"]} key={`${slide.imageUrl}-${index}`}>
							<div class="banner-slide">
								{slide.linkUrl ? (
									<a href={slide.linkUrl} class="banner-slide-link">
										<img src={slide.imageUrl} alt={slide.altText ?? slide.title} loading="lazy" class="d-block w-100 banner-slide-image" />
									</a>
								) : (
									<img src={slide.imageUrl} alt={slide.altText ?? slide.title} loading="lazy" class="d-block w-100 banner-slide-image" />
								)}
								{(slide.headline?.trim() || slide.caption?.trim()) && (
									<div class="banner-slide-copy">
										<h2 class="banner-slide-title">{slide.headline?.trim() || slide.title}</h2>
										{slide.caption?.trim() && <p class="banner-slide-caption">{slide.caption}</p>}
									</div>
								)}
							</div>
						</div>
					))
				}
			</div>
			{
				slides.length > 1 && (
					<>
						<button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
							<span class="carousel-control-prev-icon" aria-hidden="true"></span>
							<span class="visually-hidden">Previous</span>
						</button>
						<button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
							<span class="carousel-control-next-icon" aria-hidden="true"></span>
							<span class="visually-hidden">Next</span>
						</button>
						<div class="carousel-indicators">
							{
								slides.map((_, index) => (
									<button
										type="button"
										key={`dot-${index}`}
										data-bs-target="#bannerCarousel"
										data-bs-slide-to={index}
										class:list={[index === 0 && "active"]}
										aria-current={index === 0 ? "true" : undefined}
										aria-label={`Slide ${index + 1}`}
									/>
								))
							}
						</div>
					</>
				)
			}
		</div>
	</div>
</section>
<style>
	.banner-section-frame {
		position: relative;
	}

	.banner-slide {
		display: grid;
		gap: 0.75rem;
	}

	.banner-slide-image {
		min-height: 240px;
		max-height: 72vh;
		object-fit: cover;
	}

	.banner-slide-link {
		display: block;
		color: inherit;
		text-decoration: none;
	}

	.banner-slide-copy {
		padding-inline: 0.25rem;
	}

	.banner-slide-title {
		margin: 0;
		font-size: clamp(1.1rem, 2.4vw, 2rem);
		line-height: 1.1;
		font-weight: 700;
	}

	.banner-slide-caption {
		margin: 0.35rem 0 0;
		font-size: 0.95rem;
		line-height: 1.45;
		color: rgba(15, 23, 42, 0.72);
	}
</style>
