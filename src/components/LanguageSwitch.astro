---
import { getLanguageCatalog, getLanguageSwitchOptions, getUiTranslations } from "../lib/i18n";

interface Props {
	fullWidth?: boolean;
}

const { fullWidth = false } = Astro.props;
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const options = getLanguageSwitchOptions(Astro.url, language, catalog);
---

<div class:list={["language-switch", fullWidth && "language-switch-full"]} role="group" aria-label={t("headings.languageSwitcher")}>
	{
		options.map((option) => (
			<a
				class:list={[
					"btn",
					"btn-sm",
					"language-switch-link",
					option.isActive ? "btn-dark is-active" : "btn-outline-secondary",
				]}
				href={option.href}
				aria-current={option.isActive ? "true" : undefined}
			>
				{option.code.toUpperCase()}
			</a>
		))
	}
</div>
