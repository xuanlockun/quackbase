---
import LanguageSwitchScript from "./LanguageSwitchScript.astro";
import { getLanguageCatalog, getLanguageSwitchOptions, getUiTranslations } from "../lib/i18n";
import { buildLanguageSwitchHtml } from "../lib/public-template-fragments";
import { escapeHtml } from "../lib/template-html";

interface Props {
	fullWidth?: boolean;
}

const { fullWidth = false } = Astro.props;
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const options = getLanguageSwitchOptions(Astro.url, language, catalog);
---

<Fragment
	set:html={buildLanguageSwitchHtml({
		label: t("labels.language"),
		options,
		escapeHtml,
		fullWidth,
	})}
/>
<LanguageSwitchScript />
