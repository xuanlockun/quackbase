---
export const prerender = false;

import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import FormattedDate from '../../components/FormattedDate.astro';
import { getDb, listPublishedPosts } from '../../lib/blog';

let posts = [];
let loadError = "";

try {
	posts = await listPublishedPosts(getDb(Astro.locals));
} catch (error) {
	loadError = error instanceof Error ? error.message : "Failed to load posts.";
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1120px, calc(100% - 2rem));
				max-width: none;
			}
			.hero {
				display: grid;
				gap: 1rem;
				margin-bottom: 2rem;
			}
			.kicker {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				width: fit-content;
				padding: 0.45rem 0.8rem;
				border-radius: 999px;
				background: rgba(35, 55, 255, 0.08);
				color: var(--accent-dark);
				font-size: 0.85rem;
				font-weight: 700;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
			.hero h1 {
				max-width: 12ch;
				margin: 0;
			}
			.hero-copy {
				max-width: 680px;
				margin: 0;
				color: rgb(var(--gray));
			}
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1.5rem;
			}
			.post-card {
				display: block;
				text-decoration: none;
				color: inherit;
				background: white;
				border-radius: 24px;
				padding: 1rem;
				box-shadow: var(--box-shadow);
			}
			.post-card img {
				width: 100%;
				height: auto;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				margin-bottom: 1rem;
				border-radius: 18px;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				align-items: center;
				margin-bottom: 0.85rem;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.post-card h2 {
				margin: 0 0 0.55rem 0;
				font-size: 1.55rem;
				line-height: 1.2;
			}
			.post-card p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.post-card:hover {
				transform: translateY(-2px);
				box-shadow: 0 18px 34px rgba(var(--gray), 0.18);
				border-color: rgba(35, 55, 255, 0.2);
			}
			.empty-state {
				padding: 2rem;
				background: white;
				border-radius: 16px;
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 1100px) {
				.posts-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}
			@media (max-width: 720px) {
				.hero h1 {
					max-width: none;
				}
				.posts-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<span class="kicker">Editorial Feed</span>
				<h1>Ideas, notes, and writing from the CMS.</h1>
				<p class="hero-copy">
					This page updates directly from D1, so newly published posts appear here without waiting for a rebuild.
				</p>
			</section>
			<section>
				{
					loadError ? (
						<p class="empty-state">
							Blog is not ready yet. Check the D1 binding, database ID, and run the posts migration.
						</p>
					) : posts.length ? (
						<div class="posts-grid">
							{
								posts.map((post) => (
									<a class="post-card" href={`/blog/${post.slug}/`}>
										<img
											width={720}
											height={405}
											src={post.heroImage || "/blog-placeholder-1.jpg"}
											alt=""
										/>
										<div class="meta">
											<FormattedDate date={post.pubDate} />
											<span>{post.status}</span>
										</div>
										<h2>{post.title}</h2>
										<p>{post.description}</p>
									</a>
								))
							}
						</div>
					) : (
						<p class="empty-state">No published posts yet. Create one in the CMS.</p>
					)
				}
				{loadError && <p class="date">{loadError}</p>}
			</section>
		</main>
		<Footer />
	</body>
</html>
