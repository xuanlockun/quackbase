---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb } from "../../lib/blog";
import { listContactForms } from "../../lib/contact-forms";
import { countFormSubmissionsByContactFormId } from "../../lib/forms";
import ContactFormTable from "../../components/admin/ContactFormTable.astro";
import CreateAction from "../../components/admin/CreateAction.astro";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canManage = session.isSuperadmin || session.permissions.includes("contactForms.manage");
const canView = session.isSuperadmin || session.permissions.includes("contactForms.read") || canManage;
const { t } = getUiTranslations(Astro);

let forms = [];
let submissionCounts = {};
let loadError = "";

try {
	const db = getDb(Astro.locals);
	forms = await listContactForms(db);
	const counts = await countFormSubmissionsByContactFormId(db);
	submissionCounts = Object.fromEntries(Array.from(counts.entries()).map(([id, count]) => [String(id), count]));
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadContactForms");
}

const totalForms = forms.length;
const activeForms = forms.filter((form) => form.isActive).length;
const totalSubmissions = Object.values(submissionCounts).reduce((sum, count) => sum + Number(count || 0), 0);
const statCards = [
	{
		label: t("messages.totalForms", "Total Forms"),
		value: totalForms,
		accent: "#4f7cff",
		accentSoft: "rgba(79, 124, 255, 0.12)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M4 6h16v12H4z" />
				<path d="M7 10h10" />
				<path d="M7 14h6" />
			</svg>
		`,
	},
	{
		label: t("messages.activeForms", "Active Forms"),
		value: activeForms,
		accent: "#22c55e",
		accentSoft: "rgba(34, 197, 94, 0.13)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 12h14" />
				<path d="M12 5v14" />
				<path d="M7 7h10" />
			</svg>
		`,
	},
	{
		label: t("messages.totalSubmissions", "Total Submissions"),
		value: totalSubmissions,
		accent: "#f59e0b",
		accentSoft: "rgba(245, 158, 11, 0.14)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M12 5v14" />
				<path d="M8 9l4-4 4 4" />
				<path d="M6 19h12" />
			</svg>
		`,
	},
];
---

<AdminLayout
	title={t("nav.contactForms")}
	description={t("messages.manageContactForms")}
	session={session}
	pageTitle={t("nav.contactForms")}
	pageDescription={t("messages.manageContactFormsHelp")}
>
	<div slot="actions" class="admin-page-actions">
		{canManage && <CreateAction href="/admin/contact-forms/new" label={t("actions.createContactForm")} />}
	</div>

	<div class="admin-content-stack">
		<div class="contact-forms-stats">
			{statCards.map((card) => (
				<div class="contact-forms-stat-card" style={`--stat-accent:${card.accent};--stat-accent-soft:${card.accentSoft};`}>
					<span class="contact-forms-stat-icon" aria-hidden="true" set:html={card.icon}></span>
					<div>
						<div class="contact-forms-stat-label">{card.label}</div>
						<div class="contact-forms-stat-value">{card.value}</div>
					</div>
				</div>
			))}
		</div>
		{Astro.url.searchParams.get("created") && <p class="alert alert-success mb-0">{t("messages.contactFormCreated")}</p>}
		{Astro.url.searchParams.get("saved") && <p class="alert alert-success mb-0">{t("messages.contactFormSaved")}</p>}
		{Astro.url.searchParams.get("deleted") && <p class="alert alert-info mb-0">{t("messages.contactFormDeleted")}</p>}
		{Astro.url.searchParams.get("error") && <p class="alert alert-danger mb-0">{t("messages.contactFormRequestFailed")}</p>}
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}

		<ContactFormTable forms={forms} canUpdate={canManage} canDelete={canManage} canViewLeads={canView} submissionCounts={submissionCounts} />
	</div>
</AdminLayout>

<style>
	.contact-forms-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.75rem;
	}

	.contact-forms-stat-card {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.85rem 0.95rem;
		border: 1px solid color-mix(in srgb, var(--stat-accent, #4f7cff) 18%, rgba(var(--gray), 0.14));
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.96)),
			var(--stat-accent-soft, rgba(79, 124, 255, 0.12));
	}

	.contact-forms-stat-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border: 1px solid color-mix(in srgb, var(--stat-accent, #4f7cff) 28%, rgba(var(--gray), 0.16));
		border-radius: 0.7rem;
		flex: 0 0 auto;
		color: var(--stat-accent, #4f7cff);
		background: color-mix(in srgb, var(--stat-accent-soft, rgba(79, 124, 255, 0.12)) 72%, white);
	}

	.contact-forms-stat-icon svg {
		width: 1rem;
		height: 1rem;
	}

	.contact-forms-stat-label {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(15, 23, 42, 0.6);
	}

	.contact-forms-stat-value {
		margin-top: 0.15rem;
		font-size: 1.1rem;
		font-weight: 600;
		line-height: 1.1;
	}
</style>
