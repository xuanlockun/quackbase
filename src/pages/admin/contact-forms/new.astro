---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import ContactFormForm from "../../../components/admin/ContactFormForm.astro";
import { getUiTranslations } from "../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("contactForms.manage");
const { t } = getUiTranslations(Astro);
---

<AdminLayout
	title={t("actions.createContactForm")}
	description={t("messages.createContactFormHelp")}
	session={session}
	pageTitle={t("actions.createContactForm")}
	pageDescription={t("messages.createContactFormHelp")}
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("error") && <p class="alert alert-danger mb-0">{t("messages.contactFormRequestFailed")}</p>}
		<ContactFormForm mode="create" action="/api/admin/contact-forms" canSubmit={canCreate} />
	</div>
</AdminLayout>
