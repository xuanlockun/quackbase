---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import FeedbackModal from "../../../../components/admin/FeedbackModal.astro";
import ContactFormSubmissions from "../../../../components/admin/ContactFormSubmissions.astro";
import { getDb } from "../../../../lib/blog";
import { getContactFormById } from "../../../../lib/contact-forms";
import { listFormSubmissions } from "../../../../lib/forms";
import { getLanguageCatalog, getUiTranslations } from "../../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canView = session.isSuperadmin || session.permissions.includes("contactForms.read") || session.permissions.includes("contactForms.manage");
const canDelete = session.isSuperadmin || session.permissions.includes("contactForms.manage");
const { id } = Astro.params;
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);

if (!canView) {
	return Astro.redirect("/admin/contact-forms");
}

let form = null;
let submissions = [];
let loadError = "";
let notFound = false;

try {
	const formId = Number(id);
	if (!Number.isInteger(formId) || formId <= 0) {
		notFound = true;
	} else {
		const db = getDb(Astro.locals);
		form = await getContactFormById(db, formId, language, catalog);
		submissions = await listFormSubmissions(db, formId);
		notFound = !form;
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadContactForms");
}

if (Astro.url.searchParams.get("error")) {
	loadError = t("messages.contactFormRequestFailed");
}

const leadsFeedback = [
	["deleted", { title: t("messages.leadDeletedTitle", "Lead deleted"), message: t("messages.leadDeleted", "The lead was removed successfully."), tone: "success" }],
	["error", { title: t("messages.actionFailedTitle", "Action failed"), message: t("messages.leadActionFailed", "The lead action failed."), tone: "error" }],
] as const;
---

<AdminLayout
	title={t("messages.contactFormLeads", "Contact form leads")}
	description={t("messages.contactFormLeadsHelp", "Review messages submitted through this form.")}
	session={session}
	pageTitle={t("messages.contactFormLeads", "Contact form leads")}
	pageDescription={t("messages.contactFormLeadsHelp", "Review messages submitted through this form.")}
>
	<div class="admin-content-stack">
		<FeedbackModal id="contact-form-leads-feedback-modal" title={t("messages.statusUpdate", "Status update")} closeLabel={t("actions.close", "Close")} />
		{
			notFound ? (
				<div class="admin-empty-state">
					<h2>{t("messages.contactFormNotFound")}</h2>
					<p class="admin-muted">{t("messages.failedToLoadContactForms")}</p>
					<p>
						<a class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" href="/admin/contact-forms">
							<span aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 6l-6 6 6 6" />
									<path d="M20 12H8" />
								</svg>
							</span>
							{t("messages.backToContactForms")}
						</a>
					</p>
				</div>
			) : (
				<>
					<div class="admin-surface-header">
						<a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2" href="/admin/contact-forms">
							<span aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 6l-6 6 6 6" />
									<path d="M20 12H8" />
								</svg>
							</span>
							{t("actions.back")}
						</a>
						<p class="admin-inline-muted mb-0">
							{form ? `${form.title} · ${submissions.length} leads` : t("messages.contactFormLeadsHelp", "Review messages submitted through this form.")}
						</p>
					</div>

					{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

					{form && <ContactFormSubmissions form={form} submissions={submissions} canDelete={canDelete} />}
				</>
			)
		}
	</div>
</AdminLayout>

<script type="module" define:vars={{ leadsFeedback }}>
	const showFeedbackModal = window.showAdminFeedbackModal;
	const search = new URLSearchParams(window.location.search);

	for (const [key, entry] of leadsFeedback) {
		if (search.has(key)) {
			if (typeof showFeedbackModal === "function") {
				showFeedbackModal({ title: entry.title, message: entry.message, tone: entry.tone });
			}
			window.history.replaceState({}, "", window.location.pathname + window.location.hash);
			break;
		}
	}
</script>
