---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import translationManagerScript from "../../../../components/admin/translation-manager.js?url";
import { getDb } from "../../../../lib/blog";
import { getLanguageByCode, listAllLanguages, listEnabledLanguages } from "../../../../lib/languages";
import { listTranslationEntriesByKey } from "../../../../lib/translations";
import { getUiTranslations } from "../../../../lib/i18n";
import type { AdminSession } from "../../../../lib/auth/types";

const session: AdminSession | null = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);
const requestedLocale = (Astro.params.locale ?? "").toLowerCase().trim();
const requestedKey = decodeURIComponent(Astro.params.key ?? "").trim();

let languages = [];
let selectedLanguage = null;
let enabledLanguages = [];
let bundle = null;
let loadError = "";

try {
	const db = getDb(Astro.locals);
	languages = await listAllLanguages(db);
	selectedLanguage =
		(requestedLocale && (await getLanguageByCode(db, requestedLocale))) ||
		languages.find((language) => language.isDefault) ||
		languages[0] ||
		null;
	enabledLanguages = await listEnabledLanguages(db);
	bundle = requestedKey ? await listTranslationEntriesByKey(db, requestedKey) : null;
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.translationRequestFailed");
}

if (!requestedKey || !bundle) {
	loadError = loadError || t("messages.translationListEmpty");
}

const editorLanguages = [
	{ code: selectedLanguage?.code ?? enabledLanguages[0]?.code ?? languages[0]?.code ?? "en", label: selectedLanguage?.name ?? enabledLanguages[0]?.name ?? languages[0]?.name ?? "English" },
	...enabledLanguages
		.filter((entry) => entry.code !== selectedLanguage?.code)
		.map((entry) => ({ code: entry.code, label: entry.name })),
];
const selectedLocale = editorLanguages[0]?.code ?? requestedLocale ?? "en";
const headingTitle = t("labels.translationEntry", "Edit translation entry");
const helpText = t(
	"messages.manageTranslationsHelp",
	"Update the translation key across enabled languages from one place.",
);
const saveButtonLabel = t("actions.saveChanges", "Save changes");
const keyLabel = t("labels.translationKey");
const valueLabel = t("labels.translationValue");
const translationTabsLabel = t("labels.languages", "Languages");
---

<AdminLayout
	title={headingTitle}
	description={helpText}
	session={session}
	pageTitle={headingTitle}
	pageDescription={helpText}
>
	<div class="admin-content-stack">
		{loadError && <p class="alert alert-warning mb-0">{loadError}</p>}
		<div class="admin-surface-header">
			<a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2" href="/admin/languages">
				<span aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M14 6l-6 6 6 6" />
						<path d="M20 12H8" />
					</svg>
				</span>
				{t("messages.backToLanguages", "Back to languages")}
			</a>
		</div>
		<form
			data-translation-form
			class="admin-form-surface admin-form-shell"
			data-current-locale={selectedLocale}
			data-editing-key={bundle?.translationKey ?? requestedKey}
			data-route-template="/admin/languages/__locale__/__key__"
			data-language-tabs={JSON.stringify(editorLanguages)}
			data-initial-translations={JSON.stringify(bundle?.translations ?? {})}
			data-api-base-template="/api/admin/languages/__locale__/translations/__key__"
			data-text-save-button={saveButtonLabel}
			data-text-add-button={saveButtonLabel}
			data-text-create-success={t("messages.translationCreateSuccess")}
			data-text-update-success={t("messages.translationUpdateSuccess")}
			data-text-required-key="Translation key is required."
			data-text-required-values="Enter at least one translation value."
		>
			<div class="admin-surface-header mb-3">
				<div>
					<h2 class="h5 mb-1">{headingTitle}</h2>
					<p class="admin-inline-muted mb-0">{helpText}</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<label class="visually-hidden" for="translation-locale-select">{t("labels.language")}</label>
					<select
						id="translation-locale-select"
						class="form-select form-select-sm"
						data-translation-locale-select
					>
						{
							languages.map((language) => (
								<option value={language.code} selected={language.code === selectedLocale}>
									{language.name}
								</option>
							))
						}
					</select>
				</div>
			</div>

			<div class="mb-3" data-translation-notice aria-live="polite"></div>
			<div class="row g-3">
				<div class="col-12 col-lg-4">
					<label class="form-label" for="translation-key">{keyLabel}</label>
					<input class="form-control" id="translation-key" name="key" value={bundle?.translationKey ?? requestedKey} readonly />
				</div>
				<div class="col-12">
					<div class="admin-card-surface border rounded-0 p-3">
						<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
							<strong class="small text-uppercase text-muted">{translationTabsLabel}</strong>
							<span class="small text-muted">{valueLabel}</span>
						</div>
						<ul class="nav nav-tabs flex-wrap gap-1" role="tablist" data-translation-tablist>
							{
								editorLanguages.map((entry, index) => (
									<li class="nav-item" role="presentation">
										<button
											type="button"
											class:list={["nav-link", index === 0 && "active"]}
											data-translation-tab={entry.code}
											aria-selected={index === 0 ? "true" : "false"}
										>
											{entry.label}
										</button>
									</li>
								))
							}
						</ul>
						<div class="border border-top-0 rounded-0 p-3" data-translation-panels>
							{
								editorLanguages.map((entry, index) => (
									<section
										class:list={["translation-pane", index === 0 ? "" : "d-none"]}
										data-translation-panel={entry.code}
									>
										<label class="form-label" for={`translation-value-${entry.code}`}>{entry.label}</label>
										<textarea
											class="form-control"
											id={`translation-value-${entry.code}`}
											name={`value-${entry.code}`}
											rows="4"
											placeholder={`${entry.label} ${valueLabel.toLowerCase()}`}
										></textarea>
									</section>
								))
							}
						</div>
					</div>
				</div>
				<div class="col-12 d-flex flex-wrap gap-2">
					<button type="submit" class="btn btn-primary" data-translation-submit>
						{saveButtonLabel}
					</button>
				</div>
			</div>
		</form>
	</div>

	<script type="module" src={translationManagerScript} client:load></script>
</AdminLayout>
