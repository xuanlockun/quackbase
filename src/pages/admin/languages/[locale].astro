---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import IconAction from "../../../components/admin/IconAction.astro";
import CreateAction from "../../../components/admin/CreateAction.astro";
import { getDb } from "../../../lib/blog";
import { getLanguageByCode, listAllLanguages } from "../../../lib/languages";
import { listTranslationEntriesByLocale } from "../../../lib/translations";
import { getUiTranslations } from "../../../lib/i18n";
import type { AdminSession } from "../../../lib/auth/types";

const session: AdminSession | null = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);
const requestedLocale = (Astro.params.locale ?? "").toLowerCase().trim();
const requestedNamespace = (Astro.url.searchParams.get("namespace") ?? "all").trim().toLowerCase();

let languages = [];
let selectedLanguage = null;
let translationEntries = [];
let loadError = "";

try {
	const db = getDb(Astro.locals);
	languages = await listAllLanguages(db);
	selectedLanguage =
		(requestedLocale && (await getLanguageByCode(db, requestedLocale))) ||
		languages.find((language) => language.isDefault) ||
		languages[0] ||
		null;

	if (selectedLanguage?.code) {
		translationEntries = await listTranslationEntriesByLocale(db, selectedLanguage.code);
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.translationRequestFailed");
}

if (!selectedLanguage) {
	loadError = loadError || t("messages.translationListEmpty");
}

const namespaceOptions = buildNamespaceOptions(translationEntries);
const activeNamespace = namespaceOptions.some((option) => option.value === requestedNamespace)
	? requestedNamespace
	: "all";
const filteredTranslationEntries =
	activeNamespace === "all"
		? translationEntries
		: translationEntries.filter((entry) => getTranslationNamespace(entry.translationKey) === activeNamespace);

const headingTitle = t("labels.translationEntry", "Edit translation entries");
const helpText = selectedLanguage
	? t(
			"messages.manageTranslationsHelp",
			`Review and edit translation entries for ${selectedLanguage.name}.`,
		)
	: t("messages.manageTranslationsHelp", "Review and edit translation entries for this language.");
const createLink = `/admin/languages?locale=${encodeURIComponent(selectedLanguage?.code ?? requestedLocale ?? "en")}#translations`;
const filterBackLink = `/admin/languages/${encodeURIComponent(selectedLanguage?.code ?? requestedLocale ?? "en")}${
	activeNamespace !== "all" ? `?namespace=${encodeURIComponent(activeNamespace)}` : ""
}`;

function getTranslationNamespace(translationKey: string): string {
	const [namespace = "other"] = translationKey.split(".");
	return namespace.trim().toLowerCase() || "other";
}

function buildNamespaceOptions(entries: { translationKey: string }[]): Array<{ label: string; value: string }> {
	const namespaces = new Set(entries.map((entry) => getTranslationNamespace(entry.translationKey)));
	return [
		{ label: "All namespaces", value: "all" },
		...Array.from(namespaces)
			.sort((left, right) => left.localeCompare(right))
			.map((namespace) => ({
				label: namespace === "other" ? "Other" : namespace,
				value: namespace,
			})),
	];
}
---

<AdminLayout
	title={headingTitle}
	description={helpText}
	session={session}
	pageTitle={headingTitle}
	pageDescription={helpText}
>
	<div class="admin-content-stack">
		{loadError && <p class="alert alert-warning mb-0">{loadError}</p>}

		<div class="admin-form-surface">
			<div class="admin-surface-header mb-3">
				<div>
					<h2 class="h5 mb-1">
						{selectedLanguage ? `${selectedLanguage.name} translations` : headingTitle}
					</h2>
					<p class="admin-inline-muted mb-0">{helpText}</p>
				</div>
				<div class="admin-action-group">
					<a class="btn btn-outline-secondary btn-sm" href={filterBackLink}>
						<span class="d-inline-flex align-items-center gap-2">
							<span aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 6l-6 6 6 6" />
									<path d="M20 12H8" />
								</svg>
							</span>
							{t("messages.backToLanguages", "Back to languages")}
						</span>
					</a>
					<CreateAction href={createLink} label={t("actions.addTranslation", "Create translation entry")} />
				</div>
			</div>

			<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
				<label class="small text-uppercase text-muted" for="translation-namespace-filter">{t("labels.filter", "Filter")}</label>
				<select
					id="translation-namespace-filter"
					class="form-select form-select-sm w-auto"
					onchange={`window.location.href='/admin/languages/${encodeURIComponent(selectedLanguage?.code ?? requestedLocale ?? "en")}?namespace=' + encodeURIComponent(this.value)`}
				>
					{
						namespaceOptions.map((option) => (
							<option value={option.value} selected={option.value === activeNamespace}>
								{option.label}
							</option>
						))
					}
				</select>
			</div>

			<div class="table-responsive">
				<table class="table table-sm align-middle mb-0">
					<thead>
						<tr>
							<th scope="col">{t("labels.translationKey")}</th>
							<th scope="col">{t("labels.translationValue")}</th>
							<th scope="col" class="text-end">{t("actions.edit")}</th>
						</tr>
					</thead>
					<tbody>
						{
							filteredTranslationEntries.length === 0 ? (
								<tr>
									<td colspan="3" class="text-center text-muted py-4">
										{t("messages.translationListEmpty")}
									</td>
								</tr>
							) : (
								filteredTranslationEntries.map((entry) => (
									<tr>
										<td>
											<code>{entry.translationKey}</code>
										</td>
										<td class="text-break">{entry.translatedValue}</td>
										<td class="text-end admin-action-cell">
											<IconAction
												href={`/admin/languages/${encodeURIComponent(selectedLanguage!.code)}/${encodeURIComponent(entry.translationKey)}`}
												icon="edit"
												label={t("actions.edit")}
											/>
										</td>
									</tr>
								))
							)
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</AdminLayout>
