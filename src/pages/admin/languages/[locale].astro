---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getDb } from "../../../lib/blog";
import { getLanguageByCode, listAllLanguages } from "../../../lib/languages";
import { listTranslationEntriesByLocale } from "../../../lib/translations";
import { getUiTranslations } from "../../../lib/i18n";
import type { AdminSession } from "../../../lib/auth/types";

const session: AdminSession | null = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);
const requestedLocale = (Astro.params.locale ?? "").toLowerCase().trim();

let languages = [];
let selectedLanguage = null;
let translationEntries = [];
let loadError = "";

try {
	const db = getDb(Astro.locals);
	languages = await listAllLanguages(db);
	selectedLanguage =
		(requestedLocale && (await getLanguageByCode(db, requestedLocale))) ||
		languages.find((language) => language.isDefault) ||
		languages[0] ||
		null;

	if (selectedLanguage?.code) {
		translationEntries = await listTranslationEntriesByLocale(db, selectedLanguage.code);
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.translationRequestFailed");
}

if (!selectedLanguage) {
	loadError = loadError || t("messages.translationListEmpty");
}

const headingTitle = t("labels.translationEntry", "Edit translation entries");
const helpText = selectedLanguage
	? t(
			"messages.manageTranslationsHelp",
			`Review and edit translation entries for ${selectedLanguage.name}.`,
		)
	: t("messages.manageTranslationsHelp", "Review and edit translation entries for this language.");
const createLink = `/admin/languages?locale=${encodeURIComponent(selectedLanguage?.code ?? requestedLocale ?? "en")}#translations`;
---

<AdminLayout
	title={headingTitle}
	description={helpText}
	session={session}
	pageTitle={headingTitle}
	pageDescription={helpText}
>
	<div class="admin-content-stack">
		{loadError && <p class="alert alert-warning mb-0">{loadError}</p>}

		<div class="admin-form-surface">
			<div class="admin-surface-header mb-3">
				<div>
					<h2 class="h5 mb-1">
						{selectedLanguage ? `${selectedLanguage.name} translations` : headingTitle}
					</h2>
					<p class="admin-inline-muted mb-0">{helpText}</p>
				</div>
				<div class="d-flex flex-wrap gap-2">
					<a class="btn btn-outline-secondary btn-sm" href="/admin/languages">
						{t("messages.backToLanguages", "Back to languages")}
					</a>
					<a class="btn btn-primary btn-sm" href={createLink}>
						{t("actions.addTranslation", "Create translation entry")}
					</a>
				</div>
			</div>

			<div class="table-responsive">
				<table class="table table-sm align-middle mb-0">
					<thead>
						<tr>
							<th scope="col">{t("labels.translationKey")}</th>
							<th scope="col">{t("labels.translationValue")}</th>
							<th scope="col" class="text-end">{t("actions.edit")}</th>
						</tr>
					</thead>
					<tbody>
						{
							translationEntries.length === 0 ? (
								<tr>
									<td colspan="3" class="text-center text-muted py-4">
										{t("messages.translationListEmpty")}
									</td>
								</tr>
							) : (
								translationEntries.map((entry) => (
									<tr>
										<td>
											<code>{entry.translationKey}</code>
										</td>
										<td class="text-break">{entry.translatedValue}</td>
										<td class="text-end">
											<a
												class="btn btn-sm btn-outline-secondary"
												href={`/admin/languages/${encodeURIComponent(selectedLanguage!.code)}/${encodeURIComponent(entry.translationKey)}`}
											>
												{t("actions.edit")}
											</a>
										</td>
									</tr>
								))
							)
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</AdminLayout>
