---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getDb } from "../../../lib/blog";
import { getLanguageByCode, listEnabledLanguages } from "../../../lib/languages";
import { listTranslationEntriesByLocale } from "../../../lib/translations";
import { getUiTranslations } from "../../../lib/i18n";
import translationManagerScript from "../../../components/admin/translation-manager.js?url";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const requestedLocale = (Astro.params.locale ?? "").toLowerCase().trim();
if (!requestedLocale) {
	return Astro.redirect("/admin/languages");
}

const language = await getLanguageByCode(getDb(Astro.locals), requestedLocale);
if (!language) {
	return Astro.redirect("/admin/languages");
}

const enabledLanguages = await listEnabledLanguages(getDb(Astro.locals));
const editorLanguages = [
	{ code: language.code, label: language.name, isActive: true },
	...enabledLanguages
		.filter((entry) => entry.code !== language.code)
		.map((entry) => ({ code: entry.code, label: entry.name, isActive: false })),
];

const { t } = getUiTranslations(Astro);

let entries = [];
let loadError = "";
try {
	entries = await listTranslationEntriesByLocale(getDb(Astro.locals), requestedLocale);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.translationRequestFailed");
}

const entryCount = entries.length;
const headingTitle = `${language.name} ${t("labels.translations") ?? "Translations"}`;
const helpText = t("messages.manageTranslationsHelp");
const emptyText = t("messages.translationListEmpty");
const loadingText = t("messages.translationLoading");
const createSuccess = t("messages.translationCreateSuccess");
const updateSuccess = t("messages.translationUpdateSuccess");
const deleteSuccess = t("messages.translationDeleteSuccess");
const actionError = t("messages.translationRequestFailed");
const tableColumns = 4;
const addButtonLabel = t("actions.addTranslation");
const saveButtonLabel = t("actions.saveChanges", "Save changes");
const cancelEditLabel = t("actions.cancel", "Cancel");
const keyLabel = t("labels.translationKey");
const valueLabel = t("labels.translationValue");
const updatedLabel = t("labels.updated");
const translationTabsLabel = t("labels.languages", "Languages");
const translationHelpText = t(
	"messages.manageTranslationsHelp",
	"Edit one translation key across all enabled languages in a single shared form.",
);
---

<AdminLayout
	title={headingTitle}
	description={helpText}
	session={session}
	pageTitle={headingTitle}
	pageDescription={helpText}
>
	<div slot="actions" class="admin-page-actions">
		<a class="btn btn-outline-secondary" href="/admin/languages">{t("actions.back")}</a>
	</div>

	<div class="admin-content-stack">
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}
		<div class="admin-surface-header">
			<div>
				<h1 class="h3 mb-1">{headingTitle}</h1>
				{helpText && <p class="admin-inline-muted mb-0">{helpText}</p>}
			</div>
			<div class="admin-inline-muted small">
				{entryCount} {entryCount === 1 ? t("labels.translationEntry") : t("labels.translationEntries")}
			</div>
		</div>

		<div class="admin-form-surface">
			<div class="mb-3" data-translation-notice aria-live="polite"></div>
			<div class="table-responsive admin-table-surface">
				<table
					class="table table-sm table-hover align-middle mb-0 w-100"
					data-translation-table
					data-locale={language.code}
					data-api-base={`/api/admin/languages/${language.code}/translations`}
					data-text-empty={emptyText}
					data-text-loading={loadingText}
					data-message-create-success={createSuccess}
					data-message-update-success={updateSuccess}
					data-message-delete-success={deleteSuccess}
					data-message-error={actionError}
				>
					<thead>
						<tr>
							<th scope="col">{t("labels.translationKey")}</th>
							<th scope="col">{t("labels.translationValue")}</th>
							<th scope="col">{updatedLabel}</th>
							<th scope="col">{t("actions.edit")}/{t("actions.delete")}</th>
						</tr>
					</thead>
					<tbody>
						{
							entries.length === 0 ? (
								<tr>
									<td colspan={tableColumns} class="text-center text-muted py-4 small">
										{emptyText}
									</td>
								</tr>
							) : (
								entries.map((entry) => (
									<tr>
										<td><code>{entry.translationKey}</code></td>
										<td>{entry.translatedValue}</td>
										<td>{entry.updatedAt}</td>
										<td>
											<div class="d-flex flex-wrap gap-2">
												<button type="button" class="btn btn-outline-primary btn-sm" data-action="edit" data-key={entry.translationKey}>
													{t("actions.edit")}
												</button>
												<button type="button" class="btn btn-outline-danger btn-sm" data-action="delete" data-key={entry.translationKey}>
													{t("actions.delete")}
												</button>
											</div>
										</td>
									</tr>
								))
							)
						}
					</tbody>
				</table>
			</div>
		</div>

		<div class="admin-form-surface">
			<div class="admin-surface-header mb-3">
				<div>
					<h2 class="h5 mb-1">{t("labels.translationEntries")}</h2>
					<p class="admin-inline-muted mb-0">{translationHelpText}</p>
				</div>
			</div>
			<form
				data-translation-form
				class="row g-3"
				data-current-locale={language.code}
				data-language-tabs={JSON.stringify(editorLanguages)}
				data-text-add-button={addButtonLabel}
				data-text-save-button={saveButtonLabel}
				data-text-cancel-button={cancelEditLabel}
				data-text-tablist={translationTabsLabel}
			>
				<div class="col-12 col-lg-4">
					<label class="form-label" for="translation-key">{keyLabel}</label>
					<input class="form-control" id="translation-key" name="key" required />
				</div>
				<div class="col-12">
					<div class="admin-card-surface border rounded-3 p-3">
						<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
							<strong class="small text-uppercase text-muted">{translationTabsLabel}</strong>
							<span class="small text-muted">{valueLabel}</span>
						</div>
						<ul class="nav nav-tabs flex-wrap gap-1" role="tablist" data-translation-tablist>
							{
								editorLanguages.map((entry, index) => (
									<li class="nav-item" role="presentation">
										<button
											type="button"
											class:list={["nav-link", index === 0 && "active"]}
											data-translation-tab={entry.code}
											aria-selected={index === 0 ? "true" : "false"}
										>
											{entry.label}
										</button>
									</li>
								))
							}
						</ul>
						<div class="border border-top-0 rounded-bottom p-3" data-translation-panels>
							{
								editorLanguages.map((entry, index) => (
									<section
										class:list={["translation-pane", index === 0 ? "" : "d-none"]}
										data-translation-panel={entry.code}
									>
										<label class="form-label" for={`translation-value-${entry.code}`}>{entry.label}</label>
										<textarea
											class="form-control"
											id={`translation-value-${entry.code}`}
											name={`value-${entry.code}`}
											rows="4"
											placeholder={`${entry.label} ${valueLabel.toLowerCase()}`}
										></textarea>
									</section>
								))
							}
						</div>
					</div>
				</div>
				<div class="col-12 d-flex flex-wrap gap-2">
					<button type="submit" class="btn btn-primary" data-translation-submit>
						{addButtonLabel}
					</button>
					<button type="button" class="btn btn-outline-secondary" data-translation-cancel hidden>
						{cancelEditLabel}
					</button>
				</div>
			</form>
		</div>
	</div>

	<script type="module" src={translationManagerScript} client:load></script>
</AdminLayout>
