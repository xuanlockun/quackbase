---
export const prerender = false;

import RoleForm from "../../../components/admin/RoleForm.astro";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listPermissions } from "../../../lib/db/permissions";
import { getDb } from "../../../lib/blog";
import { getUiTranslations } from "../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const permissions = await listPermissions(getDb(Astro.locals));
const hasError = Astro.url.searchParams.get("error");
const { t } = getUiTranslations(Astro);
---

<AdminLayout
	title={t("actions.createRole")}
	description={t("messages.saveCreateRole")}
	session={session}
	pageTitle={t("actions.createRole")}
	pageDescription={t("messages.createRoleDescription")}
>
	<div class="admin-content-stack">
		<RoleForm
			mode="create"
			action="/api/admin/roles"
			permissions={permissions}
			canSubmit={true}
			loadError={hasError ? t("messages.roleRequestFailed") : ""}
		/>
	</div>
</AdminLayout>
