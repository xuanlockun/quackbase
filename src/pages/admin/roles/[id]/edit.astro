---
export const prerender = false;

import RoleForm from "../../../../components/admin/RoleForm.astro";
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import { listPermissions } from "../../../../lib/db/permissions";
import { getRoleById } from "../../../../lib/db/roles";
import { getDb } from "../../../../lib/blog";
import { getUiTranslations, localizeAdminHref } from "../../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { id } = Astro.params;
const db = getDb(Astro.locals);
const { t, language } = getUiTranslations(Astro);

let role = null;
let loadError = "";
let notFound = false;

try {
	const roleId = Number(id);
	if (!Number.isInteger(roleId) || roleId <= 0) {
		notFound = true;
	} else {
		role = await getRoleById(db, roleId);
		notFound = !role;
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.roleRequestFailed");
}

const permissions = await listPermissions(db);

if (Astro.url.searchParams.get("error")) {
	loadError = t("messages.roleRequestFailed");
}
---

<AdminLayout
	title={t("actions.edit")}
	description={t("messages.saveEditRole")}
	session={session}
	pageTitle={t("actions.edit")}
	pageDescription={t("messages.editRoleDescription")}
>
	<div class="admin-content-stack">
		{
			notFound ? (
				<div class="admin-empty-state">
					<h2>{t("headings.roles")}</h2>
					<p class="admin-muted">{t("messages.roleRequestFailed")}</p>
					<p>
						<a class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" href={localizeAdminHref("/admin/roles", language)}>
							<span aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 6l-6 6 6 6" />
									<path d="M20 12H8" />
								</svg>
							</span>
							{t("messages.backToRoles")}
						</a>
					</p>
				</div>
			) : (
				<RoleForm
					mode="edit"
					action={`/api/admin/roles/${id}`}
					role={role}
					permissions={permissions}
					canSubmit={true}
					loadError={loadError}
				/>
			)
		}
	</div>
</AdminLayout>
