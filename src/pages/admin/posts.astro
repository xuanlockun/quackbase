---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import FeedbackModal from "../../components/admin/FeedbackModal.astro";
import FilterBar from "../../components/admin/FilterBar.astro";
import CreateAction from "../../components/admin/CreateAction.astro";
import PostTable from "../../components/admin/PostTable.astro";
import { getDb, listAllPosts, toAdminPostSummary } from "../../lib/blog";
import { getLanguageCatalog, getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("posts.create");
const canUpdate = session.isSuperadmin || session.permissions.includes("posts.update");
const canDelete = session.isSuperadmin || session.permissions.includes("posts.delete");
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const search = (Astro.url.searchParams.get("q") ?? "").trim();
const statusParam = (Astro.url.searchParams.get("status") ?? "all").trim();
const status = ["all", "published", "draft"].includes(statusParam) ? statusParam : "all";

let posts = [];
let loadError = "";

try {
	posts = (await listAllPosts(getDb(Astro.locals), language, catalog)).map((post) =>
		toAdminPostSummary(post, language, catalog),
	);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadPosts");
}

const filteredPosts = posts.filter((post) => {
	const searchValue = search.toLowerCase();
	const matchesSearch =
		searchValue === "" ||
		[post.title, post.description, post.slug]
			.join(" ")
			.toLowerCase()
			.includes(searchValue);
	const matchesStatus = status === "all" || post.status === status;
	return matchesSearch && matchesStatus;
});

const hasActiveFilters = Boolean(search || status !== "all");
const postFeedback = [
	["saved", { title: "Post saved", message: t("messages.postSaved"), tone: "success" }],
	["deleted", { title: "Post deleted", message: t("messages.postDeleted"), tone: "success" }],
	["error", { title: "Action failed", message: t("messages.requestFailed"), tone: "error" }],
] as const;
---

<AdminLayout
	title={t("headings.posts")}
	description={t("messages.manageBlogPosts")}
	session={session}
	pageTitle={t("headings.posts")}
	pageDescription={t("messages.managePublishedArticles")}
>
	<div slot="actions" class="admin-page-actions">
		{canCreate && <CreateAction href="/admin/posts/new" label={t("actions.createPost")} />}
	</div>

	<FeedbackModal id="posts-feedback-modal" title="Status update" closeLabel={t("actions.close", "Close")} />
	<div class="admin-content-stack">
		<FilterBar
			title="Post Filters"
			description="Refine the current list using one or more filters."
			searchName="q"
			searchValue={search}
			searchPlaceholder="Search posts"
			resetHref={hasActiveFilters ? "/admin/posts" : ""}
			submitLabel="Apply filters"
			selects={[
				{
					name: "status",
					label: "Status",
					value: status,
					options: [
						{ value: "all", label: "All statuses" },
						{ value: "published", label: t("status.published") },
						{ value: "draft", label: t("status.draft") },
					],
				},
			]}
		/>
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}
		{hasActiveFilters && (
			<p class="text-body-secondary small mb-0">
				Showing {filteredPosts.length} of {posts.length} posts.
			</p>
		)}

		<PostTable
			posts={filteredPosts}
			canUpdate={canUpdate}
			canDelete={canDelete}
			emptyTitle={hasActiveFilters ? "No posts match your filters" : undefined}
			emptyDescription={hasActiveFilters ? "Try clearing the filters or broadening the search." : undefined}
		/>
	</div>
</AdminLayout>

<script type="module" define:vars={{ postFeedback }}>
	const showFeedbackModal = window.showAdminFeedbackModal;
	const search = new URLSearchParams(window.location.search);

	for (const [key, entry] of postFeedback) {
			if (search.has(key)) {
				if (typeof showFeedbackModal === "function") {
					showFeedbackModal({ title: entry.title, message: entry.message, tone: entry.tone });
				}
			window.history.replaceState({}, "", window.location.pathname + window.location.hash);
			break;
		}
	}
</script>
