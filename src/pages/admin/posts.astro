---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import PostTable from "../../components/admin/PostTable.astro";
import { getDb, listAllPosts, toAdminPostSummary } from "../../lib/blog";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("posts.create");
const canUpdate = session.isSuperadmin || session.permissions.includes("posts.update");
const canDelete = session.isSuperadmin || session.permissions.includes("posts.delete");

let posts = [];
let loadError = "";

try {
	posts = (await listAllPosts(getDb(Astro.locals))).map(toAdminPostSummary);
} catch (error) {
	loadError = error instanceof Error ? error.message : "Failed to load posts.";
}
---

<AdminLayout
	title="Posts"
	description="Manage blog posts."
	session={session}
	pageTitle="Posts"
	pageDescription="Manage published articles and drafts from a focused table view."
>
	<div slot="actions" class="admin-page-actions">
		{canCreate && <a class="admin-primary-button" href="/admin/posts/new">Create Post</a>}
		<a class="admin-ghost-button" href="/en/blog">View blog</a>
	</div>

	<div class="admin-content-stack">
		{Astro.url.searchParams.get("saved") && <p class="admin-notice">Post saved.</p>}
		{Astro.url.searchParams.get("deleted") && <p class="admin-notice">Post deleted.</p>}
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">The request failed.</p>}
		{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

		<PostTable posts={posts} canUpdate={canUpdate} canDelete={canDelete} />
	</div>
</AdminLayout>
