---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import PostTable from "../../components/admin/PostTable.astro";
import { getDb, listAllPosts, toAdminPostSummary } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("posts.create");
const canUpdate = session.isSuperadmin || session.permissions.includes("posts.update");
const canDelete = session.isSuperadmin || session.permissions.includes("posts.delete");
const { t, language } = getUiTranslations(Astro);

let posts = [];
let loadError = "";

try {
	posts = (await listAllPosts(getDb(Astro.locals))).map(toAdminPostSummary);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadPosts");
}
---

<AdminLayout
	title={t("headings.posts")}
	description={t("messages.manageBlogPosts")}
	session={session}
	pageTitle={t("headings.posts")}
	pageDescription={t("messages.managePublishedArticles")}
>
	<div slot="actions" class="admin-page-actions">
		{canCreate && <a class="admin-primary-button" href="/admin/posts/new">{t("actions.createPost")}</a>}
		<a class="admin-ghost-button" href={`/${language}/blog/`}>{t("actions.viewBlog")}</a>
	</div>

	<div class="admin-content-stack">
		{Astro.url.searchParams.get("saved") && <p class="admin-notice">{t("messages.postSaved")}</p>}
		{Astro.url.searchParams.get("deleted") && <p class="admin-notice">{t("messages.postDeleted")}</p>}
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">{t("messages.requestFailed")}</p>}
		{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

		<PostTable posts={posts} canUpdate={canUpdate} canDelete={canDelete} />
	</div>
</AdminLayout>
