---
export const prerender = false;

import RoleTable from "../../components/admin/RoleTable.astro";
import CreateAction from "../../components/admin/CreateAction.astro";
import FeedbackModal from "../../components/admin/FeedbackModal.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listRolesWithPermissions } from "../../lib/db/roles";
import { getDb } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const roles = await listRolesWithPermissions(getDb(Astro.locals));
const { t } = getUiTranslations(Astro);
const roleFeedback = [
	["created", { title: "Role created", message: t("messages.roleCreated") }],
	["saved", { title: "Role saved", message: t("messages.roleSaved") }],
	["deleted", { title: "Role deleted", message: t("messages.roleDeleted") }],
	["error", { title: "Action failed", message: t("messages.roleRequestFailed") }],
] as const;
---

<AdminLayout
	title={t("headings.roles")}
	description={t("messages.manageRoles")}
	session={session}
	pageTitle={t("headings.roles")}
	pageDescription={t("messages.manageRoleBundles")}
>
	<div slot="actions" class="admin-page-actions">
		<CreateAction href="/admin/roles/new" label={t("actions.createRole")} />
	</div>

	<FeedbackModal id="roles-feedback-modal" title="Status update" closeLabel={t("actions.close", "Close")} />
	<div class="admin-content-stack">
		<RoleTable roles={roles} />
	</div>
</AdminLayout>

<script type="module" define:vars={{ roleFeedback }}>
	const showFeedbackModal = window.showAdminFeedbackModal;
	const search = new URLSearchParams(window.location.search);

	for (const [key, entry] of roleFeedback) {
		if (search.has(key)) {
			if (typeof showFeedbackModal === "function") {
				showFeedbackModal({ title: entry.title, message: entry.message });
			}
			window.history.replaceState({}, "", window.location.pathname + window.location.hash);
			break;
		}
	}
</script>
