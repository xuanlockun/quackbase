---
export const prerender = false;

import RoleTable from "../../components/admin/RoleTable.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listRolesWithPermissions } from "../../lib/db/roles";
import { getDb } from "../../lib/blog";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const roles = await listRolesWithPermissions(getDb(Astro.locals));
---

<AdminLayout
	title="Roles"
	description="Manage RBAC roles and permission bundles."
	session={session}
	pageTitle="Roles"
	pageDescription="Manage reusable role bundles from a dedicated list with route-based actions."
>
	<div slot="actions" class="admin-page-actions">
		<a class="admin-primary-button" href="/admin/roles/new">Create Role</a>
	</div>

	<div class="admin-content-stack">
		{Astro.url.searchParams.get("created") && <p class="admin-notice">Role created.</p>}
		{Astro.url.searchParams.get("saved") && <p class="admin-notice">Role saved.</p>}
		{Astro.url.searchParams.get("deleted") && <p class="admin-notice">Role deleted.</p>}
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">The role request failed.</p>}
		<RoleTable roles={roles} />
	</div>
</AdminLayout>
