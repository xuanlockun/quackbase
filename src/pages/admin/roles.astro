---
export const prerender = false;

import AdminNav from "../../components/AdminNav.astro";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import RoleEditor from "../../components/admin/RoleEditor.astro";
import { SITE_TITLE } from "../../consts";
import { listPermissions } from "../../lib/db/permissions";
import { listRolesWithPermissions } from "../../lib/db/roles";
import { getDb } from "../../lib/blog";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const db = getDb(Astro.locals);
const [roles, permissions] = await Promise.all([listRolesWithPermissions(db), listPermissions(db)]);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Roles | ${SITE_TITLE}`} description="Manage RBAC roles and permission bundles." />
		<style>
			.cms-shell { width: min(1280px, calc(100% - 2rem)); max-width: none; display: grid; grid-template-columns: 280px minmax(0, 1fr); gap: 1.5rem; }
			.panel { background: white; border-radius: 22px; box-shadow: 0 18px 40px rgba(var(--gray), 0.12); padding: 1.35rem; border: 1px solid rgba(var(--gray-light), 0.8); }
			.muted { color: rgb(var(--gray)); }
			@media (max-width: 960px) { .cms-shell { grid-template-columns: 1fr; } }
		</style>
	</head>
	<body>
		<Header />
		<main class="cms-shell">
			<aside class="panel">
				<AdminNav session={session} />
			</aside>
			<section>
				<h1>Roles</h1>
				<p class="muted">Create reusable role bundles and tune their permission sets without redeploying the app.</p>
				<RoleEditor roles={roles} permissions={permissions} />
			</section>
		</main>
		<Footer />
	</body>
</html>
