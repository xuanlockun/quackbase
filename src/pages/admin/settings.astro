---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { SITE_TITLE } from "../../consts";
import { getDb, getSiteConfig } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";
import { getLatestAdminSecretRecordByType, listAdminSecrets, type AdminSecretRecord } from "../../lib/secrets";
import FeedbackModal from "../../components/admin/FeedbackModal.astro";
import SecretsManager from "../../components/admin/SecretsManager.astro";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);

let loadError = "";
let siteConfig = {
	siteTitle: SITE_TITLE,
	faviconUrl: "/favicon.svg",
	logoUrl: "",
	themeKey: "classic",
	mediaStorageSettings: {
		s3Endpoint: "",
		s3Bucket: "",
		s3PublicBaseUrl: "",
		s3AccessKeyId: "",
		s3SecretAccessKey: "",
		s3Region: "auto",
		s3ForcePathStyle: true,
	},
	smtpSettings: {
		host: "",
		port: 587,
		username: "",
		password: "",
		encryption: "tls",
		fromEmail: "",
		fromName: "",
	},
	captchaEnabled: false,
	captchaSiteKey: "",
	captchaSecretKey: "",
};
let secrets: AdminSecretRecord[] = [];
let secretsLoadError = "";

const db = getDb(Astro.locals);

try {
	siteConfig = await getSiteConfig(db);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadSiteSettings");
}

try {
	secrets = await listAdminSecrets(db, { secretTypes: ["cloudflare_api_access_token", "resend_api_key"] });
} catch (error) {
	secretsLoadError = error instanceof Error ? error.message : t("messages.failedToLoadSecrets");
}

let resendApiKeyStored = false;
try {
	resendApiKeyStored = Boolean(await getLatestAdminSecretRecordByType(db, "resend_api_key"));
} catch {
	resendApiKeyStored = false;
}

const formDisabled = Boolean(loadError);
const mediaStorageConnected =
	Boolean(siteConfig.mediaStorageSettings.s3Endpoint.trim()) && Boolean(siteConfig.mediaStorageSettings.s3Bucket.trim());
const mediaStorageStatusPrimary = mediaStorageConnected
	? t("messages.storageConnected", "Storage connected")
	: t("messages.storageNotConfigured", "Storage not configured");
const mediaStorageStatusSecondary = mediaStorageConnected
	? t("messages.readyToUpload", "Ready to upload")
	: t("messages.configureStorage", "Configure storage");
const emailConfigured = Boolean(siteConfig.smtpSettings.fromEmail.trim()) && Boolean(siteConfig.smtpSettings.fromName.trim());
const emailStatusPrimary = emailConfigured
	? t("messages.emailServiceReady", "Email service ready")
	: t("messages.emailServiceNotConfigured", "Email service not configured");
const emailStatusSecondary = resendApiKeyStored ? t("messages.apiKeyStored", "API key stored") : t("messages.apiKeyNotStored", "API key not stored");
const settingsFeedback = [
	["siteError", { title: t("messages.settingsFailedTitle", "Settings failed"), message: t("messages.siteSettingsFailed", "Site settings could not be saved."), tone: "error" }],
	["siteSaved", { title: t("messages.settingsSavedTitle", "Settings saved"), message: t("messages.siteSettingsSaved", "Site settings were saved successfully."), tone: "success" }],
	["secretError", { title: t("messages.secretFailedTitle", "Secret failed"), message: t("messages.secretRequestFailed", "The secret request failed."), tone: "error" }],
	["secretDeleted", { title: t("messages.secretDeletedTitle", "Secret deleted"), message: t("messages.secretDeleted", "The secret was removed."), tone: "success" }],
	["secretSaved", { title: t("messages.secretSavedTitle", "Secret saved"), message: t("messages.secretSaved", "The secret was stored successfully."), tone: "success" }],
	["mediaError", { title: t("messages.connectionFailedTitle", "Connection failed"), message: t("messages.mediaSettingsSaveFailed", "Media storage settings could not be saved."), tone: "error" }],
	["mediaSaved", { title: t("messages.settingsSavedTitle", "Settings saved"), message: t("messages.mediaSettingsSaved", "Media storage settings were saved successfully."), tone: "success" }],
	["smtpWarning", { title: t("messages.emailSavedWarningTitle", "Email saved with warning"), message: t("messages.emailSavedWarning", "Email settings were saved, but the API key could not be stored."), tone: "warning" }],
	["smtpError", { title: t("messages.emailFailedTitle", "Email failed"), message: t("messages.emailSettingsSaveFailed", "Email settings could not be saved."), tone: "error" }],
	["smtpSaved", { title: t("messages.emailSavedTitle", "Email saved"), message: t("messages.emailSettingsSaved", "Email settings were saved successfully."), tone: "success" }],
	["captchaError", { title: t("messages.captchaFailedTitle", "Captcha failed"), message: t("messages.captchaSettingsSaveFailed", "Captcha settings could not be saved."), tone: "error" }],
	["captchaSaved", { title: t("messages.captchaSavedTitle", "Captcha saved"), message: t("messages.captchaSettingsSaved", "Captcha settings were saved successfully."), tone: "success" }],
] as const;

---

<AdminLayout
	title={t("nav.settings")}
	description={t("messages.manageSiteSettings")}
	session={session}
	pageTitle={t("nav.settings")}
	pageDescription={t("messages.settingsHub")}
>
	<FeedbackModal id="admin-feedback-modal" title={t("messages.statusUpdate", "Status update")} closeLabel={t("actions.close", "Close")} />
	<div class="admin-content-stack">
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}
		<div class="admin-form-surface settings-tabs-shell">
			<div class="settings-tabs-intro px-3 px-lg-4 pt-3 pt-lg-4">
				<p class="admin-page-eyebrow mb-1">{t("nav.settings")}</p>
				<h2 class="h5 mb-1">{t("messages.settingsFoundationHeading", "Site configuration")}</h2>
				<p class="admin-inline-muted mb-0">{t("messages.settingsFoundationHelp", "Update site identity, storage, email, captcha, and secrets in place without leaving this screen.")}</p>
			</div>
			<ul class="nav nav-tabs flex-wrap gap-1 border-bottom px-3 pt-3" role="tablist" aria-label={t("labels.adminSettingsSections", "Admin settings sections")} data-settings-tablist>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link active"
						role="tab"
						aria-selected="true"
						data-settings-tab="site"
					>
						{t("nav.site", "Site")}
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link"
						role="tab"
						aria-selected="false"
						data-settings-tab="media"
					>
						{t("nav.media", "Media")}
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link"
						role="tab"
						aria-selected="false"
						data-settings-tab="smtp"
					>
						{t("labels.email", "Email")}
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link"
						role="tab"
						aria-selected="false"
						data-settings-tab="captcha"
					>
						{t("labels.captcha", "Captcha")}
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link"
						role="tab"
						aria-selected="false"
						data-settings-tab="secrets"
					>
						{t("headings.secrets", "Secrets")}
					</button>
				</li>
			</ul>
			<div class="p-3 p-lg-4">
				<section role="tabpanel" data-settings-panel="site">
					<form method="post" action="/api/admin/site" class="admin-form-shell admin-compact-form mb-0">
						<input type="hidden" name="successRedirectTo" value="/admin/settings?siteSaved=1" />
						<input type="hidden" name="errorRedirectTo" value="/admin/settings?siteError=1" />
						<input type="hidden" name="themeKey" value={siteConfig.themeKey} />
						<div class="admin-grid-two">
							<label><span>{t("labels.siteTitle")}</span><input class="form-control" name="siteTitle" value={siteConfig.siteTitle} placeholder={SITE_TITLE} disabled={formDisabled} /></label>
							<label><span>{t("labels.faviconUrl")}</span><input class="form-control" name="faviconUrl" value={siteConfig.faviconUrl} placeholder="/favicon.svg" disabled={formDisabled} /></label>
							<label><span>{t("labels.logoUrl")}</span><input class="form-control" name="logoUrl" value={siteConfig.logoUrl} placeholder="/logo.svg" disabled={formDisabled} /></label>
						</div>
						<div class="admin-form-section">
							<p class="admin-muted">{t("messages.siteSettingsHelp")}</p>
							<button class="btn btn-primary" type="submit" disabled={formDisabled}>{t("actions.saveChanges")}</button>
						</div>
					</form>
				</section>

				<section class="d-none" role="tabpanel" data-settings-panel="media">
					<form method="post" action="/api/admin/media/settings" class="admin-form-shell admin-compact-form mb-0" data-media-settings-form>
						<div class="admin-form-surface media-settings-shell">
							<div class="admin-surface-header media-settings-header">
								<div>
									<h2 class="h5 mb-1">{t("messages.mediaStorage", "Media storage")}</h2>
									<p class="admin-inline-muted mb-0">{t("messages.mediaStorageHelp", "Keep storage simple for everyday admin work.")}</p>
								</div>
								<div class="media-status-badges" aria-label={t("labels.mediaStorageStatus", "Media storage status")}>
									<span class="media-status-badge">{mediaStorageStatusPrimary}</span>
									<span class="media-status-badge">{mediaStorageStatusSecondary}</span>
								</div>
							</div>
							<div class="media-settings-actions">
								<button class="btn btn-outline-secondary" type="button" data-media-test-button disabled={formDisabled}>
									{t("actions.testConnection", "Test connection")}
								</button>
								<button class="btn btn-primary" type="submit" disabled={formDisabled}>
									{t("actions.saveMediaSettings", "Save media settings")}
								</button>
							</div>
							<div class="media-settings-advanced">
								<div class="admin-grid-two media-advanced-grid">
									<label>
										<span>{t("labels.s3UploadEndpoint", "S3 upload endpoint")}</span>
										<input
											class="form-control"
											name="s3Endpoint"
											value={siteConfig.mediaStorageSettings.s3Endpoint}
											placeholder="https://<account>.r2.cloudflarestorage.com"
											disabled={formDisabled}
										/>
									</label>
									<label>
										<span>{t("labels.bucketName", "Bucket name")}</span>
										<input
											class="form-control"
											name="s3Bucket"
											value={siteConfig.mediaStorageSettings.s3Bucket}
											placeholder="media"
											disabled={formDisabled}
										/>
									</label>
									<label>
										<span>{t("labels.publicBaseUrl", "Public base URL")}</span>
										<input
											class="form-control"
											name="s3PublicBaseUrl"
											value={siteConfig.mediaStorageSettings.s3PublicBaseUrl}
											placeholder="https://pub-...r2.dev or your CDN"
											disabled={formDisabled}
										/>
									</label>
									<label>
										<span>{t("labels.s3Region", "S3 region")}</span>
										<input
											class="form-control"
											name="s3Region"
											value={siteConfig.mediaStorageSettings.s3Region}
											placeholder="auto or us-east-1"
											disabled={formDisabled}
										/>
									</label>
									<label class="admin-check-row media-advanced-toggle">
										<input
											class="form-check-input"
											type="checkbox"
											name="s3ForcePathStyle"
											value="1"
											checked={siteConfig.mediaStorageSettings.s3ForcePathStyle}
											disabled={formDisabled}
										/>
									<span>{t("labels.usePathStyleUrls", "Use path-style URLs")}</span>
									</label>
									<div class="media-secret-field">
										<label for="s3AccessKeyId">
										<span>{t("labels.s3AccessKeyId", "S3 access key ID")}</span>
											<div class="input-group">
												<input
													id="s3AccessKeyId"
													class="form-control"
													type="password"
													name="s3AccessKeyId"
													value={siteConfig.mediaStorageSettings.s3AccessKeyId}
													autocomplete="off"
													placeholder={t("messages.accessKeyIdPlaceholder", "Enter a new access key ID")}
													disabled={formDisabled}
												/>
												<button
													class="btn btn-outline-secondary"
													type="button"
													data-media-secret-toggle
													data-media-secret-target="#s3AccessKeyId"
													aria-label={t("actions.showAccessKeyId", "Show access key ID")}
													title={t("actions.showAccessKeyId", "Show access key ID")}
													disabled={formDisabled}
												>
													<span aria-hidden="true">
														<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
															<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
															<circle cx="12" cy="12" r="3" />
														</svg>
													</span>
												</button>
											</div>
										</label>
									</div>
									<div class="media-secret-field media-secret-field-wide">
										<label for="s3SecretAccessKey">
										<span>{t("labels.s3SecretAccessKey", "S3 secret access key")}</span>
											<div class="input-group">
												<input
													id="s3SecretAccessKey"
													class="form-control"
													type="password"
													name="s3SecretAccessKey"
													value={siteConfig.mediaStorageSettings.s3SecretAccessKey}
													autocomplete="off"
													placeholder={t("messages.secretAccessKeyPlaceholder", "Enter a new secret access key")}
													disabled={formDisabled}
												/>
												<button
													class="btn btn-outline-secondary"
													type="button"
													data-media-secret-toggle
													data-media-secret-target="#s3SecretAccessKey"
													aria-label={t("actions.showSecretAccessKey", "Show secret access key")}
													title={t("actions.showSecretAccessKey", "Show secret access key")}
													disabled={formDisabled}
												>
													<span aria-hidden="true">
														<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
															<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
															<circle cx="12" cy="12" r="3" />
														</svg>
													</span>
												</button>
											</div>
										</label>
									</div>
								</div>
								<p class="admin-muted mb-0">{t("messages.mediaStorageFieldHelp", "Leave a credential field empty to keep the saved value. Use `auto` for Cloudflare R2.")}</p>
							</div>
						</div>
					</form>
				</section>

				<section class="d-none" role="tabpanel" data-settings-panel="smtp">
					<form method="post" action="/api/admin/smtp" class="admin-form-shell admin-compact-form mb-0" data-smtp-settings-form>
						<div class="admin-form-surface smtp-settings-shell">
							<div class="admin-surface-header smtp-settings-header">
								<div>
									<h2 class="h5 mb-1">{t("messages.emailProviderName", "Resend")}</h2>
									<p class="admin-inline-muted mb-0">{t("messages.emailSettingsHelp", "Configure the sender identity and API key used for contact form notifications.")}</p>
								</div>
								<div class="smtp-status-badges" aria-label={t("labels.emailServiceStatus", "Resend email service")}>
									<span class="media-status-badge">{emailStatusPrimary}</span>
									<span class="media-status-badge">{emailStatusSecondary}</span>
								</div>
							</div>
							<div class="smtp-settings-actions">
								<button class="btn btn-outline-secondary" type="button" data-smtp-test-button disabled={formDisabled}>
									{t("actions.testEmail", "Test email")}
								</button>
								<button class="btn btn-primary" type="submit" disabled={formDisabled}>
									{t("actions.saveEmailSettings", "Save Resend settings")}
								</button>
							</div>
							<div class="smtp-settings-grid admin-grid-two">
								<label class="grid-span-2">
									<span>{t("labels.senderEmail", "Sender email")}</span>
									<input class="form-control" name="smtpFromEmail" type="email" value={siteConfig.smtpSettings.fromEmail} placeholder="noreply@example.com" disabled={formDisabled} />
								</label>
								<label class="grid-span-2">
									<span>{t("labels.senderName", "Sender name")}</span>
									<input class="form-control" name="smtpFromName" value={siteConfig.smtpSettings.fromName} placeholder={SITE_TITLE} disabled={formDisabled} />
								</label>
								<label class="grid-span-2">
									<span>{t("labels.resendApiKey", "Resend API key")}</span>
									<input
										class="form-control"
										name="resendApiKey"
										type="password"
										autocomplete="off"
										placeholder={resendApiKeyStored ? t("messages.keepSavedApiKey", "Leave blank to keep the saved key") : "re_..."}
										disabled={formDisabled}
									/>
								</label>
							</div>
							<p class="admin-muted mb-0">{t("messages.emailApiKeyStoredHelp", "The API key is stored encrypted in the admin secrets table. Leave it blank to keep the existing key.")}</p>
						</div>
					</form>
				</section>

				<section class="d-none" role="tabpanel" data-settings-panel="captcha">
					<form method="post" action="/api/admin/captcha" class="admin-form-shell admin-compact-form mb-0">
						<div class="admin-form-surface">
							<div class="admin-surface-header mb-3">
								<div>
								<h2 class="h5 mb-0">{t("labels.captcha", "Captcha")}</h2>
								</div>
							</div>
							<div class="admin-form-grid">
								<label class="admin-checkbox-field" style="grid-column: 1 / -1;">
									<span>{t("labels.captchaUsage", "Captcha usage")}</span>
									<div class="form-check form-switch">
										<input
											class="form-check-input"
											type="checkbox"
											name="captchaEnabled"
											value="1"
											checked={siteConfig.captchaEnabled}
											disabled={formDisabled}
										/>
										<label class="form-check-label">
											{t("messages.captchaToggleHelp", "Enable captcha verification for contact forms that opt in.")}
										</label>
									</div>
								</label>
								<label>
									<span>{t("labels.captchaSiteKey", "Captcha site key")}</span>
									<input
										class="form-control"
										name="captchaSiteKey"
										value={siteConfig.captchaSiteKey}
										placeholder={t("messages.captchaSiteKeyPlaceholder", "Turnstile site key")}
										disabled={formDisabled}
									/>
								</label>
								<div class="media-secret-field" style="grid-column: 1 / -1;">
									<label for="captchaSecretKey">
												<span>{t("labels.captchaSecretKey", "Captcha secret key")}</span>
										<div class="input-group">
											<input
												id="captchaSecretKey"
												class="form-control"
												type="password"
												name="captchaSecretKey"
												value={siteConfig.captchaSecretKey}
												autocomplete="off"
													placeholder={t("messages.captchaSecretKeyPlaceholder", "Turnstile secret key")}
												disabled={formDisabled}
											/>
											<button
												class="btn btn-outline-secondary"
												type="button"
												data-media-secret-toggle
												data-media-secret-target="#captchaSecretKey"
												aria-label={t("actions.showCaptchaSecretKey", "Show captcha secret key")}
												title={t("actions.showCaptchaSecretKey", "Show captcha secret key")}
												disabled={formDisabled}
											>
												<span aria-hidden="true">
													<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
														<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
														<circle cx="12" cy="12" r="3" />
													</svg>
												</span>
											</button>
										</div>
									</label>
								</div>
							</div>
							<div class="admin-form-section">
								<p class="admin-muted mb-2">{t("messages.captchaSettingsHelp", "Configure the captcha keys here, then opt individual contact forms in where needed.")}</p>
								<div class="d-flex flex-wrap gap-2 align-items-center">
									<button class="btn btn-primary" type="submit" disabled={formDisabled}>
										{t("actions.saveCaptchaSettings", "Save captcha settings")}
									</button>
								</div>
							</div>
						</div>
					</form>
				</section>

				<section class="d-none" role="tabpanel" data-settings-panel="secrets">
					<SecretsManager secrets={secrets} canManage={session.isSuperadmin || session.permissions.includes("site.manage")} loadError={secretsLoadError} />
				</section>
			</div>
		</div>
	</div>
</AdminLayout>

<script type="module" define:vars={{ loadError, settingsFeedback }}>
	const tablist = document.querySelector("[data-settings-tablist]");
	const tabButtons = tablist?.querySelectorAll("[data-settings-tab]");
	const panels = document.querySelectorAll("[data-settings-panel]");
	const form = document.querySelector("[data-media-settings-form]");
	const testButton = form?.querySelector("[data-media-test-button]");
	const smtpForm = document.querySelector("[data-smtp-settings-form]");
	const smtpTestButton = smtpForm?.querySelector("[data-smtp-test-button]");
	const toggleButtons = form?.querySelectorAll("[data-media-secret-toggle]");
	const showFeedbackModal = window.showAdminFeedbackModal;
	const url = new URL(window.location.href);
	const allowedTabs = new Set(["site", "media", "smtp", "captcha", "secrets"]);

	const setActiveTab = (tabName) => {
		tabButtons?.forEach((button) => {
			if (!(button instanceof HTMLButtonElement)) {
				return;
			}

			const isActive = button.dataset.settingsTab === tabName;
			button.classList.toggle("active", isActive);
			button.setAttribute("aria-selected", isActive ? "true" : "false");
		});

		panels.forEach((panel) => {
			if (!(panel instanceof HTMLElement)) {
				return;
			}

			panel.classList.toggle("d-none", panel.dataset.settingsPanel !== tabName);
		});

		if (allowedTabs.has(tabName)) {
			url.searchParams.set("tab", tabName);
			window.history.replaceState({}, "", `${url.pathname}?${url.searchParams.toString()}${url.hash}`);
		}
	};

	tabButtons?.forEach((button) => {
		if (!(button instanceof HTMLButtonElement)) {
			return;
		}

		button.addEventListener("click", () => {
			const tabName = button.dataset.settingsTab;
			if (tabName) {
				setActiveTab(tabName);
			}
		});
	});

	const initialTab = url.searchParams.get("tab");
	setActiveTab(initialTab && allowedTabs.has(initialTab) ? initialTab : "site");

	const showModal = (title, message, detail = "", tone = "info", busy = false) => {
		if (typeof showFeedbackModal === "function") {
			showFeedbackModal({ title, message, detail, tone, busy });
		}
	};

	const showFromQuery = () => {
		const search = new URLSearchParams(window.location.search);
		for (const [key, entry] of settingsFeedback) {
			if (search.has(key)) {
				const message = search.get(key) || entry.message;
				showModal(entry.title, message, "", entry.tone);
				window.history.replaceState({}, "", window.location.pathname + window.location.hash);
				break;
			}
		}
	};

	showFromQuery();
	if (loadError) {
		showModal("Settings load failed", loadError, "", "error");
	}

	if (form instanceof HTMLFormElement && testButton instanceof HTMLButtonElement) {

		testButton.addEventListener("click", async () => {
			const payload = new FormData(form);
			payload.set("intent", "test");
			testButton.disabled = true;
			const originalLabel = testButton.textContent || "Test connection";
			testButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Testing...';
			showModal("Testing connection", "Checking the media storage connection.", "", "info", true);

			try {
				const response = await fetch(form.action, {
					method: "POST",
					credentials: "same-origin",
					headers: {
						Accept: "application/json",
						"X-Requested-With": "fetch",
					},
					body: payload,
				});

				const data = await response.json().catch(() => ({}));
				if (!response.ok || !data?.ok) {
					throw new Error(data?.error || "Media storage connection test failed.");
				}

				showModal("Connection successful", data.message || "Media storage connection succeeded.", "", "success");
			} catch (error) {
				showModal("Connection failed", error instanceof Error ? error.message : "Media storage connection test failed.", "", "error");
			} finally {
				testButton.disabled = false;
				testButton.textContent = originalLabel.trim();
			}
		});
	}

	if (smtpForm instanceof HTMLFormElement && smtpTestButton instanceof HTMLButtonElement) {
		smtpTestButton.addEventListener("click", async () => {
			const payload = new FormData(smtpForm);
			payload.set("intent", "test");
			smtpTestButton.disabled = true;
			const originalLabel = smtpTestButton.textContent || "Test email";
			smtpTestButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Testing...';
			showModal("Testing email", "Sending a test email using the current email service settings.", "", "info", true);

			try {
				const response = await fetch(smtpForm.action, {
					method: "POST",
					credentials: "same-origin",
					headers: {
						Accept: "application/json",
						"X-Requested-With": "fetch",
					},
					body: payload,
				});

				const data = await response.json().catch(() => ({}));
				if (!response.ok || !data?.ok) {
					throw new Error(data?.error || "Email test failed.");
				}

				showModal("Test email sent", data.message || "The test email was sent successfully.", "", "success");
			} catch (error) {
				showModal("Test email failed", error instanceof Error ? error.message : "Email test failed.", "", "error");
			} finally {
				smtpTestButton.disabled = false;
				smtpTestButton.textContent = originalLabel.trim();
			}
		});
	}

	toggleButtons?.forEach((button) => {
		if (!(button instanceof HTMLButtonElement)) {
			return;
		}

		button.addEventListener("click", () => {
			const targetSelector = button.dataset.mediaSecretTarget;
			if (!targetSelector) {
				return;
			}

			const target = form?.querySelector(targetSelector);
			if (!(target instanceof HTMLInputElement)) {
				return;
			}

			const willReveal = target.type === "password";
			target.type = willReveal ? "text" : "password";
			const label = willReveal ? "Hide" : "Show";
			const description = target.id === "s3SecretAccessKey" ? "secret access key" : "access key ID";
			button.setAttribute("aria-label", `${label} ${description}`);
			button.title = `${label} ${description}`;
		});
	});
</script>

