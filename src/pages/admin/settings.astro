---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { SITE_TITLE } from "../../consts";
import { getDb, getSiteConfig } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";
import { listAdminSecrets, type AdminSecretRecord } from "../../lib/secrets";
import FeedbackModal from "../../components/admin/FeedbackModal.astro";
import SecretsManager from "../../components/admin/SecretsManager.astro";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);

let loadError = "";
let siteConfig = {
	siteTitle: SITE_TITLE,
	faviconUrl: "/favicon.svg",
	logoUrl: "",
	mediaStorageSettings: {
		s3Endpoint: "",
		s3Bucket: "",
		s3PublicBaseUrl: "",
		s3AccessKeyId: "",
		s3SecretAccessKey: "",
		s3Region: "auto",
		s3ForcePathStyle: true,
	},
	captchaEnabled: false,
	captchaSiteKey: "",
	captchaSecretKey: "",
};
let secrets: AdminSecretRecord[] = [];
let secretsLoadError = "";

const db = getDb(Astro.locals);

try {
	siteConfig = await getSiteConfig(db);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadSiteSettings");
}

try {
	secrets = await listAdminSecrets(db, { secretTypes: ["cloudflare_api_access_token"] });
} catch (error) {
	secretsLoadError = error instanceof Error ? error.message : t("messages.failedToLoadSecrets");
}

const formDisabled = Boolean(loadError);
const mediaStorageConnected =
	Boolean(siteConfig.mediaStorageSettings.s3Endpoint.trim()) && Boolean(siteConfig.mediaStorageSettings.s3Bucket.trim());
const mediaStorageStatusPrimary = mediaStorageConnected ? "Storage connected" : "Storage not configured";
const mediaStorageStatusSecondary = mediaStorageConnected ? "Ready to upload" : "Configure storage";
const settingsFeedback = [
	["siteError", { title: "Settings failed", message: t("messages.siteSettingsFailed", "Site settings could not be saved."), tone: "error" }],
	["siteSaved", { title: "Settings saved", message: t("messages.siteSettingsSaved", "Site settings were saved successfully."), tone: "success" }],
	["secretError", { title: "Secret failed", message: t("messages.secretRequestFailed", "The secret request failed."), tone: "error" }],
	["secretDeleted", { title: "Secret deleted", message: t("messages.secretDeleted", "The secret was removed."), tone: "success" }],
	["secretSaved", { title: "Secret saved", message: t("messages.secretSaved", "The secret was stored successfully."), tone: "success" }],
	["mediaError", { title: "Connection failed", message: "Media storage settings could not be saved.", tone: "error" }],
	["mediaSaved", { title: "Settings saved", message: "Media storage settings were saved successfully.", tone: "success" }],
	["captchaError", { title: "Captcha failed", message: "Captcha settings could not be saved.", tone: "error" }],
	["captchaSaved", { title: "Captcha saved", message: "Captcha settings were saved successfully.", tone: "success" }],
] as const;
---

<AdminLayout
	title={t("nav.settings")}
	description={t("messages.manageSiteSettings")}
	session={session}
	pageTitle={t("nav.settings")}
	pageDescription={t("messages.settingsHub")}
>
	<FeedbackModal id="admin-feedback-modal" title={t("messages.statusUpdate", "Status update")} closeLabel={t("actions.close", "Close")} />
	<div class="admin-content-stack">
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}
		<div class="admin-form-surface settings-tabs-shell">
			<ul class="nav nav-tabs flex-wrap gap-1 border-bottom px-3 pt-3" role="tablist" aria-label="Admin settings sections" data-settings-tablist>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link active"
						role="tab"
						aria-selected="true"
						data-settings-tab="site"
					>
						Site
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link"
						role="tab"
						aria-selected="false"
						data-settings-tab="media"
					>
						Media
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link"
						role="tab"
						aria-selected="false"
						data-settings-tab="captcha"
					>
						Captcha
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button
						type="button"
						class="nav-link"
						role="tab"
						aria-selected="false"
						data-settings-tab="secrets"
					>
						Secrets
					</button>
				</li>
			</ul>
			<div class="p-3 p-lg-4">
				<section role="tabpanel" data-settings-panel="site">
					<form method="post" action="/api/admin/site" class="admin-form-shell admin-compact-form mb-0">
						<input type="hidden" name="successRedirectTo" value="/admin/settings?siteSaved=1" />
						<input type="hidden" name="errorRedirectTo" value="/admin/settings?siteError=1" />
						<div class="admin-grid-two">
							<label><span>{t("labels.siteTitle")}</span><input class="form-control" name="siteTitle" value={siteConfig.siteTitle} placeholder={SITE_TITLE} disabled={formDisabled} /></label>
							<label><span>{t("labels.faviconUrl")}</span><input class="form-control" name="faviconUrl" value={siteConfig.faviconUrl} placeholder="/favicon.svg" disabled={formDisabled} /></label>
							<label><span>{t("labels.logoUrl")}</span><input class="form-control" name="logoUrl" value={siteConfig.logoUrl} placeholder="/logo.svg" disabled={formDisabled} /></label>
						</div>
						<div class="admin-form-section">
							<p class="admin-muted">{t("messages.siteSettingsHelp")}</p>
							<button class="btn btn-primary" type="submit" disabled={formDisabled}>{t("actions.saveChanges")}</button>
						</div>
					</form>
				</section>

				<section class="d-none" role="tabpanel" data-settings-panel="media">
					<form method="post" action="/api/admin/media/settings" class="admin-form-shell admin-compact-form mb-0" data-media-settings-form>
						<div class="admin-form-surface media-settings-shell">
							<div class="admin-surface-header media-settings-header">
								<div>
									<h2 class="h5 mb-1">Media storage</h2>
									<p class="admin-inline-muted mb-0">Keep storage simple for everyday admin work.</p>
								</div>
								<div class="media-status-badges" aria-label="Media storage status">
									<span class="media-status-badge">{mediaStorageStatusPrimary}</span>
									<span class="media-status-badge">{mediaStorageStatusSecondary}</span>
								</div>
							</div>
							<div class="media-settings-actions">
								<button class="btn btn-outline-secondary" type="button" data-media-test-button disabled={formDisabled}>
									Test connection
								</button>
								<button class="btn btn-primary" type="submit" disabled={formDisabled}>
									Save media settings
								</button>
							</div>
							<div class="media-settings-advanced">
								<div class="admin-grid-two media-advanced-grid">
									<label>
										<span>S3 upload endpoint</span>
										<input
											class="form-control"
											name="s3Endpoint"
											value={siteConfig.mediaStorageSettings.s3Endpoint}
											placeholder="https://<account>.r2.cloudflarestorage.com"
											disabled={formDisabled}
										/>
									</label>
									<label>
										<span>Bucket name</span>
										<input
											class="form-control"
											name="s3Bucket"
											value={siteConfig.mediaStorageSettings.s3Bucket}
											placeholder="media"
											disabled={formDisabled}
										/>
									</label>
									<label>
										<span>Public base URL</span>
										<input
											class="form-control"
											name="s3PublicBaseUrl"
											value={siteConfig.mediaStorageSettings.s3PublicBaseUrl}
											placeholder="https://pub-...r2.dev or your CDN"
											disabled={formDisabled}
										/>
									</label>
									<label>
										<span>S3 region</span>
										<input
											class="form-control"
											name="s3Region"
											value={siteConfig.mediaStorageSettings.s3Region}
											placeholder="auto or us-east-1"
											disabled={formDisabled}
										/>
									</label>
									<label class="admin-check-row media-advanced-toggle">
										<input
											class="form-check-input"
											type="checkbox"
											name="s3ForcePathStyle"
											value="1"
											checked={siteConfig.mediaStorageSettings.s3ForcePathStyle}
											disabled={formDisabled}
										/>
										<span>Use path-style URLs</span>
									</label>
									<div class="media-secret-field">
										<label for="s3AccessKeyId">
											<span>S3 access key ID</span>
											<div class="input-group">
												<input
													id="s3AccessKeyId"
													class="form-control"
													type="password"
													name="s3AccessKeyId"
													value={siteConfig.mediaStorageSettings.s3AccessKeyId}
													autocomplete="off"
													placeholder="Enter a new access key ID"
													disabled={formDisabled}
												/>
												<button
													class="btn btn-outline-secondary"
													type="button"
													data-media-secret-toggle
													data-media-secret-target="#s3AccessKeyId"
													aria-label="Show access key ID"
													title="Show access key ID"
													disabled={formDisabled}
												>
													<span aria-hidden="true">
														<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
															<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
															<circle cx="12" cy="12" r="3" />
														</svg>
													</span>
												</button>
											</div>
										</label>
									</div>
									<div class="media-secret-field media-secret-field-wide">
										<label for="s3SecretAccessKey">
											<span>S3 secret access key</span>
											<div class="input-group">
												<input
													id="s3SecretAccessKey"
													class="form-control"
													type="password"
													name="s3SecretAccessKey"
													value={siteConfig.mediaStorageSettings.s3SecretAccessKey}
													autocomplete="off"
													placeholder="Enter a new secret access key"
													disabled={formDisabled}
												/>
												<button
													class="btn btn-outline-secondary"
													type="button"
													data-media-secret-toggle
													data-media-secret-target="#s3SecretAccessKey"
													aria-label="Show secret access key"
													title="Show secret access key"
													disabled={formDisabled}
												>
													<span aria-hidden="true">
														<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
															<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
															<circle cx="12" cy="12" r="3" />
														</svg>
													</span>
												</button>
											</div>
										</label>
									</div>
								</div>
								<p class="admin-muted mb-0">Leave a credential field empty to keep the saved value. Use `auto` for Cloudflare R2.</p>
							</div>
						</div>
					</form>
				</section>

				<section class="d-none" role="tabpanel" data-settings-panel="captcha">
					<form method="post" action="/api/admin/captcha" class="admin-form-shell admin-compact-form mb-0">
						<div class="admin-form-surface">
							<div class="admin-surface-header mb-3">
								<div>
									<h2 class="h5 mb-0">Captcha</h2>
								</div>
							</div>
							<div class="admin-form-grid">
								<label class="admin-checkbox-field" style="grid-column: 1 / -1;">
									<span>Captcha usage</span>
									<div class="form-check form-switch">
										<input
											class="form-check-input"
											type="checkbox"
											name="captchaEnabled"
											value="1"
											checked={siteConfig.captchaEnabled}
											disabled={formDisabled}
										/>
										<label class="form-check-label">
											Enable captcha verification for contact forms that opt in.
										</label>
									</div>
								</label>
								<label>
									<span>Captcha site key</span>
									<input
										class="form-control"
										name="captchaSiteKey"
										value={siteConfig.captchaSiteKey}
										placeholder="Turnstile site key"
										disabled={formDisabled}
									/>
								</label>
								<div class="media-secret-field" style="grid-column: 1 / -1;">
									<label for="captchaSecretKey">
										<span>Captcha secret key</span>
										<div class="input-group">
											<input
												id="captchaSecretKey"
												class="form-control"
												type="password"
												name="captchaSecretKey"
												value={siteConfig.captchaSecretKey}
												autocomplete="off"
												placeholder="Turnstile secret key"
												disabled={formDisabled}
											/>
											<button
												class="btn btn-outline-secondary"
												type="button"
												data-media-secret-toggle
												data-media-secret-target="#captchaSecretKey"
												aria-label="Show captcha secret key"
												title="Show captcha secret key"
												disabled={formDisabled}
											>
												<span aria-hidden="true">
													<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
														<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
														<circle cx="12" cy="12" r="3" />
													</svg>
												</span>
											</button>
										</div>
									</label>
								</div>
							</div>
							<div class="admin-form-section">
								<p class="admin-muted mb-2">Configure the captcha keys here, then opt individual contact forms in where needed.</p>
								<div class="d-flex flex-wrap gap-2 align-items-center">
									<button class="btn btn-primary" type="submit" disabled={formDisabled}>
										Save captcha settings
									</button>
								</div>
							</div>
						</div>
					</form>
				</section>

				<section class="d-none" role="tabpanel" data-settings-panel="secrets">
					<SecretsManager secrets={secrets} canManage={session.isSuperadmin || session.permissions.includes("site.manage")} loadError={secretsLoadError} />
				</section>
			</div>
		</div>
	</div>
</AdminLayout>

<script type="module" define:vars={{ loadError, settingsFeedback }}>
	const tablist = document.querySelector("[data-settings-tablist]");
	const tabButtons = tablist?.querySelectorAll("[data-settings-tab]");
	const panels = document.querySelectorAll("[data-settings-panel]");
	const form = document.querySelector("[data-media-settings-form]");
	const testButton = form?.querySelector("[data-media-test-button]");
	const toggleButtons = form?.querySelectorAll("[data-media-secret-toggle]");
	const showFeedbackModal = window.showAdminFeedbackModal;

	const setActiveTab = (tabName) => {
		tabButtons?.forEach((button) => {
			if (!(button instanceof HTMLButtonElement)) {
				return;
			}

			const isActive = button.dataset.settingsTab === tabName;
			button.classList.toggle("active", isActive);
			button.setAttribute("aria-selected", isActive ? "true" : "false");
		});

		panels.forEach((panel) => {
			if (!(panel instanceof HTMLElement)) {
				return;
			}

			panel.classList.toggle("d-none", panel.dataset.settingsPanel !== tabName);
		});
	};

	tabButtons?.forEach((button) => {
		if (!(button instanceof HTMLButtonElement)) {
			return;
		}

		button.addEventListener("click", () => {
			const tabName = button.dataset.settingsTab;
			if (tabName) {
				setActiveTab(tabName);
			}
		});
	});

	setActiveTab("site");

	const showModal = (title, message, detail = "", tone = "info", busy = false) => {
		if (typeof showFeedbackModal === "function") {
			showFeedbackModal({ title, message, detail, tone, busy });
		}
	};

	const showFromQuery = () => {
		const search = new URLSearchParams(window.location.search);
		for (const [key, entry] of settingsFeedback) {
			if (search.has(key)) {
				const message = key === "mediaError" ? search.get("mediaError") || entry.message : entry.message;
				showModal(entry.title, message, "", entry.tone);
				window.history.replaceState({}, "", window.location.pathname + window.location.hash);
				break;
			}
		}
	};

	showFromQuery();
	if (loadError) {
		showModal("Settings load failed", loadError, "", "error");
	}

	if (form instanceof HTMLFormElement && testButton instanceof HTMLButtonElement) {

		testButton.addEventListener("click", async () => {
			const payload = new FormData(form);
			payload.set("intent", "test");
			testButton.disabled = true;
			const originalLabel = testButton.textContent || "Test connection";
			testButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Testing...';
			showModal("Testing connection", "Checking the media storage connection.", "", "info", true);

			try {
				const response = await fetch(form.action, {
					method: "POST",
					credentials: "same-origin",
					headers: {
						Accept: "application/json",
						"X-Requested-With": "fetch",
					},
					body: payload,
				});

				const data = await response.json().catch(() => ({}));
				if (!response.ok || !data?.ok) {
					throw new Error(data?.error || "Media storage connection test failed.");
				}

				showModal("Connection successful", data.message || "Media storage connection succeeded.", "", "success");
			} catch (error) {
				showModal("Connection failed", error instanceof Error ? error.message : "Media storage connection test failed.", "", "error");
			} finally {
				testButton.disabled = false;
				testButton.textContent = originalLabel.trim();
			}
		});
	}

	toggleButtons?.forEach((button) => {
		if (!(button instanceof HTMLButtonElement)) {
			return;
		}

		button.addEventListener("click", () => {
			const targetSelector = button.dataset.mediaSecretTarget;
			if (!targetSelector) {
				return;
			}

			const target = form?.querySelector(targetSelector);
			if (!(target instanceof HTMLInputElement)) {
				return;
			}

			const willReveal = target.type === "password";
			target.type = willReveal ? "text" : "password";
			const label = willReveal ? "Hide" : "Show";
			const description = target.id === "s3SecretAccessKey" ? "secret access key" : "access key ID";
			button.setAttribute("aria-label", `${label} ${description}`);
			button.title = `${label} ${description}`;
		});
	});
</script>

<style>
	.media-settings-shell {
		display: grid;
		gap: 0.9rem;
	}

	.media-settings-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.9rem;
	}

	.media-status-badges {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem;
	}

	.media-status-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--gray), 0.12);
		font-size: 0.78rem;
		font-weight: 600;
	}

	.media-settings-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
	}

	.media-settings-advanced {
		display: grid;
		gap: 0.9rem;
		padding: 0.85rem 0.95rem;
		border: 1px solid rgba(var(--gray), 0.12);
		border-radius: 0.9rem;
		background: rgba(var(--gray-light), 0.16);
	}

	.media-advanced-grid {
		padding-top: 0.15rem;
	}

	.media-secret-field {
		display: grid;
		gap: 0.4rem;
	}

	.media-secret-field-wide {
		grid-column: 1 / -1;
	}

	.media-secret-field .input-group .btn {
		width: 3.25rem;
		justify-content: center;
	}

	.media-secret-field svg {
		width: 1rem;
		height: 1rem;
	}

	@media (max-width: 720px) {
		.media-settings-header {
			flex-direction: column;
		}

		.media-status-badges {
			justify-content: flex-start;
		}

		.media-settings-actions {
			flex-direction: column;
			align-items: stretch;
		}
	}
</style>
