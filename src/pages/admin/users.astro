---
export const prerender = false;

import UserTable from "../../components/admin/UserTable.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listAdminUsers } from "../../lib/db/admin-users";
import { getDb } from "../../lib/blog";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const users = await listAdminUsers(getDb(Astro.locals));
---

<AdminLayout
	title="Users"
	description="Manage admin users and role assignments."
	session={session}
	pageTitle="Users"
	pageDescription="Manage admin users from a focused list without inline create or edit panels."
>
	<div slot="actions" class="admin-page-actions">
		<a class="admin-primary-button" href="/admin/users/new">Create User</a>
	</div>

	<div class="admin-content-stack">
		{Astro.url.searchParams.get("created") && <p class="admin-notice">User created.</p>}
		{Astro.url.searchParams.get("saved") && <p class="admin-notice">User saved.</p>}
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">The user request failed.</p>}
		<UserTable users={users} />
	</div>
</AdminLayout>
