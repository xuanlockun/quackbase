---
export const prerender = false;

import UserRoleTable from "../../components/admin/UserRoleTable.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listAdminUsers } from "../../lib/db/admin-users";
import { listRoleSummaries } from "../../lib/db/roles";
import { getDb } from "../../lib/blog";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const db = getDb(Astro.locals);
const [users, roles] = await Promise.all([listAdminUsers(db), listRoleSummaries(db)]);
---

<AdminLayout
	title="Users"
	description="Manage admin users and role assignments."
	session={session}
	pageTitle="Users"
	pageDescription="Assign roles to admin users and keep access current on the next protected request."
>
	<UserRoleTable users={users} roles={roles} />
</AdminLayout>
