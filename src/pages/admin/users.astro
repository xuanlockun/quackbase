---
export const prerender = false;

import UserTable from "../../components/admin/UserTable.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listAdminUsers } from "../../lib/db/admin-users";
import { getDb } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const users = await listAdminUsers(getDb(Astro.locals));
const { t } = getUiTranslations(Astro);
---

<AdminLayout
	title={t("headings.users")}
	description={t("messages.manageUsers")}
	session={session}
	pageTitle={t("headings.users")}
	pageDescription={t("messages.manageAdminUsers")}
>
	<div slot="actions" class="admin-page-actions">
		<a class="admin-primary-button" href="/admin/users/new">{t("actions.createUser")}</a>
	</div>

	<div class="admin-content-stack">
		{Astro.url.searchParams.get("created") && <p class="admin-notice">{t("messages.userCreated")}</p>}
		{Astro.url.searchParams.get("saved") && <p class="admin-notice">{t("messages.userSaved")}</p>}
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">{t("messages.userRequestFailed")}</p>}
		<UserTable users={users} />
	</div>
</AdminLayout>
