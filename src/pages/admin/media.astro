---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import FeedbackModal from "../../components/admin/FeedbackModal.astro";
import IconAction from "../../components/admin/IconAction.astro";
import { getDb } from "../../lib/blog";
import {
	getMediaStorageStatus,
	listAllMediaAssets,
	listMediaFolders,
	type MediaAsset,
	type MediaFolderRecord,
} from "../../lib/media";
import { getUiTranslations } from "../../lib/i18n";

type FolderEntry = {
	folderPath: string;
	label: string;
	depth: number;
	itemCount: number;
	isActive: boolean;
	isAncestor: boolean;
	hasChildren: boolean;
};

type Breadcrumb = {
	label: string;
	folderPath: string;
	isCurrent: boolean;
};

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canManage = session.isSuperadmin || session.permissions.includes("site.manage");
const { t } = getUiTranslations(Astro);
const storageStatus = await getMediaStorageStatus(Astro.locals);

const currentFolder = normalizeFolderPath(Astro.url.searchParams.get("folder") ?? "");
const currentView = Astro.url.searchParams.get("view") === "list" ? "list" : "grid";

let allAssets: MediaAsset[] = [];
let folders: MediaFolderRecord[] = [];
let loadError = "";

try {
	const db = getDb(Astro.locals);
	[allAssets, folders] = await Promise.all([listAllMediaAssets(db), listMediaFolders(db)]);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.mediaLoadFailed");
}

const folderIndex = buildFolderIndex(folders, allAssets);
const folderEntries = buildFolderEntries(folderIndex, allAssets, currentFolder);
const breadcrumbs = buildBreadcrumbs(currentFolder);
const currentFolderDepth = currentFolder ? currentFolder.split("/").filter(Boolean).length : 0;
const childFolderEntries = folderEntries.filter((entry) => entry.depth === currentFolderDepth + 1);
const visibleAssets = allAssets.filter((asset) => asset.folderPath === currentFolder);
const folderOptions = [...folderIndex.values()].sort((left, right) => left.folderPath.localeCompare(right.folderPath));
const folderTitle = currentFolder ? formatFolderLabel(currentFolder) : t("messages.allMedia", "All media");
const storageConnectedLabel = storageStatus.isConfigured ? "Storage connected" : "Storage not connected";
const storageReadyLabel = storageStatus.isConfigured ? "Ready to upload" : "Connect storage to upload";
const storageSummaryText = storageStatus.isConfigured
	? "Uploads are ready and the media library is available."
	: "Connect storage in settings to enable uploads and syncing.";
const uploadIcon = `
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
		<path d="M12 16V4" />
		<path d="M8 8l4-4 4 4" />
		<path d="M4 16v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3" />
	</svg>
`;
const folderIcon = `
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
		<path d="M3.5 7.5A2.5 2.5 0 0 1 6 5h4l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19H6A2.5 2.5 0 0 1 3.5 16.5Z" />
	</svg>
`;
const refreshIcon = `
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
		<path d="M20 12a8 8 0 0 0-14.4-4.8" />
		<path d="M5 4v4h4" />
		<path d="M4 12a8 8 0 0 0 14.4 4.8" />
		<path d="M19 20v-4h-4" />
	</svg>
`;
const moreIcon = `
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="6" cy="12" r="1" />
		<circle cx="12" cy="12" r="1" />
		<circle cx="18" cy="12" r="1" />
	</svg>
`;
const fileIcon = `
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
		<path d="M7 3.5h7l5 5V20a1.5 1.5 0 0 1-1.5 1.5H7A1.5 1.5 0 0 1 5.5 20V5A1.5 1.5 0 0 1 7 3.5Z" />
		<path d="M14 3.5V9h5" />
	</svg>
`;

function formatBytes(bytes: number): string {
	if (!Number.isFinite(bytes) || bytes <= 0) {
		return "0 B";
	}

	const units = ["B", "KB", "MB", "GB", "TB"];
	let value = bytes;
	let index = 0;
	while (value >= 1024 && index < units.length - 1) {
		value /= 1024;
		index++;
	}
	return `${index === 0 ? Math.round(value) : value.toFixed(1)} ${units[index]}`;
}

function formatDate(value: Date): string {
	return new Intl.DateTimeFormat(undefined, {
		dateStyle: "medium",
		timeStyle: "short",
	}).format(value);
}

function getAssetPreviewUrl(asset: MediaAsset): string {
	return asset.publicUrl || `/api/admin/media/${asset.id}`;
}

function isImageAsset(asset: MediaAsset): boolean {
	return asset.mimeType.startsWith("image/");
}

function isVideoAsset(asset: MediaAsset): boolean {
	return asset.mimeType.startsWith("video/");
}

function getAssetKind(asset: MediaAsset): string {
	if (isImageAsset(asset)) return "Image";
	if (isVideoAsset(asset)) return "Video";
	return asset.mimeType || "File";
}

function buildFolderIndex(folderRecords: MediaFolderRecord[], assets: MediaAsset[]): Map<string, MediaFolderRecord> {
	const map = new Map<string, MediaFolderRecord>();

	for (const record of folderRecords) {
		const normalized = normalizeFolderPath(record.folderPath);
		if (!normalized) {
			continue;
		}

		map.set(normalized, {
			...record,
			folderPath: normalized,
		});
	}

	for (const asset of assets) {
		if (asset.folderPath && !map.has(asset.folderPath)) {
			map.set(asset.folderPath, {
				id: 0,
				folderPath: asset.folderPath,
				createdAt: new Date(0),
				updatedAt: new Date(0),
			});
		}
	}

	return map;
}

function buildFolderEntries(folderIndex: Map<string, MediaFolderRecord>, assets: MediaAsset[], currentFolderPath: string): FolderEntry[] {
	const currentSegments = currentFolderPath ? currentFolderPath.split("/").filter(Boolean) : [];
	const ancestorFolders = new Set<string>();
	for (let index = 1; index <= currentSegments.length; index++) {
		ancestorFolders.add(currentSegments.slice(0, index).join("/"));
	}

	const entries = [...folderIndex.values()].map((folder) => {
		const depth = folder.folderPath.split("/").filter(Boolean).length;
		const itemCount = countAssetsInFolder(folder.folderPath, assets);
		const hasChildren = [...folderIndex.keys()].some(
			(candidate) => candidate.startsWith(`${folder.folderPath}/`) && candidate !== folder.folderPath,
		);
		return {
			folderPath: folder.folderPath,
			label: formatFolderLabel(folder.folderPath),
			depth,
			itemCount,
			isActive: folder.folderPath === currentFolderPath,
			isAncestor: ancestorFolders.has(folder.folderPath),
			hasChildren,
		};
	});

	return entries.sort((left, right) => left.folderPath.localeCompare(right.folderPath));
}

function buildBreadcrumbs(folderPath: string): Breadcrumb[] {
	const segments = folderPath.split("/").filter(Boolean);
	const breadcrumbs: Breadcrumb[] = [
		{
			label: t("messages.allMedia", "All media"),
			folderPath: "",
			isCurrent: segments.length === 0,
		},
	];

	let current = "";
	for (let index = 0; index < segments.length; index++) {
		current = current ? `${current}/${segments[index]}` : segments[index];
		breadcrumbs.push({
			label: segments[index],
			folderPath: current,
			isCurrent: index === segments.length - 1,
		});
	}

	return breadcrumbs;
}

function countAssetsInFolder(folderPath: string, assets: MediaAsset[]): number {
	const normalized = normalizeFolderPath(folderPath);
	if (!normalized) {
		return assets.length;
	}

	const prefix = `${normalized}/`;
	return assets.filter((asset) => asset.folderPath === normalized || asset.folderPath.startsWith(prefix)).length;
}

function formatFolderLabel(folderPath: string): string {
	const segments = folderPath.split("/").filter(Boolean);
	if (segments.length === 0) {
		return t("messages.allMedia", "All media");
	}
	return segments.join(" / ");
}

function normalizeFolderPath(value: string): string {
	return value
		.trim()
		.replace(/^\/+|\/+$/g, "")
		.split("/")
		.map((segment) =>
			segment
				.trim()
				.replace(/\s+/g, "-")
				.replace(/[^a-zA-Z0-9._-]+/g, "-")
				.replace(/-+/g, "-")
				.replace(/^-+|-+$/g, "")
				.toLowerCase(),
		)
		.filter(Boolean)
		.join("/");
}

function buildFolderHref(folderPath: string, view = currentView): string {
	const params = new URLSearchParams();
	if (folderPath) {
		params.set("folder", folderPath);
	}
	if (view !== "grid") {
		params.set("view", view);
	}
	const query = params.toString();
	return query ? `/admin/media?${query}` : "/admin/media";
}

const mediaFeedback = [
	["uploaded", { title: "Upload complete", message: t("messages.mediaUploadSuccess"), tone: "success" }],
	["updated", { title: "Media updated", message: "The file was renamed or moved.", tone: "success" }],
	["deleted", { title: "Asset deleted", message: t("messages.mediaDeleteSuccess"), tone: "success" }],
	["folderCreated", { title: "Folder created", message: t("messages.folderCreated", "Folder created."), tone: "success" }],
	["synced", { title: "Library refreshed", message: "Media library refreshed from bucket.", tone: "success" }],
] as const;
---

<AdminLayout
	title={t("headings.mediaLibrary")}
	description={t("messages.manageMedia")}
	session={session}
	pageTitle={t("headings.mediaLibrary")}
	pageDescription={t("messages.mediaLibraryHelp")}
>
	<div class="admin-content-stack media-library-shell">
		<FeedbackModal id="media-feedback-modal" title="Status update" closeLabel={t("actions.close", "Close")} />

		<div class="media-library-header admin-form-surface">
			<div class="media-library-summary">
				<span class="media-library-status-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 4.5a7.5 7.5 0 0 0-7.5 7.5v5A2.5 2.5 0 0 0 7 19.5h2.5" />
						<path d="M12 4.5a7.5 7.5 0 0 1 7.5 7.5v5A2.5 2.5 0 0 1 17 19.5h-2.5" />
						<path d="M8.5 12h7" />
						<path d="M12 8.5v7" />
					</svg>
				</span>
				<div class="min-w-0">
					<p class="media-status-kicker mb-1">Storage</p>
					<h2 class="h5 mb-1">{storageConnectedLabel}</h2>
					<p class="mb-0 text-body-secondary">{storageSummaryText}</p>
				</div>
				<div class="media-status-meta">
					<span class:list={["badge", storageStatus.isConfigured ? "text-bg-success" : "text-bg-warning"]}>
						{storageConnectedLabel}
					</span>
					<span class="small text-body-secondary">{storageReadyLabel}</span>
				</div>
			</div>

			<div class="media-library-actions">
				<form method="post" action="/api/admin/media" enctype="multipart/form-data" class="media-action-form media-action-form-upload">
					<input type="hidden" name="folderPath" value={currentFolder} />
					<label class="visually-hidden" for="mediaFiles">Upload files</label>
					<input
						id="mediaFiles"
						class="form-control visually-hidden media-upload-input"
						type="file"
						name="files"
						multiple
						disabled={!storageStatus.isConfigured || !canManage}
					/>
					<label class:list={["btn btn-primary media-action-button", (!storageStatus.isConfigured || !canManage) && "disabled"]} for="mediaFiles">
						<span class="media-action-button-icon" aria-hidden="true" set:html={uploadIcon}></span>
						<span>Upload files</span>
					</label>
				</form>

				<form method="post" action="/api/admin/media/folders" class="media-action-form">
					<input type="hidden" name="parentFolderPath" value={currentFolder} />
					<label class="visually-hidden" for="folderName">Folder name</label>
					<div class="media-inline-action">
						<input
							id="folderName"
							class="form-control media-action-input"
							type="text"
							name="folderName"
							placeholder={currentFolder ? "new-folder" : "images"}
							disabled={!storageStatus.isConfigured || !canManage}
						/>
						<button class="btn btn-outline-secondary media-action-button" type="submit" disabled={!storageStatus.isConfigured || !canManage}>
							<span class="media-action-button-icon" aria-hidden="true" set:html={folderIcon}></span>
							<span>New folder</span>
						</button>
					</div>
				</form>

				<form method="post" action="/api/admin/media/sync" class="media-action-form">
					<label class="visually-hidden" for="syncBucket">Refresh media</label>
					<button id="syncBucket" class="btn btn-outline-secondary media-action-button" type="submit" disabled={!storageStatus.isConfigured || !canManage}>
						<span class="media-action-button-icon" aria-hidden="true" set:html={refreshIcon}></span>
						<span>Refresh</span>
					</button>
				</form>
			</div>
		</div>

		<div class="media-library-layout">
			<aside class="media-folder-panel admin-form-surface">
				<div class="d-flex align-items-center justify-content-between gap-2 mb-3">
					<h2 class="h6 mb-0">Folders</h2>
					<span class="text-body-secondary small">{folderEntries.length} folders</span>
				</div>
				<nav class="media-folder-list" aria-label="Media folders">
					<a class:list={["media-folder-item", !currentFolder ? "is-active" : ""]} href={buildFolderHref("", currentView)}>
						<span class="media-folder-item-icon" aria-hidden="true" set:html={folderIcon}></span>
						<span class="media-folder-title">{t("messages.allMedia", "All media")}</span>
						<span class="media-folder-count">{allAssets.length}</span>
					</a>
					{folderEntries.length === 0 ? (
						<p class="text-body-secondary small mb-0">No folders yet.</p>
					) : (
						folderEntries.map((folder) => (
							<a
								class:list={["media-folder-item", folder.isActive ? "is-active" : "", folder.isAncestor ? "is-ancestor" : ""]}
								href={buildFolderHref(folder.folderPath, currentView)}
								style={`--folder-depth: ${Math.min(folder.depth, 6)};`}
							>
								<span class="media-folder-item-icon" aria-hidden="true" set:html={folderIcon}></span>
								<span class="media-folder-title text-truncate">{folder.label}</span>
								<span class="media-folder-count">{folder.itemCount}</span>
							</a>
						))
					)}
				</nav>
			</aside>

			<section class="media-content-panel admin-form-surface">
				<nav class="media-breadcrumbs" aria-label="Breadcrumb">
					{breadcrumbs.map((crumb, index) => (
						<>
							{index > 0 && <span class="media-breadcrumb-separator" aria-hidden="true">/</span>}
							{crumb.isCurrent ? (
								<span class="media-breadcrumb-current">{crumb.label}</span>
							) : (
								<a class="media-breadcrumb-link" href={buildFolderHref(crumb.folderPath, currentView)}>
									{crumb.label}
								</a>
							)}
						</>
					))}
				</nav>

				<div class="media-content-header">
					<div class="min-w-0">
						<h2 class="h5 mb-1 text-break">{folderTitle}</h2>
						<p class="admin-inline-muted mb-0">
							{visibleAssets.length} files, {childFolderEntries.length} folders
						</p>
					</div>
					<div class="d-flex flex-wrap gap-2 align-items-center">
						<div class="btn-group btn-group-sm" role="group" aria-label="View mode">
							<a class:list={["btn", currentView === "grid" ? "btn-primary" : "btn-outline-secondary"]} href={buildFolderHref(currentFolder, "grid")}>
								Grid
							</a>
							<a class:list={["btn", currentView === "list" ? "btn-primary" : "btn-outline-secondary"]} href={buildFolderHref(currentFolder, "list")}>
								List
							</a>
						</div>
					</div>
				</div>

				<form class="media-selection-bar" data-media-selection-bar hidden>
					<input type="hidden" name="currentFolder" value={currentFolder} />
					<input type="hidden" name="assetIds" value="" data-media-selected-ids />
					<div class="media-selection-summary">
						<strong><span data-media-selected-count>0</span> selected</strong>
						<button class="btn btn-link btn-sm p-0" type="button" data-media-clear-selection>Clear</button>
					</div>
					<div class="media-selection-actions">
						<select class="form-select form-select-sm" name="folderPath" aria-label="Move selected files to folder" disabled={!storageStatus.isConfigured || !canManage}>
							<option value="">Root</option>
							{folderOptions.map((folder) => (
								<option value={folder.folderPath}>{formatFolderLabel(folder.folderPath)}</option>
							))}
						</select>
						<button class="btn btn-sm btn-outline-secondary" type="submit" name="_intent" value="bulk-move" disabled={!storageStatus.isConfigured || !canManage}>
							Move selected
						</button>
						<button
							class="btn btn-sm btn-outline-danger"
							type="submit"
							name="_intent"
							value="bulk-delete"
							disabled={!storageStatus.isConfigured || !canManage}
							data-admin-confirm-form
							data-confirm-title="Delete selected files?"
							data-confirm-message="The selected files will be removed from the media library."
							data-confirm-confirm-label={t("actions.delete")}
							data-confirm-tone="danger"
						>
							Delete selected
						</button>
					</div>
				</form>

				{loadError ? (
					<div class="media-empty-state">
						<span class="media-empty-state-icon" aria-hidden="true" set:html={fileIcon}></span>
						<h3 class="h6 mb-1">Media could not be loaded.</h3>
						<p class="mb-0 text-body-secondary">{loadError}</p>
					</div>
				) : (
					<>
						<section class="media-folder-section">
							<div class="media-section-heading">
								<h3 class="h6 mb-0">Folders</h3>
								<span class="small text-body-secondary">{childFolderEntries.length} subfolders</span>
							</div>
							{childFolderEntries.length === 0 ? (
								<div class="media-empty-state media-empty-state-inline">
									<span class="media-empty-state-icon" aria-hidden="true" set:html={folderIcon}></span>
									<div>
										<h3 class="h6 mb-1">No subfolders yet</h3>
										<p class="mb-0 text-body-secondary">Create a folder to keep files grouped together.</p>
									</div>
								</div>
							) : currentView === "list" ? (
								<div class="table-responsive media-folder-table-wrap">
									<table class="table table-sm align-middle mb-0">
										<tbody>
											{childFolderEntries.map((folder) => (
												<tr>
													<td class="media-folder-cell">
														<a class:list={["media-folder-list-link", folder.isActive ? "is-active" : ""]} href={buildFolderHref(folder.folderPath, currentView)}>
															<span class="media-folder-item-icon" aria-hidden="true" set:html={folderIcon}></span>
															<span class="text-truncate">{folder.label}</span>
														</a>
													</td>
													<td class="text-body-secondary small text-end">{folder.itemCount} items</td>
												</tr>
											))}
										</tbody>
									</table>
								</div>
							) : (
								<div class="media-folder-grid">
									{childFolderEntries.map((folder) => (
										<a class:list={["media-folder-card", folder.isActive ? "is-active" : ""]} href={buildFolderHref(folder.folderPath, currentView)}>
											<span class="media-folder-item-icon media-folder-card-icon" aria-hidden="true" set:html={folderIcon}></span>
											<strong class="text-break">{folder.label}</strong>
											<span class="text-body-secondary small">{folder.itemCount} items</span>
										</a>
									))}
								</div>
							)}
						</section>

						<section class="media-file-section">
							<div class="media-section-heading">
								<h3 class="h6 mb-0">Files</h3>
								<span class="small text-body-secondary">{visibleAssets.length} files</span>
							</div>

							{visibleAssets.length === 0 ? (
								<div class="media-empty-state">
									<span class="media-empty-state-icon" aria-hidden="true" set:html={fileIcon}></span>
									<div>
										<h3 class="h6 mb-1">Empty folder</h3>
										<p class="mb-0 text-body-secondary">Upload files or create a subfolder.</p>
									</div>
								</div>
							) : currentView === "list" ? (
								<div class="table-responsive media-table-wrap">
									<table class="table table-sm align-middle mb-0">
										<thead>
											<tr>
												<th class="media-select-col">
													<span class="visually-hidden">Select</span>
												</th>
												<th class="media-preview-col">Preview</th>
												<th>Name</th>
												<th>Type</th>
												<th>Size</th>
												<th>Updated</th>
												<th class="media-action-col">Actions</th>
											</tr>
										</thead>
										<tbody>
											{visibleAssets.map((asset) => {
												const previewUrl = getAssetPreviewUrl(asset);
												const publicUrl = asset.publicUrl.trim();
												const canCopyPublicUrl = Boolean(publicUrl);
												return (
													<tr class="media-item-row" data-media-item data-item-id={asset.id}>
														<td>
															<input
																class="form-check-input media-select-checkbox"
																type="checkbox"
																data-media-select
																data-asset-id={asset.id}
																aria-label={`Select ${asset.fileName}`}
															/>
														</td>
														<td>
															<div class="media-list-thumb">
																{isImageAsset(asset) ? (
																	<img src={previewUrl} alt={asset.fileName} loading="lazy" />
																) : isVideoAsset(asset) ? (
																	<video src={previewUrl} controls preload="metadata" />
																) : (
																	<div class="media-fallback-chip">{asset.mimeType || "FILE"}</div>
																)}
															</div>
														</td>
														<td>
															<div class="d-grid">
																<strong class="text-break">{asset.fileName}</strong>
																<small class="text-body-secondary text-break">{asset.folderPath || "root"}</small>
															</div>
														</td>
														<td>{getAssetKind(asset)}</td>
														<td>{formatBytes(asset.sizeBytes)}</td>
														<td>{formatDate(asset.createdAt)}</td>
														<td>
															<div class="dropdown">
																<button
																	class="btn btn-sm btn-outline-secondary media-more-button dropdown-toggle"
																	type="button"
																	data-bs-toggle="dropdown"
																	aria-expanded="false"
																>
																	<span class="visually-hidden">Media actions</span>
																	<span aria-hidden="true" class="media-more-icon" set:html={moreIcon}></span>
																</button>
