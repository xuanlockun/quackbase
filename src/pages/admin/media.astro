<script type="module" define:vars={{ mediaFeedback, loadError }}>
	const showFeedbackModal = window.showAdminFeedbackModal;
	const search = new URLSearchParams(window.location.search);

	const errorMessage = search.get("errorMessage");
	if (errorMessage && typeof showFeedbackModal === "function") {
		showFeedbackModal({ title: "Action failed", message: errorMessage, tone: "error" });
		window.history.replaceState({}, "", window.location.pathname + window.location.hash);
	} else if (search.has("error") && typeof showFeedbackModal === "function") {
		showFeedbackModal({ title: "Action failed", message: "Media request failed.", tone: "error" });
		window.history.replaceState({}, "", window.location.pathname + window.location.hash);
	} else if (loadError && typeof showFeedbackModal === "function") {
		showFeedbackModal({ title: "Media load failed", message: loadError, tone: "error" });
	} else {
		for (const [key, entry] of mediaFeedback) {
			if (search.has(key)) {
				if (typeof showFeedbackModal === "function") {
					const count = search.get(key);
					const detail =
						key === "synced" && (search.get("imported") || search.get("updated"))
							? `Imported ${search.get("imported") ?? 0}, updated ${search.get("updated") ?? 0}.`
							: count
								? key === "uploaded"
									? `${count} file${count === "1" ? "" : "s"} uploaded.`
									: key === "deleted"
										? `${count} file${count === "1" ? "" : "s"} deleted.`
										: key === "updated"
											? `${count} item${count === "1" ? "" : "s"} updated.`
											: "";
					showFeedbackModal({ title: entry.title, message: entry.message, detail, tone: entry.tone });
				}
				window.history.replaceState({}, "", window.location.pathname + window.location.hash);
				break;
			}
		}
	}
</script>

<script type="module">
	const copyButtons = document.querySelectorAll("[data-copy-media-url]");
	const selectionBar = document.querySelector("[data-media-selection-bar]");
	const selectedIdsInput = document.querySelector("[data-media-selected-ids]");
	const selectedCountNodes = document.querySelectorAll("[data-media-selected-count]");
	const clearSelectionButton = document.querySelector("[data-media-clear-selection]");
	const selectionCheckboxes = [...document.querySelectorAll("[data-media-select]")];

	const syncCopyButton = (button) => {
		if (!(button instanceof HTMLButtonElement)) {
			return;
		}

		button.addEventListener("click", async () => {
			const url = button.dataset.copyUrl?.trim() ?? "";
			if (!url || !navigator.clipboard) {
				return;
			}

			try {
				await navigator.clipboard.writeText(url);
				const originalLabel = button.dataset.copyLabel || button.getAttribute("aria-label") || "Copy URL";
				button.classList.add("is-copied");
				button.setAttribute("aria-label", "Copied");
				button.title = "Copied";
				window.setTimeout(() => {
					button.classList.remove("is-copied");
					button.setAttribute("aria-label", originalLabel);
					button.title = originalLabel;
				}, 1200);
			} catch {
				// Ignore clipboard failures and keep the button usable.
			}
		});
	};

	copyButtons.forEach(syncCopyButton);

	const updateSelectionState = () => {
		const selectedIds = selectionCheckboxes
			.filter((checkbox) => checkbox instanceof HTMLInputElement && checkbox.checked)
			.map((checkbox) => checkbox.dataset.assetId)
			.filter(Boolean);

		if (selectedIdsInput instanceof HTMLInputElement) {
			selectedIdsInput.value = selectedIds.join(",");
		}

		selectedCountNodes.forEach((node) => {
			if (node instanceof HTMLElement) {
				node.textContent = String(selectedIds.length);
			}
		});

		selectionCheckboxes.forEach((checkbox) => {
			if (!(checkbox instanceof HTMLInputElement)) {
				return;
			}

			const item = checkbox.closest("[data-media-item]");
			if (item instanceof HTMLElement) {
				item.classList.toggle("is-selected", checkbox.checked);
			}
		});

		if (selectionBar instanceof HTMLElement) {
			selectionBar.hidden = selectedIds.length === 0;
		}
	};

	selectionCheckboxes.forEach((checkbox) => {
		if (!(checkbox instanceof HTMLInputElement)) {
			return;
		}

		checkbox.addEventListener("change", updateSelectionState);
	});

	clearSelectionButton?.addEventListener("click", () => {
		selectionCheckboxes.forEach((checkbox) => {
			if (checkbox instanceof HTMLInputElement) {
				checkbox.checked = false;
			}
		});
		updateSelectionState();
	});

	updateSelectionState();

	const submitMediaAction = ({ assetId, fileName, folderPath, intent }) => {
		const form = document.createElement("form");
		form.method = "post";
		form.action = "/api/admin/media";
		form.style.display = "none";

		const addField = (name, value) => {
			const input = document.createElement("input");
			input.type = "hidden";
			input.name = name;
			input.value = value;
			form.append(input);
		};

		addField("_intent", intent);
		addField("assetId", String(assetId));
		if (typeof fileName === "string") {
			addField("fileName", fileName);
		}
		if (typeof folderPath === "string") {
			addField("folderPath", folderPath);
		}

		document.body.append(form);
		if (typeof form.requestSubmit === "function") {
			form.requestSubmit();
		} else {
			form.submit();
		}
	};

	document.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) {
			return;
		}

		const renameButton = target.closest("[data-media-rename]");
		if (renameButton instanceof HTMLElement) {
			const assetId = renameButton.dataset.assetId;
			const assetName = renameButton.dataset.assetName || "";
			if (!assetId) {
				return;
			}

			const nextName = window.prompt("Rename file", assetName);
			if (nextName === null) {
				return;
			}

			const trimmed = nextName.trim();
			if (!trimmed) {
				return;
			}

			submitMediaAction({ intent: "update", assetId: Number(assetId), fileName: trimmed });
			return;
		}

		const moveButton = target.closest("[data-media-move]");
		if (moveButton instanceof HTMLElement) {
			const assetId = moveButton.dataset.assetId;
			const assetFolder = moveButton.dataset.assetFolder || "";
			if (!assetId) {
				return;
			}

			const nextFolder = window.prompt("Move file to folder", assetFolder);
			if (nextFolder === null) {
				return;
			}

			submitMediaAction({ intent: "update", assetId: Number(assetId), folderPath: nextFolder.trim() });
		}
	});
</script>

