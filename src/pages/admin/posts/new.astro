---
export const prerender = false;

import PostForm from "../../../components/admin/PostForm.astro";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getUiTranslations } from "../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("posts.create");
const { t } = getUiTranslations(Astro);
---

<AdminLayout
	title={t("actions.createPost")}
	description={t("messages.saveCreatePost")}
	session={session}
	pageTitle={t("actions.createPost")}
	pageDescription={t("messages.createPostDescription")}
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("error") && <p class="alert alert-danger mb-0">{t("messages.requestFailed")}</p>}
		<PostForm mode="create" action="/api/admin/posts" canSubmit={canCreate} />
	</div>
</AdminLayout>
