---
export const prerender = false;

import type { AdminPostDetail } from "../../../../lib/blog";
import PostForm from "../../../../components/admin/PostForm.astro";
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import { getDb, getPostById, toAdminPostDetail } from "../../../../lib/blog";
import { getLanguageCatalog, getUiTranslations, localizeAdminHref } from "../../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canUpdate = session.isSuperadmin || session.permissions.includes("posts.update");
const { id } = Astro.params;
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);

let post: AdminPostDetail | null = null;
let loadError = "";
let notFound = false;

try {
	const postId = Number(id);
	if (!Number.isInteger(postId) || postId <= 0) {
		notFound = true;
	} else {
		const record = await getPostById(getDb(Astro.locals), postId, language, catalog);
		post = record ? toAdminPostDetail(record, language, catalog) : null;
		notFound = !post;
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadPosts");
}
---

<AdminLayout
	title={t("actions.editPost")}
	description={t("messages.saveEditPost")}
	session={session}
	pageTitle={t("actions.editPost")}
	pageDescription={t("messages.editPostDescription")}
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("error") && <p class="alert alert-danger mb-0">{t("messages.requestFailed")}</p>}
		{
			notFound ? (
				<div class="admin-empty-state">
					<h2>{t("messages.postNotFound")}</h2>
					<p class="admin-muted">{t("messages.failedToLoadPosts")}</p>
					<p>
						<a class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" href={localizeAdminHref("/admin/posts", language)}>
							<span aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 6l-6 6 6 6" />
									<path d="M20 12H8" />
								</svg>
							</span>
							{t("messages.backToPosts")}
						</a>
					</p>
				</div>
			) : (
				<PostForm
					mode="edit"
					action={`/api/admin/posts/${id}`}
					post={post}
					canSubmit={canUpdate}
					loadError={loadError}
				/>
			)
		}
	</div>
</AdminLayout>
