---
export const prerender = false;

import type { AdminPostDetail } from "../../../../lib/blog";
import PostForm from "../../../../components/admin/PostForm.astro";
import AdminLayout from "../../../../layouts/AdminLayout.astro";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canUpdate = session.isSuperadmin || session.permissions.includes("posts.update");
const { id } = Astro.params;

let post: AdminPostDetail | null = null;
let loadError = "";
let notFound = false;

try {
	const response = await fetch(new URL(`/api/admin/posts/${id}`, Astro.url), {
		headers: {
			cookie: Astro.request.headers.get("cookie") ?? "",
			accept: "application/json",
		},
	});

	if (response.status === 404) {
		notFound = true;
	} else if (!response.ok) {
		throw new Error("Failed to load the requested post.");
	} else {
		const data = await response.json();
		post = data.post ?? null;
		notFound = !post;
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : "Failed to load the requested post.";
}
---

<AdminLayout
	title="Edit Post"
	description="Edit an existing blog post."
	session={session}
	pageTitle="Edit Post"
	pageDescription="Make changes in a dedicated editor tied to one post record."
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">The post could not be updated.</p>}
		{
			notFound ? (
				<div class="admin-empty-state">
					<h2>Post not found</h2>
					<p class="admin-muted">The requested post could not be loaded for editing.</p>
					<p><a class="admin-ghost-button" href="/admin/posts">Back to posts</a></p>
				</div>
			) : (
				<PostForm
					mode="edit"
					action={`/api/admin/posts/${id}`}
					post={post}
					canSubmit={canUpdate}
					loadError={loadError}
				/>
			)
		}
	</div>
</AdminLayout>
