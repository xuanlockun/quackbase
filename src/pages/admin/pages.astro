---
export const prerender = false;

import PageTable from "../../components/admin/PageTable.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, listAllPages } from "../../lib/blog";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("pages.create");
const canUpdate = session.isSuperadmin || session.permissions.includes("pages.update");
const canDelete = session.isSuperadmin || session.permissions.includes("pages.delete");

let pages = [];
let loadError = "";

try {
	pages = await listAllPages(getDb(Astro.locals));
} catch (error) {
	loadError = error instanceof Error ? error.message : "Failed to load pages.";
}
---

<AdminLayout
	title="Pages"
	description="Manage custom pages."
	session={session}
	pageTitle="Pages"
	pageDescription="Manage landing pages and reusable route content from a dedicated list workspace."
>
	<div slot="actions" class="admin-page-actions">
		{canCreate && <a class="admin-primary-button" href="/admin/pages/new">Create Page</a>}
		<a class="admin-ghost-button" href="/">View site</a>
	</div>

	<div class="admin-content-stack">
		{Astro.url.searchParams.get("created") && <p class="admin-notice">Page created.</p>}
		{Astro.url.searchParams.get("saved") && <p class="admin-notice">Page saved.</p>}
		{Astro.url.searchParams.get("deleted") && <p class="admin-notice">Page deleted.</p>}
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">The page request failed.</p>}
		{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

		<PageTable pages={pages} canUpdate={canUpdate} canDelete={canDelete} />
	</div>
</AdminLayout>
