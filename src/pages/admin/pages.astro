---
export const prerender = false;

import PageTable from "../../components/admin/PageTable.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, listAllPages } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("pages.create");
const canUpdate = session.isSuperadmin || session.permissions.includes("pages.update");
const canDelete = session.isSuperadmin || session.permissions.includes("pages.delete");
const { t, language } = getUiTranslations(Astro);

let pages = [];
let loadError = "";

try {
	pages = await listAllPages(getDb(Astro.locals));
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadPages");
}
---

<AdminLayout
	title={t("headings.pages")}
	description={t("messages.manageCustomPages")}
	session={session}
	pageTitle={t("headings.pages")}
	pageDescription={t("messages.manageLandingPages")}
>
	<div slot="actions" class="admin-page-actions">
		{canCreate && <a class="admin-primary-button" href="/admin/pages/new">{t("actions.createPage")}</a>}
		<a class="admin-ghost-button" href={`/${language}/`}>{t("actions.viewSite")}</a>
	</div>

	<div class="admin-content-stack">
		{Astro.url.searchParams.get("created") && <p class="admin-notice">{t("messages.pageCreated")}</p>}
		{Astro.url.searchParams.get("saved") && <p class="admin-notice">{t("messages.pageSaved")}</p>}
		{Astro.url.searchParams.get("deleted") && <p class="admin-notice">{t("messages.pageDeleted")}</p>}
		{Astro.url.searchParams.get("error") && <p class="admin-notice admin-notice-error">{t("messages.pageRequestFailed")}</p>}
		{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}

		<PageTable pages={pages} canUpdate={canUpdate} canDelete={canDelete} />
	</div>
</AdminLayout>
