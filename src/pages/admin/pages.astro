---
export const prerender = false;

import FilterBar from "../../components/admin/FilterBar.astro";
import PageTable from "../../components/admin/PageTable.astro";
import NavigationItemsEditor from "../../components/admin/NavigationItemsEditor.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, getSiteConfig, listAllPages } from "../../lib/blog";
import { getLanguageCatalog, getUiTranslations } from "../../lib/i18n";
import { SITE_TITLE } from "../../consts";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("pages.create");
const canUpdate = session.isSuperadmin || session.permissions.includes("pages.update");
const canDelete = session.isSuperadmin || session.permissions.includes("pages.delete");
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const pageSearch = (Astro.url.searchParams.get("q") ?? "").trim();
const pageStatusParam = (Astro.url.searchParams.get("status") ?? "all").trim();
const pageStatus = ["all", "published", "draft"].includes(pageStatusParam) ? pageStatusParam : "all";

let pages = [];
let siteConfig = {
	siteTitle: SITE_TITLE,
	homePageSlug: "home",
	faviconUrl: "/favicon.svg",
	logoUrl: "",
	headerBackground: "#ffffff",
	headerTextColor: "#0f1219",
	headerAccentColor: "#2337ff",
	footerText: "Edge CMS. Content updates go live straight from D1.",
	footerBackground: "#eef2f7",
	footerTextColor: "#60739f",
	navItems: [],
};
let loadError = "";
let settingsError = "";

try {
	const db = getDb(Astro.locals);
	pages = await listAllPages(db, language, catalog);
	siteConfig = await getSiteConfig(db);
} catch (error) {
	if (!pages.length) {
		loadError = error instanceof Error ? error.message : t("messages.failedToLoadPages");
	} else {
		settingsError = error instanceof Error ? error.message : t("messages.failedToLoadSiteSettings");
	}
}

const filteredPages = pages.filter((page) => {
	const q = pageSearch.toLowerCase();
	const matchesSearch =
		q === "" ||
		[page.title, page.description, page.slug]
			.join(" ")
			.toLowerCase()
			.includes(q);
	const matchesStatus = pageStatus === "all" || page.status === pageStatus;
	return matchesSearch && matchesStatus;
});

const hasPageFilters = Boolean(pageSearch || pageStatus !== "all");
---

<AdminLayout
	title={t("headings.pages")}
	description={t("messages.manageCustomPages")}
	session={session}
	pageTitle={t("headings.pages")}
	pageDescription={t("messages.manageLandingPages")}
>
	<div slot="actions" class="admin-page-actions">
		{canCreate && <a class="btn btn-primary" href="/admin/pages/new">{t("actions.createPage")}</a>}
		<a class="btn btn-outline-secondary" href={`/${language}/`}>{t("actions.viewSite")}</a>
	</div>

	<div class="admin-content-stack">
		<section class="card border-0 shadow-sm admin-page-hub">
			<div class="card-body">
				<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
					<div class="admin-page-hub-copy">
						<p class="text-uppercase small fw-semibold mb-1 admin-eyebrow">{t("headings.pages")}</p>
						<h2 class="h5 mb-1">{t("messages.pageNavigationHub")}</h2>
						<p class="mb-0 text-body-secondary small">{t("messages.pageNavigationHubHelp")}</p>
					</div>
					<div class="admin-page-hub-badge">
						<span class="badge text-bg-light border">{t("labels.navigationItems")}</span>
					</div>
				</div>
				{settingsError && <p class="alert alert-warning mb-3">{settingsError}</p>}
				<form method="post" action="/api/admin/site" class="admin-form-shell">
					<input type="hidden" name="siteTitle" value={siteConfig.siteTitle} />
					<input type="hidden" name="homePageSlug" value={siteConfig.homePageSlug} />
					<input type="hidden" name="faviconUrl" value={siteConfig.faviconUrl} />
					<input type="hidden" name="logoUrl" value={siteConfig.logoUrl} />
					<input type="hidden" name="headerBackground" value={siteConfig.headerBackground} />
					<input type="hidden" name="headerTextColor" value={siteConfig.headerTextColor} />
					<input type="hidden" name="headerAccentColor" value={siteConfig.headerAccentColor} />
					<input type="hidden" name="footerText" value={siteConfig.footerText} />
					<input type="hidden" name="footerBackground" value={siteConfig.footerBackground} />
					<input type="hidden" name="footerTextColor" value={siteConfig.footerTextColor} />
					<NavigationItemsEditor navItems={siteConfig.navItems ?? []} loadError={settingsError} />
				</form>
			</div>
		</section>

		<FilterBar
			title={t("messages.pageListFilters")}
			searchName="q"
			searchValue={pageSearch}
			searchPlaceholder={t("messages.searchPages")}
			resetHref={hasPageFilters ? "/admin/pages" : ""}
			submitLabel={t("actions.applyFilters")}
			selects={[
				{
					name: "status",
					label: t("labels.status"),
					value: pageStatus,
					options: [
						{ value: "all", label: t("messages.allStatuses") },
						{ value: "published", label: t("status.published") },
						{ value: "draft", label: t("status.draft") },
					],
				},
			]}
		/>

		{Astro.url.searchParams.get("created") && <p class="alert alert-success mb-0">{t("messages.pageCreated")}</p>}
		{Astro.url.searchParams.get("saved") && <p class="alert alert-success mb-0">{t("messages.pageSaved")}</p>}
		{Astro.url.searchParams.get("deleted") && <p class="alert alert-info mb-0">{t("messages.pageDeleted")}</p>}
		{Astro.url.searchParams.get("error") && <p class="alert alert-danger mb-0">{t("messages.pageRequestFailed")}</p>}
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}

		<PageTable
			pages={filteredPages}
			canUpdate={canUpdate}
			canDelete={canDelete}
			emptyTitle={hasPageFilters ? t("messages.noPagesMatchFilters") : undefined}
			emptyDescription={hasPageFilters ? t("messages.tryAdjustPageFilters") : undefined}
		/>
	</div>
</AdminLayout>

<style>
	.admin-page-hub {
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0));
	}

	.admin-page-hub-copy {
		max-width: 52rem;
	}

	.admin-page-hub-badge {
		padding-top: 0.15rem;
	}
</style>
