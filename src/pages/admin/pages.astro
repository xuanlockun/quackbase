---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import AdminNav from "../../components/AdminNav.astro";
import { SITE_TITLE } from "../../consts";
import { getAdminToken, getDb, isAdminAuthenticated, listAllPages } from "../../lib/blog";

if (getAdminToken(Astro.locals) && !isAdminAuthenticated(Astro.request, Astro.locals)) {
	return Astro.redirect("/admin/login");
}

let pages = [];
let loadError = "";

try {
	pages = await listAllPages(getDb(Astro.locals));
} catch (error) {
	loadError = error instanceof Error ? error.message : "Failed to load pages.";
}

const selectedSlug = Astro.url.searchParams.get("slug");
const selectedPage = selectedSlug ? pages.find((page) => page.slug === selectedSlug) ?? null : null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Pages | ${SITE_TITLE}`} description="Manage custom pages." />
		<style>
			.cms-shell {
				width: min(1280px, calc(100% - 2rem));
				max-width: none;
				display: grid;
				grid-template-columns: 280px minmax(0, 1fr);
				gap: 1.5rem;
			}
			.panel {
				background: white;
				border-radius: 22px;
				box-shadow: 0 18px 40px rgba(var(--gray), 0.12);
				padding: 1.35rem;
				border: 1px solid rgba(var(--gray-light), 0.8);
			}
			.muted {
				color: rgb(var(--gray));
			}
			.toolbar,
			.row-actions,
			.row-actions-inline {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				align-items: center;
			}
			.toolbar {
				justify-content: space-between;
			}
			.main-stack {
				display: grid;
				gap: 1.5rem;
			}
			form.editor {
				display: grid;
				gap: 1rem;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}
			label {
				display: grid;
				gap: 0.5rem;
				font-weight: 700;
				font-size: 0.95rem;
			}
			input,
			select,
			textarea,
			button {
				font: inherit;
				padding: 0.9rem 1rem;
				border-radius: 14px;
				border: 1px solid rgb(var(--gray-light));
				box-sizing: border-box;
			}
			textarea {
				min-height: 320px;
				resize: vertical;
			}
			button {
				cursor: pointer;
			}
			.primary,
			.secondary,
			.success,
			.danger {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				font-weight: 700;
				text-decoration: none;
				transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
			}
			.primary {
				background: linear-gradient(135deg, #1f4fff, #3a7bff);
				color: white;
				border: none;
				box-shadow: 0 12px 24px rgba(31, 79, 255, 0.22);
			}
			.success {
				background: linear-gradient(135deg, #177245, #2ba56a);
				color: white;
				border: none;
				box-shadow: 0 12px 24px rgba(23, 114, 69, 0.2);
			}
			.secondary {
				background: white;
				color: rgb(var(--gray-dark));
				border: 1px solid rgb(var(--gray-light));
			}
			.danger {
				background: #fff1f2;
				color: #9f1239;
				border: 1px solid #fecdd3;
			}
			.primary:hover,
			.secondary:hover,
			.success:hover,
			.danger:hover {
				transform: translateY(-1px);
			}
			.notice {
				padding: 0.95rem 1rem;
				border-radius: 14px;
				background: rgba(35, 55, 255, 0.08);
				color: var(--accent-dark);
			}
			.table-wrap {
				overflow-x: auto;
			}
			table {
				width: 100%;
				border-collapse: separate;
				border-spacing: 0;
				font-size: 0.98rem;
			}
			th,
			td {
				padding: 1rem 0.85rem;
				text-align: left;
				border-bottom: 1px solid rgb(var(--gray-light));
				vertical-align: top;
			}
			th {
				font-size: 0.78rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
			}
			tbody tr:hover {
				background: rgba(35, 55, 255, 0.03);
			}
			.status-pill {
				display: inline-block;
				padding: 0.24rem 0.58rem;
				border-radius: 999px;
				background: rgba(35, 55, 255, 0.1);
				color: var(--accent-dark);
				font-size: 0.78rem;
				font-weight: 700;
				text-transform: uppercase;
			}
			.inline-form {
				margin: 0;
			}
			.section-box {
				padding: 1rem;
				border-radius: 16px;
				background: rgba(var(--gray-light), 0.35);
				border: 1px solid rgba(var(--gray-light), 0.9);
			}
			.check-grid {
				display: grid;
				gap: 0.7rem;
				margin-top: 0.8rem;
			}
			.check-grid label {
				font-weight: 500;
				font-size: 0.95rem;
			}
			@media (max-width: 960px) {
				.cms-shell,
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="cms-shell">
			<aside class="panel">
				<AdminNav />
			</aside>

			<div class="main-stack">
				<section class="panel">
					<div class="toolbar">
						<div>
							<h1>Pages</h1>
							<p class="muted">Manage landing pages and reusable route content.</p>
						</div>
						<div class="toolbar">
							<a class="success" href="/admin/pages">New page</a>
							<a href="/">View site</a>
						</div>
					</div>

					{Astro.url.searchParams.get("pageSaved") && <p class="notice">Page saved.</p>}
					{Astro.url.searchParams.get("pageDeleted") && <p class="notice">Page deleted.</p>}
					{Astro.url.searchParams.get("pageError") && <p class="notice">The page request failed.</p>}
					{loadError && <p class="notice">{loadError}</p>}

					<div class="table-wrap">
						<table>
							<thead>
								<tr>
									<th>Title</th>
									<th>Status</th>
									<th>Updated</th>
									<th>Slug</th>
									<th>Actions</th>
								</tr>
							</thead>
							<tbody>
								{
									pages.map((page) => (
										<tr>
											<td>
												<strong>{page.title}</strong>
												<br />
												<span class="muted">{page.description}</span>
											</td>
											<td><span class="status-pill">{page.status}</span></td>
											<td><FormattedDate date={page.updatedAt} /></td>
											<td><code>{page.slug}</code></td>
											<td>
												<div class="row-actions-inline">
													<a href={`/admin/pages?slug=${page.slug}`}>Edit</a>
													<a href={`/${page.slug}/`}>View</a>
													<form class="inline-form" method="post" action="/api/admin/pages/delete">
														<input type="hidden" name="id" value={page.id} />
														<button class="danger" type="submit">Delete</button>
													</form>
												</div>
											</td>
										</tr>
									))
								}
							</tbody>
						</table>
					</div>
				</section>

				<section class="panel">
					<div class="toolbar">
						<h2>{selectedPage ? "Edit Page" : "Create Page"}</h2>
						{getAdminToken(Astro.locals) && (
							<form method="post" action="/api/admin/logout">
								<button class="secondary" type="submit">Log out</button>
							</form>
						)}
					</div>

					<form class="editor" method="post" action="/api/admin/pages">
						{selectedPage && <input type="hidden" name="id" value={selectedPage.id} />}
						<div class="grid">
							<label><span>Title</span><input name="title" required value={selectedPage?.title ?? ""} disabled={Boolean(loadError)} /></label>
							<label><span>Slug</span><input name="slug" required pattern="[a-z0-9-]+" value={selectedPage?.slug ?? ""} placeholder="services" disabled={Boolean(loadError)} /></label>
							<label><span>Description</span><input name="description" required value={selectedPage?.description ?? ""} placeholder="Page summary" disabled={Boolean(loadError)} /></label>
							<label><span>Status</span><select name="status" disabled={Boolean(loadError)}><option value="published" selected={selectedPage?.status !== "draft"}>Published</option><option value="draft" selected={selectedPage?.status === "draft"}>Draft</option></select></label>
						</div>
						<label><span>Page content</span><textarea name="contentMarkdown" required disabled={Boolean(loadError)}>{selectedPage?.contentMarkdown ?? "# New page"}</textarea></label>
						<div class="section-box">
							<span>Page sections</span>
							<div class="check-grid">
								<label><span><input type="checkbox" name="pageSections" value="blog_feed" checked={selectedPage?.pageSections.includes("blog_feed")} disabled={Boolean(loadError)} /> Blog feed grid</span></label>
								<label><span><input type="checkbox" name="pageSections" value="nav_grid" checked={selectedPage?.pageSections.includes("nav_grid")} disabled={Boolean(loadError)} /> Navigation card grid</span></label>
								<label><span><input type="checkbox" name="pageSections" value="page_grid" checked={selectedPage?.pageSections.includes("page_grid")} disabled={Boolean(loadError)} /> Other pages grid</span></label>
							</div>
							<p class="muted">Tick as many sections as you want. They render below the main page content.</p>
						</div>
						<div class="row-actions">
							<button class="primary" type="submit" disabled={Boolean(loadError)}>{selectedPage ? "Save page" : "Create page"}</button>
							{selectedPage && <a href={`/${selectedPage.slug}/`}>Open page</a>}
						</div>
					</form>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
