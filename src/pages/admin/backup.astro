---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";
import { getD1BackupConfig, isD1BackupConfigured, listD1TableNames } from "../../lib/backup";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);
const env = Astro.locals.runtime.env as Record<string, string | undefined>;
const backupConfigured = isD1BackupConfigured(env);
const backupConfig = getD1BackupConfig(env);
const pageTitle = t("nav.backup", "Backup");
const description = t(
	"messages.backupHelp",
	"Export the live D1 database as an SQL file for recovery, migration, or archival backups.",
);

let tableNames: string[] = [];
let tableLoadError = "";

try {
	tableNames = await listD1TableNames(getDb(Astro.locals));
} catch (error) {
	tableLoadError = error instanceof Error ? error.message : "Failed to load table names.";
}
---

<AdminLayout
	title={pageTitle}
	description={description}
	session={session}
	pageTitle={pageTitle}
	pageDescription={description}
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("exportError") && (
			<p class="alert alert-danger mb-0">{Astro.url.searchParams.get("exportError")}</p>
		)}
		{Astro.url.searchParams.get("imported") && (
			<p class="alert alert-success mb-0">SQL import completed successfully.</p>
		)}
		{Astro.url.searchParams.get("importError") && (
			<p class="alert alert-danger mb-0">{Astro.url.searchParams.get("importError")}</p>
		)}
		<div class="admin-form-surface">
			<div class="admin-surface-header mb-3">
				<div>
					<h1 class="h4 mb-1">{pageTitle}</h1>
					<p class="admin-inline-muted mb-0">{description}</p>
				</div>
			</div>

			{!backupConfigured && (
				<div class="alert alert-danger mb-3">
					{t(
						"messages.backupUnavailable",
						"Backup export is not configured. Set CLOUDFLARE_ACCOUNT_ID and CLOUDFLARE_API_TOKEN as secrets, and optionally D1_DATABASE_ID.",
					)}
				</div>
			)}

			{tableLoadError && <div class="alert alert-warning mb-3">{tableLoadError}</div>}

			<div class="row g-4">
				<div class="col-12 col-lg-7">
					<div class="backup-card">
						<div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
							<div>
								<h2 class="h5 mb-1">Export backup</h2>
								<p class="text-body-secondary mb-0">
									Leave the table list empty to export the full database. Select one or more tables to export only those tables.
								</p>
							</div>
							<a class="btn btn-outline-secondary" href="/admin/settings">
								{t("actions.back", "Back")}
							</a>
						</div>

						<form action="/api/admin/backup/export" method="post" class="admin-form-stack">
							<label class="form-label fw-semibold" for="backupTables">Tables</label>
							<select
								id="backupTables"
								class="form-select"
								name="tables"
								multiple
								size={Math.min(Math.max(tableNames.length, 4), 10)}
								disabled={!backupConfigured || tableNames.length === 0}
							>
								{tableNames.map((tableName) => <option value={tableName}>{tableName}</option>)}
							</select>
							<p class="form-text mb-0">
								Hold Ctrl on Windows or Command on Mac to select multiple tables.
							</p>
							<div class="d-flex flex-wrap gap-2 align-items-center">
								<button type="submit" class="btn btn-primary" disabled={!backupConfigured}>
									{tableNames.length > 0 ? "Download backup" : "Download full backup"}
								</button>
								<span class="text-body-secondary small">
									{tableNames.length > 0
										? `${tableNames.length} tables available for selection`
										: "Table list unavailable, full export remains available."}
								</span>
							</div>
						</form>
					</div>
				</div>

				<div class="col-12 col-lg-5">
					<div class="backup-card">
						<h2 class="h5 mb-3">Import SQL</h2>
						<p class="text-body-secondary">
							Upload an SQL file to import data into the live D1 database. This action blocks the database while it runs.
						</p>
						<form action="/api/admin/backup/import" method="post" enctype="multipart/form-data" class="admin-form-stack">
							<label class="form-label fw-semibold" for="sqlFile">SQL file</label>
							<input id="sqlFile" class="form-control" type="file" name="sqlFile" accept=".sql,text/sql,application/sql" disabled={!backupConfigured} />
							<p class="form-text mb-0">Use a file exported from D1 or any compatible SQLite SQL dump.</p>
							<button type="submit" class="btn btn-warning" disabled={!backupConfigured}>
								Import SQL
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>

		<div class="admin-form-surface">
			<h2 class="h5 mb-3">{t("labels.details", "Details")}</h2>
			<ul class="mb-0 text-muted">
				<li>{t("messages.backupIncludesSchema", "The export includes the current D1 schema and data as SQL.")}</li>
				<li>{t("messages.backupDownloadHint", "When the backup is ready, your browser will download a .sql file directly.")}</li>
				<li>{t("messages.backupConfigHint", `Current database ID: ${backupConfig?.databaseId ?? "not set"}`)}</li>
				<li>Selected-table export uses Cloudflare D1 dump options and keeps the SQL importable.</li>
				<li>SQL import is processed directly by Cloudflare D1 using the uploaded file.</li>
			</ul>
		</div>
	</div>
</AdminLayout>

<style>
	.backup-card {
		height: 100%;
		padding: 1.25rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98));
		box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
	}

	.admin-form-stack {
		display: grid;
		gap: 0.875rem;
	}
</style>
