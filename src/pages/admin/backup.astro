---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import FeedbackModal from "../../components/admin/FeedbackModal.astro";
import { getDb } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";
import { getD1BackupConfig, isD1BackupConfigured, listD1TableNames } from "../../lib/backup";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);
const env = Astro.locals.runtime.env as Record<string, string | undefined>;
const backupConfigured = isD1BackupConfigured(env);
const backupConfig = getD1BackupConfig(env);
const pageTitle = t("nav.backup", "Backup");
const description = t(
	"messages.backupHelp",
	"Export the live D1 database as an SQL file for recovery, migration, or archival backups.",
);
const exportTitle = t("messages.backupExportTitle", "Export SQL backup");
const exportHelp = t(
	"messages.backupExportHelp",
	"Download a portable SQL backup of the live database. Use the full export by default, or optionally narrow the export to selected tables.",
);
const tablesLabel = t("labels.tables", "Tables");
const downloadLabel = t("actions.downloadBackup", "Download selected tables");
const downloadFullLabel = t("actions.downloadFullBackup", "Download full SQL backup");
const importTitle = t("messages.backupImportTitle", "Restore from SQL backup");
const importHelp = t(
	"messages.backupImportHelp",
	"Upload an SQL file and apply it to the live D1 database. This can overwrite live content and should be used carefully.",
);
const sqlFileLabel = t("labels.sqlFile", "SQL file");
const tableSelectHelp = t(
	"messages.backupTableSelectHelp",
	"Hold Ctrl on Windows or Command on Mac to select multiple tables.",
);
const backupStatusTitle = t("messages.backupStatusTitle", "Status update");
const tablesAvailableLabel = t("messages.backupTablesAvailable", "{count} tables available for selection");
const noTableListLabel = t(
	"messages.backupNoTableList",
	"Table list unavailable, full export remains available.",
);

let tableNames: string[] = [];
let tableLoadError = "";

try {
	tableNames = await listD1TableNames(getDb(Astro.locals));
} catch (error) {
	tableLoadError = error instanceof Error ? error.message : "Failed to load table names.";
}

const backupFeedback = [
	["exportError", { title: t("messages.backupExportFailedTitle", "Export failed"), message: Astro.url.searchParams.get("exportError") || t("messages.backupExportFailed", "Backup export failed."), tone: "error" }],
	["imported", { title: t("messages.backupImportCompletedTitle", "Import completed"), message: t("messages.backupImportCompleted", "SQL import completed successfully."), tone: "success" }],
	["importError", { title: t("messages.backupImportFailedTitle", "Import failed"), message: Astro.url.searchParams.get("importError") || t("messages.backupImportFailed", "SQL import failed."), tone: "error" }],
] as const;
---

<AdminLayout
	title={pageTitle}
	description={description}
	session={session}
	pageTitle={pageTitle}
	pageDescription={description}
>
	<div class="admin-content-stack">
	<FeedbackModal id="backup-feedback-modal" title={backupStatusTitle} closeLabel={t("actions.close", "Close")} />
		<div class="admin-form-surface">
			<div class="admin-surface-header mb-3">
				<div>
					<h1 class="h4 mb-1">{pageTitle}</h1>
					<p class="admin-inline-muted mb-0">Use export for routine safekeeping. Use restore only when you intentionally need to replace live data.</p>
				</div>
			</div>

			{!backupConfigured && (
				<div class="alert alert-danger mb-3">
					{t(
						"messages.backupUnavailable",
						"Backup export is not configured. Set CLOUDFLARE_ACCOUNT_ID and CLOUDFLARE_API_TOKEN as secrets, and optionally D1_DATABASE_ID.",
					)}
				</div>
			)}

			<div class="row g-4">
				<div class="col-12 col-lg-7">
					<div class="backup-card">
						<div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
							<div>
								<h2 class="h5 mb-1">{exportTitle}</h2>
								<p class="text-body-secondary mb-0">{exportHelp}</p>
							</div>
							<a class="btn btn-outline-secondary" href="/admin/settings">
								{t("actions.back", "Back")}
							</a>
						</div>

						<form action="/api/admin/backup/export" method="post" class="admin-form-stack">
							<div class="d-flex flex-wrap gap-2 align-items-center">
								<button type="submit" class="btn btn-primary" disabled={!backupConfigured}>{downloadFullLabel}</button>
								<span class="text-body-secondary small">
									Includes schema and data in one SQL file.
								</span>
							</div>
							{tableNames.length > 0 ? (
								<details class="backup-advanced-options">
									<summary class="backup-advanced-summary">Advanced: export selected tables only</summary>
									<div class="backup-advanced-body">
										<label class="form-label fw-semibold" for="backupTables">{tablesLabel}</label>
										<select
											id="backupTables"
											class="form-select"
											name="tables"
											multiple
											size={Math.min(Math.max(tableNames.length, 4), 10)}
											disabled={!backupConfigured}
										>
											{tableNames.map((tableName) => <option value={tableName}>{tableName}</option>)}
										</select>
										<p class="form-text mb-0">{tableSelectHelp}</p>
										<div class="d-flex flex-wrap gap-2 align-items-center">
											<button type="submit" class="btn btn-outline-secondary" disabled={!backupConfigured}>
												{downloadLabel}
											</button>
											<span class="text-body-secondary small">{tablesAvailableLabel.replace("{count}", String(tableNames.length))}</span>
										</div>
									</div>
								</details>
							) : (
								<p class="form-text mb-0">{noTableListLabel}</p>
							)}
						</form>
					</div>
				</div>

				<div class="col-12 col-lg-5">
					<div class="backup-card backup-card-warning">
						<h2 class="h5 mb-3">{importTitle}</h2>
						<p class="text-body-secondary">{importHelp}</p>
						<div class="backup-restore-warning">
							<strong>Before restoring</strong>
							<p class="mb-0 small text-body-secondary">Confirm the SQL file is the exact backup you want to apply. The live database is locked while the restore runs.</p>
						</div>
						<form
							action="/api/admin/backup/import"
							method="post"
							enctype="multipart/form-data"
							class="admin-form-stack"
							data-admin-confirm-form
							data-confirm-title="Restore live database from SQL backup?"
							data-confirm-message="This will apply the uploaded SQL file to the live database."
							data-confirm-detail="Make sure you exported a fresh backup first if you may need to roll back."
							data-confirm-confirm-label="Restore database"
							data-confirm-tone="warning"
						>
							<label class="form-label fw-semibold" for="sqlFile">{sqlFileLabel}</label>
							<input id="sqlFile" class="form-control" type="file" name="sqlFile" accept=".sql,text/sql,application/sql" disabled={!backupConfigured} />
							<p class="form-text mb-0">Use a file exported from D1 or any compatible SQLite SQL dump.</p>
							<button type="submit" class="btn btn-warning" disabled={!backupConfigured}>
								Restore database
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>

		<div class="admin-form-surface">
			<h2 class="h5 mb-3">{t("labels.details", "Details")}</h2>
			<ul class="mb-0 text-muted">
				<li>{t("messages.backupIncludesSchema", "The export includes the current D1 schema and data as SQL.")}</li>
				<li>{t("messages.backupDownloadHint", "When the backup is ready, your browser will download a .sql file directly.")}</li>
				<li>{t("messages.backupConfigHint", `Current database ID: ${backupConfig?.databaseId ?? "not set"}`)}</li>
			<li>{t("messages.backupSelectedTablesNote", "Selected-table export uses Cloudflare D1 dump options and keeps the SQL importable.")}</li>
			<li>{t("messages.backupImportNote", "SQL import is processed directly by Cloudflare D1 using the uploaded file.")}</li>
			</ul>
		</div>
	</div>
</AdminLayout>

<script type="module" define:vars={{ backupFeedback, tableLoadError }}>
	const showFeedbackModal = window.showAdminFeedbackModal;
	const search = new URLSearchParams(window.location.search);

	for (const [key, entry] of backupFeedback) {
		if (search.has(key)) {
			if (typeof showFeedbackModal === "function") {
				const detail =
					key === "imported"
						? `Imported ${search.get("imported") ?? 0}, updated ${search.get("updated") ?? 0}.`
						: "";
				showFeedbackModal({ title: entry.title, message: entry.message, detail, tone: entry.tone });
			}
			window.history.replaceState({}, "", window.location.pathname + window.location.hash);
			break;
		}
	}

	if (tableLoadError && typeof showFeedbackModal === "function") {
		showFeedbackModal({
			title: t("messages.backupTableListUnavailableTitle", "Table list unavailable"),
			message: tableLoadError,
			tone: "warning",
		});
	}
</script>

<style>
	.backup-card {
		height: 100%;
		padding: 1.25rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98));
		box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
	}

	.admin-form-stack {
		display: grid;
		gap: 0.875rem;
	}

	.backup-card-warning {
		border-color: rgba(245, 158, 11, 0.28);
		background: linear-gradient(180deg, rgba(255, 251, 235, 0.98), rgba(255, 255, 255, 0.98));
	}

	.backup-advanced-options {
		display: grid;
		gap: 0.75rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0.9rem;
		background: rgba(248, 250, 252, 0.76);
	}

	.backup-advanced-summary {
		padding: 0.85rem 0.95rem;
		cursor: pointer;
		font-weight: 600;
	}

	.backup-advanced-body {
		display: grid;
		gap: 0.875rem;
		padding: 0 0.95rem 0.95rem;
	}

	.backup-restore-warning {
		display: grid;
		gap: 0.25rem;
		padding: 0.85rem 0.95rem;
		border-radius: 0.85rem;
		background: rgba(255, 247, 237, 0.9);
		border: 1px solid rgba(245, 158, 11, 0.2);
	}
</style>
