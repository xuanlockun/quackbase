---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getUiTranslations, localizeAdminHref } from "../../lib/i18n";
import {
	inspectWordPressSite,
	type WordPressInspectionResult,
} from "../../lib/wordpress";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);
const siteInput = (Astro.url.searchParams.get("site") ?? "").trim();
let inspection: WordPressInspectionResult | null = null;
let loadError = "";

if (siteInput) {
	try {
		inspection = await inspectWordPressSite(siteInput);
	} catch (error) {
		loadError = error instanceof Error ? error.message : t("messages.wordpressLookupFailed", "The WordPress lookup failed.");
	}
}

const resultCards = inspection?.items ?? [];
const successCount = resultCards.filter((item) => item.count !== null).length;
const resourceDescriptions: Record<string, string> = {
	Users: t("messages.wordpressUsersDescription", "Public authors and user accounts available for import."),
	Types: t("messages.wordpressTypesDescription", "Registered WordPress content types available from the source site."),
	Media: t("messages.wordpressMediaDescription", "Images, uploaded files, videos, PDFs, and other media assets."),
	Pages: t("messages.wordpressPagesDescription", "Static pages available to import from the source site."),
	Posts: t("messages.wordpressPostsDescription", "Posts and article entries available to import."),
};
---

<AdminLayout
	title={t("nav.wordpress", "WordPress")}
	description={t("messages.wordpressInspectorHelp", "Enter a WordPress site URL and review import totals before building migration tools.")}
	session={session}
	pageEyebrow={t("app.admin")}
	pageTitle={t("nav.wordpress", "WordPress")}
	pageDescription={t("messages.wordpressInspectorHelp", "Enter a WordPress site URL and review import totals before building migration tools.")}
>
	<div class="admin-content-stack wordpress-shell">
		<section class="admin-form-surface admin-stack-section wordpress-hero">
			<div class="wordpress-hero-copy">
				<p class="wordpress-kicker mb-1">{t("messages.wordpressInspectorKicker", "WordPress import source")}</p>
				<h2 class="h4 mb-2">{t("messages.wordpressInspectorTitle", "Review WordPress import totals")}</h2>
				<p class="mb-0 text-body-secondary">
					{t("messages.wordpressInspectorBody", "This step only checks import totals for users, content types, media, pages, and posts. Migration can be added later.")}
				</p>
			</div>
			<form method="get" action={localizeAdminHref("/admin/wordpress")} class="wordpress-form">
				<label class="form-label fw-semibold" for="wordpress-site">
					{t("labels.wordpressSiteUrl", "Enter URL WordPress site")}
				</label>
				<div class="wordpress-form-row">
					<input
						id="wordpress-site"
						name="site"
						type="url"
						inputmode="url"
						class="form-control"
						placeholder="https://example.com"
						value={siteInput}
						required
					/>
					<button type="submit" class="btn btn-primary">
						{t("actions.checkWordpressCounts", "Load import totals")}
					</button>
				</div>
				<p class="admin-inline-muted mb-0">
					{t("messages.wordpressInspectorInputHelp", "Example: https://your-wordpress-site.com")}
				</p>
			</form>
		</section>

		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}

		{inspection && (
			<>
				<section class="admin-form-surface admin-stack-section wordpress-summary">
					<div>
						<p class="wordpress-summary-label mb-1">{t("messages.wordpressSourceLabel", "Import source")}</p>
						<h3 class="h5 mb-1 text-break">{inspection.siteUrl}</h3>
						<p class="mb-0 text-body-secondary">{t("messages.wordpressSourceHelp", "Public WordPress data available for import review.")}</p>
					</div>
					<div class="wordpress-summary-badge">
						<strong>{successCount}/{resultCards.length}</strong>
						<span>{t("messages.wordpressChecksCompleted", "resources ready")}</span>
					</div>
				</section>

				<section class="admin-form-surface admin-stack-section">
					<div class="wordpress-results-grid">
						{resultCards.map((item) => (
							<article class="wordpress-result-card">
								<div class="wordpress-result-head">
									<div>
										<h3 class="h6 mb-1">{item.label}</h3>
										<p class="mb-0 text-body-secondary">
											{resourceDescriptions[item.label] ?? t("messages.wordpressDefaultDescription", "WordPress resource available for import review.")}
										</p>
									</div>
									<span class:list={["badge", item.error ? "text-bg-warning" : "text-bg-success"]}>
										{item.error ? t("messages.wordpressNeedsReview", "Needs review") : t("messages.wordpressCountAvailable", "Ready")}
									</span>
								</div>
								<div class="wordpress-result-body">
									<p class="wordpress-result-label mb-1">{t("labels.importCount", "Import count")}</p>
									<strong class="wordpress-result-value">{item.count ?? "-"}</strong>
								</div>
								{item.error && <p class="mb-0 small text-warning-emphasis">{item.error}</p>}
							</article>
						))}
					</div>
				</section>
			</>
		)}
	</div>
</AdminLayout>

<style>
	.wordpress-shell {
		display: grid;
		gap: 1rem;
	}

	.wordpress-hero,
	.wordpress-summary {
		display: grid;
		gap: 1rem;
	}

	.wordpress-kicker,
	.wordpress-summary-label {
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(15, 23, 42, 0.58);
	}

	.wordpress-form {
		display: grid;
		gap: 0.65rem;
	}

	.wordpress-form-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.65rem;
		align-items: center;
	}

	.wordpress-summary {
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
	}

	.wordpress-summary-badge {
		display: grid;
		justify-items: center;
		padding: 0.9rem 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1rem;
		background: rgba(248, 250, 252, 0.92);
		min-width: 8rem;
	}

	.wordpress-summary-badge strong {
		font-size: 1.2rem;
		line-height: 1.1;
	}

	.wordpress-summary-badge span {
		font-size: 0.85rem;
		color: rgba(15, 23, 42, 0.64);
	}

	.wordpress-results-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 0.9rem;
	}

	.wordpress-result-card {
		display: grid;
		gap: 0.9rem;
		padding: 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.96));
	}

	.wordpress-result-head {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.wordpress-result-body {
		display: grid;
		gap: 0.2rem;
	}

	.wordpress-result-label {
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgba(15, 23, 42, 0.54);
	}

	.wordpress-result-value {
		font-size: 1.55rem;
		line-height: 1.05;
		font-weight: 700;
	}

	@media (max-width: 767.98px) {
		.wordpress-form-row,
		.wordpress-summary {
			grid-template-columns: 1fr;
		}

		.wordpress-form-row .btn {
			width: 100%;
		}

		.wordpress-summary-badge {
			justify-items: start;
		}
	}
</style>
