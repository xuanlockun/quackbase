---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import LanguageForm from "../../components/admin/LanguageForm.astro";
import LanguageTable from "../../components/admin/LanguageTable.astro";
import CreateSubmit from "../../components/admin/CreateSubmit.astro";
import languageManagerScript from "../../components/admin/language-manager.ts?url";
import translationManagerScript from "../../components/admin/translation-manager.js?url";
import { getDb } from "../../lib/blog";
import { getLanguageByCode, listAllLanguages, listEnabledLanguages } from "../../lib/languages";
import { getUiTranslations } from "../../lib/i18n";
import type { AdminSession } from "../../lib/auth/types";

const session: AdminSession | null = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

let languages = [];
let selectedLanguage = null;
let enabledLanguages = [];
let loadError = "";
const { t } = getUiTranslations(Astro);
const searchLocale = (Astro.url.searchParams.get("locale") ?? "").toLowerCase().trim();

try {
	const db = getDb(Astro.locals);
	languages = await listAllLanguages(db);
	selectedLanguage =
		(searchLocale && (await getLanguageByCode(db, searchLocale))) ||
		languages.find((language) => language.isDefault) ||
		languages[0] ||
		null;
	enabledLanguages = await listEnabledLanguages(db);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.languageRequestFailed");
}

const editorLanguages = [
	{
		code: selectedLanguage?.code ?? enabledLanguages[0]?.code ?? languages[0]?.code ?? "en",
		label: selectedLanguage?.name ?? enabledLanguages[0]?.name ?? languages[0]?.name ?? "English",
		isActive: true,
	},
	...enabledLanguages
		.filter((entry) => entry.code !== selectedLanguage?.code)
		.map((entry) => ({ code: entry.code, label: entry.name, isActive: false })),
];
const selectedLocale = editorLanguages[0]?.code ?? "";
const headingTitle = t("headings.languages");
const translationSectionTitle = t("labels.translationEntry", "Create translation entry");
const addButtonLabel = t("actions.addTranslation", "Create translation entry");
const keyLabel = t("labels.translationKey");
const valueLabel = t("labels.translationValue");
const translationTabsLabel = t("labels.languages", "Languages");
const addLanguageTitle = t("actions.addLanguage", "Add language");
const languageFeedback = [
	["imported", { title: t("messages.languageImportCompletedTitle", "Import completed"), message: t("messages.languageImportCompleted", "Language JSON import completed."), tone: "success" }],
	["importError", { title: t("messages.languageImportFailedTitle", "Import failed"), message: Astro.url.searchParams.get("importError") || t("messages.languageImportFailed", "Language JSON import failed."), tone: "error" }],
] as const;
---

<AdminLayout
	title={headingTitle}
	description={t("messages.manageLanguagesHelp")}
	session={session}
	pageTitle={headingTitle}
	pageDescription={t("messages.manageLanguagesHelp")}
>
	<div class="admin-content-stack">
		{loadError && <p class="alert alert-warning mb-0">{loadError}</p>}
		<div class="admin-form-surface">
			<div class="admin-surface-header mb-3">
				<div>
					<h2 class="h5 mb-1">{t("messages.languageJsonTools", "Language JSON tools")}</h2>
					<p class="admin-inline-muted mb-0">{t("messages.languageJsonToolsHelp", "Export languages and translations as JSON, or import a JSON bundle to merge updates into this workspace.")}</p>
				</div>
			</div>
			<div class="d-flex flex-wrap gap-3 align-items-end justify-content-between">
				<a class="btn btn-outline-secondary" href="/api/admin/languages/translations/export">
					{t("actions.exportLanguagesJson", "Export JSON")}
				</a>
				<form method="post" action="/api/admin/languages/translations/import" enctype="multipart/form-data" class="d-flex flex-wrap gap-2 align-items-end">
					<label class="d-grid gap-1">
						<span class="small text-muted">{t("messages.languageJsonFileLabel", "JSON file")}</span>
						<input class="form-control" type="file" name="translationsFile" accept="application/json,.json" required />
					</label>
					<button class="btn btn-primary" type="submit">{t("actions.importLanguagesJson", "Import JSON")}</button>
				</form>
			</div>
		</div>
		<div class="admin-form-surface">
			<LanguageTable
				languages={languages}
				tableMessages={{
					createSuccess: t("messages.languageCreated"),
					updateSuccess: t("messages.languageSaved"),
					error: t("messages.languageRequestFailed"),
				}}
				/>
		</div>
		<details class="admin-collapsible-surface admin-form-surface">
			<summary class="admin-collapsible-summary">
				<div>
					<h2 class="h5 mb-0">{addLanguageTitle}</h2>
				</div>
				<span class="admin-collapsible-toggle" aria-hidden="true"></span>
			</summary>
			<div class="admin-collapsible-body">
				<LanguageForm
					showHeader={false}
					formMessages={{
						success: t("messages.languageCreated"),
						error: t("messages.languageCreateFailed"),
					}}
				/>
			</div>
		</details>
			<details class="admin-collapsible-surface admin-form-surface" id="translations">
			<summary class="admin-collapsible-summary">
				<div>
					<h2 class="h5 mb-1">{translationSectionTitle}</h2>
				</div>
				<span class="admin-collapsible-toggle" aria-hidden="true"></span>
			</summary>
			<div class="admin-collapsible-body">
				<div class="admin-collapsible-toolbar mb-3">
					<label class="visually-hidden" for="translation-locale-select">{t("labels.language")}</label>
					<select
						id="translation-locale-select"
						class="form-select form-select-sm w-auto"
						data-translation-locale-select
					>
						{
							languages.map((language) => (
								<option value={language.code} selected={language.code === selectedLocale}>
									{language.name}
								</option>
							))
						}
					</select>
				</div>

				<div class="mb-3" data-translation-notice aria-live="polite"></div>
				<form
					data-translation-form
					class="row g-3"
					data-current-locale={selectedLocale}
					data-language-tabs={JSON.stringify(editorLanguages)}
					data-api-base-template="/api/admin/languages/__locale__/translations"
					data-text-add-button={addButtonLabel}
					data-text-create-success={t("messages.translationCreateSuccess")}
					data-text-required-key="Translation key is required."
					data-text-required-values="Enter at least one translation value."
					data-text-tablist={translationTabsLabel}
				>
					<div class="col-12 col-lg-4">
						<label class="form-label" for="translation-key">{keyLabel}</label>
						<input class="form-control" id="translation-key" name="key" required />
					</div>
					<div class="col-12">
						<div class="admin-form-surface p-3">
							<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
								<strong class="small text-uppercase text-muted">{translationTabsLabel}</strong>
								<span class="small text-muted">{valueLabel}</span>
							</div>
							<ul class="nav nav-tabs flex-wrap gap-1" role="tablist" data-translation-tablist>
								{
									editorLanguages.map((entry, index) => (
										<li class="nav-item" role="presentation">
											<button
												type="button"
												class:list={["nav-link", index === 0 && "active"]}
												data-translation-tab={entry.code}
												aria-selected={index === 0 ? "true" : "false"}
											>
												{entry.label}
											</button>
										</li>
									))
								}
							</ul>
							<div class="p-0 pt-3" data-translation-panels>
								{
									editorLanguages.map((entry, index) => (
										<section
											class:list={["translation-pane", index === 0 ? "" : "d-none"]}
											data-translation-panel={entry.code}
										>
											<label class="form-label" for={`translation-value-${entry.code}`}>{entry.label}</label>
											<textarea
												class="form-control"
												id={`translation-value-${entry.code}`}
												name={`value-${entry.code}`}
												rows="4"
											></textarea>
										</section>
									))
								}
							</div>
						</div>
					</div>
					<div class="col-12 d-flex flex-wrap gap-2">
						<CreateSubmit label={addButtonLabel} attrs={{ "data-translation-submit": "" }} />
					</div>
				</form>
			</div>
		</details>
	</div>

	<script type="module" src={languageManagerScript} client:load></script>
	<script type="module" src={translationManagerScript} client:load></script>
	<script type="module" define:vars={{ languageFeedback }}>
		const showFeedbackModal = window.showAdminFeedbackModal;
		const search = new URLSearchParams(window.location.search);

		for (const [key, entry] of languageFeedback) {
			if (search.has(key)) {
				const message =
					key === "imported"
						? `${entry.message} ${search.get("languagesUpdated") ?? 0} languages, ${search.get("translationsUpdated") ?? 0} translation keys.`
						: search.get(key) || entry.message;
				if (typeof showFeedbackModal === "function") {
					showFeedbackModal({ title: entry.title, message, tone: entry.tone });
				}
				window.history.replaceState({}, "", window.location.pathname + window.location.hash);
				break;
			}
		}
	</script>
</AdminLayout>
