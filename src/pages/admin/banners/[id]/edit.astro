---
export const prerender = false;

import BannerForm from "../../../../components/admin/BannerForm.astro";
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import { getDb } from "../../../../lib/blog";
import { getBannerById } from "../../../../lib/banners";
import { getUiTranslations } from "../../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canUpdate = session.isSuperadmin || session.permissions.includes("banners.manage");
const { id } = Astro.params;
const { t } = getUiTranslations(Astro);

let banner = null;
let loadError = "";
let notFound = false;

try {
	const bannerId = Number(id);
	if (!Number.isInteger(bannerId) || bannerId <= 0) {
		notFound = true;
	} else {
		banner = await getBannerById(getDb(Astro.locals), bannerId);
		notFound = !banner;
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadBanners");
}

if (Astro.url.searchParams.get("error")) {
	loadError = t("messages.bannerRequestFailed");
}
---

<AdminLayout
	title={t("actions.editBanner")}
	description={t("messages.saveEditBanner")}
	session={session}
	pageTitle={t("actions.editBanner")}
	pageDescription={t("messages.saveEditBanner")}
>
	<div class="admin-content-stack">
		{
			notFound ? (
				<div class="admin-empty-state">
					<h2>{t("messages.bannerNotFound")}</h2>
					<p class="admin-muted">{t("messages.failedToLoadBanners")}</p>
					<p><a class="btn btn-outline-secondary" href="/admin/banners">{t("messages.backToBanners")}</a></p>
				</div>
			) : (
				<BannerForm mode="edit" action="/api/admin/banners" banner={banner} canSubmit={canUpdate} loadError={loadError} />
			)
		}
	</div>
</AdminLayout>
