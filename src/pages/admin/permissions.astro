---
export const prerender = false;

import PermissionBadge from "../../components/admin/PermissionBadge.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listPermissions } from "../../lib/db/permissions";
import { getDb } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const permissions = await listPermissions(getDb(Astro.locals));
const groupedPermissions = Object.entries(
	permissions.reduce<Record<string, typeof permissions>>((groups, permission) => {
		groups[permission.resource] ??= [];
		groups[permission.resource].push(permission);
		return groups;
	}, {}),
);
const { t } = getUiTranslations(Astro);
---

<AdminLayout
	title={t("nav.permissions")}
	description={t("messages.managePermissions")}
	session={session}
	pageTitle={t("headings.permissionCatalog")}
	pageDescription={t("messages.permissionCatalogDescription")}
>
	<section class="admin-card-stack">
		{
			groupedPermissions.map(([resource, resourcePermissions]) => (
				<article class="admin-resource-card">
					<h2 class="h5 mb-3 text-capitalize">{resource}</h2>
					<div class="permission-badge-row">
						{resourcePermissions.map((permission) => (
							<div class="permission-entry">
								<PermissionBadge label={permission.label} resource={permission.resource} />
								<p><code>{permission.name}</code></p>
								<p class="admin-muted">{permission.description}</p>
							</div>
						))}
					</div>
				</article>
			))
		}
	</section>
</AdminLayout>

<style>
	.permission-badge-row {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 0.75rem;
	}

	.permission-entry {
		display: grid;
		gap: 0.35rem;
		padding: 0.85rem;
		border: 1px solid rgba(var(--gray), 0.16);
		background: #f7f8fa;
		border-radius: 0.75rem;
	}

	.permission-entry p {
		margin: 0;
	}

	code {
		font-size: 0.82rem;
	}
</style>
