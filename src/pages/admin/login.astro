---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

const error = Astro.url.searchParams.get("error");
const errorMessage =
	error === "access-denied"
		? "Your account authenticated, but it does not currently have admin access."
		: error === "invalid"
			? "The email or password was invalid."
			: "";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Admin Login | ${SITE_TITLE}`} description="Sign in to manage Edge CMS." />
		<style>
			.panel {
				max-width: 540px;
				margin: 2rem auto;
				padding: 2rem;
				background: white;
				border-radius: 18px;
				box-shadow: var(--box-shadow);
			}
			form,
			label {
				display: grid;
				gap: 1rem;
			}
			input,
			button {
				font: inherit;
				padding: 0.85rem 1rem;
				border-radius: 12px;
				border: 1px solid rgb(var(--gray-light));
			}
			button {
				background: var(--accent);
				color: white;
				border: none;
				cursor: pointer;
			}
			.error {
				color: #a61b29;
				margin: 0;
			}
			.muted {
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="panel">
				<h1>Admin Login</h1>
				<p class="muted">Sign in with your admin email and password to access the CMS dashboard.</p>
				{errorMessage && <p class="error">{errorMessage}</p>}
				<form method="post" action="/api/admin/auth/login">
					<label>
						<span>Email</span>
						<input type="email" name="email" autocomplete="username" required />
					</label>
					<label>
						<span>Password</span>
						<input type="password" name="password" autocomplete="current-password" required />
					</label>
					<button type="submit">Sign in</button>
				</form>
			</section>
		</main>
		<Footer />
	</body>
</html>
