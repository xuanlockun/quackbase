---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";
import { getUiTranslations } from "../../lib/i18n";

const error = Astro.url.searchParams.get("error");
const { language, t } = getUiTranslations(Astro);
const errorMessage =
	error === "access-denied"
		? t("messages.accessDenied")
		: error === "invalid"
			? t("messages.invalidCredentials")
			: "";
---

<!doctype html>
<html lang={language}>
	<head>
		<BaseHead title={`${t("headings.adminLogin")} | ${SITE_TITLE}`} description={t("messages.signInIntro")} />
		<style>
			.panel {
				max-width: 540px;
				margin: 2rem auto;
				padding: 2rem;
				background: white;
				border-radius: 18px;
				box-shadow: var(--box-shadow);
			}
			form,
			label {
				display: grid;
				gap: 1rem;
			}
			input,
			button {
				font: inherit;
				padding: 0.85rem 1rem;
				border-radius: 12px;
				border: 1px solid rgb(var(--gray-light));
			}
			button {
				background: var(--accent);
				color: white;
				border: none;
				cursor: pointer;
			}
			.error {
				color: #a61b29;
				margin: 0;
			}
			.muted {
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="panel">
				<h1>{t("headings.adminLogin")}</h1>
				<p class="muted">{t("messages.signInIntro")}</p>
				{errorMessage && <p class="error">{errorMessage}</p>}
				<form method="post" action="/api/admin/auth/login">
					<label>
						<span>{t("labels.email")}</span>
						<input type="email" name="email" autocomplete="username" required />
					</label>
					<label>
						<span>{t("labels.password")}</span>
						<input type="password" name="password" autocomplete="current-password" required />
					</label>
					<button type="submit">{t("actions.signIn")}</button>
				</form>
			</section>
		</main>
		<Footer />
	</body>
</html>
