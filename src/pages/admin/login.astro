---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
import { getAdminToken, isAdminAuthenticated } from "../../lib/blog";

const hasToken = Boolean(getAdminToken(Astro.locals));
if (!hasToken || isAdminAuthenticated(Astro.request, Astro.locals)) {
	return Astro.redirect("/admin");
}

const error = Astro.url.searchParams.get("error");
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Admin Login | ${SITE_TITLE}`} description="Sign in to manage blog posts." />
		<style>
			.panel {
				max-width: 520px;
				margin: 2rem auto;
				padding: 2rem;
				background: white;
				border-radius: 18px;
				box-shadow: var(--box-shadow);
			}
			form {
				display: grid;
				gap: 1rem;
			}
			label {
				display: grid;
				gap: 0.5rem;
			}
			input,
			button {
				font: inherit;
				padding: 0.85rem 1rem;
				border-radius: 12px;
				border: 1px solid rgb(var(--gray-light));
			}
			button {
				background: var(--accent);
				color: white;
				border: none;
				cursor: pointer;
			}
			.error {
				color: #a61b29;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="panel">
				<h1>Admin Login</h1>
				<p>Use the `CMS_ADMIN_TOKEN` secret to access the CMS.</p>
				{error && <p class="error">Invalid admin token.</p>}
				<form method="post" action="/api/admin/login">
					<label>
						<span>Admin token</span>
						<input type="password" name="token" required />
					</label>
					<button type="submit">Sign in</button>
				</form>
			</section>
		</main>
		<Footer />
	</body>
</html>
