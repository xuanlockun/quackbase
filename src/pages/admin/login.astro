---
export const prerender = false;

import AdminAuthLayout from "../../layouts/AdminAuthLayout.astro";
import { getDb } from "../../lib/blog";
import { ensureAdminBootstrapSchema } from "../../lib/db/admin-bootstrap";
import { getUiTranslations } from "../../lib/i18n";
import { countAdminUsers } from "../../lib/db/admin-users";

const error = Astro.url.searchParams.get("error");
const setupError = Astro.url.searchParams.get("setupError");
const { t } = getUiTranslations(Astro);
let needsInitialSetup = false;
let bootstrapError = "";

try {
	const db = getDb(Astro.locals);
	await ensureAdminBootstrapSchema(db);
	const adminUserCount = await countAdminUsers(db);
	needsInitialSetup = adminUserCount === 0;
} catch (error) {
	bootstrapError = error instanceof Error ? error.message : "Admin setup is unavailable right now.";
}

const errorMessage =
	error === "access-denied"
		? t("messages.accessDenied", "You do not have access to that page.")
		: error === "invalid"
			? t("messages.invalidCredentials", "The email or password is incorrect.")
			: "";
const setupErrorMessage = setupError || "";
const initialSetupTitle = t("messages.initialSetupTitle", "Initial setup");
const initialSetupHelp = t(
	"messages.initialSetupHelp",
	"Create the first admin account for this fresh install.",
);
const displayNameLabel = t("labels.displayName", "Display name");
const createAccountLabel = t("actions.createAdminAccount", "Create admin account");
const loginTitle = t("headings.adminLogin", "Admin login");
const signInIntro = t("messages.signInIntro", "Sign in to continue to the admin workspace.");
const authEyebrow = t("app.admin");
const authTitle = needsInitialSetup ? initialSetupTitle : loginTitle;
const authIntro = needsInitialSetup ? initialSetupHelp : signInIntro;
const rememberMeLabel = t("labels.rememberMe", "Remember me");
const forgotPasswordLabel = t("actions.forgotPassword", "Forgot password?");
---

<AdminAuthLayout title={loginTitle} description={signInIntro} eyebrow={authEyebrow} heading={authTitle} intro={authIntro}>
	{bootstrapError ? (
		<p class="admin-auth-alert admin-auth-alert-error" role="alert">{bootstrapError}</p>
	) : needsInitialSetup ? (
		<>
			{setupErrorMessage && <p class="admin-auth-alert admin-auth-alert-error" role="alert">{setupErrorMessage}</p>}
			<form class="admin-auth-form" method="post" action="/api/admin/auth/setup">
				<label class="admin-auth-field">
					<span>{t("labels.email")}</span>
					<span class="admin-auth-input-wrap">
						<span class="admin-auth-input-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="3" y="5" width="18" height="14" rx="2" />
								<path d="m4 7 8 6 8-6" />
							</svg>
						</span>
						<input class="form-control admin-auth-input" type="email" name="email" autocomplete="username" placeholder="name@quackbase.com" required />
					</span>
				</label>
				<label class="admin-auth-field">
					<span>{displayNameLabel}</span>
					<span class="admin-auth-input-wrap">
						<span class="admin-auth-input-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M18 20a6 6 0 0 0-12 0" />
								<circle cx="12" cy="10" r="4" />
							</svg>
						</span>
						<input class="form-control admin-auth-input" type="text" name="displayName" autocomplete="name" placeholder="Quackbase Owner" required />
					</span>
				</label>
				<label class="admin-auth-field">
					<span>{t("labels.password")}</span>
					<span class="admin-auth-input-wrap">
						<span class="admin-auth-input-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="4" y="11" width="16" height="9" rx="2" />
								<path d="M8 11V8a4 4 0 1 1 8 0v3" />
							</svg>
						</span>
						<input class="form-control admin-auth-input" type="password" name="password" autocomplete="new-password" placeholder="Create a strong password" required />
					</span>
				</label>
				<div class="admin-auth-actions">
					<button class="btn btn-primary admin-auth-submit" type="submit">
						<span class="admin-auth-submit-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="4" y="11" width="16" height="9" rx="2" />
								<path d="M8 11V8a4 4 0 1 1 8 0v3" />
							</svg>
						</span>
						<span>{createAccountLabel}</span>
					</button>
				</div>
			</form>
		</>
	) : (
		<>
			{errorMessage && <p class="admin-auth-alert admin-auth-alert-error" role="alert">{errorMessage}</p>}
			<form class="admin-auth-form" method="post" action="/api/admin/auth/login">
				<label class="admin-auth-field">
					<span>{t("labels.email")}</span>
					<span class="admin-auth-input-wrap">
						<span class="admin-auth-input-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="3" y="5" width="18" height="14" rx="2" />
								<path d="m4 7 8 6 8-6" />
							</svg>
						</span>
						<input class="form-control admin-auth-input" type="email" name="email" autocomplete="username" placeholder="Enter your email" required />
					</span>
				</label>
				<label class="admin-auth-field">
					<span>{t("labels.password")}</span>
					<span class="admin-auth-input-wrap">
						<span class="admin-auth-input-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="4" y="11" width="16" height="9" rx="2" />
								<path d="M8 11V8a4 4 0 1 1 8 0v3" />
							</svg>
						</span>
						<input class="form-control admin-auth-input" type="password" name="password" autocomplete="current-password" placeholder="Enter your password" required />
						<span class="admin-auth-input-affordance" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
								<circle cx="12" cy="12" r="2.5" />
							</svg>
						</span>
					</span>
				</label>
				<div class="admin-auth-row">
					<label class="admin-auth-checkbox">
						<input type="checkbox" name="remember" value="1" />
						<span>{rememberMeLabel}</span>
					</label>
					<span class="admin-auth-help-link">{forgotPasswordLabel}</span>
				</div>
				<div class="admin-auth-actions">
					<button class="btn btn-primary admin-auth-submit" type="submit">
						<span class="admin-auth-submit-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="4" y="11" width="16" height="9" rx="2" />
								<path d="M8 11V8a4 4 0 1 1 8 0v3" />
							</svg>
						</span>
						<span>{t("actions.signIn")}</span>
					</button>
				</div>
			</form>
		</>
	)}
</AdminAuthLayout>
