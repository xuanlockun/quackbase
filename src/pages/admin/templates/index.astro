---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import AdminOptionGrid from "../../../components/admin/AdminOptionGrid.astro";
import { getUiTranslations } from "../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t, localizeAdminHref } = getUiTranslations(Astro);

const templateOptions = [
	{
		key: "header",
		label: t("nav.header"),
		href: "/admin/templates/header",
		description: "Edit the full public top bar HTML.",
		order: "01",
	},
	{
		key: "page",
		label: "Page",
		href: "/admin/templates/page",
		description: "Edit the HTML wrapper and styles used around rendered page content.",
		order: "02",
	},
	{
		key: "posts",
		label: "Posts",
		href: "/admin/templates/posts",
		description: "Edit the HTML used for the public posts section.",
		order: "03",
	},
	{
		key: "footer",
		label: t("nav.footer"),
		href: "/admin/templates/footer",
		description: "Edit the raw HTML used for the public footer.",
		order: "04",
	},
];

const selectedTemplate = Astro.url.searchParams.get("template");
const initialHref = templateOptions.find((template) => template.key === selectedTemplate)?.href ?? templateOptions[0].href;
const initialAdminHref = localizeAdminHref(initialHref);
const chevronIcon = `
	<svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
		<path d="M8 5l4 5-4 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
	</svg>
`;
---

<AdminLayout
	title={t("nav.template")}
	description={t("messages.templateHubHelp", "Choose which public template fragment to edit.")}
	session={session}
	pageEyebrow={t("nav.template")}
	pageTitle={t("nav.template")}
	pageDescription={t("messages.templateHubHelp", "Choose which public template fragment to edit.")}
>
	<div class="admin-content-stack">
		<div class="admin-form-section">
			<div class="template-hub-copy">
				<strong>{t("messages.templateHubHeading", "Recommended editing order")}</strong>
				<p class="admin-muted mb-0">
					{t("messages.templateHubOrderHelp", "Start at the header, then shape the page wrapper, the posts block, and finally the footer.")}
				</p>
			</div>
			<label class="d-grid gap-2">
				<span>{t("labels.templateToEdit", "Template to edit")}</span>
				<select
					class="form-select"
					id="templatePicker"
					onchange="window.location.href = this.value;"
				>
					{
						templateOptions.map((template) => (
							<option value={localizeAdminHref(template.href)} selected={localizeAdminHref(template.href) === initialAdminHref}>
								{template.label}
							</option>
						))
					}
				</select>
			</label>
			<p class="admin-muted mb-0">
				This page only changes the public template HTML saved in D1. The admin shell stays untouched.
			</p>
		</div>

		<div class="admin-form-section">
			<AdminOptionGrid
				items={templateOptions.map((template) => ({
					title: template.label,
					description: template.description,
					href: localizeAdminHref(template.href),
					indexLabel: template.order,
				}))}
				columns="two"
				iconHtml={chevronIcon}
			/>
		</div>
	</div>
</AdminLayout>

<style>
	.template-hub-copy {
		display: grid;
		gap: 0.35rem;
	}
</style>
