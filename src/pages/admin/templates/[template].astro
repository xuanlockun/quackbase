---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import { DEFAULT_PAGE_TEMPLATE_HTML, getDb, getSiteConfig } from "../../../lib/blog";
import { getLanguageCatalog, getLanguageSwitchOptions, getUiTranslations } from "../../../lib/i18n";
import {
	DEFAULT_BLOG_FEED_TEMPLATE_HTML,
	DEFAULT_HEADER_TEMPLATE_HTML,
	DEFAULT_NAVIGATION_TEMPLATE_HTML,
	escapeHtml,
	renderTemplateHtml,
} from "../../../lib/template-html";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t, language, localizeHref } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const templateKind = Astro.params.template ?? "header";
if (templateKind === "navbar") {
	return Astro.redirect("/admin/templates/header");
}
const templateMeta = {
	header: {
		label: t("nav.header"),
		description: "Edit the full public top bar. Use {{brand}} and {{navigation}} for dynamic content.",
		value: (config) => config.headerTemplateHtml,
		defaultHtml: DEFAULT_HEADER_TEMPLATE_HTML,
	},
	page: {
		label: "Page",
		description: "Edit the HTML wrapper and styles used around rendered page content.",
		value: (config) => config.pageTemplateHtml,
		defaultHtml: DEFAULT_PAGE_TEMPLATE_HTML,
	},
	posts: {
		label: "Posts",
		description: "Edit the HTML wrapper and card layout used for the public posts section. Use {{posts}}, {{heading}}, {{viewAllHref}}, and {{viewAllLabel}}.",
		value: (config) => config.blogFeedTemplateHtml,
		defaultHtml: DEFAULT_BLOG_FEED_TEMPLATE_HTML,
	},
	footer: {
		label: t("nav.footer"),
		description: "Edit the raw HTML used for the public footer. Use {{footerText}} and {{year}} for dynamic content.",
		value: (config) => config.footerTemplateHtml,
		defaultHtml: `<footer>&copy; {{year}} {{footerText}}</footer>`,
	},
} as const;

type TemplateKind = keyof typeof templateMeta;
const kind = (templateKind in templateMeta ? templateKind : "footer") as TemplateKind;
const meta = templateMeta[kind];
const defaultTemplateHtml = meta.defaultHtml;

let loadError = "";
let templateHtml = "";
let previewHtml = "";

try {
	const config = await getSiteConfig(getDb(Astro.locals));
	templateHtml = meta.value(config);
	previewHtml = renderTemplatePreview(kind, templateHtml, config);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadSiteSettings");
}

function renderTemplatePreview(
	template: TemplateKind,
	templateHtml: string,
	config: Awaited<ReturnType<typeof getSiteConfig>>,
): string {
	const source = templateHtml.trim() || defaultTemplateFor(template);

	switch (template) {
		case "header": {
			const navigationSource = config.headerTemplateHtml.trim()
				? DEFAULT_NAVIGATION_TEMPLATE_HTML
				: config.navbarTemplateHtml.trim() || DEFAULT_NAVIGATION_TEMPLATE_HTML;
			return renderTemplateHtml(source, {
				brand: buildBrandHtml(config.siteTitle, config.logoUrl),
				navigation: buildNavigationHtml(config.navItems, navigationSource),
				navItems: buildNavItemsHtml(config.navItems),
				languageSwitch: buildLanguageSwitchHtml(),
			});
		}
		case "footer":
			return renderTemplateHtml(source, {
				footerText: escapeHtml(config.footerText),
				year: String(new Date().getFullYear()),
				socialLinks: buildSocialLinksHtml(),
			});
		case "posts":
			return renderTemplateHtml(source, {
				heading: "Latest posts",
				viewAllHref: "/blog",
				viewAllLabel: "View all",
				posts: buildPostsPreviewHtml(),
			});
		case "page":
		default:
			return renderTemplateHtml(source, {
				content: `<div class="border p-3 bg-white"><h2 class="h4 mb-3">Preview content</h2><p class="mb-0">This is where page content will be injected.</p></div>`,
			});
	}
}

function defaultTemplateFor(template: TemplateKind): string {
	switch (template) {
		case "header":
			return templateMeta.header.defaultHtml;
		case "page":
			return templateMeta.page.defaultHtml;
		case "posts":
			return templateMeta.posts.defaultHtml;
		case "footer":
		default:
			return templateMeta.footer.defaultHtml;
	}
}

function buildBrandHtml(siteTitle: string, logoUrl: string): string {
	const homeHref = escapeHtml(localizeHref("/"));
	const title = escapeHtml(siteTitle);
	return logoUrl
		? `<a class="navbar-brand d-flex align-items-center gap-2 fs-5 fw-bold flex-shrink-0" href="${homeHref}"><img src="${escapeHtml(logoUrl)}" alt="${title}" class="site-navbar-logo" loading="eager" width="128" height="32" style="height:32px;width:auto;max-width:128px;object-fit:contain;" /><span class="site-navbar-title">${title}</span></a>`
		: `<a class="navbar-brand d-flex align-items-center gap-2 fs-5 fw-bold flex-shrink-0" href="${homeHref}"><span class="site-navbar-mark" aria-hidden="true">${escapeHtml(siteTitle.charAt(0) || siteTitle)}</span><span class="site-navbar-title">${title}</span></a>`;
}

function buildNavigationHtml(
	navItems: Awaited<ReturnType<typeof getSiteConfig>>["navItems"],
	navigationTemplateHtml: string,
): string {
	const navItemsHtml = buildNavItemsHtml(navItems);
	return renderTemplateHtml(navigationTemplateHtml.trim() ? navigationTemplateHtml : DEFAULT_NAVIGATION_TEMPLATE_HTML, {
		navItems: navItemsHtml,
		languageSwitch: buildLanguageSwitchHtml(),
	});
}

function buildPostsPreviewHtml(): string {
	return [
		`<a class="col text-decoration-none" href="/blog/example-1"><article class="blog-card card h-100 shadow-sm border-0 overflow-hidden"><div class="post-thumbnail" style="aspect-ratio: 16 / 10;"><img src="/blog-placeholder-1.jpg" class="post-image" alt="" loading="lazy" /></div><div class="blog-card-body card-body post-content"><h3 class="h5 card-title post-title">Sample post one</h3><p class="text-muted small mb-0 card-text post-excerpt">Preview text for the first post card.</p></div></article></a>`,
		`<a class="col text-decoration-none" href="/blog/example-2"><article class="blog-card card h-100 shadow-sm border-0 overflow-hidden"><div class="post-thumbnail" style="aspect-ratio: 16 / 10;"><img src="/blog-placeholder-2.jpg" class="post-image" alt="" loading="lazy" /></div><div class="blog-card-body card-body post-content"><h3 class="h5 card-title post-title">Sample post two</h3><p class="text-muted small mb-0 card-text post-excerpt">Preview text for the second post card.</p></div></article></a>`,
	].join("");
}

function buildNavItemsHtml(navItems: Awaited<ReturnType<typeof getSiteConfig>>["navItems"]): string {
	const renderItem = (item: (typeof navItems)[number]): string => {
		const label = escapeHtml(item.labelTranslations?.[language] ?? item.labelTranslations?.en ?? item.label);
		const href = escapeHtml(item.href.startsWith("/admin") ? item.href : localizeHref(item.href));
		if (!item.children?.length) {
			return `<li class="nav-item"><a class="nav-link" href="${href}">${label}</a></li>`;
		}

		return `<li class="nav-item dropdown"><a class="nav-link dropdown-toggle" href="${href}" data-bs-toggle="dropdown" aria-expanded="false">${label}</a><ul class="dropdown-menu dropdown-submenu-menu">${item.children.map(renderItem).join("")}</ul></li>`;
	};

	return navItems.map(renderItem).join("");
}

function buildLanguageSwitchHtml(): string {
	const options = getLanguageSwitchOptions(Astro.url, language, catalog);
	const optionsHtml = options
		.map(
			(option) =>
				`<option value="${escapeHtml(option.href)}"${option.isActive ? " selected" : ""}>${escapeHtml(option.label)}</option>`,
		)
		.join("");

	return `<label class="language-switch"><span class="visually-hidden">${escapeHtml(t("labels.language"))}</span><select class="form-select form-select-sm language-switch-select w-auto" aria-label="${escapeHtml(t("labels.language"))}" data-language-switch>${optionsHtml}</select></label><script>document.querySelectorAll("[data-language-switch]").forEach((select) => {if (!(select instanceof HTMLSelectElement)) {return;}select.addEventListener("change", () => {if (select.value) {window.location.href = select.value;}});});</script>`;
}

function buildSocialLinksHtml(): string {
	return `<div class="social-links">
		<a href="https://m.webtoo.ls/@astro" target="_blank" rel="noopener noreferrer">
			<span class="sr-only">${escapeHtml(t("messages.followAstroMastodon"))}</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"><path fill="currentColor" d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z" /></svg>
		</a>
		<a href="https://twitter.com/astrodotbuild" target="_blank" rel="noopener noreferrer">
			<span class="sr-only">${escapeHtml(t("messages.followAstroTwitter"))}</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"><path fill="currentColor" d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z" /></svg>
		</a>
		<a href="https://github.com/withastro/astro" target="_blank" rel="noopener noreferrer">
			<span class="sr-only">${escapeHtml(t("messages.visitAstroGithub"))}</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" /></svg>
		</a>
	</div>`;
}
---

<AdminLayout
	title={meta.label}
	description={meta.description}
	session={session}
	pageEyebrow={t("nav.template")}
	pageTitle={meta.label}
	pageDescription={meta.description}
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("saved") && <p class="alert alert-success mb-0">{t("messages.templateSaved")}</p>}
		{Astro.url.searchParams.get("error") && <p class="alert alert-danger mb-0">{t("messages.templateSaveFailed")}</p>}
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}
		<form method="post" action={`/api/admin/templates/${kind}`} class="admin-form-shell">
			<div class="admin-form-section">
				<label style="grid-column: 1 / -1;">
					<span>{meta.label} HTML</span>
					<textarea
						class="form-control"
						name="templateHtml"
						rows="14"
						spellcheck="false"
						placeholder={defaultTemplateHtml}
						disabled={Boolean(loadError)}
					>{templateHtml.trim() ? templateHtml : defaultTemplateHtml}</textarea>
				</label>
				<p class="admin-muted">{meta.description}</p>
				<button class="btn btn-primary" type="submit" disabled={Boolean(loadError)}>Save template</button>
			</div>
		</form>
		<div class="admin-form-section">
			<strong>Preview</strong>
			<div class="template-preview" set:html={previewHtml}></div>
		</div>
	</div>
</AdminLayout>

<style>
	.template-preview {
		background: #fff;
	}

	.template-preview .site-navbar-logo {
		display: block;
		width: auto;
		max-width: 128px;
		height: 32px;
		object-fit: contain;
	}

	.template-preview .site-navbar-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: 2px solid #2337ff;
		border-radius: 0;
		font-weight: 700;
		font-size: 0.95rem;
		line-height: 1;
		color: #2337ff;
	}

	.template-preview .site-navbar-title {
		white-space: nowrap;
	}

	.template-preview .navbar-nav .dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
	}

	.template-preview .navbar-nav .dropdown-menu.show {
		display: block;
	}

	.template-preview .navbar-nav .nav-item.dropdown:hover > .dropdown-menu,
	.template-preview .navbar-nav .dropdown-submenu:hover > .dropdown-menu {
		display: block;
	}

	.template-preview .navbar-nav .dropdown-submenu {
		position: relative;
	}

	.template-preview .navbar-nav .dropdown-submenu .dropdown-menu {
		top: 0;
		left: 100%;
		margin-left: 0.25rem;
	}

	.template-preview .dropdown-submenu-menu {
		min-width: 12rem;
	}

	@media (max-width: 992px) {
		.template-preview .navbar-nav .dropdown-menu {
			position: static;
		}

		.template-preview .site-navbar-logo {
			max-width: 112px;
			height: 30px;
		}

		.template-preview .site-navbar-mark {
			width: 34px;
			height: 34px;
			font-size: 0.85rem;
		}

		.template-preview .site-navbar-title {
			font-size: 0.95rem;
		}
	}
</style>

