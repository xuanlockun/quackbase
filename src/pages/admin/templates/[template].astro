---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import LanguageSwitchScript from "../../../components/LanguageSwitchScript.astro";
import AdminOptionGrid from "../../../components/admin/AdminOptionGrid.astro";
import FeedbackModal from "../../../components/admin/FeedbackModal.astro";
import "../../../styles/site-theme.css";
import { DEFAULT_PAGE_TEMPLATE_HTML, getDb, getSiteConfig } from "../../../lib/blog";
import { getLanguageCatalog, getLanguageSwitchOptions, getUiTranslations } from "../../../lib/i18n";
import {
	buildBrandHtml as renderBrandHtml,
	buildLanguageSwitchHtml as renderLanguageSwitchHtml,
	buildNavItemsHtml as renderNavItemsHtml,
	buildSocialLinksHtml as renderSocialLinksHtml,
} from "../../../lib/public-template-fragments";
import {
	DEFAULT_BLOG_FEED_TEMPLATE_HTML,
	DEFAULT_HEADER_TEMPLATE_HTML,
	DEFAULT_NAVIGATION_TEMPLATE_HTML,
	escapeHtml,
	renderTemplateHtml,
} from "../../../lib/template-html";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t, language, localizeHref, localizeAdminHref } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const templateKind = Astro.params.template ?? "header";
if (templateKind === "navbar") {
	return Astro.redirect("/admin/templates/header");
}
const templateMeta = {
	header: {
		label: t("nav.header"),
		description: t("messages.templateHeaderHelp", "Edit the full public top bar. Use {{brand}} and {{navigation}} for dynamic content."),
		value: (config) => config.headerTemplateHtml,
		defaultHtml: DEFAULT_HEADER_TEMPLATE_HTML,
	},
	page: {
		label: t("headings.page", "Page"),
		description: t("messages.templatePageHelp", "Edit the HTML wrapper and styles used around rendered page content."),
		value: (config) => config.pageTemplateHtml,
		defaultHtml: DEFAULT_PAGE_TEMPLATE_HTML,
	},
	posts: {
		label: t("headings.posts", "Posts"),
		description: t("messages.templatePostsHelp", "Edit the HTML wrapper and card layout used for the public posts section. Use {{posts}} and {{heading}}."),
		value: (config) => config.blogFeedTemplateHtml,
		defaultHtml: DEFAULT_BLOG_FEED_TEMPLATE_HTML,
	},
	footer: {
		label: t("nav.footer"),
		description: t("messages.templateFooterHelp", "Edit the raw HTML used for the public footer. Use {{footerText}} and {{year}} for dynamic content."),
		value: (config) => config.footerTemplateHtml,
		defaultHtml: `<footer class="site-footer-fallback"><div class="site-footer-fallback__body"><p class="site-footer-fallback__copy mb-0">{{footerText}}</p><p class="site-footer-fallback__meta mb-0">&copy; {{year}}</p></div>{{socialLinks}}</footer>`,
	},
} as const;

type TemplateKind = keyof typeof templateMeta;
const kind = (templateKind in templateMeta ? templateKind : "footer") as TemplateKind;
const meta = templateMeta[kind];
const defaultTemplateHtml = meta.defaultHtml;

let loadError = "";
let templateHtml = "";
let previewHtml = "";

try {
	const config = await getSiteConfig(getDb(Astro.locals));
	templateHtml = meta.value(config);
	previewHtml = renderTemplatePreview(kind, templateHtml, config);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadSiteSettings");
}

const templateFeedback = [
	["saved", { title: "Template saved", message: t("messages.templateSaved"), tone: "success" }],
	["error", { title: "Template save failed", message: t("messages.templateSaveFailed"), tone: "error" }],
] as const;

const templateOrder = [
	{ key: "header", label: t("nav.header"), href: "/admin/templates/header" },
	{ key: "page", label: t("headings.page", "Page"), href: "/admin/templates/page" },
	{ key: "posts", label: t("headings.posts", "Posts"), href: "/admin/templates/posts" },
	{ key: "footer", label: t("nav.footer"), href: "/admin/templates/footer" },
] as const;
const templateTokenMap = {
	header: ["{{brand}}", "{{navigation}}", "{{navItems}}", "{{languageSwitch}}"],
	page: ["{{content}}"],
	posts: ["{{heading}}", "{{posts}}"],
	footer: ["{{footerText}}", "{{year}}", "{{socialLinks}}"],
} as const;

function renderTemplatePreview(
	template: TemplateKind,
	templateHtml: string,
	config: Awaited<ReturnType<typeof getSiteConfig>>,
): string {
	const source = templateHtml.trim() || defaultTemplateFor(template);

	switch (template) {
		case "header": {
			const navigationSource = config.headerTemplateHtml.trim()
				? DEFAULT_NAVIGATION_TEMPLATE_HTML
				: config.navbarTemplateHtml.trim() || DEFAULT_NAVIGATION_TEMPLATE_HTML;
			const renderedHeader = renderTemplateHtml(source, {
				brand: buildBrandHtml(config.siteTitle, config.logoUrl),
				navigation: buildNavigationHtml(config.navItems, navigationSource),
				navItems: buildNavItemsHtml(config.navItems),
				languageSwitch: buildLanguageSwitchHtml(),
			});
			return `<div class="site-header" style="--site-header-background:${escapeHtml(config.headerBackground)};--site-header-text:${escapeHtml(config.headerTextColor)};--site-header-accent:${escapeHtml(config.headerAccentColor)};">${renderedHeader}</div>`;
		}
		case "footer":
			return `<div class="site-footer-shell" style="--site-footer-background:${escapeHtml(config.footerBackground)};--site-footer-text:${escapeHtml(config.footerTextColor)};">${renderTemplateHtml(source, {
				footerText: escapeHtml(config.footerText),
				year: String(new Date().getFullYear()),
				socialLinks: buildSocialLinksHtml(),
			})}</div>`;
		case "posts":
			return renderTemplateHtml(source, {
				heading: t("messages.templateLatestPosts", "Latest posts"),
				posts: buildPostsPreviewHtml(),
			});
		case "page":
		default:
			return renderTemplateHtml(source, {
				content: `<div class="border p-3 bg-white"><h2 class="h4 mb-3">${escapeHtml(t("messages.templatePreviewContent", "Preview content"))}</h2><p class="mb-0">${escapeHtml(t("messages.templatePageInjectionHint", "This is where page content will be injected."))}</p></div>`,
			});
	}
}

function defaultTemplateFor(template: TemplateKind): string {
	switch (template) {
		case "header":
			return templateMeta.header.defaultHtml;
		case "page":
			return templateMeta.page.defaultHtml;
		case "posts":
			return templateMeta.posts.defaultHtml;
		case "footer":
		default:
			return templateMeta.footer.defaultHtml;
	}
}

function buildBrandHtml(siteTitle: string, logoUrl: string): string {
	return buildBrandHtmlFragment(siteTitle, logoUrl);
}

function buildNavigationHtml(
	navItems: Awaited<ReturnType<typeof getSiteConfig>>["navItems"],
	navigationTemplateHtml: string,
): string {
	const navItemsHtml = buildNavItemsHtml(navItems);
	return renderTemplateHtml(navigationTemplateHtml.trim() ? navigationTemplateHtml : DEFAULT_NAVIGATION_TEMPLATE_HTML, {
		navItems: navItemsHtml,
		languageSwitch: buildLanguageSwitchHtml(),
	});
}

function buildPostsPreviewHtml(): string {
	return `
		<a class="blog-feed-featured-link text-decoration-none" href="/blog/example-featured">
			<article class="blog-feed-featured card border-0 overflow-hidden">
				<div class="row g-0 align-items-stretch">
					<div class="col-lg-5 blog-feed-featured-copy">
						<div class="card-body p-4 p-lg-5 h-100 d-flex flex-column justify-content-center gap-3">
							<div class="d-flex flex-wrap align-items-center gap-2">
								<span class="badge bg-primary-subtle text-uppercase">{t("labels.featured", "Featured")}</span>
								<span class="badge text-bg-light text-uppercase">{t("labels.pinned", "Pinned")}</span>
							</div>
							<h3 class="display-6 fw-semibold mb-0 blog-feed-title">{t("messages.templateFeaturedHeadline", "Featured post headline")}</h3>
							<p class="lead text-muted mb-0 blog-feed-excerpt">{t("messages.templateFeaturedSummary", "This preview shows the editorial layout with one featured story and a consistent grid below.")}</p>
						</div>
					</div>
					<div class="col-lg-7">
						<div class="blog-feed-featured-media">
							<img src="/blog-placeholder-1.jpg" class="blog-feed-image" alt="" loading="eager" />
						</div>
					</div>
				</div>
			</article>
		</a>
		<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
			<a class="col text-decoration-none" href="/blog/example-1">
				<article class="blog-feed-card card h-100 border-0 overflow-hidden">
						<div class="blog-feed-card-media"><img src="/blog-placeholder-2.jpg" class="blog-feed-image" alt="" loading="lazy" /></div>
					<div class="card-body p-3 p-lg-4 blog-feed-card-body">
						<h3 class="h5 card-title mb-2 blog-feed-title">{t("messages.templateSamplePostOne", "Sample post one")}</h3>
						<p class="text-muted small mb-0 blog-feed-excerpt">{t("messages.templateSamplePostOneHelp", "Preview text for the first post card.")}</p>
					</div>
				</article>
			</a>
			<a class="col text-decoration-none" href="/blog/example-2">
				<article class="blog-feed-card card h-100 border-0 overflow-hidden">
						<div class="blog-feed-card-media"><img src="/blog-placeholder-3.jpg" class="blog-feed-image" alt="" loading="lazy" /></div>
					<div class="card-body p-3 p-lg-4 blog-feed-card-body">
						<h3 class="h5 card-title mb-2 blog-feed-title">{t("messages.templateSamplePostTwo", "Sample post two")}</h3>
						<p class="text-muted small mb-0 blog-feed-excerpt">{t("messages.templateSamplePostTwoHelp", "Preview text for the second post card.")}</p>
					</div>
				</article>
			</a>
		</div>`;
}

function buildNavItemsHtml(navItems: Awaited<ReturnType<typeof getSiteConfig>>["navItems"]): string {
	return buildNavItemsHtmlFragment(navItems);
}

function buildLanguageSwitchHtml(): string {
	const options = getLanguageSwitchOptions(Astro.url, language, catalog);
	return buildLanguageSwitchFragment(options);
}

function buildSocialLinksHtml(): string {
	return buildSocialLinksFragment();
}

function buildBrandHtmlFragment(siteTitle: string, logoUrl: string): string {
	return renderBrandHtml({
		siteTitle,
		logoUrl,
		homeHref: localizeHref("/"),
		escapeHtml,
	});
}

function buildNavItemsHtmlFragment(navItems: Awaited<ReturnType<typeof getSiteConfig>>["navItems"]): string {
	return renderNavItemsHtml({
		items: navItems,
		language,
		resolveHref: (href = "/") => (href.startsWith("/admin") ? href : localizeHref(href)),
		escapeHtml,
	});
}

function buildLanguageSwitchFragment(options: ReturnType<typeof getLanguageSwitchOptions>): string {
	return renderLanguageSwitchHtml({
		label: t("labels.language"),
		options,
		escapeHtml,
	});
}

function buildSocialLinksFragment(): string {
	return renderSocialLinksHtml({
		mastodonLabel: t("messages.followAstroMastodon"),
		twitterLabel: t("messages.followAstroTwitter"),
		githubLabel: t("messages.visitAstroGithub"),
		escapeHtml,
	});
}
---

<AdminLayout
	title={meta.label}
	description={meta.description}
	session={session}
	pageEyebrow={t("nav.template")}
	pageTitle={meta.label}
	pageDescription={meta.description}
>
	<div class="admin-content-stack">
		<FeedbackModal id="template-feedback-modal" title="Status update" closeLabel={t("actions.close", "Close")} />
		<div class="template-flow">
			<div class="admin-form-section template-flow-panel">
				<div class="template-flow-copy">
					<strong>{t("messages.templateEditorFlowHeading", "Editing flow")}</strong>
					<p class="admin-muted mb-0">
						{t("messages.templateEditorFlowHelp", "Move through the public shell in order so layout changes stay predictable.")}
					</p>
				</div>
				<AdminOptionGrid
					items={templateOrder.map((entry, index) => ({
						title: entry.label,
						href: localizeAdminHref(entry.href),
						indexLabel: String(index + 1).padStart(2, "0"),
						active: entry.key === kind,
					}))}
					columns="four"
				/>
			</div>

			<form method="post" action={`/api/admin/templates/${kind}`} class="admin-form-shell">
				<div class="admin-form-section template-editor-panel">
					<div class="template-editor-header">
						<div>
							<strong>{meta.label} HTML</strong>
							<p class="admin-muted mb-0">{meta.description}</p>
						</div>
						<button class="btn btn-primary" type="submit" disabled={Boolean(loadError)}>Save template</button>
					</div>
					<label style="grid-column: 1 / -1;">
						<span>{t("messages.templateEditorFieldHelp", "Saved HTML")}</span>
						<div class="admin-editor-shell">
							<div class="admin-editor-toolbar" aria-label="Template placeholders">
								{templateTokenMap[kind].map((token) => (
									<button type="button" class="admin-editor-tool" data-template-token={token}>
										{token}
									</button>
								))}
							</div>
							<p class="admin-editor-help mb-0">Insert saved placeholders directly into the template. The preview on this page still uses the same stored HTML contract.</p>
						<textarea
							class="form-control template-editor-textarea admin-editor-textarea"
							name="templateHtml"
							rows="16"
							spellcheck="false"
							placeholder={defaultTemplateHtml}
							disabled={Boolean(loadError)}
						>{templateHtml.trim() ? templateHtml : defaultTemplateHtml}</textarea>
						</div>
					</label>
				</div>
			</form>
			<div class="admin-form-section template-preview-panel">
				<div class="template-editor-header">
					<div>
						<strong>{t("labels.preview", "Preview")}</strong>
						<p class="admin-muted mb-0">
							{t("messages.templatePreviewHelp", "Preview updates reflect the current saved values and shared site settings.")}
						</p>
					</div>
				</div>
				<div class="template-preview site-app">
					<div set:html={previewHtml}></div>
				</div>
				<div class="template-preview-note">
					<p class="admin-muted mb-0">
						{t("messages.templatePreviewNote", "Use placeholders for dynamic content. Static markup here should stay neutral and reusable.")}
					</p>
				</div>
			</div>
			<LanguageSwitchScript />
		</div>
	</div>
</AdminLayout>

<script type="module" define:vars={{ templateFeedback, loadError }}>
	const showFeedbackModal = window.showAdminFeedbackModal;
	const search = new URLSearchParams(window.location.search);

	for (const [key, entry] of templateFeedback) {
		if (search.has(key)) {
			if (typeof showFeedbackModal === "function") {
				showFeedbackModal({ title: entry.title, message: entry.message, tone: entry.tone });
			}
			window.history.replaceState({}, "", window.location.pathname + window.location.hash);
			break;
		}
	}

	if (loadError && typeof showFeedbackModal === "function") {
		showFeedbackModal({ title: "Template load failed", message: loadError, tone: "error" });
	}

	document.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLButtonElement) || !target.matches("[data-template-token]")) {
			return;
		}

		const textarea = document.querySelector(".template-editor-textarea");
		if (!(textarea instanceof HTMLTextAreaElement)) {
			return;
		}

		const token = target.dataset.templateToken || "";
		const start = textarea.selectionStart ?? textarea.value.length;
		const end = textarea.selectionEnd ?? textarea.value.length;
		textarea.value = `${textarea.value.slice(0, start)}${token}${textarea.value.slice(end)}`;
		const caret = start + token.length;
		textarea.focus();
		textarea.setSelectionRange(caret, caret);
	});
</script>

<style>
	.template-flow {
		display: grid;
		gap: 1rem;
	}

	.template-flow-panel,
	.template-editor-panel,
	.template-preview-panel {
		gap: 0.9rem;
	}

	.template-flow-copy {
		display: grid;
		gap: 0.35rem;
	}

	.template-editor-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.template-editor-textarea {
		min-height: 24rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
		font-size: 0.92rem;
		line-height: 1.5;
	}

	.template-preview {
		border-radius: 1rem;
		overflow: hidden;
		border: 1px solid rgba(15, 23, 42, 0.08);
	}

	.template-preview-note {
		padding-top: 0.25rem;
	}

</style>

