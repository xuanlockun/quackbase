---
export const prerender = false;

import UserForm from "../../../components/admin/UserForm.astro";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listRoleSummaries } from "../../../lib/db/roles";
import { getDb } from "../../../lib/blog";
import { getUiTranslations } from "../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const roles = await listRoleSummaries(getDb(Astro.locals));
const hasError = Astro.url.searchParams.get("error");
const { t } = getUiTranslations(Astro);
---

<AdminLayout
	title={t("actions.createUser")}
	description={t("messages.saveCreateUser")}
	session={session}
	pageTitle={t("actions.createUser")}
	pageDescription={t("messages.createUserDescription")}
>
	<div class="admin-content-stack">
		<UserForm
			mode="create"
			action="/api/admin/users"
			roles={roles}
			canSubmit={true}
			loadError={hasError ? t("messages.userRequestFailed") : ""}
		/>
	</div>
</AdminLayout>
