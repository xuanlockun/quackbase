---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, hasPageSection, listAllPages } from "../../lib/blog";
import { getLanguageCatalog, getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("pages.create");
const canUpdate = session.isSuperadmin || session.permissions.includes("pages.update");
const { t, language } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);

let contactPages = [];
let loadError = "";

try {
	contactPages = (await listAllPages(getDb(Astro.locals), language, catalog)).filter((page) =>
		hasPageSection(page.pageSections, "contact_form"),
	);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadPages");
}
---

<AdminLayout
	title={t("nav.contactForm")}
	description={t("messages.contactFormHub")}
	session={session}
	pageTitle={t("nav.contactForm")}
	pageDescription={t("messages.contactFormSectionHelp")}
>
	<div slot="actions" class="admin-page-actions">
		{canCreate && <a class="btn btn-primary" href="/admin/pages/new">{t("actions.createPage")}</a>}
		<a class="btn btn-outline-secondary" href="/admin/pages">{t("actions.view")}</a>
	</div>

	<div class="admin-content-stack">
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}
		<div class="alert alert-info mb-0">
			{t("messages.contactFormSectionHelp")}
		</div>

		<div class="table-responsive">
			<table class="table align-middle">
				<thead>
					<tr>
						<th>{t("labels.title")}</th>
						<th>{t("labels.slug")}</th>
						<th>{t("labels.status")}</th>
						<th>{t("labels.action")}</th>
					</tr>
				</thead>
				<tbody>
					{
						contactPages.length > 0 ? (
							contactPages.map((page) => (
								<tr>
									<td><strong>{page.title}</strong></td>
									<td>{page.slug}</td>
									<td>{t(`status.${page.status}`)}</td>
									<td>
										{canUpdate && (
											<a class="btn btn-sm btn-outline-primary" href={`/admin/pages/${page.id}/edit`}>
												{t("actions.edit")}
											</a>
										)}
									</td>
								</tr>
							))
						) : (
							<tr>
								<td colSpan="4">
									<div class="admin-empty-state py-4">
										<h2 class="h5 mb-2">{t("messages.noPagesYet")}</h2>
										<p class="mb-0 admin-muted">{t("messages.contactFormSectionHelp")}</p>
									</div>
								</td>
							</tr>
						)
					}
				</tbody>
			</table>
		</div>
	</div>
</AdminLayout>
