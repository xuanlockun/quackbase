---
export const prerender = false;

import PageForm from "../../../../components/admin/PageForm.astro";
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import { getDb, getPageById } from "../../../../lib/blog";
import { listFormFields } from "../../../../lib/forms";
import { getUiTranslations, localizeAdminHref } from "../../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canUpdate = session.isSuperadmin || session.permissions.includes("pages.update");
const { id } = Astro.params;
const { t, language } = getUiTranslations(Astro);

let page = null;
let contactFormFields = [];
let loadError = "";
let notFound = false;

try {
	const pageId = Number(id);
	if (!Number.isInteger(pageId) || pageId <= 0) {
		notFound = true;
	} else {
		const db = getDb(Astro.locals);
		page = await getPageById(db, pageId);
		contactFormFields = await listFormFields(db);
		notFound = !page;
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadPages");
}

if (Astro.url.searchParams.get("error")) {
	loadError = t("messages.pageRequestFailed");
}
---

<AdminLayout
	title={t("actions.edit")}
	description={t("messages.saveEditPage")}
	session={session}
	pageTitle={t("actions.edit")}
	pageDescription={t("messages.editPageDescription")}
>
	<div class="admin-content-stack">
		{
			notFound ? (
				<div class="admin-empty-state">
					<h2>{t("messages.pageNotFound")}</h2>
					<p class="admin-muted">{t("messages.failedToLoadPages")}</p>
					<p><a class="admin-ghost-button" href={localizeAdminHref("/admin/pages", language)}>{t("messages.backToPages")}</a></p>
				</div>
			) : (
				<PageForm
					mode="edit"
					action="/api/admin/pages"
					page={page}
					canSubmit={canUpdate}
					loadError={loadError}
					contactFormFields={contactFormFields}
				/>
			)
		}
	</div>
</AdminLayout>
