---
export const prerender = false;

import PageForm from "../../../components/admin/PageForm.astro";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getDb } from "../../../lib/blog";
import { listBanners } from "../../../lib/banners";
import { listContactForms } from "../../../lib/contact-forms";
import { getLanguageCatalog, getUiTranslations } from "../../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const canCreate = session.isSuperadmin || session.permissions.includes("pages.create");
const hasError = Astro.url.searchParams.get("error");
const { t } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const language = Astro.locals.uiLanguage ?? catalog.defaultLanguageCode;
let bannerCatalog = [];
let contactFormCatalog = [];

try {
	const db = getDb(Astro.locals);
	bannerCatalog = await listBanners(db, false, language, catalog);
	contactFormCatalog = await listContactForms(db);
} catch {
	bannerCatalog = [];
	contactFormCatalog = [];
}
---

<AdminLayout
	title={t("actions.createPage")}
	description={t("messages.saveCreatePage")}
	session={session}
	pageTitle={t("actions.createPage")}
	pageDescription={t("messages.createPageDescription")}
>
	<div class="admin-content-stack">
		<PageForm
			mode="create"
			action="/api/admin/pages"
			canSubmit={canCreate}
			loadError={hasError ? t("messages.pageRequestFailed") : ""}
			bannerCatalog={bannerCatalog}
			contactFormCatalog={contactFormCatalog}
		/>
	</div>
</AdminLayout>
