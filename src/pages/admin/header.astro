---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { SITE_TITLE } from "../../consts";
import { getDb, getSiteConfig } from "../../lib/blog";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

let loadError = "";
let siteConfig = {
	siteTitle: SITE_TITLE,
	homePageSlug: "home",
	headerBackground: "#ffffff",
	headerTextColor: "#0f1219",
	headerAccentColor: "#2337ff",
	footerText: "Edge CMS. Content updates go live straight from D1.",
	footerBackground: "#eef2f7",
	footerTextColor: "#60739f",
	navItems: [{ label: "Home", href: "/", sortOrder: 0 }],
};

try {
	siteConfig = await getSiteConfig(getDb(Astro.locals));
} catch (error) {
	loadError = error instanceof Error ? error.message : "Failed to load site settings.";
}
---

<AdminLayout
	title="Header"
	description="Manage site settings."
	session={session}
	pageTitle="Header & Footer"
	pageDescription="Manage the brand title, navigation links, and the site chrome colors."
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("siteSaved") && <p class="admin-notice">Header settings saved.</p>}
		{Astro.url.searchParams.get("siteError") && <p class="admin-notice admin-notice-error">Header settings could not be saved.</p>}
		{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}
		<form method="post" action="/api/admin/site" class="admin-form-stack">
			<div class="admin-grid-two">
				<label><span>Site title</span><input name="siteTitle" required value={siteConfig.siteTitle} disabled={Boolean(loadError)} /></label>
				<label><span>Home page slug</span><input name="homePageSlug" required value={siteConfig.homePageSlug} placeholder="home" disabled={Boolean(loadError)} /></label>
				<label><span>Header background</span><input name="headerBackground" value={siteConfig.headerBackground} placeholder="#ffffff" disabled={Boolean(loadError)} /></label>
				<label><span>Header text color</span><input name="headerTextColor" value={siteConfig.headerTextColor} placeholder="#0f1219" disabled={Boolean(loadError)} /></label>
				<label><span>Header accent color</span><input name="headerAccentColor" value={siteConfig.headerAccentColor} placeholder="#2337ff" disabled={Boolean(loadError)} /></label>
				<label><span>Footer background</span><input name="footerBackground" value={siteConfig.footerBackground} placeholder="#eef2f7" disabled={Boolean(loadError)} /></label>
				<label><span>Footer text color</span><input name="footerTextColor" value={siteConfig.footerTextColor} placeholder="#60739f" disabled={Boolean(loadError)} /></label>
				<label style="grid-column: 1 / -1;"><span>Footer text</span><input name="footerText" value={siteConfig.footerText} disabled={Boolean(loadError)} /></label>
			</div>
			<label><span>Navigation items</span><textarea name="navItems" disabled={Boolean(loadError)}>{siteConfig.navItems.map((item) => `${item.label}|${item.href}`).join("\n")}</textarea></label>
			<div class="admin-form-section">
				<p class="admin-muted">For the homepage use a page slug like `home` or `/home`. Empty or `/` also falls back to `home`.</p>
				<p class="admin-muted">One item per line: `Label|/path` or `Label|https://example.com`.</p>
				<button class="admin-primary-button" type="submit" disabled={Boolean(loadError)}>Save header</button>
			</div>
		</form>
	</div>
</AdminLayout>

<style>
	textarea {
		min-height: 220px;
	}
</style>
