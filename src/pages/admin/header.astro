---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { SITE_TITLE } from "../../consts";
import { getDb, getSiteConfig, type SiteNavItem } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}
const { t } = getUiTranslations(Astro);

const flattenNavItems = (items: SiteNavItem[] = [], depth = 0): { item: SiteNavItem; depth: number }[] => {
	const rows: { item: SiteNavItem; depth: number }[] = [];
	for (const entry of items) {
		rows.push({ item: entry, depth });
		if (entry.children?.length) {
			rows.push(...flattenNavItems(entry.children, depth + 1));
		}
	}
	return rows;
};

let loadError = "";
let siteConfig = {
	siteTitle: SITE_TITLE,
	homePageSlug: "home",
	faviconUrl: "/favicon.svg",
	headerBackground: "#ffffff",
	headerTextColor: "#0f1219",
	headerAccentColor: "#2337ff",
	footerText: "Edge CMS. Content updates go live straight from D1.",
	footerBackground: "#eef2f7",
	footerTextColor: "#60739f",
	navItems: [
		{
			label: t("nav.home"),
			labelTranslations: { en: "Home", vi: "Trang chu" },
			href: "/",
			sortOrder: 0,
		},
	],
};

try {
	siteConfig = await getSiteConfig(getDb(Astro.locals));
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadSiteSettings");
}

const navRows = flattenNavItems(siteConfig.navItems ?? []);
--- 

<AdminLayout
	title={t("nav.header")}
	description={t("messages.manageSiteSettings")}
	session={session}
	pageTitle={t("headings.headerFooter")}
	pageDescription={t("messages.headerFooterDescription")}
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("siteSaved") && <p class="alert alert-success mb-0">{t("messages.headerSettingsSaved")}</p>}
		{Astro.url.searchParams.get("siteError") && <p class="alert alert-danger mb-0">{t("messages.headerSettingsFailed")}</p>}
		{loadError && <p class="alert alert-danger mb-0">{loadError}</p>}
		<form method="post" action="/api/admin/site" class="admin-form-shell">
			<div class="admin-grid-two">
				<label><span>{t("labels.siteTitle")}</span><input class="form-control" name="siteTitle" required value={siteConfig.siteTitle} disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.homePageSlug")}</span><input class="form-control" name="homePageSlug" required value={siteConfig.homePageSlug} placeholder="home" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.faviconUrl")}</span><input class="form-control" name="faviconUrl" value={siteConfig.faviconUrl} placeholder="/favicon.svg" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.headerBackground")}</span><input class="form-control" name="headerBackground" value={siteConfig.headerBackground} placeholder="#ffffff" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.headerTextColor")}</span><input class="form-control" name="headerTextColor" value={siteConfig.headerTextColor} placeholder="#0f1219" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.headerAccentColor")}</span><input class="form-control" name="headerAccentColor" value={siteConfig.headerAccentColor} placeholder="#2337ff" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.footerBackground")}</span><input class="form-control" name="footerBackground" value={siteConfig.footerBackground} placeholder="#eef2f7" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.footerTextColor")}</span><input class="form-control" name="footerTextColor" value={siteConfig.footerTextColor} placeholder="#60739f" disabled={Boolean(loadError)} /></label>
				<label style="grid-column: 1 / -1;"><span>{t("labels.footerText")}</span><input class="form-control" name="footerText" value={siteConfig.footerText} disabled={Boolean(loadError)} /></label>
			</div>
			<div class="admin-form-section">
				<span>{t("labels.navigationItems")}</span>
				<input
					type="hidden"
					name="navItems"
					id="nav-items-payload"
					value={JSON.stringify(siteConfig.navItems ?? [])}
					disabled={Boolean(loadError)}
				/>
				<div
					class="nav-items-editor"
					data-nav-items-editor
					data-disabled={Boolean(loadError)}
					data-remove-label={t("actions.remove")}
					data-add-child-label={t("actions.addChild")}
					data-indent-label={t("actions.indent")}
					data-outdent-label={t("actions.outdent")}
				>
					<div class="table-responsive admin-table-surface">
						<table class="table table-sm table-hover align-middle nav-items-table mb-0" role="table">
						<thead>
							<tr>
								<th></th>
								<th>{t("labels.label")} (EN)</th>
								<th>{t("labels.label")} (VI)</th>
								<th>{t("labels.link")}</th>
								<th>{t("labels.action")}</th>
							</tr>
						</thead>
						<tbody data-nav-items-rows>
							<tr class="admin-table-empty-row admin-muted" data-nav-empty hidden={navRows.length > 0}>
								<td colSpan="5">{t("messages.noNavigationItemsConfigured")}</td>
							</tr>
							{
								navRows.map(({ item, depth }, index) => (
									<tr
										class="nav-item-row"
										role="row"
										data-nav-row
										data-depth={depth}
										style={`--nav-depth: ${depth}`}
										draggable={!Boolean(loadError) ? "true" : "false"}
										data-row-index={index}
									>
										<td class="drag-cell">
											<span class="nav-drag-handle" data-drag-handle aria-label="Drag to reorder"></span>
										</td>
										<td class="nav-label-cell">
											<input
												class="form-control form-control-sm"
												type="text"
												value={item.labelTranslations?.en ?? item.label ?? ""}
												placeholder="Home"
												data-nav-label-en
												disabled={Boolean(loadError)}
											/>
										</td>
										<td class="nav-label-cell">
											<input
												class="form-control form-control-sm"
												type="text"
												value={item.labelTranslations?.vi ?? ""}
												placeholder="Trang chu"
												data-nav-label-vi
												disabled={Boolean(loadError)}
											/>
										</td>
										<td>
											<input
												class="form-control form-control-sm"
												type="text"
												value={item.href}
												placeholder="/about or https://example.com"
												data-nav-href
												disabled={Boolean(loadError)}
											/>
										</td>
										<td class="nav-item-actions">
											<div class="nav-action-buttons">
												<button
													class="btn btn-sm btn-outline-secondary nav-action mini"
													type="button"
													data-nav-add-child
													disabled={Boolean(loadError)}
													aria-label={t("actions.addChild")}
												>
													+ Child
												</button>
												<button
													class="btn btn-sm btn-outline-secondary nav-action mini"
													type="button"
													data-nav-indent
													disabled={Boolean(loadError)}
													aria-label={t("actions.indent")}
												>
													↳
												</button>
												<button
													class="btn btn-sm btn-outline-secondary nav-action mini"
													type="button"
													data-nav-outdent
													disabled={Boolean(loadError)}
													aria-label={t("actions.outdent")}
												>
													↰
												</button>
												<button
													class="btn btn-sm btn-outline-danger nav-item-remove"
													type="button"
													data-nav-remove
													disabled={Boolean(loadError)}
												>
													{t("actions.remove")}
												</button>
											</div>
										</td>
									</tr>
								))
							}
						</tbody>
						</table>
					</div>
					<button class="btn btn-outline-secondary" type="button" data-nav-add disabled={Boolean(loadError)}>
						{t("actions.addRow")}
					</button>
				</div>
			</div>
			<div class="admin-form-section">
				<p class="admin-muted">{t("messages.navStorageHelp")}</p>
				<button class="btn btn-primary" type="submit" disabled={Boolean(loadError)}>{t("actions.saveHeader")}</button>
			</div>
		</form>
		<div class="admin-form-section">
			<strong>{t("headings.contactFormFields")}</strong>
			<p class="admin-muted">{t("messages.contactFormSharedConfig")}</p>
			<p><a class="btn btn-outline-secondary" href="/admin/pages">{t("actions.manageContactForm")}</a></p>
		</div>
	</div>
</AdminLayout>

<style>
	.nav-items-editor {
		display: grid;
		gap: 0.85rem;
	}

	.nav-items-table {
		width: 100%;
	}

	.nav-items-table thead th {
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		color: var(--admin-muted, #60739f);
		letter-spacing: 0.04em;
	}

	.nav-item-row td {
		vertical-align: middle;
	}

	.drag-cell {
		width: 48px;
	}

	.nav-item-actions {
		padding: 0;
	}

	.nav-items-table .nav-item-row {
		--nav-depth: 0;
	}

	.nav-item-row .nav-label-cell {
		padding-left: calc(0.5rem + var(--nav-depth, 0) * 1.5rem);
	}

	.nav-action-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.nav-action-buttons .nav-action.mini {
		padding-inline: 0.55rem;
		min-width: 2.5rem;
	}
</style>

<script type="module">
	const editor = document.querySelector("[data-nav-items-editor]");
	const rowsContainer = editor?.querySelector("[data-nav-items-rows]");
	const payloadInput = document.getElementById("nav-items-payload");
	const addButton = editor?.querySelector("[data-nav-add]");
	const emptyStateRow = editor?.querySelector("[data-nav-empty]");
	const removeLabel = editor?.dataset.removeLabel ?? "Remove";
	const addChildLabel = editor?.dataset.addChildLabel ?? "Add child";
	const indentLabel = editor?.dataset.indentLabel ?? "Indent";
	const outdentLabel = editor?.dataset.outdentLabel ?? "Outdent";
	const isReadOnly = editor?.dataset.disabled === "true";
	let draggedNavRow = null;
	const MAX_NAV_DEPTH = 4;

	const clampDepth = (value) => {
		const depth = Number.isFinite(value) ? value : 0;
		return Math.max(0, Math.min(MAX_NAV_DEPTH, Math.floor(depth)));
	};

	const setRowDepth = (row, depth) => {
		const normalized = clampDepth(depth);
		row.dataset.depth = String(normalized);
		row.style.setProperty("--nav-depth", String(normalized));
		return normalized;
	};

	const buildNodeFromRow = (row) => {
		const labelEn = row.querySelector("[data-nav-label-en]");
		const labelVi = row.querySelector("[data-nav-label-vi]");
		const href = row.querySelector("[data-nav-href]");

		if (
			!(labelEn instanceof HTMLInputElement) ||
			!(labelVi instanceof HTMLInputElement) ||
			!(href instanceof HTMLInputElement)
		) {
			return null;
		}

		const trimmedHref = href.value.trim();
		const trimmedEn = labelEn.value.trim();
		const trimmedVi = labelVi.value.trim();
		if (!trimmedEn || !trimmedHref) {
			return null;
		}

		return {
			label: trimmedEn,
			labelTranslations: {
				en: trimmedEn,
				...(trimmedVi ? { vi: trimmedVi } : {}),
			},
			href: trimmedHref,
			children: [],
		};
	};

	const syncPayload = () => {
		if (!(rowsContainer instanceof HTMLElement) || !(payloadInput instanceof HTMLInputElement)) {
			return;
		}

		const tree = [];
		const stack = [{ depth: -1, children: tree }];
		for (const row of rowsContainer.querySelectorAll("[data-nav-row]")) {
			const currentDepth = clampDepth(Number(row.dataset.depth ?? "0"));
			setRowDepth(row, currentDepth);
			const node = buildNodeFromRow(row);
			if (!node) {
				continue;
			}

			while (stack[stack.length - 1].depth >= currentDepth) {
				stack.pop();
			}

			stack[stack.length - 1].children.push(node);
			stack.push({ depth: currentDepth, children: node.children });
		}

		payloadInput.value = JSON.stringify(tree);
		updateEmptyState();
	};

	const attachNavRow = (row) => {
		if (!(row instanceof HTMLElement) || row.dataset.navRowAttached === "true") {
			return;
		}
		row.dataset.navRowAttached = "true";
		setRowDepth(row, Number(row.dataset.depth ?? "0"));
		row.draggable = !isReadOnly;
		row.addEventListener("dragstart", onNavDragStart);
		row.addEventListener("dragover", onNavDragOver);
		row.addEventListener("drop", onNavDragDrop);
		row.addEventListener("dragend", onNavDragEnd);
	};

	const findNavRow = (target) => (target instanceof Element ? target.closest("[data-nav-row]") : null);

	const onNavDragStart = (event) => {
		if (isReadOnly) {
			return;
		}
		const row = event.currentTarget;
		if (!(row instanceof HTMLElement)) {
			return;
		}
		draggedNavRow = row;
		row.classList.add("is-dragging");
		event.dataTransfer?.setData("text/plain", "");
		event.dataTransfer?.setDragImage(row, 0, 0);
	};

	const onNavDragOver = (event) => {
		if (!draggedNavRow) {
			return;
		}
		event.preventDefault();
		const row = event.currentTarget;
		if (!(row instanceof HTMLElement) || row === draggedNavRow) {
			return;
		}
		const bounding = row.getBoundingClientRect();
		const after = event.clientY > bounding.top + bounding.height / 2;
		if (after) {
			row.after(draggedNavRow);
		} else {
			row.before(draggedNavRow);
		}
	};

	const onNavDragDrop = (event) => {
		event.preventDefault();
		if (!draggedNavRow) {
			return;
		}
		draggedNavRow.classList.remove("is-dragging");
		draggedNavRow = null;
		syncPayload();
	};

	const onNavDragEnd = () => {
		if (draggedNavRow) {
			draggedNavRow.classList.remove("is-dragging");
			draggedNavRow = null;
		}
	};

	const createNavRow = (entry = {}, depth = 0) => {
		const labelTranslations = entry.label ?? entry.labelTranslations ?? {};
		const labelEn = labelTranslations.en ?? entry.label ?? "";
		const labelVi = labelTranslations.vi ?? "";

		const row = document.createElement("tr");
		row.className = "nav-item-row";
		row.setAttribute("role", "row");
		row.dataset.navRow = "";
		setRowDepth(row, depth);
		row.draggable = !isReadOnly;

		const dragCell = document.createElement("td");
		dragCell.className = "drag-cell";
		const handle = document.createElement("span");
		handle.className = "nav-drag-handle";
		handle.dataset.dragHandle = "";
		handle.setAttribute("aria-label", "Drag to reorder");
		dragCell.append(handle);
		row.append(dragCell);

		const enCell = document.createElement("td");
		enCell.className = "nav-label-cell";
		const enInput = document.createElement("input");
		enInput.type = "text";
		enInput.dataset.navLabelEn = "";
		enInput.placeholder = "Home";
		enInput.value = labelEn;
		if (isReadOnly) {
			enInput.disabled = true;
		}
		enCell.append(enInput);
		row.append(enCell);

		const viCell = document.createElement("td");
		viCell.className = "nav-label-cell";
		const viInput = document.createElement("input");
		viInput.type = "text";
		viInput.dataset.navLabelVi = "";
		viInput.placeholder = "Trang chu";
		viInput.value = labelVi;
		if (isReadOnly) {
			viInput.disabled = true;
		}
		viCell.append(viInput);
		row.append(viCell);

		const linkCell = document.createElement("td");
		const hrefInput = document.createElement("input");
		hrefInput.type = "text";
		hrefInput.dataset.navHref = "";
		hrefInput.placeholder = "/about or https://example.com";
		hrefInput.value = entry.href ?? "";
		if (isReadOnly) {
			hrefInput.disabled = true;
		}
		linkCell.append(hrefInput);
		row.append(linkCell);

		const actionCell = document.createElement("td");
		actionCell.className = "nav-item-actions";
		const buttonGroup = document.createElement("div");
		buttonGroup.className = "nav-action-buttons";

		const childButton = document.createElement("button");
		childButton.type = "button";
		childButton.className = "btn btn-sm btn-outline-secondary nav-action mini";
		childButton.dataset.navAddChild = "";
		childButton.textContent = "+ Child";
		childButton.setAttribute("aria-label", addChildLabel);
		if (isReadOnly) {
			childButton.disabled = true;
		}
		buttonGroup.append(childButton);

		const indentButton = document.createElement("button");
		indentButton.type = "button";
		indentButton.className = "btn btn-sm btn-outline-secondary nav-action mini";
		indentButton.dataset.navIndent = "";
		indentButton.textContent = ">";
		indentButton.setAttribute("aria-label", indentLabel);
		if (isReadOnly) {
			indentButton.disabled = true;
		}
		buttonGroup.append(indentButton);

		const outdentButton = document.createElement("button");
		outdentButton.type = "button";
		outdentButton.className = "btn btn-sm btn-outline-secondary nav-action mini";
		outdentButton.dataset.navOutdent = "";
		outdentButton.textContent = "<";
		outdentButton.setAttribute("aria-label", outdentLabel);
		if (isReadOnly) {
			outdentButton.disabled = true;
		}
		buttonGroup.append(outdentButton);

		const removeButton = document.createElement("button");
		removeButton.type = "button";
		removeButton.className = "btn btn-sm btn-outline-danger nav-item-remove";
		removeButton.dataset.navRemove = "";
		removeButton.textContent = removeLabel;
		if (isReadOnly) {
			removeButton.disabled = true;
		}
		buttonGroup.append(removeButton);

		actionCell.append(buttonGroup);
		row.append(actionCell);

		attachNavRow(row);
		return row;
	};

	const findInsertPositionForChild = (row) => {
		let reference = row;
		const parentDepth = clampDepth(Number(row.dataset.depth ?? "0"));
		while (reference.nextElementSibling instanceof HTMLElement) {
			const nextDepth = clampDepth(Number(reference.nextElementSibling.dataset.depth ?? "0"));
			if (nextDepth <= parentDepth) {
				break;
			}
			reference = reference.nextElementSibling;
		}
		return reference;
	};

	const changeDepth = (row, delta) => {
		const current = Number(row.dataset.depth ?? "0");
		setRowDepth(row, current + delta);
		syncPayload();
	};

	const addChildRow = (parentRow) => {
		if (isReadOnly || !(rowsContainer instanceof HTMLElement)) {
			return;
		}
		const depth = clampDepth(Number(parentRow.dataset.depth ?? "0") + 1);
		const newRow = createNavRow({}, depth);
		const insertAfter = findInsertPositionForChild(parentRow);
		insertAfter.after(newRow);
		const focusInput = newRow.querySelector("[data-nav-label-en]");
		if (focusInput instanceof HTMLInputElement) {
			focusInput.focus();
		}
		syncPayload();
	};

	Array.from(rowsContainer?.querySelectorAll("[data-nav-row]") ?? []).forEach((row) => attachNavRow(row));

	rowsContainer?.addEventListener("input", syncPayload);
	rowsContainer?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) {
			return;
		}
		const row = findNavRow(target);
		if (!row) {
			return;
		}

		if (target.matches("[data-nav-remove]")) {
			row.remove();
			syncPayload();
			return;
		}

		if (target.matches("[data-nav-add-child]")) {
			addChildRow(row);
			return;
		}

		if (target.matches("[data-nav-indent]")) {
			changeDepth(row, 1);
			return;
		}

		if (target.matches("[data-nav-outdent]")) {
			changeDepth(row, -1);
			return;
		}
	});

	addButton?.addEventListener("click", () => {
		if (isReadOnly || !(rowsContainer instanceof HTMLElement)) {
			return;
		}
		const newRow = createNavRow({}, 0);
		rowsContainer.append(newRow);
		const focusInput = newRow.querySelector("[data-nav-label-en]");
		if (focusInput instanceof HTMLInputElement) {
			focusInput.focus();
		}
		syncPayload();
	});

	const updateEmptyState = () => {
		if (!emptyStateRow || !rowsContainer) {
			return;
		}
		const hasRows = Boolean(rowsContainer.querySelector("[data-nav-row]"));
		emptyStateRow.hidden = hasRows;
	};

	updateEmptyState();
	syncPayload();
</script>
