---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { SITE_TITLE } from "../../consts";
import { getDb, getSiteConfig } from "../../lib/blog";
import { getUiTranslations } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}
const { t } = getUiTranslations(Astro);

let loadError = "";
let siteConfig = {
	siteTitle: SITE_TITLE,
	homePageSlug: "home",
	headerBackground: "#ffffff",
	headerTextColor: "#0f1219",
	headerAccentColor: "#2337ff",
	footerText: "Edge CMS. Content updates go live straight from D1.",
	footerBackground: "#eef2f7",
	footerTextColor: "#60739f",
	navItems: [
		{
			label: t("nav.home"),
			labelTranslations: { en: "Home", vi: "Trang chu" },
			href: "/",
			sortOrder: 0,
		},
	],
};

try {
	siteConfig = await getSiteConfig(getDb(Astro.locals));
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadSiteSettings");
}
---

<AdminLayout
	title={t("nav.header")}
	description={t("messages.manageSiteSettings")}
	session={session}
	pageTitle={t("headings.headerFooter")}
	pageDescription={t("messages.headerFooterDescription")}
>
	<div class="admin-content-stack">
		{Astro.url.searchParams.get("siteSaved") && <p class="admin-notice">{t("messages.headerSettingsSaved")}</p>}
		{Astro.url.searchParams.get("siteError") && <p class="admin-notice admin-notice-error">{t("messages.headerSettingsFailed")}</p>}
		{loadError && <p class="admin-notice admin-notice-error">{loadError}</p>}
		<form method="post" action="/api/admin/site" class="admin-form-stack">
			<div class="admin-grid-two">
				<label><span>{t("labels.siteTitle")}</span><input name="siteTitle" required value={siteConfig.siteTitle} disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.homePageSlug")}</span><input name="homePageSlug" required value={siteConfig.homePageSlug} placeholder="home" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.headerBackground")}</span><input name="headerBackground" value={siteConfig.headerBackground} placeholder="#ffffff" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.headerTextColor")}</span><input name="headerTextColor" value={siteConfig.headerTextColor} placeholder="#0f1219" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.headerAccentColor")}</span><input name="headerAccentColor" value={siteConfig.headerAccentColor} placeholder="#2337ff" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.footerBackground")}</span><input name="footerBackground" value={siteConfig.footerBackground} placeholder="#eef2f7" disabled={Boolean(loadError)} /></label>
				<label><span>{t("labels.footerTextColor")}</span><input name="footerTextColor" value={siteConfig.footerTextColor} placeholder="#60739f" disabled={Boolean(loadError)} /></label>
				<label style="grid-column: 1 / -1;"><span>{t("labels.footerText")}</span><input name="footerText" value={siteConfig.footerText} disabled={Boolean(loadError)} /></label>
			</div>
			<div class="admin-form-section">
				<span>{t("labels.navigationItems")}</span>
				<input
					type="hidden"
					name="navItems"
					id="nav-items-payload"
					value={JSON.stringify(
						siteConfig.navItems.map((item, index) => ({
							label: item.labelTranslations,
							href: item.href,
							order: index + 1,
						})),
					)}
					disabled={Boolean(loadError)}
				/>
				<div
					class="nav-items-editor"
					data-nav-items-editor
					data-disabled={Boolean(loadError)}
					data-remove-label={t("actions.remove")}
				>
					<table class="nav-items-table admin-table" role="table">
						<thead>
							<tr>
								<th></th>
								<th>{t("labels.label")} (EN)</th>
								<th>{t("labels.label")} (VI)</th>
								<th>{t("labels.link")}</th>
								<th>{t("labels.action")}</th>
							</tr>
						</thead>
						<tbody data-nav-items-rows>
							<tr
								class="admin-table-empty-row admin-muted"
								data-nav-empty
								hidden={siteConfig.navItems.length > 0}
							>
								<td colSpan="5">{t("messages.noNavigationItemsConfigured")}</td>
							</tr>
							{
								siteConfig.navItems.map((item) => (
									<tr
										class="nav-item-row"
										role="row"
										data-nav-row
										draggable={!Boolean(loadError) ? "true" : "false"}
									>
										<td class="drag-cell">
											<span class="nav-drag-handle" data-drag-handle aria-label="Drag to reorder"></span>
										</td>
										<td>
											<input
												type="text"
												value={item.labelTranslations?.en ?? item.label ?? ""}
												placeholder="Home"
												data-nav-label-en
												disabled={Boolean(loadError)}
											/>
										</td>
										<td>
											<input
												type="text"
												value={item.labelTranslations?.vi ?? ""}
												placeholder="Trang chu"
												data-nav-label-vi
												disabled={Boolean(loadError)}
											/>
										</td>
										<td>
											<input
												type="text"
												value={item.href}
												placeholder="/about or https://example.com"
												data-nav-href
												disabled={Boolean(loadError)}
											/>
										</td>
										<td class="nav-item-actions">
											<button
												class="admin-ghost-button nav-item-remove"
												type="button"
												data-nav-remove
												disabled={Boolean(loadError)}
											>
												{t("actions.remove")}
											</button>
										</td>
									</tr>
								))
							}
						</tbody>
					</table>
					<button class="admin-ghost-button" type="button" data-nav-add disabled={Boolean(loadError)}>
						{t("actions.addRow")}
					</button>
				</div>
			</div>
			<div class="admin-form-section">
				<p class="admin-muted">{t("messages.navStorageHelp")}</p>
				<button class="admin-primary-button" type="submit" disabled={Boolean(loadError)}>{t("actions.saveHeader")}</button>
			</div>
		</form>
		<div class="admin-form-section">
			<strong>{t("headings.contactFormFields")}</strong>
			<p class="admin-muted">{t("messages.contactFormSharedConfig")}</p>
			<p><a class="admin-ghost-button" href="/admin/pages">{t("actions.manageContactForm")}</a></p>
		</div>
	</div>
</AdminLayout>

<style>
	.nav-items-editor {
		display: grid;
		gap: 0.7rem;
	}

	.nav-items-table {
		width: 100%;
		border-collapse: collapse;
	}

	.nav-items-table th,
	.nav-items-table td {
		padding: 0.45rem 0.6rem;
		border-bottom: 1px solid rgba(var(--gray), 0.18);
		vertical-align: middle;
	}

	.nav-items-table thead th {
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		color: var(--admin-muted, #60739f);
		letter-spacing: 0.04em;
	}

	.nav-items-table tbody tr:last-child td {
		border-bottom: none;
	}

	.nav-item-row input {
		width: 100%;
		border-radius: 6px;
		border: 1px solid rgba(var(--gray), 0.3);
		background: white;
		font: inherit;
		padding: 0.35rem 0.5rem;
	}

	.nav-item-row td {
		padding-top: 0.55rem;
		padding-bottom: 0.55rem;
	}

	.drag-cell {
		width: 48px;
	}

	.nav-item-actions {
		padding: 0;
	}
</style>

<script type="module">
	const editor = document.querySelector("[data-nav-items-editor]");
	const rowsContainer = editor?.querySelector("[data-nav-items-rows]");
	const payloadInput = document.getElementById("nav-items-payload");
	const addButton = editor?.querySelector("[data-nav-add]");
	const emptyStateRow = editor?.querySelector("[data-nav-empty]");
	const removeLabel = editor?.dataset.removeLabel ?? "Remove";
	const isReadOnly = editor?.dataset.disabled === "true";
	let draggedNavRow = null;

	const syncPayload = () => {
		if (!(rowsContainer instanceof HTMLElement) || !(payloadInput instanceof HTMLInputElement)) {
			return;
		}

		const entries = Array.from(rowsContainer.querySelectorAll("[data-nav-row]"))
			.map((row, index) => {
				const labelEn = row.querySelector("[data-nav-label-en]");
				const labelVi = row.querySelector("[data-nav-label-vi]");
				const href = row.querySelector("[data-nav-href]");

				if (
					!(labelEn instanceof HTMLInputElement) ||
					!(labelVi instanceof HTMLInputElement) ||
					!(href instanceof HTMLInputElement)
				) {
					return null;
				}

				const trimmedHref = href.value.trim();
				const trimmedEn = labelEn.value.trim();
				const trimmedVi = labelVi.value.trim();
				if (!trimmedEn || !trimmedHref) {
					return null;
				}

				return {
					label: {
						en: trimmedEn,
						...(trimmedVi ? { vi: trimmedVi } : {}),
					},
					href: trimmedHref,
					order: index + 1,
				};
			})
			.filter((entry) => Boolean(entry));

		payloadInput.value = JSON.stringify(entries);
		updateEmptyState();
	};

	const attachNavRow = (row) => {
		if (!(row instanceof HTMLElement) || row.dataset.navRowAttached === "true") {
			return;
		}
		row.dataset.navRowAttached = "true";
		row.draggable = !isReadOnly;
		row.addEventListener("dragstart", onNavDragStart);
		row.addEventListener("dragover", onNavDragOver);
		row.addEventListener("drop", onNavDragDrop);
		row.addEventListener("dragend", onNavDragEnd);
	};

	const findNavRow = (target) => (target instanceof Element ? target.closest("[data-nav-row]") : null);

	const onNavDragStart = (event) => {
		if (isReadOnly) {
			return;
		}
		const row = event.currentTarget;
		if (!(row instanceof HTMLElement)) {
			return;
		}
		draggedNavRow = row;
		row.classList.add("is-dragging");
		event.dataTransfer?.setData("text/plain", "");
		event.dataTransfer?.setDragImage(row, 0, 0);
	};

	const onNavDragOver = (event) => {
		if (!draggedNavRow) {
			return;
		}
		event.preventDefault();
		const row = event.currentTarget;
		if (!(row instanceof HTMLElement) || row === draggedNavRow) {
			return;
		}
		const bounding = row.getBoundingClientRect();
		const after = event.clientY > bounding.top + bounding.height / 2;
		if (after) {
			row.after(draggedNavRow);
		} else {
			row.before(draggedNavRow);
		}
	};

	const onNavDragDrop = (event) => {
		event.preventDefault();
		if (!draggedNavRow) {
			return;
		}
		draggedNavRow.classList.remove("is-dragging");
		draggedNavRow = null;
		syncPayload();
	};

	const onNavDragEnd = () => {
		if (draggedNavRow) {
			draggedNavRow.classList.remove("is-dragging");
			draggedNavRow = null;
		}
	};

	const createNavRow = (entry = {}) => {
		const labelTranslations = entry.label ?? entry.labelTranslations ?? {};
		const labelEn = labelTranslations.en ?? entry.label ?? "";
		const labelVi = labelTranslations.vi ?? "";

		const row = document.createElement("tr");
		row.className = "nav-item-row";
		row.setAttribute("role", "row");
		row.dataset.navRow = "";
		row.draggable = !isReadOnly;

		const dragCell = document.createElement("td");
		dragCell.className = "drag-cell";
		const handle = document.createElement("span");
		handle.className = "nav-drag-handle";
		handle.dataset.dragHandle = "";
		handle.setAttribute("aria-label", "Drag to reorder");
		dragCell.append(handle);
		row.append(dragCell);

		const enCell = document.createElement("td");
		const enInput = document.createElement("input");
		enInput.type = "text";
		enInput.dataset.navLabelEn = "";
		enInput.placeholder = "Home";
		enInput.value = labelEn;
		if (isReadOnly) {
			enInput.disabled = true;
		}
		enCell.append(enInput);
		row.append(enCell);

		const viCell = document.createElement("td");
		const viInput = document.createElement("input");
		viInput.type = "text";
		viInput.dataset.navLabelVi = "";
		viInput.placeholder = "Trang chu";
		viInput.value = labelVi;
		if (isReadOnly) {
			viInput.disabled = true;
		}
		viCell.append(viInput);
		row.append(viCell);

		const linkCell = document.createElement("td");
		const hrefInput = document.createElement("input");
		hrefInput.type = "text";
		hrefInput.dataset.navHref = "";
		hrefInput.placeholder = "/about or https://example.com";
		hrefInput.value = entry.href ?? "";
		if (isReadOnly) {
			hrefInput.disabled = true;
		}
		linkCell.append(hrefInput);
		row.append(linkCell);

		const actionCell = document.createElement("td");
		actionCell.className = "nav-item-actions";
		const removeButton = document.createElement("button");
		removeButton.type = "button";
		removeButton.className = "admin-ghost-button nav-item-remove";
		removeButton.dataset.navRemove = "";
		removeButton.textContent = removeLabel;
		if (isReadOnly) {
			removeButton.disabled = true;
		}
		actionCell.append(removeButton);
		row.append(actionCell);

		attachNavRow(row);
		return row;
	};

	Array.from(rowsContainer?.querySelectorAll("[data-nav-row]") ?? []).forEach((row) => attachNavRow(row));

	rowsContainer?.addEventListener("input", syncPayload);
	rowsContainer?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement) || !target.matches("[data-nav-remove]")) {
			return;
		}
		const row = findNavRow(target);
		if (row) {
			row.remove();
			syncPayload();
		}
	});

	addButton?.addEventListener("click", () => {
		if (isReadOnly || !(rowsContainer instanceof HTMLElement)) {
			return;
		}
		const newRow = createNavRow();
		rowsContainer.append(newRow);
		const focusInput = newRow.querySelector("[data-nav-label-en]");
		if (focusInput instanceof HTMLInputElement) {
			focusInput.focus();
		}
		syncPayload();
	});

	const updateEmptyState = () => {
		if (!emptyStateRow || !rowsContainer) {
			return;
		}
		const hasRows = Boolean(rowsContainer.querySelector("[data-nav-row]"));
		emptyStateRow.hidden = hasRows;
	};

	updateEmptyState();
	syncPayload();
</script>
