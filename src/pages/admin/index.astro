---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, getSiteConfig } from "../../lib/blog";
import { listContactForms } from "../../lib/contact-forms";
import { listAdminUsers } from "../../lib/db/admin-users";
import { listRoleSummaries } from "../../lib/db/roles";
import { listAllLanguages } from "../../lib/languages";
import { getUiTranslations, localizeAdminHref, localizeHref } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t, language } = getUiTranslations(Astro);
const db = getDb(Astro.locals);

const defaultConfig = {
	siteTitle: "Edge CMS",
	homePageSlug: "home",
};

let config = defaultConfig;
let postsTotal = 0;
let pagesTotal = 0;
let bannersTotal = 0;
let contactFormsTotal = 0;
let usersTotal = 0;
let rolesTotal = 0;
let languagesTotal = 0;
let postsPublished = 0;
let pagesPublished = 0;

try {
	const countRows = async (sql: string): Promise<number> => {
		const result = await db.prepare(sql).first<{ count: number }>();
		return Number(result?.count ?? 0);
	};

	const [siteConfig, postsCount, pagesCount, bannersCount, formsCount, usersCount, rolesCount, languagesCount, publishedPostsCount, publishedPagesCount] =
		await Promise.all([
			getSiteConfig(db),
			countRows(`SELECT COUNT(*) AS count FROM posts`),
			countRows(`SELECT COUNT(*) AS count FROM site_pages`),
			countRows(`SELECT COUNT(*) AS count FROM banners`),
			(async () => (await listContactForms(db)).length)(),
			(async () => (await listAdminUsers(db)).length)(),
			(async () => (await listRoleSummaries(db)).length)(),
			(async () => (await listAllLanguages(db)).length)(),
			countRows(`SELECT COUNT(*) AS count FROM posts WHERE status = 'published'`),
			countRows(`SELECT COUNT(*) AS count FROM site_pages WHERE status = 'published'`),
		]);

	config = siteConfig;
	postsTotal = postsCount;
	pagesTotal = pagesCount;
	bannersTotal = bannersCount;
	contactFormsTotal = formsCount;
	usersTotal = usersCount;
	rolesTotal = rolesCount;
	languagesTotal = languagesCount;
	postsPublished = publishedPostsCount;
	pagesPublished = publishedPagesCount;
} catch {
	// Fall back to zeroed stats if the dashboard data cannot be loaded.
}

const statCards = [
	{
		title: t("headings.posts", "Posts"),
		value: postsTotal,
		href: "/admin/posts",
		description: `${postsPublished} published`,
	},
	{
		title: t("headings.pages", "Pages"),
		value: pagesTotal,
		href: "/admin/pages",
		description: `${pagesPublished} published`,
	},
	{
		title: t("nav.banners", "Banners"),
		value: bannersTotal,
		href: "/admin/banners",
		description: "Reusable visual sections",
	},
	{
		title: t("nav.contactForms", "Contact Forms"),
		value: contactFormsTotal,
		href: "/admin/contact-forms",
		description: "Shared form definitions",
	},
	{
		title: t("nav.users", "Users"),
		value: usersTotal,
		href: "/admin/users",
		description: "Admin accounts",
	},
	{
		title: t("nav.roles", "Roles"),
		value: rolesTotal,
		href: "/admin/roles",
		description: "Permission bundles",
	},
	{
		title: t("nav.languages", "Languages"),
		value: languagesTotal,
		href: "/admin/languages",
		description: "Active locales",
	},
];

const quickActions = [
	{ label: t("actions.createPost"), href: "/admin/posts/new" },
	{ label: t("actions.createPage"), href: "/admin/pages/new" },
	{ label: t("nav.template"), href: "/admin/templates" },
	{ label: t("nav.settings"), href: "/admin/settings" },
];
---

<AdminLayout
	title={t("headings.dashboard", "Dashboard")}
	description={t("messages.dashboardIntro", "Overview of your CMS content, site settings, and admin workspace.")}
	session={session}
	pageEyebrow={t("app.admin")}
	pageTitle={t("headings.dashboard", "Dashboard")}
	pageDescription={t("messages.dashboardIntro", "Overview of your CMS content, site settings, and admin workspace.")}
>
	<div slot="actions" class="admin-page-actions">
		<a class="btn btn-primary" href={localizeAdminHref("/admin/templates")}>{t("nav.template")}</a>
		<a class="btn btn-outline-secondary" href={localizeHref("/")}>{t("actions.viewSite")}</a>
	</div>

	<div class="admin-content-stack">
		<section class="dashboard-hero">
			<div class="dashboard-hero-copy">
				<p class="dashboard-kicker">{t("app.brand")}</p>
				<h2 class="dashboard-title">
					{t("messages.dashboardWelcome", "Welcome back, {name}.").replace("{name}", session.displayName ?? t("messages.adminUserFallback"))}
				</h2>
				<p class="dashboard-summary">
					{t("messages.dashboardIntro", "Overview of your CMS content, site settings, and admin workspace.")}
				</p>
			</div>
			<div class="dashboard-meta">
				<div>
					<span>Site</span>
					<strong>{config.siteTitle}</strong>
				</div>
				<div>
					<span>Home</span>
					<strong>{config.homePageSlug}</strong>
				</div>
				<div>
					<span>Language</span>
					<strong>{language}</strong>
				</div>
			</div>
		</section>

		<section>
			<div class="dashboard-section-head">
				<h3 class="h5 mb-0">{t("messages.dashboardSummary", "Content overview")}</h3>
			</div>
			<div class="row g-3">
				{statCards.map((card) => (
					<div class="col-12 col-md-6 col-xl-4">
						<a href={localizeAdminHref(card.href)} class="dashboard-stat">
							<span class="dashboard-stat-title">{card.title}</span>
							<strong class="dashboard-stat-value">{card.value}</strong>
							<span class="dashboard-stat-description">{card.description}</span>
						</a>
					</div>
				))}
			</div>
		</section>

		<section class="dashboard-panels">
			<div class="dashboard-panel">
				<h3 class="h5 mb-0">{t("messages.dashboardQuickActions", "Quick actions")}</h3>
				<div class="dashboard-links">
					{quickActions.map((action) => (
						<a href={localizeAdminHref(action.href)} class="dashboard-action-link">
							<span>{action.label}</span>
							<span aria-hidden="true">→</span>
						</a>
					))}
				</div>
			</div>
			<div class="dashboard-panel">
				<h3 class="h5 mb-0">{t("nav.template")}</h3>
				<p class="dashboard-panel-copy">
					{t("messages.dashboardTemplateHelp", "Edit the raw HTML shell for the public header, navbar, page wrapper, and footer.")}
				</p>
				<div class="dashboard-links">
					<a class="dashboard-action-link" href={localizeAdminHref("/admin/templates")}>
						<span>{t("nav.template")}</span>
						<span aria-hidden="true">→</span>
					</a>
					<a class="dashboard-action-link" href={localizeAdminHref("/admin/templates/page")}>
						<span>Page</span>
						<span aria-hidden="true">→</span>
					</a>
				</div>
			</div>
		</section>
	</div>
</AdminLayout>

<style>
	.dashboard-hero {
		display: grid;
		gap: 1rem;
		padding: 1rem 1.1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0;
		background: #fff;
	}

	.dashboard-hero-copy {
		display: grid;
		gap: 0.35rem;
	}

	.dashboard-kicker {
		margin: 0;
		font-size: 0.62rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: rgba(15, 23, 42, 0.52);
	}

	.dashboard-title {
		margin: 0;
		font-size: clamp(1.35rem, 2vw, 1.75rem);
		line-height: 1.1;
		font-weight: 700;
	}

	.dashboard-summary {
		margin: 0;
		max-width: 58ch;
		color: rgba(15, 23, 42, 0.68);
	}

	.dashboard-meta {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		padding-top: 0.75rem;
		border-top: 1px solid rgba(15, 23, 42, 0.08);
	}

	.dashboard-meta div {
		display: grid;
		gap: 0.15rem;
	}

	.dashboard-meta span,
	.dashboard-stat-title {
		font-size: 0.62rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(15, 23, 42, 0.52);
	}

	.dashboard-meta strong,
	.dashboard-stat-value {
		font-size: 1rem;
		line-height: 1.1;
		font-weight: 700;
	}

	.dashboard-section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.dashboard-stat {
		display: grid;
		gap: 0.35rem;
		padding: 0.9rem 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0;
		background: #fff;
		color: inherit;
		text-decoration: none;
	}

	.dashboard-stat:hover {
		background: rgba(248, 250, 252, 0.96);
	}

	.dashboard-stat-description,
	.dashboard-panel-copy {
		font-size: 0.9rem;
		color: rgba(15, 23, 42, 0.66);
	}

	.dashboard-panels {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.dashboard-panel {
		display: grid;
		gap: 0.8rem;
		padding: 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0;
		background: #fff;
	}

	.dashboard-links {
		display: grid;
		gap: 0.45rem;
	}

	.dashboard-action-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.7rem 0.8rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0;
		color: inherit;
		text-decoration: none;
		background: #fff;
	}

	.dashboard-action-link:hover {
		background: rgba(248, 250, 252, 0.96);
	}

	@media (max-width: 991px) {
		.dashboard-meta,
		.dashboard-panels {
			grid-template-columns: 1fr;
		}
	}
</style>
