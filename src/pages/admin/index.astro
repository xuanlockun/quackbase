---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminOptionGrid from "../../components/admin/AdminOptionGrid.astro";
import { getDb } from "../../lib/blog";
import { listContactForms } from "../../lib/contact-forms";
import { listAdminUsers } from "../../lib/db/admin-users";
import { listRoleSummaries } from "../../lib/db/roles";
import { listAllLanguages } from "../../lib/languages";
import { getUiTranslations, localizeAdminHref } from "../../lib/i18n";

const session = Astro.locals.adminSession;
if (!session) {
	return Astro.redirect("/admin/login");
}

const { t } = getUiTranslations(Astro);
const db = getDb(Astro.locals);
let postsTotal = 0;
let pagesTotal = 0;
let bannersTotal = 0;
let contactFormsTotal = 0;
let usersTotal = 0;
let rolesTotal = 0;
let languagesTotal = 0;
let postsPublished = 0;
let pagesPublished = 0;

try {
	const countRows = async (sql: string): Promise<number> => {
		const result = await db.prepare(sql).first<{ count: number }>();
		return Number(result?.count ?? 0);
	};

	const [postsCount, pagesCount, bannersCount, formsCount, usersCount, rolesCount, languagesCount, publishedPostsCount, publishedPagesCount] = await Promise.all([
		countRows(`SELECT COUNT(*) AS count FROM posts`),
		countRows(`SELECT COUNT(*) AS count FROM site_pages`),
		countRows(`SELECT COUNT(*) AS count FROM banners`),
		(async () => (await listContactForms(db)).length)(),
		(async () => (await listAdminUsers(db)).length)(),
		(async () => (await listRoleSummaries(db)).length)(),
		(async () => (await listAllLanguages(db)).length)(),
		countRows(`SELECT COUNT(*) AS count FROM posts WHERE status = 'published'`),
		countRows(`SELECT COUNT(*) AS count FROM site_pages WHERE status = 'published'`),
	]);
	postsTotal = postsCount;
	pagesTotal = pagesCount;
	bannersTotal = bannersCount;
	contactFormsTotal = formsCount;
	usersTotal = usersCount;
	rolesTotal = rolesCount;
	languagesTotal = languagesCount;
	postsPublished = publishedPostsCount;
	pagesPublished = publishedPagesCount;
} catch {
	// Fall back to zeroed stats if the dashboard data cannot be loaded.
}

const statCards = [
	{
		title: t("headings.posts", "Posts"),
		value: postsTotal,
		href: "/admin/posts",
		description: `${postsPublished} published`,
		accent: "#4f7cff",
		accentSoft: "rgba(79, 124, 255, 0.12)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M7 4h10l4 4v12H7z" />
				<path d="M14 4v5h5" />
				<path d="M9 12h6" />
				<path d="M9 16h6" />
			</svg>
		`,
	},
	{
		title: t("headings.pages", "Pages"),
		value: pagesTotal,
		href: "/admin/pages",
		description: `${pagesPublished} published`,
		accent: "#2dd4bf",
		accentSoft: "rgba(45, 212, 191, 0.12)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 5h10l4 4v10H5z" />
				<path d="M15 5v4h4" />
				<path d="M8 12h6" />
				<path d="M8 16h4" />
			</svg>
		`,
	},
	{
		title: t("nav.banners", "Banners"),
		value: bannersTotal,
		href: "/admin/banners",
		description: "Reusable visual sections",
		accent: "#c084fc",
		accentSoft: "rgba(192, 132, 252, 0.14)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<rect x="4" y="5" width="16" height="11" rx="0" />
				<path d="M4 9h16" />
				<path d="M8 16l-2 3h12l-2-3" />
			</svg>
		`,
	},
	{
		title: t("nav.contactForms", "Contact Forms"),
		value: contactFormsTotal,
		href: "/admin/contact-forms",
		description: "Shared form definitions",
		accent: "#34d399",
		accentSoft: "rgba(52, 211, 153, 0.14)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M4 6h16v12H4z" />
				<path d="M7 10h10" />
				<path d="M7 14h6" />
			</svg>
		`,
	},
	{
		title: t("nav.users", "Users"),
		value: usersTotal,
		href: "/admin/users",
		description: "Admin accounts",
		accent: "#f59e0b",
		accentSoft: "rgba(245, 158, 11, 0.14)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="12" cy="8" r="3.25" />
				<path d="M6 19c1.5-3.3 3.8-5 6-5s4.5 1.7 6 5" />
			</svg>
		`,
	},
	{
		title: t("nav.roles", "Roles"),
		value: rolesTotal,
		href: "/admin/roles",
		description: "Permission bundles",
		accent: "#fb7185",
		accentSoft: "rgba(251, 113, 133, 0.14)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M4 8h16" />
				<path d="M7 12h10" />
				<path d="M10 16h4" />
				<path d="M6.5 5.5h11v13h-11z" />
			</svg>
		`,
	},
	{
		title: t("nav.languages", "Languages"),
		value: languagesTotal,
		href: "/admin/languages",
		description: "Active locales",
		accent: "#a3e635",
		accentSoft: "rgba(163, 230, 53, 0.16)",
		icon: `
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M4 7h8" />
				<path d="M8 7c0 4-1.8 7.5-4 10" />
				<path d="M10 17c2.2-2.2 3.8-4.7 5-7" />
				<path d="M12 10h8" />
				<path d="M15 5h4v14" />
			</svg>
		`,
	},
];

const quickActions = [
	{ label: t("actions.createPost"), href: "/admin/posts/new" },
	{ label: t("actions.createPage"), href: "/admin/pages/new" },
	{ label: t("nav.template"), href: "/admin/templates" },
	{ label: t("nav.settings"), href: "/admin/settings" },
];

const setupSteps = [
	{
		title: t("nav.settings"),
		description: t("messages.dashboardSetupSite", "Start with the site title, logo, storage, email, and captcha defaults."),
		href: localizeAdminHref("/admin/settings"),
		indexLabel: "01",
	},
	{
		title: t("nav.template"),
		description: t("messages.dashboardSetupTemplate", "Adjust the neutral public shell in this order: header, page, posts, then footer."),
		href: localizeAdminHref("/admin/templates"),
		indexLabel: "02",
	},
	{
		title: t("headings.pages", "Pages"),
		description: t("messages.dashboardSetupPages", "Build reusable page sections and assign banners or forms where they belong."),
		href: localizeAdminHref("/admin/pages"),
		indexLabel: "03",
	},
];

const chevronIcon = `
	<svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
		<path d="M8 5l4 5-4 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
	</svg>
`;
---

<AdminLayout
	title={t("headings.dashboard", "Dashboard")}
	description={t("messages.dashboardIntro", "Overview of your CMS content, site settings, and admin workspace.")}
	session={session}
	pageEyebrow={t("app.admin")}
	pageTitle={t("headings.dashboard", "Dashboard")}
	pageDescription={t("messages.dashboardIntro", "Overview of your CMS content, site settings, and admin workspace.")}
>
	<div class="admin-content-stack">
		<p class="dashboard-kicker mb-0">{t("messages.dashboardWelcome", "Welcome back, {name}.").replace("{name}", session.displayName ?? t("messages.adminUserFallback"))}</p>

		<section class="dashboard-setup">
			<div class="dashboard-section-head">
				<div class="dashboard-section-copy">
					<h3 class="h5 mb-0">{t("messages.dashboardSetupHeading", "Recommended setup flow")}</h3>
					<p class="dashboard-section-note mb-0">
						{t("messages.dashboardSetupHelp", "Use this order when you are shaping the default template or onboarding a new admin workspace.")}
					</p>
				</div>
			</div>
			<AdminOptionGrid items={setupSteps} columns="three" iconHtml={chevronIcon} />
		</section>

		<section>
			<div class="dashboard-section-head">
				<div class="dashboard-section-copy">
					<h3 class="h5 mb-0">{t("messages.dashboardSummary", "Content overview")}</h3>
					<p class="dashboard-section-note mb-0">{t("messages.dashboardSummaryHelp", "Jump into the main content areas and check what is already published.")}</p>
				</div>
			</div>
			<div class="row g-3">
				{statCards.map((card) => (
					<div class="col-12 col-md-6 col-xl-4">
						<a
							href={localizeAdminHref(card.href)}
							class="dashboard-stat"
							style={`--stat-accent:${card.accent};--stat-accent-soft:${card.accentSoft};`}
						>
							<span class="dashboard-stat-top">
								<span class="dashboard-stat-icon" aria-hidden="true" set:html={card.icon}></span>
								<span class="dashboard-stat-title">{card.title}</span>
							</span>
							<strong class="dashboard-stat-value">{card.value}</strong>
							<span class="dashboard-stat-description">{card.description}</span>
						</a>
					</div>
				))}
			</div>
		</section>

		<section class="dashboard-panels">
			<div class="dashboard-panel">
				<h3 class="h5 mb-0">{t("messages.dashboardQuickActions", "Quick actions")}</h3>
				<p class="dashboard-panel-copy mb-0">{t("messages.dashboardQuickActionsHelp", "Start a common task without leaving the dashboard.")}</p>
				<div class="dashboard-links">
					{quickActions.map((action) => (
						<a href={localizeAdminHref(action.href)} class="dashboard-action-link">
							<span>{action.label}</span>
							<span class="dashboard-action-icon" aria-hidden="true" set:html={chevronIcon}></span>
						</a>
					))}
				</div>
			</div>
			<div class="dashboard-panel">
				<h3 class="h5 mb-0">{t("nav.template")}</h3>
				<p class="dashboard-panel-copy">
					{t("messages.dashboardTemplateHelp", "Edit the raw HTML shell for the public header, page wrapper, posts section, and footer.")}
				</p>
				<div class="dashboard-links">
					<a class="dashboard-action-link" href={localizeAdminHref("/admin/templates")}>
						<span>{t("nav.template")}</span>
						<span class="dashboard-action-icon" aria-hidden="true" set:html={chevronIcon}></span>
					</a>
					<a class="dashboard-action-link" href={localizeAdminHref("/admin/templates/page")}>
						<span>{t("headings.page", "Page")}</span>
						<span class="dashboard-action-icon" aria-hidden="true" set:html={chevronIcon}></span>
					</a>
				</div>
			</div>
		</section>
	</div>
</AdminLayout>

<style>
	.dashboard-kicker {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 600;
		color: rgba(15, 23, 42, 0.7);
	}

	.dashboard-section-copy {
		display: grid;
		gap: 0.2rem;
	}

	.dashboard-section-note {
		font-size: 0.9rem;
		color: rgba(15, 23, 42, 0.62);
	}

	.dashboard-setup {
		display: grid;
		gap: 0.85rem;
	}

	.dashboard-stat-title {
		font-size: 0.62rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(15, 23, 42, 0.52);
	}

	.dashboard-stat-value {
		font-size: 1rem;
		line-height: 1.1;
		font-weight: 700;
	}

	.dashboard-section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.dashboard-stat {
		display: grid;
		gap: 0.4rem;
		padding: 0.95rem 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0.8rem;
		background: #fff;
		color: inherit;
		text-decoration: none;
	}

	.dashboard-stat:hover {
		background: rgba(249, 250, 251, 0.98);
		border-color: color-mix(in srgb, var(--stat-accent, #4f7cff) 30%, rgba(15, 23, 42, 0.08));
	}

	.dashboard-stat-top {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		min-width: 0;
	}

	.dashboard-stat-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		flex: 0 0 auto;
		border: 1px solid color-mix(in srgb, var(--stat-accent, #4f7cff) 32%, rgba(15, 23, 42, 0.08));
		border-radius: 0.7rem;
		color: var(--stat-accent, #4f7cff);
		background: color-mix(in srgb, var(--stat-accent-soft, rgba(79, 124, 255, 0.12)) 72%, white);
	}

	.dashboard-stat-icon svg {
		width: 1rem;
		height: 1rem;
	}

	.dashboard-stat-description,
	.dashboard-panel-copy {
		font-size: 0.9rem;
		color: rgba(15, 23, 42, 0.66);
	}

	.dashboard-panels {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.dashboard-panel {
		display: grid;
		gap: 0.8rem;
		padding: 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0;
		background: #fff;
	}

	.dashboard-links {
		display: grid;
		gap: 0.45rem;
	}

	.dashboard-action-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.7rem 0.8rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 0;
		color: inherit;
		text-decoration: none;
		background: #fff;
	}

	.dashboard-action-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 1.15rem;
		height: 1.15rem;
		color: rgba(15, 23, 42, 0.55);
	}

	.dashboard-action-icon svg {
		width: 100%;
		height: 100%;
	}

	.dashboard-action-link:hover {
		background: rgba(248, 250, 252, 0.96);
	}

	@media (max-width: 991px) {
		.dashboard-panels {
			grid-template-columns: 1fr;
		}
	}
</style>
