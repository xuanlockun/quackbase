---
export const prerender = false;

import BlogPost from "../layouts/BlogPost.astro";
import CmsPageSections from "../components/CmsPageSections.astro";
import { getDb, getPublishedPageBySlug } from "../lib/blog";

const reservedSlugs = new Set(["admin"]);
const slug = Astro.params.slug ?? "";

let page = null;

if (!reservedSlugs.has(slug)) {
	try {
		const db = getDb(Astro.locals);
		page = await getPublishedPageBySlug(db, slug);
	} catch {
		page = null;
	}
}

if (!page) {
	Astro.response.status = 404;
}
---

{
	page ? (
		<BlogPost
			title={page.title}
			description={page.description}
			pubDate={page.updatedAt}
			contentHtml={page.contentHtml}
			showDate={false}
			wideContent={true}
		>
			<CmsPageSections pageSlug={page.slug} pageSections={page.pageSections} />
		</BlogPost>
	) : (
		<BlogPost
			title="Page not found"
			description="The requested page does not exist."
			pubDate={new Date()}
			contentHtml="<p>This page does not exist.</p>"
			showDate={false}
			wideContent={true}
		/>
	)
}
