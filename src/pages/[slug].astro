---
export const prerender = false;

import BlogPost from "../layouts/BlogPost.astro";
import CmsPageSections from "../components/CmsPageSections.astro";
import { getDb, getPublishedPageBySlug, getSiteConfig } from "../lib/blog";
import { getLanguageCatalog, getUiTranslations, isSupportedLanguage, resolveLanguage } from "../lib/i18n";

const reservedSlugs = new Set(["admin"]);
const slug = Astro.params.slug ?? "";
const { t } = getUiTranslations(Astro);
const catalog = getLanguageCatalog(Astro.locals);
const def = catalog.defaultLanguageCode;

let page = null;
let language = def;
let config = null;

if (isSupportedLanguage(slug, catalog)) {
	try {
		const db = getDb(Astro.locals);
		config = await getSiteConfig(db);
		language = resolveLanguage(slug, catalog);
		page = await getPublishedPageBySlug(db, config.homePageSlug, language, catalog);
	} catch {
		page = null;
	}
} else if (!reservedSlugs.has(slug)) {
	try {
		const db = getDb(Astro.locals);
		page = await getPublishedPageBySlug(db, slug, def, catalog);
	} catch {
		page = null;
	}
}

if (!page) {
	Astro.response.status = 404;
}
---

{
	page ? (
		<BlogPost
			title={page.title}
			description={page.description}
			pubDate={page.updatedAt}
			showDate={false}
			wideContent={true}
			showTitle={page.showTitle}
			lang={language}
			faviconHref={config?.faviconUrl}
		>
			<CmsPageSections
				pageSections={page.pageSections}
				contentHtml={page.contentHtml}
				pageTemplateHtml={config?.pageTemplateHtml}
				blogFeedTemplateHtml={config?.blogFeedTemplateHtml}
				currentLanguage={language}
				currentPath={Astro.url.pathname}
			/>
		</BlogPost>
	) : (
		<BlogPost
			title={t("messages.pageNotFound")}
			description={t("messages.pageNotFoundDescription")}
			pubDate={new Date()}
			contentHtml={`<p>${t("messages.pageNotFoundBody")}</p>`}
			showDate={false}
			wideContent={true}
			showTitle={true}
			lang={language}
			faviconHref={config?.faviconUrl}
		/>
	)
}
