---
export const prerender = false;

import BlogPost from "../layouts/BlogPost.astro";
import CmsPageSections from "../components/CmsPageSections.astro";
import { getDb, getPublishedPageBySlug } from "../lib/blog";
import { getUiTranslations } from "../lib/i18n";

const reservedSlugs = new Set(["admin"]);
const slug = Astro.params.slug ?? "";
const { t } = getUiTranslations(Astro);

let page = null;

if (!reservedSlugs.has(slug)) {
	try {
		const db = getDb(Astro.locals);
		page = await getPublishedPageBySlug(db, slug, "en");
	} catch {
		page = null;
	}
}

if (!page) {
	Astro.response.status = 404;
}
---

{
	page ? (
		<BlogPost
			title={page.title}
			description={page.description}
			pubDate={page.updatedAt}
			showDate={false}
			wideContent={true}
			lang="en"
		>
			<CmsPageSections pageSections={page.pageSections} contentHtml={page.contentHtml} currentLanguage="en" />
		</BlogPost>
	) : (
		<BlogPost
			title={t("messages.pageNotFound")}
			description={t("messages.pageNotFoundDescription")}
			pubDate={new Date()}
			contentHtml={`<p>${t("messages.pageNotFoundBody")}</p>`}
			showDate={false}
			wideContent={true}
			lang="en"
		/>
	)
}
