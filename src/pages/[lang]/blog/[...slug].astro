---
export const prerender = false;

import BlogPost from "../../../layouts/BlogPost.astro";
import { getDb, getPublishedPostBySlug } from "../../../lib/blog";
import { getUiTranslations, isSupportedLanguage, resolveLanguage } from "../../../lib/i18n";

const requestedLanguage = Astro.params.lang ?? "";
const slug = Astro.params.slug ?? "";

let post = null;
let loadError = "";
const { t } = getUiTranslations(Astro);

if (!isSupportedLanguage(requestedLanguage)) {
	Astro.response.status = 404;
} else {
	try {
		post = await getPublishedPostBySlug(getDb(Astro.locals), slug, resolveLanguage(requestedLanguage));
	} catch (error) {
		loadError = error instanceof Error ? error.message : t("messages.failedToLoadPosts");
	}
}

if (!post && !loadError && Astro.response.status !== 404) {
	Astro.response.status = 404;
} else if (loadError) {
	Astro.response.status = 503;
}
---

{
	post ? (
		<BlogPost
			title={post.title}
			description={post.description}
			pubDate={post.pubDate}
			updatedDate={post.updatedDate}
			heroImage={post.heroImage}
			contentHtml={post.contentHtml}
			lang={post.resolvedLanguage}
		/>
	) : (
		<BlogPost
			title={loadError ? t("messages.blogNotReady") : t("messages.postNotFound")}
			description={loadError ? t("messages.blogNotReadyDescription") : t("messages.postNotFoundDescription")}
			pubDate={new Date()}
			contentHtml={
				loadError
					? `<p>${t("messages.blogNotReadyBody")}</p><p><code>${loadError}</code></p>`
					: `<p>${t("messages.postNotFoundBody")}</p>`
			}
			lang={resolveLanguage(requestedLanguage)}
		/>
	)
}
