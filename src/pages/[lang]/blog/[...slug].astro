---
export const prerender = false;

import BlogPost from "../../../layouts/BlogPost.astro";
import { getDb, getPublishedPostBySlug } from "../../../lib/blog";
import { isSupportedLanguage, resolveLanguage } from "../../../lib/i18n";

const requestedLanguage = Astro.params.lang ?? "";
const slug = Astro.params.slug ?? "";

let post = null;
let loadError = "";

if (!isSupportedLanguage(requestedLanguage)) {
	Astro.response.status = 404;
} else {
	try {
		post = await getPublishedPostBySlug(getDb(Astro.locals), slug, resolveLanguage(requestedLanguage));
	} catch (error) {
		loadError = error instanceof Error ? error.message : "Failed to load post.";
	}
}

if (!post && !loadError && Astro.response.status !== 404) {
	Astro.response.status = 404;
} else if (loadError) {
	Astro.response.status = 503;
}
---

{
	post ? (
		<BlogPost
			title={post.title}
			description={post.description}
			pubDate={post.pubDate}
			updatedDate={post.updatedDate}
			heroImage={post.heroImage}
			contentHtml={post.contentHtml}
			lang={post.resolvedLanguage}
		/>
	) : (
		<BlogPost
			title={loadError ? "Blog is not ready" : "Post not found"}
			description={loadError ? "The CMS database is not configured yet." : "The requested post does not exist."}
			pubDate={new Date()}
			contentHtml={
				loadError
					? `<p>Check the D1 binding, database ID, and run the posts migration.</p><p><code>${loadError}</code></p>`
					: "<p>This post does not exist or is not published.</p>"
			}
			lang={resolveLanguage(requestedLanguage)}
		/>
	)
}
