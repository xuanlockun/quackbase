---
export const prerender = false;

import BlogPost from "../../../layouts/BlogPost.astro";
import { getDb, getPublishedPostBySlug } from "../../../lib/blog";
import {
	getLanguageCatalog,
	getLocalizedPostPath,
	getUiTranslations,
	isSupportedLanguage,
	resolveLanguage,
} from "../../../lib/i18n";

const catalog = getLanguageCatalog(Astro.locals);
const requestedLanguage = Astro.params.lang ?? "";
const slug = Astro.params.slug ?? "";

let post = null;
let loadError = "";
const { t } = getUiTranslations(Astro);

if (!isSupportedLanguage(requestedLanguage, catalog)) {
	const target = new URL(Astro.url);
	target.pathname = `/${catalog.defaultLanguageCode}/blog/${slug}/`;
	return Astro.redirect(target.toString(), 301);
}

const lang = resolveLanguage(requestedLanguage, catalog);

try {
	post = await getPublishedPostBySlug(getDb(Astro.locals), slug, lang, catalog);
} catch (error) {
	loadError = error instanceof Error ? error.message : t("messages.failedToLoadPosts");
}

if (!post && !loadError) {
	Astro.response.status = 404;
} else if (loadError) {
	Astro.response.status = 503;
}

if (post) {
	return Astro.redirect(getLocalizedPostPath(post.slugTranslations, lang, catalog), 301);
}
---

<BlogPost
	title={loadError ? t("messages.blogNotReady") : t("messages.postNotFound")}
	description={loadError ? t("messages.blogNotReadyDescription") : t("messages.postNotFoundDescription")}
	pubDate={new Date()}
	contentHtml={
		loadError
			? `<p>${t("messages.blogNotReadyBody")}</p><p><code>${loadError}</code></p>`
			: `<p>${t("messages.postNotFoundBody")}</p>`
	}
	lang={lang}
/>
