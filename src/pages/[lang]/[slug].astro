---
export const prerender = false;

import BlogPost from "../../layouts/BlogPost.astro";
import CmsPageSections from "../../components/CmsPageSections.astro";
import { getDb, getPublishedPageBySlug, getPublishedPostBySlug } from "../../lib/blog";
import { getUiTranslations, isSupportedLanguage, resolveLanguage } from "../../lib/i18n";

const requestedLanguage = Astro.params.lang ?? "";
const slug = Astro.params.slug ?? "";
const { t } = getUiTranslations(Astro);

let page = null;
let post = null;
let loadError = "";

if (!isSupportedLanguage(requestedLanguage)) {
	Astro.response.status = 404;
} else {
	try {
		const db = getDb(Astro.locals);
		page = await getPublishedPageBySlug(db, slug, resolveLanguage(requestedLanguage));
		if (!page) {
			post = await getPublishedPostBySlug(db, slug, resolveLanguage(requestedLanguage));
		}
	} catch (error) {
		loadError = error instanceof Error ? error.message : t("messages.failedToLoadPosts");
	}
}

if (!page && !post && !loadError && Astro.response.status !== 404) {
	Astro.response.status = 404;
} else if (loadError) {
	Astro.response.status = 503;
}
---

{
	page ? (
		<BlogPost
			title={page.title}
			description={page.description}
			pubDate={page.updatedAt}
			showDate={false}
			wideContent={true}
			lang={page.resolvedLanguage}
		>
			<CmsPageSections
				pageSections={page.pageSections}
				contentHtml={page.contentHtml}
				currentLanguage={resolveLanguage(requestedLanguage)}
				currentPath={Astro.url.pathname}
			/>
		</BlogPost>
	) : post ? (
		<BlogPost
			title={post.title}
			description={post.description}
			pubDate={post.pubDate}
			updatedDate={post.updatedDate}
			heroImage={post.heroImage}
			contentHtml={post.contentHtml}
			lang={post.resolvedLanguage}
		/>
	) : (
		<BlogPost
			title={loadError ? t("messages.blogNotReady") : t("messages.pageNotFound")}
			description={
				loadError ? t("messages.blogNotReadyDescription") : t("messages.pageNotFoundDescription")
			}
			pubDate={new Date()}
			contentHtml={
				loadError
					? `<p>${t("messages.blogNotReadyBody")}</p><p><code>${loadError}</code></p>`
					: `<p>${t("messages.pageNotFoundBody")}</p>`
			}
			showDate={false}
			wideContent={true}
			lang={resolveLanguage(requestedLanguage)}
		/>
	)
}
