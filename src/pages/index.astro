---
export const prerender = false;

import BlogPost from '../layouts/BlogPost.astro';
import CmsPageSections from '../components/CmsPageSections.astro';
import { getDb, getPublishedPageBySlug, getSiteConfig } from '../lib/blog';

let page = null;

try {
	const db = getDb(Astro.locals);
	const config = await getSiteConfig(db);
	page = await getPublishedPageBySlug(db, config.homePageSlug);
} catch {
	page = null;
}

if (!page) {
	Astro.response.status = 404;
}
---

{
	page ? (
		<BlogPost
			title={page.title}
			description={page.description}
			pubDate={page.updatedAt}
			showDate={false}
			wideContent={true}
		>
			<CmsPageSections pageSections={page.pageSections} contentHtml={page.contentHtml} />
		</BlogPost>
	) : (
		<BlogPost
			title="Home page not configured"
			description="Create a CMS page and choose its slug as the home page in the header settings."
			pubDate={new Date()}
			contentHtml="<p>Create and publish a CMS page, then open the header settings and set <code>Home page slug</code> to that page slug, for example <code>home</code>.</p>"
			showDate={false}
			wideContent={true}
		/>
	)
}
