---
import BaseHead from "../components/BaseHead.astro";
import Sidebar from "../components/admin/Sidebar.astro";
import LanguageSwitch from "../components/LanguageSwitch.astro";
import { SITE_TITLE } from "../consts";
import type { AdminSession } from "../lib/auth/types";
import { getUiTranslations } from "../lib/i18n";

interface Props {
	title: string;
	description: string;
	session: AdminSession | null;
	pageTitle: string;
	pageDescription?: string;
	pageEyebrow?: string;
}

const {
	title,
	description,
	session,
	pageTitle,
	pageDescription,
	pageEyebrow = "Admin",
} = Astro.props;
const { t, language } = getUiTranslations(Astro);

const profileName = session?.displayName ?? t("messages.adminUserFallback");
const profileEmail = session?.email ?? "";
const profileInitials = profileName
	.split(/\s+/)
	.filter(Boolean)
	.map((part) => part.charAt(0))
	.slice(0, 2)
	.join("")
	.toUpperCase() || "A";
const toggleLabel = "Toggle sidebar navigation";

---

<!doctype html>
<html lang={language}>
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
	</head>
	<body class="admin-app">
		<div class="admin-shell">
			<header class="admin-topbar border-bottom">
				<div class="container-fluid d-flex align-items-center gap-3 px-3 px-lg-4">
					<button
						class="btn btn-outline-secondary admin-topbar-toggler d-lg-none"
						type="button"
						data-bs-toggle="offcanvas"
						data-bs-target="#adminSidebar"
						aria-controls="adminSidebar"
					>
						<span class="admin-toggler-icon" aria-hidden="true"></span>
						<span class="visually-hidden">{toggleLabel}</span>
					</button>
					<div class="d-flex align-items-center gap-2 admin-topbar-brand">
						<span class="brand-gradient rounded-pill px-3 py-2">{t("app.brand")}</span>
						<div class="d-none d-sm-flex flex-column lh-sm">
							<strong class="small text-uppercase letter-spacing-wide">{t("app.admin")}</strong>
							<span class="small text-muted">Workspace</span>
						</div>
					</div>
					<div class="d-flex align-items-center gap-3 ms-auto admin-topbar-actions">
						<div class="d-none d-lg-flex align-items-center">
							<LanguageSwitch />
						</div>
						<div class="dropdown">
							<button
								class="btn btn-outline-secondary btn-sm dropdown-toggle d-flex align-items-center gap-2 admin-user-button"
								type="button"
								data-bs-toggle="dropdown"
								aria-expanded="false"
							>
								<span class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:38px;height:38px;font-weight:700;">
									{profileInitials}
								</span>
								<span class="text-start admin-user-labels">
									<strong class="d-block">{profileName}</strong>
									{profileEmail && <small class="text-muted">{profileEmail}</small>}
								</span>
								</button>
							<ul class="dropdown-menu dropdown-menu-end shadow">
								<li><h6 class="dropdown-header">{t("labels.user")}</h6></li>
								{profileEmail && <li><span class="dropdown-item-text text-truncate px-3">{profileEmail}</span></li>}
								<li><hr class="dropdown-divider" /></li>
								<li>
									<form method="post" action="/api/admin/auth/logout">
										<button type="submit" class="dropdown-item text-danger">
											{t("actions.logOut")}
										</button>
									</form>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</header>

			<div
				class="offcanvas offcanvas-start admin-offcanvas d-lg-none"
				tabindex="-1"
				id="adminSidebar"
				aria-labelledby="adminSidebarLabel"
			>
				<div class="offcanvas-header d-lg-none">
					<h5 class="offcanvas-title" id="adminSidebarLabel">{t("app.admin")}</h5>
					<button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
				</div>
				<div class="offcanvas-body p-0 d-flex flex-column">
					<Sidebar session={session} />
				</div>
			</div>

			<div class="admin-content d-flex flex-grow-1 align-items-stretch">
				<aside class="admin-sidebar d-none d-lg-flex flex-column h-100">
					<Sidebar session={session} />
				</aside>
				<main class="admin-main flex-grow-1">
					<div class="container-fluid px-3 px-lg-4 py-4 py-lg-4">
						<div class="row justify-content-center">
							<div class="col-12 col-xxl-11">
								<section class="card admin-page-shell">
									<header class="card-header border-0">
										<div class="d-flex flex-column flex-xl-row justify-content-between align-items-start align-items-xl-center gap-3">
											<div class="admin-header-title">
												<p class="eyebrow mb-0">{pageEyebrow}</p>
												<h1 class="h4">{pageTitle}</h1>
												{pageDescription && <p>{pageDescription}</p>}
											</div>
											<div class="admin-page-actions">
												<slot name="actions" />
											</div>
										</div>
									</header>
									<div class="card-body">
										<slot />
									</div>
								</section>
							</div>
						</div>
					</div>
				</main>
			</div>
		</div>
		<script is:inline>
			document.querySelectorAll("[data-admin-sidebar-link]").forEach((link) => {
				if (!(link instanceof HTMLAnchorElement)) {
					return;
				}

				link.addEventListener("click", () => {
					const offcanvas = link.closest(".offcanvas");
					if (!(offcanvas instanceof HTMLElement)) {
						return;
					}

					const bootstrap = window.bootstrap;
					if (bootstrap?.Offcanvas) {
						const instance =
							bootstrap.Offcanvas.getInstance(offcanvas) ??
							bootstrap.Offcanvas.getOrCreateInstance(offcanvas);
						instance.hide();
					}
				});
			});
		</script>
	</body>
</html>
