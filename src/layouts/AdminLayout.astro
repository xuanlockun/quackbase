---
import BaseHead from "../components/BaseHead.astro";
import Sidebar from "../components/admin/Sidebar.astro";
import LanguageSwitch from "../components/LanguageSwitch.astro";
import { SITE_TITLE } from "../consts";
import type { AdminSession } from "../lib/auth/types";
import { getUiTranslations } from "../lib/i18n";

interface Props {
	title: string;
	description: string;
	session: AdminSession | null;
	pageTitle: string;
	pageDescription?: string;
	pageEyebrow?: string;
}

const {
	title,
	description,
	session,
	pageTitle,
	pageDescription,
	pageEyebrow = "Admin",
} = Astro.props;
const { t, language } = getUiTranslations(Astro);

const profileName = session?.displayName ?? t("messages.adminUserFallback");
const profileEmail = session?.email ?? "";
const profileInitials = profileName
	.split(/\s+/)
	.filter(Boolean)
	.map((part) => part.charAt(0))
	.slice(0, 2)
	.join("")
	.toUpperCase() || "A";
const toggleLabel = "Toggle sidebar navigation";

---

<!doctype html>
<html lang={language}>
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
	</head>
<body class="bg-light">
		<div class="min-vh-100 d-flex flex-column">
			<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3 px-4">
				<div class="container-fluid">
					<button
						class="btn btn-outline-secondary d-lg-none me-3"
						type="button"
						data-bs-toggle="offcanvas"
						data-bs-target="#adminSidebar"
						aria-controls="adminSidebar"
					>
						<span class="navbar-toggler-icon"></span>
						<span class="visually-hidden">{toggleLabel}</span>
					</button>
					<div class="d-flex align-items-center gap-2">
						<span class="badge bg-primary rounded-pill px-3 py-2">{t("app.brand")}</span>
						<span class="text-muted">{t("app.admin")}</span>
					</div>
					<div class="d-flex align-items-center gap-3 ms-auto">
						<div class="d-none d-lg-flex align-items-center">
							<LanguageSwitch />
						</div>
						<div class="dropdown">
							<button
								class="btn btn-outline-secondary btn-sm dropdown-toggle d-flex align-items-center gap-2"
								type="button"
								data-bs-toggle="dropdown"
								aria-expanded="false"
							>
								<span class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width:38px;height:38px;font-weight:700;">
									{profileInitials}
								</span>
								<span class="text-start">
									<strong class="d-block">{profileName}</strong>
									{profileEmail && <small class="text-muted">{profileEmail}</small>}
								</span>
							</button>
							<ul class="dropdown-menu dropdown-menu-end shadow">
								<li><h6 class="dropdown-header">{t("labels.user")}</h6></li>
								{profileEmail && <li><span class="dropdown-item-text text-truncate px-3">{profileEmail}</span></li>}
								<li><hr class="dropdown-divider" /></li>
								<li>
									<form method="post" action="/api/admin/auth/logout">
										<button type="submit" class="dropdown-item text-danger">
											{t("actions.logOut")}
										</button>
									</form>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</nav>

			<div
				class="offcanvas offcanvas-start offcanvas-lg bg-white border-end"
				tabindex="-1"
				id="adminSidebar"
				aria-labelledby="adminSidebarLabel"
			>
				<div class="offcanvas-header d-lg-none">
					<h5 class="offcanvas-title" id="adminSidebarLabel">{t("app.admin")}</h5>
					<button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
				</div>
				<div class="offcanvas-body p-0 d-flex flex-column">
					<Sidebar session={session} />
				</div>
			</div>

			<div class="container-fluid px-4 py-4">
				<div class="row justify-content-center">
					<div class="col-12">
						<section class="card shadow-sm border-0">
							<header class="card-header bg-white border-0 px-4 py-3 d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
								<div>
									<p class="text-uppercase text-muted fs-7 mb-1">{pageEyebrow}</p>
									<h1 class="h4 mb-1">{pageTitle}</h1>
									{pageDescription && <p class="text-muted mb-0">{pageDescription}</p>}
								</div>
								<div class="d-flex align-items-center gap-2">
									<slot name="actions" />
								</div>
							</header>
							<div class="card-body p-4">
								<slot />
							</div>
						</section>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
