---
import "bootstrap/dist/css/bootstrap.min.css";
import BaseHead from "../components/BaseHead.astro";
import Sidebar from "../components/admin/Sidebar.astro";
import { SITE_TITLE } from "../consts";
import type { AdminSession } from "../lib/auth/types";
import { getUiTranslations } from "../lib/i18n";

interface Props {
	title: string;
	description: string;
	session: AdminSession | null;
	pageTitle: string;
	pageDescription?: string;
	pageEyebrow?: string;
}

const {
	title,
	description,
	session,
	pageTitle,
	pageDescription,
	pageEyebrow = "Admin",
} = Astro.props;
const { language } = getUiTranslations(Astro);
---

<!doctype html>
<html lang={language}>
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
	</head>
	<body class="admin-body">
		<main class="admin-shell d-flex min-vh-100 align-items-stretch">
			<aside class="admin-sidebar-column flex-shrink-0">
				<Sidebar session={session} />
			</aside>

			<div class="admin-content-column flex-grow-1 min-vw-0 p-2 p-lg-3">
				<section class="admin-panel admin-panel-main h-100">
					<header class="admin-page-header">
						<div class="admin-page-copy">
							<p class="admin-page-eyebrow">{pageEyebrow}</p>
							<h1>{pageTitle}</h1>
							{pageDescription && <p class="admin-page-description">{pageDescription}</p>}
						</div>
						<div class="admin-page-actions">
							<slot name="actions" />
						</div>
					</header>
					<slot />
				</section>
			</div>
		</main>
	</body>
</html>
