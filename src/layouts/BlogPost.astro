---
import SiteLayout from "../components/site/SiteLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { getUiTranslations } from "../lib/i18n";

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string;
	contentHtml?: string;
	showDate?: boolean;
	wideContent?: boolean;
	showTitle?: boolean;
	lang?: string;
	faviconHref?: string;
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	contentHtml,
	showDate = true,
	wideContent = false,
	showTitle = true,
	lang = "en",
	faviconHref,
} = Astro.props;
const { t } = getUiTranslations(Astro);
const mainClass = wideContent ? "site-main site-main--wide" : "site-main";
---

<SiteLayout title={title} description={description} lang={lang} faviconHref={faviconHref} mainClass={mainClass}>
	{wideContent ? (
		<article class="site-article site-article--wide">
			{heroImage && (
				<div class="site-hero-media">
					<img src={heroImage} alt="" class="img-fluid" />
				</div>
			)}
			{showDate && (
				<div class="site-meta-row d-flex flex-column flex-md-row justify-content-between mb-3 text-muted small">
					<div>
						<span>{t("messages.publishedOn")} </span>
						<FormattedDate date={pubDate} />
					</div>
					{updatedDate && (
						<div>
							<span>{t("messages.lastUpdatedOn")} </span>
							<FormattedDate date={updatedDate} />
						</div>
					)}
				</div>
			)}
			{showTitle && (
				<>
					<h1 class="display-5">{title}</h1>
					<hr class="site-section-divider" />
				</>
			)}
			{contentHtml && <div class="site-prose site-prose--wide" set:html={contentHtml} />}
			<slot />
		</article>
	) : (
		<div class="container">
			<article class="site-article site-surface-article card shadow-sm border-0">
				<div class="row g-0">
					{
						heroImage && (
							<div class="col-12">
								<img src={heroImage} alt="" class="img-fluid rounded-top" />
							</div>
						)
					}
					<div class="col-12">
						<div class="card-body">
							{showDate && (
								<div class="site-meta-row d-flex flex-column flex-md-row justify-content-between mb-3 text-muted small">
									<div>
										<span>{t("messages.publishedOn")} </span>
										<FormattedDate date={pubDate} />
									</div>
									{updatedDate && (
										<div>
											<span>{t("messages.lastUpdatedOn")} </span>
											<FormattedDate date={updatedDate} />
										</div>
									)}
								</div>
							)}
							{showTitle && (
								<>
									<h1 class="display-5">{title}</h1>
									<hr class="site-section-divider" />
								</>
							)}
							<div class="site-prose" set:html={contentHtml} />
							<slot />
						</div>
					</div>
				</div>
			</article>
		</div>
	)}
</SiteLayout>
