---
import BaseHead from "../components/BaseHead.astro";
import LanguageSwitch from "../components/LanguageSwitch.astro";
import { SITE_TITLE } from "../consts";
import { getUiTranslations } from "../lib/i18n";

interface Props {
	title: string;
	description: string;
	eyebrow?: string;
	heading: string;
	intro?: string;
}

const { title, description, eyebrow, heading, intro } = Astro.props;
const { t, localizeHref, language } = getUiTranslations(Astro);
const viewSiteLabel = t("actions.viewSite", "View site");
const adminBrandName = t("app.brand", "Quackbase");
const adminBrandTagline = t(
	"messages.signInIntro",
	"Sign in with your admin email and password to access the CMS dashboard.",
);
---

<!doctype html>
<html lang={language} data-theme="classic" data-mode="light">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
	</head>
	<body class="admin-auth-app">
		<main class="admin-auth-shell">
			<section class="admin-auth-stage">
				<div class="admin-auth-frame">
					<div class="admin-auth-meta">
						<a class="admin-auth-home-link" href={localizeHref("/")}>
							<span class="admin-auth-home-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 3h7v7h-2V6.41l-8.29 8.3-1.42-1.42 8.3-8.29H14V3Z" />
									<path d="M5 5h6V3H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-6h-2v6H5V5Z" />
								</svg>
							</span>
							<span>{viewSiteLabel}</span>
						</a>
						<div class="admin-auth-language">
							<LanguageSwitch />
						</div>
					</div>
					<div class="admin-auth-card">
						<div class="admin-auth-card-inner">
							<div class="admin-auth-brand">
								<div class="admin-auth-brand-lockup">
									<div class="admin-auth-mark">
										<img src="/favicon.svg" alt={`${adminBrandName} logo`} width="72" height="72" loading="eager" decoding="async" />
									</div>
									<div class="admin-auth-brand-copy">
										<p class="admin-auth-brand-name">{adminBrandName}</p>
										<p class="admin-auth-brand-tagline">{adminBrandTagline}</p>
									</div>
								</div>
								<div class="admin-auth-brand-dots admin-auth-brand-dots-top" aria-hidden="true"></div>
								<div class="admin-auth-brand-dots admin-auth-brand-dots-bottom" aria-hidden="true"></div>
								{eyebrow && <p class="admin-auth-eyebrow">{eyebrow}</p>}
								<h1 class="admin-auth-title">{heading}</h1>
								{intro && <p class="admin-auth-intro">{intro}</p>}
							</div>
							<div class="admin-auth-content">
								<slot />
							</div>
						</div>
					</div>
					<p class="admin-auth-footnote">
						<span class="admin-auth-footnote-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="5" y="11" width="14" height="9" rx="2" />
								<path d="M8 11V8a4 4 0 1 1 8 0v3" />
							</svg>
						</span>
						<span>{t("messages.secureAdminAccess", "Secure admin access")}</span>
					</p>
				</div>
			</section>
		</main>
	</body>
</html>
